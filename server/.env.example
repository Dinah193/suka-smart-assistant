# Backend server port
PORT=8787

# Choose one (Places preferred)
GOOGLE_PLACES_API_KEY=YOUR_KEY_HERE
GOOGLE_MAPS_API_KEY=

# Optional tuning
LOCALS_CACHE_TTL_MS=300000
LOCALS_RATE_LIMIT_WINDOW_MS=60000
LOCALS_RATE_LIMIT_MAX=60

# CORS (comma separated) - for dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
