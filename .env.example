# Suka Smart Assistant - Root Environment Template
# Copy to .env and fill values for your environment.

# -----------------------------------------------------------------------------
# Server Core
# -----------------------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
TRUST_PROXY=loopback
TZ=America/New_York

# -----------------------------------------------------------------------------
# CORS / HTTP Tuning
# -----------------------------------------------------------------------------
CORS_ORIGIN=*
SOCKET_CORS=*
JSON_LIMIT=2mb
URLENC_LIMIT=2mb
RATE_WINDOW_MS=60000
RATE_MAX=600
REALTIME_HTTP_RATE_WINDOW_MS=60000
REALTIME_HTTP_RATE_MAX=120

# In production set ALLOW_INSECURE_HEADER_AUTH=false and explicit origins.
ALLOW_INSECURE_HEADER_AUTH=true

# -----------------------------------------------------------------------------
# Realtime / Runtime Validation Flags
# -----------------------------------------------------------------------------
SSA_ENABLE_RUNTIME_CONTRACT_TESTS=false
SSA_REALTIME_STRICT_ENVELOPE=false
SSA_REALTIME_APPEND_LOG_ENABLED=false
SSA_REALTIME_REPLAY_ON_BOOT=false
SSA_REALTIME_EVENTLOG_FALLBACK_MEMORY=true

# -----------------------------------------------------------------------------
# Database (Mongo-compatible bootstrap)
# Leave empty to run in file-fallback mode.
# -----------------------------------------------------------------------------
MONGODB_URI=
# MONGO_URI=
# MONGO_URL=
MONGO_SERVER_SELECTION_TIMEOUT_MS=2000
MONGO_MAX_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Webhook Security (n8n)
# -----------------------------------------------------------------------------
N8N_INBOUND_SECRET=
# N8N_SHARED_SECRET=
N8N_SIGNATURE_HEADER=x-n8n-signature
N8N_TIMESTAMP_HEADER=x-suka-timestamp
N8N_NONCE_HEADER=x-suka-nonce
N8N_ALLOWED_DRIFT_SEC=300

# -----------------------------------------------------------------------------
# Optional app/security integrations
# -----------------------------------------------------------------------------
JWT_SECRET=
OPENAI_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Startup validation behavior
# - false: warn only in dev/staging (default)
# - true: fail startup when required env vars are missing
# -----------------------------------------------------------------------------
STRICT_STARTUP_ENV=false
