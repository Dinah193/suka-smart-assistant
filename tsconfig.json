{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": [
    "tools/scripts/**/*.cjs",
    "src/server/db/adapters/**/*.js",
    "src/services/mongodb/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".tmp"
  ]
}
