/** CleaningStep */
{
  "id":"step-uuid",
  "zoneId":"kitchen",
  "action":"Degrease range hood",
  "durationSec": 300,
  "tools":["microfiber","degreaser"],
  "cleaner":{"sku":"CITRUS_DEGREASER","homemade":true},
