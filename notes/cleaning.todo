}
/** SuppliesDelta */
{
  "consume":[{"sku":"MICROFIBER_CLOTH","qty":3,"unit":"pc"},{"sku":"VINEGAR","qty":200,"unit":"ml"}],
  "missing":[{"sku":"BAKING_SODA","qty":500,"unit":"g"}],
  "homemade":[{"name":"Citrus Degreaser","needs":["citrus peels","vinegar","jar","spray bottle"]}]
}
/** CleaningPlan */
{
  "id":"plan-uuid",
  "zones":["kitchen","bathroom","entry"],
  "mode":"batch", // batch | deep
  "steps":[...CleaningStep],
  "estimatedMin": 85,
  "roles":{"rhonda":["kitchen-wipe","entry-reset"],"helper":["bathroom-sink"]},
  "hrTarget":"moderate"
}

9) Agent Pseudocode — Plan & Supplies
/*
export async function buildCleaningPlan(zones, constraints, prefs){
  const steps = loadPresets(zones, prefs.materials);
