  const drilled = injectMicroDrills(tuned, prefs.hrTarget); // add HR boosters
  const sequenced = scheduleByMode(drilled, prefs.mode); // batch vs deep
  return { steps: sequenced, estimatedMin: sum(sequenced.map(s=>s.durationSec))/60 };
}
export async function computeSuppliesDelta(steps, inventory){
  // aggregate per SKU; suggest homemade where viable
  return { consume, missing, homemade };
}
