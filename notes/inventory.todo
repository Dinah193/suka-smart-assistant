14) Component Snippets (wire-in ready)
/* AnimalsIntakeForm.jsx — submit */
async function onRegister(intake){
  const { animalIds } = await animalAgent.registerAnimals(intake);
  const events = await animalAgent.planProcessing(animalIds, calendar, hebrewCal);
  emit('animals.registered',{animalIds,intake});
  emit('animals.processing.scheduled',{events});
  emit('calendar.synced',{events});
}

/* ButcheryCutSheetMapper.jsx — commit packages */
async function onCommitPackages(rows){
  const { delta, packages, yields } = await butcheryAgent.mapCutsToSkus(rows, skuCatalog, {grindPct, trimPct});
  const patchId = await inventory.applyDelta(delta);
  const pdf = await labelAgent.buildButcheryLabels(packages);
  saveBlob(pdf, `butchery-${packages?.[0]?.lotId || Date.now()}.pdf`);
  emit('butchery.completed',{animalId:packages?.[0]?.sourceAnimalId, cutSheetId:packages?.[0]?.cutSheetId, packages, yields, patchId});
}

/* AnimalShareMarketPanel.jsx — open linked offer */
async function openOfferLinked(form){
  // species, shareType, model, rate, deposit, eta, animalIds[], cutSheetIds[], allowPooling
  const { offerId } = await animalShareAgent.openOffer(form);
  emit('sales.offer.opened',{offerId, animalIds:form.animalIds, cutSheetIds:form.cutSheetIds});
}

/* ShareAllocator.jsx — eligible only */
async function loadEligible(offerId){
  const pkgs = await animalShareAgent.eligiblePackages({offerId});
  setEligible(pkgs); // each pkg has sourceAnimalId & cutSheetId
}

/* ShareAllocator.jsx — finalize */
async function finalize(order, packageMap){
  const { deltaMove, labels } = await animalShareAgent.finalizeAllocation({orderId:order.orderId, packageMap});
  const patchId = await inventory.applyDelta({move:deltaMove});
  await labelAgent.buildBuyerLabels(labels, order.buyer);
  emit('sales.order.finalized',{orderId:order.orderId, deltaMove, animalIds:order.animalIds, cutSheetIds:order.cutSheetIds, patchId});
}

/* CoolingTracker.jsx — move when chilled */
function moveWhenChilled(item){
  if(item.ok){ emit('inventory.moved',{sku:item.sku,from:'Chill Room',to:'Freezer1',qty:item.qty}); }
}

/* InventoryOverview.jsx — yield tile */
<StatCard title="Yield (live→retail)" value={`${yieldPct}%`} hint="Target 60–70% beef / 45–55% lamb (example)"/>

