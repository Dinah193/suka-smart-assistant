9) Planning pseudocode (agents)
/* gardenShim.js */
export async function buildGardenPlan(crops,beds,zone,prefs,hebrewCal){
  const base = assignCropsToBeds(crops,beds,zone,prefs.microclimate);
  const companionMap = computeCompanions(base);
  const gregorian = makeSowTransplantSchedule(base,zone);
  const aligned = shiftByHebrewCalendar(gregorian,hebrewCal,{monthStartRule:'fullMoon'});
  const tasks = weeklyTasksFromSchedule(aligned,base);
  return { plan:{...base,companionMap,calendar:aligned}, tasks };
}
export async function computeHarvestDelta(entry, inventory){
  const produce=[{sku:skuFromCrop(entry.cropId),qty:entry.qty,unit:entry.unit}];
  const value=entry.qty*entry.pricePerUnit;
  const preservePlan=suggestPreservation(entry.cropId, entry.qty);
  return { delta:{produce,missing:[],preservePlan}, value };
}

/* soilAndWaterShim.js */
