  "rules": [
    {
      "name": "Hub-only features visible only in Suka Village Family Fund Hub",
      "if": { "context.tier": "hub" },
      "set": {
        "toggles.familyFundMode": true,
        "familyFundMode": true,
        "gating.visibleInNonHub.scan.compare": true,
        "gating.visibleInNonHub.scan.trust": true,
        "storehouse.sharedStockPool": true,
        "garden.coOpPlanningBoard": true,
        "animals.sharedButcherySchedule": true,
        "preservation.sharedBatchBoard": true,
        "commerce.enabled": true
      }
    },
    {
      "name": "Non-hub hides hubOnly items",
      "if": { "context.tier": { "$ne": "hub" } },
      "set": {
        "toggles.familyFundMode": false,
        "familyFundMode": false,
        "gating.visibleInNonHub.scan.compare": true,
        "gating.visibleInNonHub.scan.trust": true
      }
    },
    {
      "name": "Admins and Testers get full access",
      "if": { "context.role": { "$in": ["admin", "tester"] } },
      "set": {
        "toggles.import-all-domains": true,
        "toggles.analytics": true,
        "toggles.commerce": true,
        "familyFundMode": true,
        "rollouts.scan.trust.supplierTrace.percent": 100,
        "rollouts.scan.compare.bulkPriceAudit.percent": 100,
        "rollouts.coupons.partnerPerks.percent": 100,
        "rollouts.cleaning.zoneRoutineEngine.percent": 100,
        "rollouts.garden.careAndHarvestEngine.percent": 100,
        "rollouts.storehouse.storehouseStockPlanner.percent": 100,
        "rollouts.animals.butcherySessionEngine.percent": 100,
        "rollouts.preservation.preservationSessionEngine.percent": 100,
        "rollouts.session.runner.wakeLock.percent": 100,
        "rollouts.session.runner.notifications.percent": 100,
        "rollouts.session.runner.pictureInPicture.percent": 100,
        "rollouts.session.runner.mediaSession.percent": 100,
        "rollouts.session.runner.tts.percent": 100,
        "rollouts.session.runner.backgroundShims.percent": 100
      }
    },
    {
      "name": "Sabbath guard off for demo booths",
      "if": { "context.deviceProfile": "kiosk-demo" },
      "set": { "sabbathGuard.enabled": false }
    }
