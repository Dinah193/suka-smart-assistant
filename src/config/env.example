# =============================================================================
# Suka Smart Assistant (SSA)
# Environment variable template for build setup
# File: src/config/env.example
#
# COPY TO:
#   .env.local                 ← local/dev runs
#   .env.development.local     ← if you split environments
#   .env.staging.local
#   .env.production.local
#
# IMPORTANT:
# - Anything that starts with VITE_ will be exposed to the browser (Vite rule).
# - Do NOT put real secrets in VITE_ vars.
# - Server-only secrets (JWT, session, API keys) should NOT be prefixed with VITE_.
#
# PIPELINE IT SUPPORTS:
#   imports → normalize → link to inventory/storehouse
#           → generate sessions (cooking, cleaning, garden, animal, preservation)
#           → emit events { type, ts, source, data }
#           → (optional) export to Hub if familyFundMode=true
#
# This template is aligned with:
#   - src/config/featureFlags.json (incl. top-level toggles)
#   - your event-driven automation runtime
#   - multi-domain import strategy (recipe, cleaning, garden/seed, animal, storehouse, video/how-to)
# =============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# App & Build
# ──────────────────────────────────────────────────────────────────────────────
VITE_APP_ENV=development                     # development | staging | production
VITE_APP_NAME="Suka Smart Assistant"
VITE_APP_BASE_URL=/                          # usually "/"
VITE_TIMEZONE="America/Chicago"
VITE_APP_VERSION="2025.11.01-dev"            # surfaced in event payloads / logs


# ──────────────────────────────────────────────────────────────────────────────
# HIGH-LEVEL TOGGLES (match featureFlags.json → defaults.toggles)
# These are single switches your React/automation code can check first.
# ──────────────────────────────────────────────────────────────────────────────
VITE_TOGGLE_IMPORT_ALL_DOMAINS=true          # if false, UI should hide non-meal imports
VITE_TOGGLE_FAMILY_FUND_MODE=false           # Hub export is OPTIONAL; SSA still owns data
VITE_TOGGLE_ANALYTICS=true                   # emit analytics.* events to eventBus
VITE_TOGGLE_COMMERCE=false                   # experimental buy-lists / preferred vendors


# ──────────────────────────────────────────────────────────────────────────────
# Feature Flags (client hints; server should still enforce)
# These map to the domains we enabled in featureFlags.json
# ──────────────────────────────────────────────────────────────────────────────
VITE_FEATURE_ENABLE_SCAN_COMPARE_TRUST=true
VITE_FEATURE_ENABLE_COUPONS=true
VITE_FEATURE_ENABLE_PRICE_COMPARE=true
VITE_FEATURE_ENABLE_RECALLS_CHECK=true
VITE_FEATURE_ENABLE_INGREDIENTS_CHECK=true

# NEW domains (to match featureFlags.json)
VITE_FEATURE_ENABLE_CLEANING=true
VITE_FEATURE_ENABLE_GARDEN=true
VITE_FEATURE_ENABLE_STOREHOUSE=true
VITE_FEATURE_ENABLE_MEALS=true
VITE_FEATURE_ENABLE_ANIMALS=true
VITE_FEATURE_ENABLE_PRESERVATION=true
VITE_FEATURE_ENABLE_IMPORT=true


# ──────────────────────────────────────────────────────────────────────────────
# User Ownership (global + per-domain)
# SSA requirement: “users can save their own favorite sessions and schedules”
# ──────────────────────────────────────────────────────────────────────────────
VITE_ALLOW_USER_FAVORITES=true
VITE_ALLOW_USER_SCHEDULES=true

VITE_CLEANING_ALLOW_USER_FAVORITES=true
VITE_CLEANING_ALLOW_USER_SCHEDULES=true

VITE_GARDEN_ALLOW_USER_FAVORITES=true
VITE_GARDEN_ALLOW_USER_SCHEDULES=true

VITE_STOREHOUSE_ALLOW_USER_FAVORITES=true
VITE_STOREHOUSE_ALLOW_USER_SCHEDULES=true

VITE_MEALS_ALLOW_USER_FAVORITES=true
VITE_MEALS_ALLOW_USER_SCHEDULES=true

VITE_ANIMALS_ALLOW_USER_FAVORITES=true
VITE_ANIMALS_ALLOW_USER_SCHEDULES=true

VITE_PRESERVATION_ALLOW_USER_FAVORITES=true
VITE_PRESERVATION_ALLOW_USER_SCHEDULES=true

VITE_IMPORT_ALLOW_USER_FAVORITES=true
VITE_IMPORT_ALLOW_USER_SCHEDULES=true


# ──────────────────────────────────────────────────────────────────────────────
# Rhythms / Guards (applies to all session generators)
# automation runtime should look at these BEFORE scheduling
# ──────────────────────────────────────────────────────────────────────────────
VITE_SABBATH_GUARD_ENABLED=true
VITE_SABBATH_GUARD_START_HINT="Fri 18:00"
VITE_SABBATH_GUARD_END_HINT="Sat 21:00"
VITE_QUIET_HOURS_START=22
VITE_QUIET_HOURS_END=7


# ──────────────────────────────────────────────────────────────────────────────
# Event Bus / Automation Runtime
# SSA is event-driven → emit { type, ts, source, data } to a shared bus
# ──────────────────────────────────────────────────────────────────────────────
VITE_EVENTBUS_ENABLED=true
VITE_EVENTBUS_DOM_CHANNEL="window.__suka?.eventBus"   # must match featureFlags.runtimeHints.domChannel
VITE_AUTOMATION_ENABLED=true
VITE_AUTOMATION_OFFLINE_RESILIENT=true
VITE_AUTOMATION_SABBATH_AWARE=true
VITE_AUTOMATION_SHARED_BUS=true
VITE_AUTOMATION_ALLOWED_DOMAINS="scan,meals,cleaning,garden,storehouse,animals,preservation,import"


# ──────────────────────────────────────────────────────────────────────────────
# HUB / FAMILY FUND CONNECTOR (OPTIONAL)
# SSA must be able to run by itself. If these are blank → exportToHubIfEnabled()
# in your engines should just fail silently.
# ──────────────────────────────────────────────────────────────────────────────
VITE_HUB_API_BASE=""
VITE_HUB_API_TOKEN=""
VITE_HUB_QUEUE_IF_OFFLINE=true
VITE_HUB_FORMAT_PACKETS=true


# ──────────────────────────────────────────────────────────────────────────────
# MULTI-DOMAIN IMPORT STACK
# This is the front-door of: imports → intelligence → automation → (optional) hub
# ──────────────────────────────────────────────────────────────────────────────
VITE_IMPORT_ENABLED=true
VITE_IMPORT_SOURCE_BOOKMARKLET=true
VITE_IMPORT_SOURCE_FILE_UPLOAD=true
VITE_IMPORT_SOURCE_LINKED_ACCOUNTS=true
VITE_IMPORT_SOURCE_SCAN_COMPARE_TRUST=true
VITE_IMPORT_SOURCE_PINTEREST_TO_PLANNER=true
VITE_IMPORT_SOURCE_GARDEN_SEED_PLAN=true
VITE_IMPORT_SOURCE_CLEANING_PLAN=true
VITE_IMPORT_SOURCE_STOREHOUSE_STOCK=true
VITE_IMPORT_SOURCE_ANIMAL_PLAN_REVERSE=true
VITE_IMPORT_SOURCE_PRESERVATION_PLAN=true
VITE_IMPORT_SOURCE_VIDEO_HOWTO=true
VITE_IMPORT_SHARED_BUS_ENABLED=true
VITE_IMPORT_DOM_CHANNEL="window.__suka?.eventBus"
VITE_IMPORT_CONTEXT_INTELLIGENCE_ENABLED=true     # ingredient patterns, methods, equipment, seasonality


# ──────────────────────────────────────────────────────────────────────────────
# Scan • Compare • Trust — Providers (opt-in)
# ──────────────────────────────────────────────────────────────────────────────
VITE_SCAN_CAMERA_DEFAULT_MODE="barcode+ocr"        # barcode | ocr | barcode+ocr
VITE_OCR_ENGINE="tesseract"                        # tesseract | google-vision
VITE_TESSERACT_LANGS="eng"                         # "eng,spa" etc.
GOOGLE_VISION_API_KEY=                             # server-only; do NOT prefix with VITE in real env
VITE_OCR_PROXY_URL=

# Barcode / Product lookup
VITE_BARCODE_PRIMARY="openfoodfacts"
VITE_OPENFOODFACTS_BASE_URL="https://world.openfoodfacts.org"
VITE_OPENFOODFACTS_ENABLED=true
UPCITEMDB_API_KEY=
VITE_UPCITEMDB_PROXY_URL=
VITE_UPCITEMDB_ENABLED=false

# Recalls
VITE_USDA_RECALLS_ENABLED=true
VITE_USDA_RECALLS_BASE_URL="https://www.fsis.usda.gov/recalls"
VITE_FDA_RECALLS_ENABLED=true
VITE_FDA_RECALLS_BASE_URL="https://api.fda.gov/food/enforcement.json"

# Ingredient safety
VITE_INGREDIENTS_DB_ENABLED=true
VITE_INGREDIENTS_DB_BASE_URL=""
INGREDIENTS_DB_API_KEY=

# Price compare
VITE_PRICE_COMPARE_ENABLED=true
VITE_PRICING_PRIMARY="custom"
PRICING_API_KEY=
VITE_PRICING_PROXY_URL=

# Retailers
VITE_PROVIDER_SAMS_ENABLED=true
VITE_PROVIDER_COSTCO_ENABLED=true
VITE_PROVIDER_ALDI_ENABLED=true
SAMS_OAUTH_CLIENT_ID=
SAMS_OAUTH_CLIENT_SECRET=
SAMS_PRIVATE_API_KEY=
COSTCO_PRIVATE_API_KEY=
ALDI_PRIVATE_API_KEY=
RETAIL_PROXY_BASE_URL=


# ──────────────────────────────────────────────────────────────────────────────
# Coupons / Loyalty
# ──────────────────────────────────────────────────────────────────────────────
VITE_COUPONS_ENABLED=true
VITE_COUPONS_STACKING_ENABLED=true
VITE_COUPONS_MAX_PER_ITEM=3
COUPONS_PARTNER_A_API_KEY=
COUPONS_PARTNER_B_API_KEY=
COUPONS_PROXY_BASE_URL=
VITE_COUPONS_SCHEDULE_REFRESH_DAILY="enabled"
VITE_COUPONS_SCHEDULE_LEARN_WEEKLY="enabled"

# Trust (often Hub-only, but SSA should still understand the toggle)
VITE_TRUST_SUPPLIER_TRACE_ENABLED=false


# ──────────────────────────────────────────────────────────────────────────────
# CLEANING (declutter / zone / deep-clean sessions)
# ──────────────────────────────────────────────────────────────────────────────
VITE_CLEANING_ENGINE_ENABLED=true
VITE_CLEANING_IMPORT_FROM_PINTEREST=true
VITE_CLEANING_IMPORT_FROM_CSV=true
VITE_CLEANING_UI_SHOW_DASHBOARD_WIDGET=true
VITE_CLEANING_UI_SHOW_SESSION_PLANNER=true
VITE_CLEANING_SABBATH_AWARE=true
VITE_CLEANING_QUIET_HOURS_AWARE=true


# ──────────────────────────────────────────────────────────────────────────────
# GARDEN (plan / care / harvest)
# ──────────────────────────────────────────────────────────────────────────────
VITE_GARDEN_PLAN_ENGINE_ENABLED=true
VITE_GARDEN_QUEUE_ENGINE_ENABLED=true
VITE_GARDEN_CARE_ENGINE_ENABLED=true
VITE_GARDEN_IMPORT_FROM_SEED_SITES=true
VITE_GARDEN_IMPORT_FROM_BOOKMARKLET=true
VITE_GARDEN_IMPORT_FROM_CSV=true
VITE_GARDEN_UI_SHOW_DASHBOARD_WIDGET=true
VITE_GARDEN_UI_SHOW_SEASONAL_VIEW=true
VITE_GARDEN_UI_SHOW_CARE_HARVEST_TABS=true
VITE_GARDEN_COLLAB_ENABLED=true
VITE_GARDEN_COOP_PLANNING_ENABLED=true


# ──────────────────────────────────────────────────────────────────────────────
# STOREHOUSE (goals planner vs inventory execution)
# ──────────────────────────────────────────────────────────────────────────────
VITE_STOREHOUSE_GOAL_ENGINE_ENABLED=true
VITE_STOREHOUSE_STOCK_PLANNER_ENABLED=true
VITE_STOREHOUSE_IMPORT_FROM_GROCERY_SECTIONS=true
VITE_STOREHOUSE_IMPORT_FROM_SHOPPING_LISTS=true
VITE_STOREHOUSE_IMPORT_FROM_MEAL_PLANS=true
VITE_STOREHOUSE_UI_SHOW_GROCERY_SECTION_INSPO=true
VITE_STOREHOUSE_UI_SHOW_PANTRY_TARGETS=true
VITE_STOREHOUSE_UI_SHOW_ROTATION_NEEDS=true
VITE_STOREHOUSE_COOP_ENABLED=true
VITE_STOREHOUSE_BULK_BUY_EVENTS_ENABLED=true


# ──────────────────────────────────────────────────────────────────────────────
# MEALS (meal planner, batch cooking, reverse generation)
# ──────────────────────────────────────────────────────────────────────────────
VITE_MEAL_PLAN_ENGINE_ENABLED=true
VITE_COOKING_SESSION_ENGINE_ENABLED=true
VITE_MEALS_IMPORT_FROM_ALLRECIPES=true
VITE_MEALS_IMPORT_FROM_LOVEANDLEMONS=true
VITE_MEALS_IMPORT_FROM_TIKTOK=true
VITE_MEALS_IMPORT_FROM_YOUTUBE=true
VITE_MEALS_IMPORT_FROM_FACEBOOK=true
VITE_MEALS_IMPORT_FROM_PINTEREST_BOARDS=true
VITE_MEALS_UI_SHOW_RECIPE_CONSOLIDATOR=true
VITE_MEALS_UI_SHOW_MEAL_PLANNER=true
VITE_MEALS_UI_SHOW_BATCH_COOKING=true
VITE_MEALS_REVERSE_TO_ANIMAL_PLANNER=true
VITE_MEALS_REVERSE_TO_STOREHOUSE=true
VITE_MEALS_REVERSE_TO_SHOPPING_LIST=true
VITE_MEALS_REVERSE_TO_PRESERVATION=true


# ──────────────────────────────────────────────────────────────────────────────
# ANIMALS (acquisition, care, butchery, reverse-from-recipes)
# ──────────────────────────────────────────────────────────────────────────────
VITE_ANIMAL_PLANNER_ENGINE_ENABLED=true
VITE_ANIMAL_CARE_ENGINE_ENABLED=true
VITE_BUTCHERY_SESSION_ENGINE_ENABLED=true
VITE_ANIMALS_IMPORT_FROM_RECIPES_REVERSE=true
VITE_ANIMALS_IMPORT_FROM_BREED_LIBRARIES=true
VITE_ANIMALS_IMPORT_FROM_LOCAL_MARKETS=true
VITE_ANIMALS_UI_SHOW_DASHBOARD_WIDGET=true
VITE_ANIMALS_UI_SHOW_BREED_SUGGESTIONS=true
VITE_ANIMALS_UI_SHOW_ACQUISITION_PLANNER=true
VITE_ANIMALS_UI_SHOW_BUTCHERY_LOG=true
VITE_ANIMALS_REVERSE_GENERATE_FROM_RECIPES=true
VITE_ANIMALS_GEO_AWARE_BREEDS_ENABLED=true
VITE_ANIMALS_GEO_DEFAULT_SOURCE="usda-zone-ish"


# ──────────────────────────────────────────────────────────────────────────────
# PRESERVATION (new domain in your featureFlags)
# ──────────────────────────────────────────────────────────────────────────────
VITE_PRESERVATION_PLANNER_ENGINE_ENABLED=true
VITE_PRESERVATION_SESSION_ENGINE_ENABLED=true
VITE_PRESERVATION_IMPORT_FROM_MEAL_PLANS=true
VITE_PRESERVATION_IMPORT_FROM_STOREHOUSE_ROTATION=true
VITE_PRESERVATION_IMPORT_FROM_GARDEN_HARVESTS=true
VITE_PRESERVATION_IMPORT_FROM_VIDEO=true
VITE_PRESERVATION_UI_SHOW_DASHBOARD_WIDGET=true
VITE_PRESERVATION_UI_SHOW_METHODS_TABS=true
VITE_PRESERVATION_UI_SHOW_BATCH_SESSIONS=true
VITE_PRESERVATION_REVERSE_TO_STOREHOUSE=true
VITE_PRESERVATION_REVERSE_TO_MEALS=true


# ──────────────────────────────────────────────────────────────────────────────
# Analytics / Telemetry
# ──────────────────────────────────────────────────────────────────────────────
VITE_ANALYTICS_PROVIDER="posthog"               # posthog | segment | none
VITE_ANALYTICS_EMIT_EVENTS=true
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST="https://app.posthog.com"
VITE_SEGMENT_WRITE_KEY=
VITE_LOG_LEVEL="info"                           # debug | info | warn | error


# ──────────────────────────────────────────────────────────────────────────────
# UI Defaults
# ──────────────────────────────────────────────────────────────────────────────
VITE_UI_THEME="system"                          # light | dark | system
VITE_SCAN_UI_SHEET="compact"
VITE_SCAN_UI_HAPTICS=true
VITE_SCAN_UI_VOICE=true
VITE_SCAN_DEFAULT_PROVIDERS="sams,costco,aldi"
VITE_SCAN_DEFAULT_CHECKS="recalls,ingredients,coupons,priceCompare"
VITE_UI_SHOW_HUB_MODULES=false                  # SSA should still gate in code


# ──────────────────────────────────────────────────────────────────────────────
# Server-only Secrets (DO NOT PREFIX WITH VITE_)
# ──────────────────────────────────────────────────────────────────────────────
SESSION_SECRET=
JWT_SECRET=
ENCRYPTION_KEY_32B=
REDIS_URL=
REDIS_NAMESPACE="suka"
CACHE_DEFAULT_TTL_SECONDS=900
SENDGRID_API_KEY=
POSTMARK_SERVER_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
