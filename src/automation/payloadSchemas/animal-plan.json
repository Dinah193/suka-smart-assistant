{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnimalPlan",
  "type": "object",
  "required": ["userId", "herd", "goals"],
  "properties": {
    "userId": { "type": "string", "minLength": 1 },
    "herd": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["species", "count"],
        "properties": {
          "species": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 },
          "avgWeightKg": { "type": "number" },
          "ageMonths": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "goals": {
      "type": "object",
      "properties": {
        "eggsPerWeek": { "type": "number" },
        "meatKgPerMonth": { "type": "number" },
        "butcherPlan": { "type": "string" },
        "breedingPlan": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
