        "nodeType": "planner",
        "tagsAny": ["session-ready"]
      },
      "to": {
        "targetId": "storehouse.sessions.launcher",
        "label": "Open Session Launcher",
        "reason": "You’ve finished planning. Launch a live session using this plan.",
        "priority": 5,
        "tags": ["launcher", "session", "planner"],
        "autoStartSession": false
