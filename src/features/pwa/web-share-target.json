{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "Suka Smart Assistant – Share-to-Import",
  "short_name": "Suka Share",
  "description": "Accept shared recipes, meal plans, cleaning plans, garden planning/care/harvest, storehouse stock (grocery-style sections), animal acquisition/care/butchery, store ads, and social posts straight into Suka Smart Assistant. Users can auto-favorite, attach schedules, and keep reverse-generation metadata.",
  "start_url": "/import/share-capture?src=pwa",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#0f172a",
  "icons": [
    {
      "src": "/icons/suka-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/suka-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "/import/share-capture",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": [
            "text/*",
            "image/*",
            "application/json",
            "application/pdf"
          ]
        }
      ]
    }
  },
  "suka": {
    "integration": "pwa-share-target",
    "features": {
      "saveUserFavorites": true,
      "attachSchedule": true,
      "reverseGeneration": true,
      "sharedOrchestration": true,
      "sources": [
        "pwa-share",
        "bookmarklet",
        "pinterest",
        "garden-site",
        "cleaning-blog",
        "grocery-circular",
        "livestock-listing",
        "butchery-post",
        "scan-compare-trust"
      ],
      "importTypes": [
        "recipe",
        "mealPlan",
        "cleaningPlan",
        "gardenPlan",
        "gardenCare",
        "harvestPlan",
        "storehouseGoal",
        "storehouseStock",
        "animalAcquisition",
        "animalPlan",
        "butcherySession",
        "inventoryUpdate",
        "generic"
      ]
    },
    "defaults": {
      "autoOpenPreview": true,
      "autoSaveFavorite": false,
      "autoSchedule": false,
      "autoScheduleRule": "once+5min",
      "reverseMeta": {
        "shareTarget": "family-fund-hub",
        "includeShare": true,
        "format": "json",
        "reverseFromId": null
      },
      "sessionTemplates": {
        "cleaningPlan": {
          "kind": "cleaning",
          "recurring": "weekly"
        },
        "gardenCare": {
          "kind": "garden-care",
          "recurring": "2x/week"
        },
        "harvestPlan": {
          "kind": "garden-harvest",
          "recurring": null
        },
        "storehouseStock": {
          "kind": "storehouse-restock",
          "recurring": "weekly"
        },
        "butcherySession": {
          "kind": "butchery",
          "recurring": null
        },
        "animalAcquisition": {
          "kind": "inventory-sync",
          "recurring": null
        }
      }
    },
    "events": {
      "emit": [
        "import.queue.enqueue",
        "import.preview.open",
        "automation.schedule.request",
        "import.bookmarklet.replayed",
        "import.pwa-share.received"
      ],
      "listen": [
        "import.settings.changed",
        "import.queue.updated",
        "automation.schedule.updated"
      ]
    },
    "notes": "Your /import/share-capture route should: (1) read the POSTed share payload (title, text, url, optional file), (2) run it through the same ImportNormalizer used by bookmarklet/import routes, (3) detect site/kind → set __importType to one of: recipe, mealPlan, cleaningPlan, gardenPlan, gardenCare, harvestPlan, storehouseStock, animalAcquisition, butcherySession, and (4) emit import.queue.enqueue and import.preview.open. This keeps mobile 'Share → Suka' flows aligned with desktop bookmarklet flows and preserves user-owned favorites + schedules."
  }
}
