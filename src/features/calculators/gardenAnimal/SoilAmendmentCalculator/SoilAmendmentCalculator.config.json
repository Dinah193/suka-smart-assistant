    "garden",
    "soil",
    "planning",
    "amendments"
  ],

  "inputs": {
    "soilProfile": "garden.soilProfile.outputs.profile",
    "soilTests": "garden.soilProfile.outputs.tests",
    "plantingPlan": "garden.plantingCalendar.outputs.plantingWindows",
    "gardenLayout": "garden.layout.outputs.beds",
    "householdProfile": "core.householdProfile.outputs.profile"
  },

  "outputs": {
    "amendmentPlan": "garden.soilAmendment.outputs.amendmentPlan",
    "amendmentSessions": "garden.soilAmendment.outputs.sessions",
    "amendmentSummary": "garden.soilAmendment.outputs.summary"
  }
}
