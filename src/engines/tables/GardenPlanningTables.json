{
  "metadata": {
    "name": "GardenPlanningTables",
    "version": "1.0.0",
    "updatedAt": "2025-11-10T00:00:00.000Z",
    "units": "metric",
    "notes": "Cuisine-forward planning tables that help the synthesis engine generate sow/plant windows, successions, trellising, and harvest/storage plans. Values are conservative baselines; prefer local extension data when available."
  },

  "schemaHints": {
    "_comment": "Shape guidance for consumers; not enforced here.",
    "crop": {
      "id": "string (snake_case)",
      "family": "string (rotation family key)",
      "lifeCycle": "annual|biennial|perennial",
      "daysToMaturity": { "directSow": "range", "transplant": "range" },
      "sowDepthCm": "number",
      "thinToCm": "number (or null for not applicable)",
      "transplantAgeWeeks": "number (nursery age) | null when direct sow",
      "soilTempMinC": "number (germination floor at 5cm)",
      "photoperiod": "neutral|long-day|short-day|notes",
      "planningWindows": {
        "directSow": {
          "fromLastFrostDays": "int (negative = before LF)",
          "toFirstFrostDays": "int"
        },
        "transplant": {
          "fromLastFrostDays": "int",
          "soilMinC": "number minimum soil temp for transplant",
          "airNightMinC": "number"
        }
      },
      "succession": { "intervalDays": "int", "rounds": "int", "untilFirstFrostDays": "int" },
      "trellis": { "required": "bool", "systems": ["list of system ids"], "rowSupportCm": "number|null" },
      "pruning": { "method": "string", "notes": "string" },
      "companions": { "good": ["ids"], "avoid": ["ids"], "notes": "string" },
      "harvest": { "cues": ["strings"], "cutRepeat": "bool", "coolingPriority": "low|medium|high" },
      "storage": { "method": "room|cool|refrigerated|cured", "tempC": "range or single", "humidityPct": "range", "lifeDays": "approx int or null" },
      "yield": { "kgPerM2": "range", "notes": "string" },
      "seedViabilityYears": "int (avg)",
      "source": "manual:curated|scraped:<origin>"
    }
  },

  "rotationFamilies": {
    "_comment": "Use to diversify rotations and reduce disease pressure.",
    "solanaceae": ["tomato", "pepper", "eggplant", "african_eggplant"],
    "cucurbitaceae": ["cucumber", "squash", "melon", "bitter_melon", "chayote"],
    "brassicaceae": ["bok_choy", "mizuna", "tatsoi", "broccoli", "cabbage"],
    "allium": ["onion", "garlic", "leek"],
    "legume": ["bean_bush", "bean_pole", "yardlong_bean", "pea"],
    "amaranthaceae": ["amaranth_leaf", "beet", "spinach", "chard"],
    "umbellifer": ["carrot", "cilantro", "culantro"],
    "araceae": ["taro"],
    "euphorbiaceae": ["cassava"],
    "lamiaceae": ["basil", "thai_basil", "shiso_perilla (mint family alias)"],
    "poaceae": ["corn", "sorghum", "millet"]
  },

  "trellisSystems": {
    "_comment": "Canonical trellis IDs referenced in crops.trellis.systems.",
    "systems": {
      "single_stake": { "heightCm": 180, "notes": "Twine tie every 20–30 cm" },
      "florida_weave": { "heightCm": 120, "notes": "Reinforce every 20–30 cm growth" },
      "a_frame": { "heightCm": 200, "notes": "Cucurbits & beans; 15–20 cm grid" },
      "string_drop": { "heightCm": 220, "notes": "Greenhouse tomatoes/ cukes" },
      "netting": { "heightCm": 150, "notes": "Peas/beans/light cucurbits" },
      "arch_trellis": { "heightCm": 200, "notes": "Walkthrough for vining gourds" }
    }
  },

  "plannerDefaults": {
    "_comment": "Synthesis uses these when dates aren’t provided explicitly.",
    "climateAnchors": {
      "lastFrostDate": "use per-location dataset (SSA to supply)",
      "firstFrostDate": "use per-location dataset (SSA to supply)"
    },
    "soilProbeDepthCm": 5,
    "coolingPriorityMap": { "low": 0, "medium": 1, "high": 2 }
  },

