  "surfacePresets": {
    "_comment": "Quick picks for planners; engines combine with preferences (petSafeOnly, scentFamily).",
    "bathroom_high_touch": {
      "preferred": ["hydrogen_peroxide_accelerated", "quaternary_ammonium_quat", "citric_acid_disinfectant"],
      "avoid": [],
      "fragrance": ["fresh", "unscented"]
    },
    "kitchen_food_contact": {
      "preferred": ["sanitizersFoodService.quat_200ppm", "sanitizersFoodService.chlorine_50ppm"],
      "avoid": ["bleach_sodium_hypochlorite (unless rinsed)"],
      "fragrance": ["unscented"]
    },
    "pet_areas": {
      "preferred": ["hydrogen_peroxide_standard_3pct", "steam_100C"],
      "avoid": ["quaternary_ammonium_quat", "bleach_sodium_hypochlorite"],
      "fragrance": ["unscented"]
    },
    "stone_countertops": {
      "preferred": ["quaternary_ammonium_quat (stone-safe label)", "hydrogen_peroxide_accelerated"],
      "avoid": ["citric_acid_disinfectant", "acetic_acid_vinegar_cleaner", "bleach_sodium_hypochlorite"],
      "fragrance": ["unscented", "fresh"]
    }
  },
  "plannerHints": {
    "_comment": "Helpers for synthesis/validator.",
    "keepSurfaceWet": true,
    "reapplyIfDriesEarly": true,
    "preCleanSoilRequired": true,
    "ppe": ["gloves (chemistry-dependent)", "eye_protection (splashes)", "ventilation"],
    "neverMix": [
      "bleach + ammonia",
      "bleach + acids (vinegar/citric)",
      "peroxide + vinegar (in closed container)"
    ],
    "contactTimeFloorMin": 10,
    "overrideByPreference": {
      "petSafeOnly": {
        "excludeChemistries": ["bleach_sodium_hypochlorite", "quaternary_ammonium_quat"],
        "prefer": ["hydrogen_peroxide_standard_3pct", "steam_100C"]
      },
      "scentFamily": {
        "unscented": { "prefer": ["unscented"] },
        "citrus": { "prefer": ["citrus"] },
        "floral": { "prefer": ["floral"] },
