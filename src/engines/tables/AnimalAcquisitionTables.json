  "schemaHints": {
    "_comment": "Shape guidance for consumers; not enforced.",
    "speciesRecord": {
      "id": "string",
      "commonName": "string",
      "acquisitionAges": ["list of strings like 'day-old', 'weaner', 'point-of-lay'"],
      "seasonality": { "preferredMonths": ["1..12"], "notes": "string" },
      "vendorChecklist": ["items to verify before purchase"],
      "paperwork": ["docs such as CVI, bill of sale, NPIP"],
      "transport": {
        "crateSize": { "widthCm": "number", "depthCm": "number", "heightCm": "number" },
        "maxCrateOccupancy": "int (typical safe max per crate)",
