        "isolationDistanceM": "number",
        "biosecurity": ["notes"],
        "initialHealthChecks": ["notes"],
        "vaccination": { "recommended": ["items"], "optional": ["items"], "timingNotes": "string" },
        "parasiteControl": { "strategy": "string", "timingNotes": "string" },
        "withdrawalIfRescueDays": "int",
        "intakeWeightExpectationsKg": { "min": "number", "max": "number" },
        "mortalityScreenWindowDays": "int"
      },
      "feedingTransition": {
        "startFeed": "string",
        "transitionPlan": ["steps"],
        "waterSupplements": ["items"]
      },
      "welfare": {
        "grouping": "notes",
        "enrichment": ["items"]
      },
      "eventsMap": {
        "acquire.scheduled": ["species", "count", "vendor"],
        "transport.prep": ["crates", "ventilation", "tempTargetC"],
        "intake.quarantine.start": ["days", "location"],
        "health.vaccination.planned": ["vaccines", "dayOffset"],
        "feeding.transition.planned": ["from", "to", "days"],
        "records.paperwork.logged": ["docs"]
      },
      "source": "manual:curated"
    }
  },

