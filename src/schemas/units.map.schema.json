{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "file:///src/schemas/units.map.schema.json",
  "title": "SSA • Units Map Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "updatedAt",
    "meta",
    "canonicalUnits",
    "map"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "string",
      "description": "Semantic version of the data contract for this catalog.",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO-8601 date or datetime.",
      "anyOf": [{ "format": "date" }, { "format": "date-time" }]
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "domain", "locale", "normalization"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\.\\-]+$",
          "minLength": 3
        },
        "type": {
          "type": "string",
          "const": "unit_map"
        },
        "domain": {
          "type": "string",
          "const": "measurements"
        },
        "locale": {
          "type": "string",
          "minLength": 2
        },
        "normalization": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "case",
            "trim",
            "collapseWhitespace",
            "stripPunctuation"
          ],
          "properties": {
            "case": {
              "type": "string",
              "enum": ["lower", "none"],
              "default": "lower"
            },
            "trim": { "type": "boolean", "default": true },
            "collapseWhitespace": { "type": "boolean", "default": true },
            "stripPunctuation": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "canonicalUnits": {
      "type": "object",
      "description": "Unit metadata indexed by canonical unit ID.",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z0-9_\\.\\-]+$",
        "minLength": 2,
        "maxLength": 64
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "dimension", "system"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "dimension": {
            "type": "string",
            "enum": [
              "count",
              "volume",
              "mass",
              "length",
              "temperature",
              "time",
              "other"
            ]
          },
          "system": {
            "type": "string",
            "enum": ["neutral", "metric", "us_customary", "imperial"]
          }
        }
      }
    },
    "map": {
      "type": "object",
      "description": "Map of normalized unit tokens -> canonical unit IDs.",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 0,
        "maxLength": 64,
        "pattern": "^$|^[^\\u0000-\\u001F]+$",
        "description": "Allows empty string key (SSA default for 'no unit') or a non-control unit token."
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z0-9_\\.\\-]+$",
        "minLength": 2,
        "maxLength": 64
      }
    }
  }
}
