{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "file:///src/schemas/ruleset.schema.json",
  "title": "SSA • Ruleset Schema",
  "description": "JSON Schema for SSA deterministic rulesets (e.g., cuisine rulesets) used by planners and recipe adapters.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "updatedAt", "kind", "meta", "scope", "rules"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional self-declared schema reference used by editors like VS Code.",
      "minLength": 1
    },

    "schemaVersion": {
      "type": "string",
      "description": "Ruleset file version (SSA ruleset format version).",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },

    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp (ISO 8601)."
    },

    "kind": {
      "type": "string",
      "description": "Kind of ruleset document.",
      "enum": ["cuisine_ruleset", "ruleset"]
    },

    "meta": { "$ref": "#/$defs/Meta" },

    "scope": { "$ref": "#/$defs/Scope" },

    "normalization": {
      "type": "object",
      "description": "Optional normalization and alias maps to support deterministic matching (ingredients, methods, equipment, dishes).",
      "additionalProperties": false,
      "properties": {
        "idPattern": { "type": "string" },
        "idCase": { "type": "string", "enum": ["lower", "upper", "preserve"] },
        "aliasCaseFold": { "type": "boolean" },
        "keywordCaseFold": { "type": "boolean" },
        "trimWhitespace": { "type": "boolean" },
        "collapseSpaces": { "type": "boolean" },
        "tokens": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stopWords": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "ingredientAliases": { "$ref": "#/$defs/AliasMap" },
        "dishAliases": { "$ref": "#/$defs/AliasMap" },
        "equipmentAliases": { "$ref": "#/$defs/AliasMap" },
        "methodAliases": { "$ref": "#/$defs/AliasMap" }
      }
    },

    "globals": {
      "type": "object",
      "description": "Optional global signals and plate-model defaults used by planners/adapters.",
      "additionalProperties": true
    },

    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Rule" }
    }
  },

  "$defs": {
    "Meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "label", "status", "source"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\.\\-]+$"
        },
        "type": {
          "type": "string",
          "enum": ["cuisine_ruleset", "ruleset"]
        },
        "label": { "type": "string", "minLength": 1 },
        "cuisineId": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["canonical", "draft", "experimental", "deprecated"]
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["catalog", "user", "import", "generated"]
            },
            "name": { "type": "string", "minLength": 1 },
            "notes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },

    "Scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["cuisine", "global", "module"]
        },
        "cuisineId": { "type": "string" },
        "locales": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        }
      }
    },

    "AliasMap": {
      "type": "object",
      "description": "Map of canonical IDs -> list of alias strings.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    },

    "Rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "enabled", "priority", "title", "when", "then"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\.\\-]+$"
        },
        "enabled": { "type": "boolean" },
        "priority": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": { "type": "string", "minLength": 1 },
        "stopOnMatch": { "type": "boolean" },

        "when": { "$ref": "#/$defs/LogicNode" },
        "then": { "$ref": "#/$defs/ThenBlock" }
      }
    },

    "ThenBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actions"],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Action" }
        }
      }
    },

    "LogicNode": {
      "description": "Boolean logic tree used by rule 'when'. Supports op: all|any|not and leaf conditions.",
      "oneOf": [
        { "$ref": "#/$defs/LogicGroup" },
        { "$ref": "#/$defs/Condition" }
      ]
    },

    "LogicGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "conditions"],
      "properties": {
        "op": { "type": "string", "enum": ["all", "any", "not"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/LogicNode" }
        }
      }
    },

    "Condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "eq",
            "exists",
            "hasTag",
            "intersects",
            "matches",
            "contains",
            "lt",
            "lte",
            "gt",
            "gte"
          ]
        },

        "path": {
          "type": "string",
          "description": "JSONPath-like pointer used by engines (SSA convention).",
          "minLength": 1
        },

        "value": {
          "description": "Single comparison value.",
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" },
            { "type": "object" },
            { "type": "array" }
          ]
        },

        "values": {
          "type": "array",
          "description": "Array of values (used by intersects/contains, etc.).",
          "items": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "integer" },
              { "type": "boolean" }
            ]
          }
        },

        "regex": {
          "type": "string",
          "description": "Regex used by matches condition."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "exists" } },
            "required": ["type"]
          },
          "then": { "required": ["path"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "eq" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "value"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "hasTag" } },
            "required": ["type"]
          },
          "then": { "required": ["value"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "intersects" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "values"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "matches" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "regex"] }
        }
      ]
    },

    "Action": {
      "oneOf": [
        { "$ref": "#/$defs/ActionAddTag" },
        { "$ref": "#/$defs/ActionScoreAdjust" },
        { "$ref": "#/$defs/ActionSet" },
        { "$ref": "#/$defs/ActionEmitEvent" }
      ]
    },

    "ActionAddTag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "const": "addTag" },
        "value": { "type": "string", "minLength": 1 }
      }
    },

    "ActionScoreAdjust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "scoreDelta"],
      "properties": {
        "type": { "type": "string", "const": "scoreAdjust" },
        "scoreDelta": { "type": "number" }
      }
    },

    "ActionSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path", "value"],
      "properties": {
        "type": { "type": "string", "const": "set" },
        "path": { "type": "string", "minLength": 1 },
        "value": {
          "description": "Arbitrary JSON value set into the evaluation context.",
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" },
            { "type": "object" },
            { "type": "array" }
          ]
        }
      }
    },

    "ActionEmitEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "event"],
      "properties": {
        "type": { "type": "string", "const": "emitEvent" },
        "event": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "payload"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "payload": {
              "description": "Event payload object (SSA event bus conventions).",
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
