{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://suka.smart-assistant/schemas/realtime.event.envelope.schema.json",
  "title": "Realtime Event Envelope",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "correlationId", "event", "sourceModule", "version", "actorId", "scope", "scopeId"],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "causationId": {
      "type": "string"
    },
    "event": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string"
    },
    "sourceModule": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "actorId": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": ["household", "family", "community"],
      "default": "household"
    },
    "scopeId": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "payload": {
      "type": ["object", "array", "string", "number", "boolean", "null"]
    },
    "privacyScope": {
      "type": "string"
    }
  }
}
