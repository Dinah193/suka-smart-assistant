{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://suka-smart-assistant.local/schemas/homestead/visibility_rules.schema.json",
  "title": "SSA • Homestead Visibility Rules Schema",
  "description": "Schema wrapper for Homestead UI visibility gating rules. This is a homestead-specific profile of the generic SSA ruleset schema, intended for validating visibility_rules.catalog.json and documenting its expected context shape for UI engines.",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "$schema",
    "schemaVersion",
    "updatedAt",
    "kind",
    "meta",
    "scope",
    "rules"
  ],

  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "$id": { "type": "string" },

    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Homestead visibility rules document version (SSA ruleset format version)."
    },

    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp (ISO 8601)."
    },

    "kind": {
      "type": "string",
      "enum": ["ruleset"],
      "description": "Homestead visibility rules are stored as SSA ruleset documents."
    },

    "meta": { "$ref": "#/$defs/Meta" },

    "scope": { "$ref": "#/$defs/Scope" },

    "normalization": { "$ref": "#/$defs/Normalization" },

    "globals": { "$ref": "#/$defs/Globals" },

    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Rule" }
    }
  },

  "$defs": {
    "Id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\.\\-]+$",
      "minLength": 2,
      "maxLength": 140
    },

    "Tag": {
      "type": "string",
      "pattern": "^[a-z0-9_\\.\\-]+$",
      "minLength": 2,
      "maxLength": 80
    },

    "ShortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^[^\\u0000-\\u001F]+$"
    },

    "Text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "^[^\\u0000-\\u001F]+$"
    },

    "Locale": { "type": "string", "minLength": 2, "maxLength": 35 },

    "Meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "label", "status", "source"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "type": { "type": "string", "const": "ruleset" },
        "label": { "$ref": "#/$defs/ShortText" },
        "status": {
          "type": "string",
          "enum": ["canonical", "draft", "experimental", "deprecated"]
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["catalog", "user", "import", "generated"]
            },
            "name": { "$ref": "#/$defs/ShortText" },
            "notes": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        }
      }
    },

    "Scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["module"] },
        "locales": {
          "type": "array",
          "items": { "$ref": "#/$defs/Locale" },
          "default": ["en-US"]
        }
      }
    },

    "Normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idPattern",
        "idCase",
        "aliasCaseFold",
        "keywordCaseFold",
        "trimWhitespace",
        "collapseSpaces"
      ],
      "properties": {
        "idPattern": { "type": "string", "minLength": 1 },
        "idCase": { "type": "string", "enum": ["lower", "upper", "preserve"] },
        "aliasCaseFold": { "type": "boolean" },
        "keywordCaseFold": { "type": "boolean" },
        "trimWhitespace": { "type": "boolean" },
        "collapseSpaces": { "type": "boolean" },
        "tokens": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stopWords": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "default": []
            }
          },
          "default": { "stopWords": [] }
        }
      }
    },

    "Globals": {
      "type": "object",
      "description": "Optional global defaults and engine hints for UI evaluation context.",
      "additionalProperties": false,
      "properties": {
        "module": {
          "type": "string",
          "minLength": 1,
          "default": "homestead.visibility"
        },
        "engineHints": { "$ref": "#/$defs/EngineHints" },
        "defaults": { "$ref": "#/$defs/UiDefaults" }
      },
      "default": {
        "module": "homestead.visibility",
        "engineHints": {},
        "defaults": {
          "visibility": "visible",
          "locked": false,
          "lockReason": null,
          "lockBadge": null,
          "score": 0
        }
      }
    },

    "EngineHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contextPaths": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        },
        "conventions": {
          "type": "array",
          "items": { "$ref": "#/$defs/ShortText" },
          "default": []
        }
      },
      "default": { "contextPaths": {}, "conventions": [] }
    },

    "UiDefaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibility", "locked", "lockReason", "lockBadge", "score"],
      "properties": {
        "visibility": {
          "type": "string",
          "enum": ["visible", "locked", "hidden"],
          "default": "visible"
        },
        "locked": { "type": "boolean", "default": false },
        "lockReason": { "type": ["string", "null"], "default": null },
        "lockBadge": { "type": ["string", "null"], "default": null },
        "score": { "type": "number", "default": 0 }
      }
    },

    "Rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "enabled", "priority", "title", "when", "then"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "enabled": { "type": "boolean" },
        "priority": { "type": "integer", "minimum": 0 },
        "title": { "$ref": "#/$defs/ShortText" },
        "description": { "$ref": "#/$defs/Text" },
        "tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/Tag" },
          "default": []
        },
        "source": { "$ref": "#/$defs/ShortText" },
        "stopOnMatch": { "type": "boolean", "default": false },

        "when": { "$ref": "#/$defs/LogicNode" },
        "then": { "$ref": "#/$defs/ThenBlock" }
      }
    },

    "ThenBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actions"],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Action" }
        }
      }
    },

    "LogicNode": {
      "description": "Boolean logic tree used by rule 'when'. Group nodes use op + conditions; leaves use condition shape.",
      "oneOf": [
        { "$ref": "#/$defs/LogicGroup" },
        { "$ref": "#/$defs/Condition" }
      ]
    },

    "LogicGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "conditions"],
      "properties": {
        "op": { "type": "string", "enum": ["all", "any", "not"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/LogicNode" }
        }
      }
    },

    "Condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "eq",
            "exists",
            "hasTag",
            "intersects",
            "matches",
            "contains",
            "lt",
            "lte",
            "gt",
            "gte"
          ]
        },
        "path": {
          "type": "string",
          "description": "JSONPath-like pointer used by engines (SSA convention).",
          "minLength": 1
        },
        "value": {
          "description": "Single comparison value.",
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" },
            { "type": "object" },
            { "type": "array" }
          ]
        },
        "values": {
          "type": "array",
          "description": "Array of values (used by intersects/contains, etc.).",
          "items": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "integer" },
              { "type": "boolean" }
            ]
          }
        },
        "regex": {
          "type": "string",
          "description": "Regex used by matches condition."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "exists" } },
            "required": ["type"]
          },
          "then": { "required": ["path"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "eq" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "value"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "hasTag" } },
            "required": ["type"]
          },
          "then": { "required": ["value"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "intersects" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "values"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "contains" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "value"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "matches" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "regex"] }
        },
        {
          "if": {
            "properties": { "type": { "enum": ["lt", "lte", "gt", "gte"] } },
            "required": ["type"]
          },
          "then": { "required": ["path", "value"] }
        }
      ]
    },

    "Action": {
      "oneOf": [
        { "$ref": "#/$defs/ActionAddTag" },
        { "$ref": "#/$defs/ActionScoreAdjust" },
        { "$ref": "#/$defs/ActionSet" },
        { "$ref": "#/$defs/ActionEmitEvent" }
      ]
    },

    "ActionAddTag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "const": "addTag" },
        "value": { "$ref": "#/$defs/Tag" }
      }
    },

    "ActionScoreAdjust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "scoreDelta"],
      "properties": {
        "type": { "type": "string", "const": "scoreAdjust" },
        "scoreDelta": { "type": "number" }
      }
    },

    "ActionSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path", "value"],
      "properties": {
        "type": { "type": "string", "const": "set" },
        "path": { "type": "string", "minLength": 1 },
        "value": {
          "description": "Arbitrary JSON value set into the evaluation context.",
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" },
            { "type": "object" },
            { "type": "array" }
          ]
        }
      }
    },

    "ActionEmitEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "event"],
      "properties": {
        "type": { "type": "string", "const": "emitEvent" },
        "event": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "payload"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "payload": { "type": "object", "additionalProperties": true }
          }
        }
      }
    }
  }
}
