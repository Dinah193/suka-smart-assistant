{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://suka-smart-assistant.local/schemas/farm_to_table/components.catalog.schema.json",
  "title": "SSA • Farm-to-Table Components Catalog Schema",
  "description": "Schema for SSA farm-to-table components catalogs (canonical component definitions used by planners/resolvers). Extends the generic SSA catalog contract (id + tags) with optional, structured component fields: role, readiness, sourcing, storage, seasonality, and planner signals. Designed for forward compatibility and deterministic matching.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "meta", "items"],
  "properties": {
    "$schema": { "type": "string" },
    "$id": { "type": "string" },
    "schemaVersion": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },

    "meta": { "$ref": "#/$defs/Meta" },

    "scope": {
      "description": "Optional scoping for planners/resolvers (e.g., module, locale).",
      "type": ["string", "object"],
      "additionalProperties": true
    },

    "defaults": {
      "description": "Optional defaults used by planners (e.g., default role weights, fallback readiness).",
      "type": "object",
      "additionalProperties": true
    },

    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ComponentItem" }
    }
  },

  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9_\\.\\-]+$"
    },

    "Tag": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9_\\.\\-]+$"
    },

    "ShortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^[^\\u0000-\\u001F]+$"
    },

    "Text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "^[^\\u0000-\\u001F]+$"
    },

    "Meta": {
      "type": "object",
      "required": ["id", "type", "name"],
      "additionalProperties": true,
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "type": { "type": "string", "const": "catalog" },
        "domain": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 2 },
        "name": { "$ref": "#/$defs/ShortText" },
        "label": { "$ref": "#/$defs/ShortText" },
        "subtitle": { "$ref": "#/$defs/ShortText" },
        "source": {
          "type": ["object", "null"],
          "additionalProperties": true
        }
      }
    },

    "CatalogRefs": {
      "description": "Optional cross references (aliases, related IDs, conversions, etc.).",
      "type": "object",
      "additionalProperties": true
    },

    "Sourcing": {
      "description": "Optional sourcing/provenance data for farm-to-table scoring.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "description": "Primary sourcing channel.",
          "type": "string",
          "enum": [
            "homegrown",
            "garden",
            "animals",
            "butchery",
            "preserved",
            "local_farm",
            "co_op",
            "retail",
            "restaurant",
            "unknown"
          ]
        },
        "priority": {
          "description": "Optional deterministic priority hint. Lower is preferred.",
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ShortText" },
          "default": []
        }
      }
    },

    "Readiness": {
      "description": "Component readiness state for time-budgeting and batch-day planning.",
      "type": "string",
      "enum": [
        "readiness.raw",
        "readiness.cleaned",
        "readiness.trimmed",
        "readiness.chopped",
        "readiness.prepped",
        "readiness.marinated",
        "readiness.parcooked",
        "readiness.cooked",
        "readiness.assembled",
        "readiness.preserved_shelf_stable",
        "readiness.preserved_frozen"
      ]
    },

    "Storage": {
      "description": "Preferred storage context for the component.",
      "type": "string",
      "enum": [
        "storage.pantry",
        "storage.fridge",
        "storage.freezer",
        "storage.root_cellar",
        "storage.cellar",
        "storage.shelf_stable",
        "storage.frozen",
        "storage.ferment",
        "storage.dry"
      ]
    },

    "Seasonality": {
      "description": "Seasonality hint (generic; location-specific seasonality can override elsewhere).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["unknown", "in_season", "out_of_season", "year_round"]
        },
        "months": {
          "description": "Optional month list (1-12) for typical in-season window.",
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 12 },
          "default": []
        },
        "notes": { "$ref": "#/$defs/ShortText" }
      }
    },

    "Signals": {
      "description": "Planner-friendly booleans and hints for filtering and ranking.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "batchFriendly": { "type": "boolean", "default": false },
        "weeknightFriendly": { "type": "boolean", "default": false },
        "freezerFriendly": { "type": "boolean", "default": false },
        "leftoversFriendly": { "type": "boolean", "default": false },
        "quickPrep": { "type": "boolean", "default": false },
        "lowEffort": { "type": "boolean", "default": false }
      },
      "default": {}
    },

    "RoleRef": {
      "description": "Component role reference (ties into component_roles.catalog.json).",
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "weight": {
          "description": "Optional role weight for multi-role components (higher preferred).",
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "default": 1
        }
      }
    },

    "ComponentItem": {
      "description": "Farm-to-table component definition. Requires generic catalog minimum: id + tags. Provides optional structured properties for deterministic matching.",
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "tags"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/Tag" },
          "default": []
        },

        "label": { "$ref": "#/$defs/ShortText" },
        "group": { "$ref": "#/$defs/ShortText" },
        "rank": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["active", "draft", "deprecated"]
        },
        "notes": { "$ref": "#/$defs/Text" },

        "path": {
          "description": "Optional relative path to an external JSON describing the component in more detail.",
          "type": "string"
        },

        "roles": {
          "description": "One or more roles the component can fulfill (e.g., role.protein, role.vegetable).",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/RoleRef" }
        },

        "readiness": {
          "description": "Primary readiness state.",
          "anyOf": [{ "$ref": "#/$defs/Readiness" }, { "type": "null" }]
        },

        "readinessOptions": {
          "description": "Optional alternate readiness states this component can be in (inventory may override).",
          "type": "array",
          "items": { "$ref": "#/$defs/Readiness" },
          "default": []
        },

        "sourcing": {
          "description": "Optional sourcing/provenance data.",
          "anyOf": [{ "$ref": "#/$defs/Sourcing" }, { "type": "null" }]
        },

        "storage": {
          "description": "Preferred storage type for waste/rotation planning.",
          "anyOf": [{ "$ref": "#/$defs/Storage" }, { "type": "null" }]
        },

        "seasonality": {
          "description": "Optional seasonality hints.",
          "anyOf": [{ "$ref": "#/$defs/Seasonality" }, { "type": "null" }]
        },

        "signals": {
          "description": "Optional planner signals used by UI filters and scoring layers.",
          "anyOf": [{ "$ref": "#/$defs/Signals" }, { "type": "null" }]
        },

        "allergens": {
          "description": "Optional allergen IDs/tags (SSA convention: ingredient/diet/allergen IDs).",
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        },

        "dietFlags": {
          "description": "Optional dietary flags (e.g., diet.vegan, diet.gluten_free).",
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        },

        "refs": { "$ref": "#/$defs/CatalogRefs" }
      },

      "allOf": [
        {
          "if": { "required": ["roles"] },
          "then": {
            "properties": {
              "roles": { "type": "array", "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
