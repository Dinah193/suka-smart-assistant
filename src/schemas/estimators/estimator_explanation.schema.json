{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://suka-smart-assistant.local/schemas/estimators/estimator_explanation.schema.json",
  "title": "SSA • Estimators • Explanation Schema",
  "description": "Defines the structure for human-readable explanations of estimates (summary sentences, supporting bullets, confidence language, and 'why this matters' blocks). Keeps explanations consistent, supports localization/tone changes, and prevents logic text from living in UI components.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "$id",
    "schemaVersion",
    "updatedAt",
    "meta",
    "explanations"
  ],

  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "$id": { "type": "string", "minLength": 1 },

    "schemaVersion": {
      "type": "string",
      "description": "Schema document version (not the catalog data version).",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },

    "updatedAt": { "type": "string", "format": "date-time" },

    "meta": { "$ref": "#/$defs/Meta" },

    "defaults": {
      "description": "Optional global defaults for renderers (tone, locale fallback, etc.).",
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },

    "explanations": {
      "description": "Explanation templates and blocks keyed by id (e.g., 'food_security.summary').",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Explanation" }
    }
  },

  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "pattern": "^[a-z0-9_\\.\\-]+$"
    },

    "Tag": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "pattern": "^[a-z0-9_\\.\\-]+$"
    },

    "Locale": { "type": "string", "minLength": 2, "maxLength": 35 },

    "SafeText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "^[^\\u0000-\\u001F]+$"
    },

    "ShortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^[^\\u0000-\\u001F]+$"
    },

    "Meta": {
      "description": "Schema document metadata (not the explanation content itself).",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "domain", "label", "status", "source"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "type": { "type": "string", "const": "schema" },
        "domain": { "type": "string", "const": "estimators" },
        "label": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["canonical", "draft", "experimental", "deprecated"]
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["catalog", "user", "import", "generated"]
            },
            "name": { "type": "string", "minLength": 1 },
            "notes": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        }
      }
    },

    "Explanation": {
      "description": "A single explanation template family (summary + bullets + confidence language + why-matters blocks).",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "enabled",
        "priority",
        "locale",
        "title",
        "summary",
        "blocks"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },

        "kind": {
          "description": "Estimator explanation type.",
          "type": "string",
          "enum": [
            "food_security",
            "cost_delta",
            "valuation",
            "coverage",
            "general"
          ]
        },

        "enabled": { "type": "boolean", "default": true },

        "priority": {
          "description": "Higher priority templates win when multiple match (UI/engine selection policy).",
          "type": "integer",
          "minimum": 0,
          "default": 100
        },

        "locale": { "$ref": "#/$defs/Locale" },

        "tags": {
          "description": "Optional tags to help select this explanation (e.g., 'tone.friendly', 'ux.tooltip').",
          "type": "array",
          "items": { "$ref": "#/$defs/Tag" },
          "default": []
        },

        "title": { "$ref": "#/$defs/ShortText" },

        "summary": { "$ref": "#/$defs/SummaryTemplate" },

        "blocks": {
          "description": "Supporting blocks rendered under the summary (bullets, confidence, why-matters, next steps).",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Block" }
        }
      }
    },

    "SummaryTemplate": {
      "description": "Summary sentence(s) shown at top. Renderers should substitute variables deterministically.",
      "type": "object",
      "additionalProperties": false,
      "required": ["template", "vars"],
      "properties": {
        "template": {
          "description": "String template using {{var}} placeholders.",
          "$ref": "#/$defs/SafeText"
        },
        "vars": {
          "description": "Declared variables allowed in template. Prevents UI from substituting unknown keys.",
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        },
        "tone": {
          "description": "Optional tone marker used by UX (copy variants).",
          "type": "string",
          "enum": ["neutral", "friendly", "direct", "educational"],
          "default": "neutral"
        }
      }
    },

    "Block": {
      "description": "A renderable block under the summary (bullets, confidence language, why-matters, etc.).",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title", "enabled", "content"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },

        "type": {
          "type": "string",
          "enum": [
            "bullets",
            "confidence",
            "why_matters",
            "callout",
            "next_steps",
            "details"
          ]
        },

        "title": { "$ref": "#/$defs/ShortText" },

        "enabled": { "type": "boolean", "default": true },

        "when": {
          "description": "Optional deterministic gating for this block (logic lives outside components). Engines evaluate against estimator context and include/exclude blocks.",
          "$ref": "#/$defs/LogicNode"
        },

        "content": { "$ref": "#/$defs/BlockContent" }
      }
    },

    "BlockContent": {
      "description": "Union of block content shapes by block type.",
      "oneOf": [
        { "$ref": "#/$defs/BulletsBlock" },
        { "$ref": "#/$defs/ConfidenceBlock" },
        { "$ref": "#/$defs/WhyMattersBlock" },
        { "$ref": "#/$defs/CalloutBlock" },
        { "$ref": "#/$defs/NextStepsBlock" },
        { "$ref": "#/$defs/DetailsBlock" }
      ]
    },

    "BulletsBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bullets"],
      "properties": {
        "bullets": {
          "description": "Bullet items with optional gating and templating.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Bullet" }
        }
      }
    },

    "Bullet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "vars"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "text": {
          "description": "Template using {{var}} placeholders.",
          "$ref": "#/$defs/SafeText"
        },
        "vars": {
          "description": "Declared variables allowed in bullet template.",
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        },
        "when": { "$ref": "#/$defs/LogicNode" },
        "severity": {
          "description": "UI hint for icons/colors (renderer decides).",
          "type": "string",
          "enum": ["info", "success", "warning", "danger"],
          "default": "info"
        },
        "tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/Tag" },
          "default": []
        }
      }
    },

    "ConfidenceBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "bands"],
      "properties": {
        "language": {
          "description": "High-level explanation of confidence and how it is determined.",
          "$ref": "#/$defs/SafeText"
        },
        "bands": {
          "description": "Copy variants based on confidence score (0..1).",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ConfidenceBand" }
        },
        "vars": {
          "description": "Optional declared variables used in confidence copy (e.g., confidenceScore, completeness).",
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        }
      }
    },

    "ConfidenceBand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "min", "max", "template", "vars"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "min": { "type": "number", "minimum": 0, "maximum": 1 },
        "max": { "type": "number", "minimum": 0, "maximum": 1 },
        "template": { "$ref": "#/$defs/SafeText" },
        "vars": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        },
        "tone": {
          "type": "string",
          "enum": ["neutral", "friendly", "direct", "educational"],
          "default": "neutral"
        }
      },
      "allOf": [
        {
          "description": "Ensure band ranges are valid.",
          "if": { "required": ["min", "max"] },
          "then": {
            "properties": {
              "max": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      ]
    },

    "WhyMattersBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "description": "Short paragraphs explaining why the number matters.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/WhyMattersItem" }
        }
      }
    },

    "WhyMattersItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "vars"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "text": { "$ref": "#/$defs/SafeText" },
        "vars": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        },
        "when": { "$ref": "#/$defs/LogicNode" }
      }
    },

    "CalloutBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "text", "vars"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["tip", "warning", "note", "success"]
        },
        "text": { "$ref": "#/$defs/SafeText" },
        "vars": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        }
      }
    },

    "NextStepsBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "description": "Deterministic next-step suggestions (not AI).",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/NextStep" }
        }
      }
    },

    "NextStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "action", "when"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "label": { "$ref": "#/$defs/ShortText" },
        "description": { "$ref": "#/$defs/SafeText" },
        "action": {
          "description": "UI action key (router/modal/etc.).",
          "$ref": "#/$defs/Id"
        },
        "payload": {
          "description": "Optional action payload (route params, modal ids).",
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "when": {
          "description": "Deterministic gating for this suggestion.",
          "$ref": "#/$defs/LogicNode"
        },
        "rank": {
          "description": "Ordering hint (lower first).",
          "type": "integer",
          "minimum": 0,
          "default": 100
        }
      }
    },

    "DetailsBlock": {
      "description": "Expandable details: short key/value facts and/or paragraphs.",
      "type": "object",
      "additionalProperties": false,
      "required": ["facts", "paragraphs"],
      "properties": {
        "facts": {
          "type": "array",
          "items": { "$ref": "#/$defs/Fact" },
          "default": []
        },
        "paragraphs": {
          "type": "array",
          "items": { "$ref": "#/$defs/DetailsParagraph" },
          "default": []
        }
      }
    },

    "Fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "valueTemplate", "vars"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "label": { "$ref": "#/$defs/ShortText" },
        "valueTemplate": {
          "description": "Template using {{var}} placeholders (rendered deterministically).",
          "$ref": "#/$defs/SafeText"
        },
        "vars": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        },
        "when": { "$ref": "#/$defs/LogicNode" }
      }
    },

    "DetailsParagraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "vars"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "text": { "$ref": "#/$defs/SafeText" },
        "vars": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" },
          "default": []
        },
        "when": { "$ref": "#/$defs/LogicNode" }
      }
    },

    "LogicNode": {
      "description": "Deterministic boolean logic tree (mirrors SSA ruleset logic conventions).",
      "oneOf": [
        { "$ref": "#/$defs/LogicGroup" },
        { "$ref": "#/$defs/Condition" }
      ]
    },

    "LogicGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "conditions"],
      "properties": {
        "op": { "type": "string", "enum": ["all", "any", "not"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/LogicNode" }
        }
      }
    },

    "Condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "eq",
            "exists",
            "hasTag",
            "intersects",
            "matches",
            "contains",
            "lt",
            "lte",
            "gt",
            "gte"
          ]
        },
        "path": {
          "description": "JSONPath-like pointer used by engines (SSA convention).",
          "type": "string",
          "minLength": 1
        },
        "value": {
          "description": "Single comparison value.",
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "null" },
            { "type": "object" },
            { "type": "array" }
          ]
        },
        "values": {
          "type": "array",
          "description": "Array of values (used by intersects/contains).",
          "items": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "integer" },
              { "type": "boolean" }
            ]
          }
        },
        "regex": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "exists" } },
            "required": ["type"]
          },
          "then": { "required": ["path"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "eq" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "value"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "hasTag" } },
            "required": ["type"]
          },
          "then": { "required": ["value"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "intersects" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "values"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "matches" } },
            "required": ["type"]
          },
          "then": { "required": ["path", "regex"] }
        }
      ]
    }
  }
}
