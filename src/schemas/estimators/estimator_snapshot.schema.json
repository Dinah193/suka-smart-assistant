{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://suka-smart-assistant.local/schemas/estimators/estimator_snapshot.schema.json",
  "title": "SSA • Estimators • Snapshot Schema",
  "description": "Schema for stored estimator outputs over time (weekly/monthly snapshots). Protects historical integrity, supports comparisons across versions, and prevents breaking old snapshots when estimator logic improves.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "$id",
    "schemaVersion",
    "updatedAt",
    "meta",
    "snapshot"
  ],

  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "$id": { "type": "string", "minLength": 1 },

    "schemaVersion": {
      "type": "string",
      "description": "Schema document version (not the data file version).",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },

    "updatedAt": { "type": "string", "format": "date-time" },

    "meta": { "$ref": "#/$defs/Meta" },

    "notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },

    "snapshot": { "$ref": "#/$defs/Snapshot" }
  },

  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "pattern": "^[a-z0-9_\\.\\-]+$"
    },

    "Tag": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "pattern": "^[a-z0-9_\\.\\-]+$"
    },

    "Locale": { "type": "string", "minLength": 2, "maxLength": 35 },

    "Money": {
      "description": "Money values for cost deltas/projections.",
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "value"],
      "properties": {
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "default": "USD"
        },
        "value": { "type": "number" }
      }
    },

    "Meta": {
      "description": "Schema document metadata (not the snapshot data metadata).",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "domain", "label", "status", "source"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "type": { "type": "string", "const": "schema" },
        "domain": { "type": "string", "const": "estimators" },
        "label": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["canonical", "draft", "experimental", "deprecated"]
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["catalog", "user", "import", "generated"]
            },
            "name": { "type": "string", "minLength": 1 },
            "notes": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        }
      }
    },

    "Snapshot": {
      "description": "A single stored snapshot of estimator outputs at a point in time.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "createdAt",
        "period",
        "household",
        "homestead",
        "metrics",
        "confidence",
        "provenance"
      ],
      "properties": {
        "id": {
          "description": "Stable snapshot id (SSA-safe). Typically generated at write time.",
          "$ref": "#/$defs/Id"
        },

        "createdAt": {
          "description": "When the snapshot was written (ISO 8601).",
          "type": "string",
          "format": "date-time"
        },

        "period": { "$ref": "#/$defs/Period" },

        "household": { "$ref": "#/$defs/HouseholdContext" },

        "homestead": { "$ref": "#/$defs/HomesteadContext" },

        "metrics": { "$ref": "#/$defs/EstimatorMetrics" },

        "confidence": { "$ref": "#/$defs/ConfidenceBlock" },

        "provenance": { "$ref": "#/$defs/Provenance" },

        "tags": {
          "description": "Optional tags for grouping/search in reports.",
          "type": "array",
          "items": { "$ref": "#/$defs/Tag" },
          "default": []
        },

        "raw": {
          "description": "Optional raw estimator outputs for auditing/debugging (kept permissive).",
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },

    "Period": {
      "description": "The time window the snapshot summarizes (weekly/monthly).",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "startDate", "endDate", "label"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["week", "month", "quarter", "year", "custom"]
        },
        "startDate": {
          "description": "Inclusive start date (YYYY-MM-DD).",
          "type": "string",
          "format": "date"
        },
        "endDate": {
          "description": "Inclusive end date (YYYY-MM-DD).",
          "type": "string",
          "format": "date"
        },
        "label": {
          "description": "Human label (e.g., '2026-W04', '2026-01').",
          "type": "string",
          "minLength": 1
        },
        "timezone": {
          "description": "IANA timezone at snapshot time (for consistent bucketing).",
          "type": "string",
          "minLength": 3,
          "default": "America/Chicago"
        }
      }
    },

    "HouseholdContext": {
      "description": "Household settings at time of snapshot (minimal but sufficient for comparisons).",
      "type": "object",
      "additionalProperties": false,
      "required": ["householdId", "locale", "size"],
      "properties": {
        "householdId": { "$ref": "#/$defs/Id" },
        "locale": { "$ref": "#/$defs/Locale" },
        "size": {
          "description": "Household size used by estimators at snapshot time.",
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "members": {
          "description": "Optional per-member breakdown (kept lightweight).",
          "type": "array",
          "items": { "$ref": "#/$defs/HouseholdMember" },
          "default": []
        }
      }
    },

    "HouseholdMember": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "role": {
          "description": "High-level role used for portion assumptions (adult/child/etc.).",
          "type": "string",
          "enum": ["adult", "child", "senior", "infant", "unknown"]
        },
        "notes": { "type": "string" }
      }
    },

    "HomesteadContext": {
      "description": "Homestead level context at the time of snapshot.",
      "type": "object",
      "additionalProperties": false,
      "required": ["levelId", "levelOrder"],
      "properties": {
        "levelId": { "$ref": "#/$defs/Id" },
        "levelOrder": {
          "description": "Numeric level order (0..4).",
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "uiFlags": {
          "description": "Optional UI feature flags at the time (useful for interpreting missing data).",
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },

    "EstimatorMetrics": {
      "description": "High-level estimator outputs. Keep stable; add fields under 'extensions' if needed.",
      "type": "object",
      "additionalProperties": false,
      "required": ["foodSecurity", "coverage", "costDelta", "projections"],
      "properties": {
        "foodSecurity": { "$ref": "#/$defs/FoodSecurityMetric" },
        "coverage": { "$ref": "#/$defs/CoverageMetric" },
        "costDelta": { "$ref": "#/$defs/CostDeltaMetric" },
        "projections": { "$ref": "#/$defs/ProjectionMetric" },
        "extensions": {
          "description": "Forward-compatible extension bucket for new metrics.",
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },

    "FoodSecurityMetric": {
      "description": "Food security percent and related rollups at snapshot time.",
      "type": "object",
      "additionalProperties": false,
      "required": ["percent", "status"],
      "properties": {
        "percent": {
          "description": "0..100 food security score (coverage-based).",
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "description": "Coarse label used by UI (stable buckets).",
          "type": "string",
          "enum": ["critical", "low", "moderate", "good", "excellent"]
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },

    "CoverageMetric": {
      "description": "Days of coverage and supporting summary.",
      "type": "object",
      "additionalProperties": false,
      "required": ["days", "mealsCovered", "mealsRequired"],
      "properties": {
        "days": {
          "description": "Estimated days of food coverage (can be fractional).",
          "type": "number",
          "minimum": 0
        },
        "mealsCovered": {
          "description": "Estimated meals currently covered by inventory.",
          "type": "number",
          "minimum": 0
        },
        "mealsRequired": {
          "description": "Meals required for the snapshot period (or comparison baseline).",
          "type": "number",
          "minimum": 0.0001
        },
        "byFoodClass": {
          "description": "Optional rollup by class tags (e.g., protein, grains).",
          "type": "array",
          "items": { "$ref": "#/$defs/CoverageByClass" },
          "default": []
        }
      }
    },

    "CoverageByClass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classTag", "days"],
      "properties": {
        "classTag": { "$ref": "#/$defs/Tag" },
        "days": { "type": "number", "minimum": 0 },
        "notes": { "type": "string" }
      }
    },

    "CostDeltaMetric": {
      "description": "Cost delta calculations for budget reduction messaging.",
      "type": "object",
      "additionalProperties": false,
      "required": ["monthly", "method"],
      "properties": {
        "monthly": {
          "description": "Monthly net savings (positive) or cost increase (negative).",
          "$ref": "#/$defs/Money"
        },
        "method": {
          "description": "Estimator strategy used to compute cost delta.",
          "type": "string",
          "enum": ["default_assumptions", "user_spend", "hybrid"]
        },
        "inputs": {
          "description": "Optional summary of key inputs used for explaining deltas.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "groceryCostPerMeal": { "$ref": "#/$defs/Money" },
            "eatingOutCostPerMeal": { "$ref": "#/$defs/Money" },
            "mealsPlanned": { "type": "number", "minimum": 0 },
            "batchSavingsFactor": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "preservationValueFactor": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "inflationBufferPct": {
              "type": "number",
              "minimum": 0,
              "maximum": 2
            }
          },
          "default": {}
        }
      }
    },

    "ProjectionMetric": {
      "description": "Annualized and longer-horizon projections derived from cost delta and coverage growth trends.",
      "type": "object",
      "additionalProperties": false,
      "required": ["annualized", "horizon"],
      "properties": {
        "annualized": {
          "description": "Annualized projection based on monthly delta.",
          "$ref": "#/$defs/Money"
        },
        "horizon": {
          "description": "Optional multi-year projections (kept small).",
          "type": "array",
          "items": { "$ref": "#/$defs/HorizonProjection" },
          "default": []
        }
      }
    },

    "HorizonProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["years", "value"],
      "properties": {
        "years": { "type": "integer", "minimum": 1, "maximum": 20 },
        "value": { "$ref": "#/$defs/Money" },
        "notes": { "type": "string" }
      }
    },

    "ConfidenceBlock": {
      "description": "Confidence and completeness indicators to avoid overclaiming improvements.",
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "completeness", "signals"],
      "properties": {
        "score": {
          "description": "0..1 confidence score (1 = high confidence).",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "completeness": {
          "description": "0..1 estimate of data completeness (inventory coverage, profile completion, etc.).",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "signals": {
          "description": "Explainable reasons behind confidence/completeness.",
          "type": "array",
          "items": { "$ref": "#/$defs/ConfidenceSignal" },
          "default": []
        }
      }
    },

    "ConfidenceSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "weight", "message"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "kind": {
          "type": "string",
          "enum": [
            "data_missing",
            "assumption_used",
            "stale_data",
            "high_quality",
            "override"
          ]
        },
        "weight": {
          "description": "Signed contribution to score (-1..+1).",
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "message": { "type": "string", "minLength": 1 },
        "paths": {
          "description": "Optional context paths involved (SSA JSONPath-like).",
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },

    "Provenance": {
      "description": "Immutable provenance of estimator versions and catalog versions used.",
      "type": "object",
      "additionalProperties": false,
      "required": ["estimators", "catalogs", "engine", "dataRefs"],
      "properties": {
        "estimators": {
          "description": "Estimator versions used for this snapshot.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/EstimatorVersionRef" }
        },
        "catalogs": {
          "description": "Catalogs (and versions) referenced during evaluation (valuation map, defaults, etc.).",
          "type": "array",
          "items": { "$ref": "#/$defs/CatalogVersionRef" },
          "default": []
        },
        "engine": {
          "description": "Runtime/engine identifier.",
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "dataRefs": {
          "description": "Pointers to data sources used (Dexie tables, import ids). Keep permissive.",
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },

    "EstimatorVersionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },

    "CatalogVersionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "schemaVersion", "updatedAt"],
      "properties": {
        "id": { "$ref": "#/$defs/Id" },
        "path": { "type": "string", "minLength": 1 },
        "schemaVersion": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "format": "date-time" },
        "hash": {
          "description": "Optional integrity hash of catalog content used (sha256, etc.).",
          "type": "string"
        }
      }
    }
  }
}
