{
  "id": "wf.modern.modern_efficiency",
  "domain": "workflow",
  "kind": "workflow_overlay",
  "title": "Modern Efficiency Workflow (Opt-in Overlay)",
  "intentTags": [
    "overlay:workflow",
    "culture:modern_efficiency",
    "group:modern"
  ],
  "inputs": [
    {
      "key": "enabled",
      "label": "Enabled (opt-in)",
      "type": "boolean",
      "required": true,
      "default": false,
      "notes": "Overlays must be explicitly enabled by user/household."
    },
    {
      "key": "householdMode",
      "label": "Household mode",
      "type": "string",
      "default": "default",
      "notes": "Examples: default, communal, travel, recovery."
    },
    {
      "key": "dietaryLaws",
      "label": "Dietary laws / household rules",
      "type": "object",
      "default": {},
      "notes": "Merged with household prefs; overlay never overrides hard constraints."
    },
    {
      "key": "quietHours",
      "label": "Quiet hours / Sabbath guard",
      "type": "object",
      "default": {
        "enabled": false
      }
    },
    {
      "key": "season",
      "label": "Season",
      "type": "string"
    }
  ],
  "outputs": [
    {
      "key": "tagOverlays",
      "label": "Canonical tags to apply",
      "type": "array",
      "required": true
    },
    {
      "key": "patternBiases",
      "label": "Pattern bias suggestions",
      "type": "object",
      "required": true
    },
    {
      "key": "constraintOverlays",
      "label": "Constraint overlays (soft)",
      "type": "object",
      "required": true
    },
    {
      "key": "uiOverlays",
      "label": "UI label/order defaults",
      "type": "object",
      "required": true
    },
    {
      "key": "roleDefaults",
      "label": "Role-based defaults (optional)",
      "type": "object",
      "default": {}
    }
  ],
  "constraints": [
    "optInOnly",
    "neverStereotype",
    "userEditable",
    "respectDietaryLaws",
    "respectQuietHours"
  ],
  "steps": [
    {
      "id": "overlay.apply",
      "title": "Apply workflow overlay",
      "template": "tpl.workflow.overlay.apply",
      "domain": "workflow",
      "params": {
        "cultureTag": "culture:modern_efficiency",
        "mergeMode": "soft"
      },
      "hints": [
        "emitHintTag:applyWorkflowOverlay"
      ]
    }
  ],
  "kpis": [
    {
      "key": "adoptionRate",
      "label": "Overlay adoption rate",
      "direction": "up",
      "unit": "%",
      "notes": "How often households keep overlay enabled."
    },
    {
      "key": "overrideEdits",
      "label": "User edits vs defaults",
      "direction": "down",
      "unit": "count",
      "notes": "High edits may indicate defaults need tuning."
    }
  ],
  "meta": {
    "version": "1.0.0",
    "updatedAt": "2025-12-27",
    "changelog": [
      {
        "date": "2025-12-27",
        "note": "Initial workflow overlay catalog (opt-in, non-stereotyped)."
      }
    ],
    "tags": [
      "culture:modern_efficiency",
      "group:modern"
    ],
    "family": "workflows"
  },
  "workflow": {
    "preferredStaples": {
      "canonicalTags": [
        "meal_components",
        "proteins",
        "veg",
        "starches"
      ],
      "examples": [
        {
          "tag": "staple:meal_components",
          "examples": [
            "cook once, mix-and-match components"
          ]
        }
      ],
      "notes": "Component cooking is a method bias; households still choose ingredients."
    },
    "mealRhythms": {
      "canonicalTags": [
        "component_cooking",
        "prep_only_bias",
        "calendar_blocks"
      ],
      "defaults": {
        "weeklyCadence": {
          "prepBlocks": 2,
          "cookBlocks": 1
        },
        "structure": [
          "components",
          "assemble"
        ],
        "leftoversNights": 2
      },
      "notes": "Bias toward predictable blocks and reduced context switching."
    },
    "preservationEmphasis": {
      "canonicalTags": [
        "freezing",
        "labeling",
        "fifo"
      ],
      "defaults": {
        "prioritize": [
          "freezing",
          "fifo"
        ],
        "secondary": [
          "labeling"
        ]
      },
      "notes": "Used to trigger FIFO labeling and quick freeze sessions."
    },
    "valuePriorities": {
      "canonicalTags": [
        "efficiency",
        "predictability",
        "low_cognitive_load"
      ],
      "defaults": {
        "efficiencyMode": "on"
      },
      "notes": "Optimizes for time, fewer decisions, and steady cadence."
    },
    "notes": "All fields are suggestions. Users can disable any default and replace with their own."
  },
  "outputs_default": {
    "tagOverlays": [
      "staple:veg",
      "preservation:fifo",
      "value:predictability",
      "rhythm:calendar_blocks",
      "value:efficiency",
      "value:low_cognitive_load",
      "rhythm:component_cooking",
      "rhythm:prep_only_bias",
      "preservation:labeling",
      "staple:meal_components",
      "staple:starches",
      "staple:proteins",
      "preservation:freezing"
    ],
    "patternBiases": {
      "favor": {
        "pat.meals.weekly_batch": 1.18,
        "pat.storehouse.weekly_restock": 1.1,
        "pat.storehouse.monthly_cycle_count": 1.08
      },
      "avoid": {
        "pat.meals.feast_anchored": 0.95
      },
      "notes": "Biases are advisory; resolvers may downrank/boost patterns, not block unless user also sets a hard constraint.",
      "emitHintTags": [
        "workflow:component_cooking",
        "workflow:calendar_blocks"
      ]
    },
    "constraintOverlays": {
      "soft": {
        "preferShortSessions": true,
        "preferLowDishCount": true
      },
      "hard": {}
    },
    "uiOverlays": {
      "labels": {},
      "ordering": {
        "plannerSections": [
          "inventory",
          "components",
          "sessions",
          "shopping",
          "labels"
        ]
      },
      "defaults": {
        "defaultMealMode": "component_cooking",
        "showTimers": true
      }
    },
    "roleDefaults": {}
  }
}
