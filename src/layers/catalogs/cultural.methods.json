    {
      "id": "cultural.overlay.select",
      "name": "Select a Cultural Workflow Overlay",
      "summary": "Pick an opt-in cultural workflow overlay (or none) that influences naming, ordering, defaults, and constraints used by planning patterns.",
      "tags": [
        "overlay",
        "preferences",
        "planning",
        "opt-in",
        "non-stereotyped"
      ],
      "inputs": [
        {
          "key": "primaryOverlayId",
          "type": "string",
          "required": false,
          "examples": [
            "workflows/indigenous/israelite_household",
            "workflows/modern/modern_efficiency"
          ]
        },
        {
          "key": "blendSecondaryOverlayId",
          "type": "string",
          "required": false,
          "examples": [
            "workflows/indigenous/west_african"
          ]
        },
        {
          "key": "blendMode",
          "type": "string",
          "required": false,
          "examples": [
            "primaryOnly",
            "blend"
          ]
        },
        {
          "key": "householdValues",
          "type": "array",
          "required": false,
          "examples": [
            [
              "value:community_sharing",
              "value:thrift"
            ]
          ]
        }
      ],
      "outputs": [
        {
          "key": "overlaySelection",
          "type": "object"
        },
        {
          "key": "overlayPatch",
          "type": "object"
        }
      ],
      "defaultSteps": [
        {
          "i": 1,
          "title": "Choose primary overlay",
          "action": "Select a primary workflow overlay (or 'none').",
          "ui": {
            "control": "select",
            "optionsFrom": "catalog.workflows.index"
          }
        },
        {
          "i": 2,
          "title": "Optional blend",
          "action": "Optionally choose a secondary overlay to blend (naming + staples + rhythm), and set blend strength.",
          "ui": {
            "control": "blendPicker",
            "fields": [
              "blendSecondaryOverlayId",
              "blendStrength"
            ]
          }
        },
        {
          "i": 3,
          "title": "Review what changes",
          "action": "Preview naming, ordering, default staples, and constraints that will be applied.",
          "ui": {
            "control": "previewPanel"
          }
        },
        {
          "i": 4,
          "title": "Confirm & save",
          "action": "Confirm selection and persist as user/household preference (opt-in).",
          "checks": [
            "User confirms opt-in"
          ]
        }
      ],
      "cues": {
        "doneLooksLike": [
          "A saved overlay preference exists for the selected scope (user/household)."
        ],
        "qualityChecks": [
          "Overlay is editable: user can override staples/rhythm/constraints."
        ],
        "commonMistakes": [
          "Assuming overlay is mandatory. It is optional and should never block planning."
        ]
      },
      "kpiHints": {
        "countsToward": [
          "prefs.culture.overlay.set"
        ],
        "estimatedMinutes": 3
      }
    },
    {
      "id": "cultural.overlay.blend",
      "name": "Blend Cultural Overlays (Primary + Secondary)",
      "summary": "Create a blended overlay patch (primary dominates; secondary contributes selected dimensions like staples, ordering, and feast rhythms).",
      "tags": [
        "overlay",
        "blend",
        "preferences",
        "planning"
      ],
      "inputs": [
        {
          "key": "primaryOverlayPatch",
          "type": "object",
          "required": true
        },
        {
          "key": "secondaryOverlayPatch",
          "type": "object",
          "required": true
        },
        {
          "key": "blendStrength",
          "type": "number",
          "required": false,
          "examples": [
            0.25,
            0.5
          ]
        }
      ],
      "outputs": [
        {
          "key": "blendedOverlayPatch",
          "type": "object"
        }
      ],
      "defaultSteps": [
        {
          "i": 1,
          "title": "Set blend strength",
          "action": "Choose how strongly the secondary overlay influences staples, rhythms, and defaults.",
          "ui": {
            "control": "slider",
            "min": 0,
            "max": 1,
            "step": 0.05
          }
        },
        {
          "i": 2,
          "title": "Pick blend dimensions",
          "action": "Choose what to blend: labels, staples, rhythms, preservation emphasis, constraints.",
          "ui": {
            "control": "chips",
            "options": [
              "display.labels",
              "defaults.staplesBias",
              "defaults.mealRhythm",
              "defaults.preservationEmphasis",
              "constraints.tags"
            ]
          }
        },
        {
          "i": 3,
          "title": "Preview blended result",
          "action": "Preview the resulting overlay patch before applying.",
          "ui": {
            "control": "previewPanel"
          }
        }
      ],
      "cues": {
        "doneLooksLike": [
          "A blended overlay patch is produced."
        ],
        "qualityChecks": [
          "Primary overlay remains dominant unless strength=1.0."
        ]
      },
      "kpiHints": {
        "countsToward": [
          "prefs.culture.overlay.blended"
        ],
        "estimatedMinutes": 4
      }
    },
