  "substitutionRules": [
    {
      "id": "sub.curry_base_indian_vs_caribbean",
      "label": "Curry base: Indian vs Caribbean",
      "description": "Map similar 'curry' intent into cuisine-specific aromatics, acids, and heat.",
      "when": {
        "intentTags": [
          "curry",
          "stew",
          "gravy"
        ],
        "componentGroupsAny": [
          "spice.curry_blend",
          "spice.curry_powder"
        ]
      },
      "then": {
        "prefer": {
          "indian": {
            "addSpices": [
              "spice.garam_masala",
              "spice.turmeric",
              "spice.coriander",
              "spice.cumin"
            ],
            "addAromatics": [
              "spice.ginger",
              "spice.garlic",
              "spice.onion"
            ],
            "addAcids": [
              "spice.lemon"
            ],
            "fatOption": [
              "spice.butter",
              "spice.olive_oil"
            ],
            "notes": "Layer spices; finish with garam masala; balance with yogurt or ghee if desired."
          },
          "caribbean": {
            "addSpices": [
              "spice.allspice",
              "spice.thyme",
              "spice.curry_powder"
            ],
            "addAromatics": [
              "spice.scallion",
              "spice.garlic",
              "spice.onion"
            ],
            "addAcids": [
              "spice.lime",
              "spice.vinegar"
