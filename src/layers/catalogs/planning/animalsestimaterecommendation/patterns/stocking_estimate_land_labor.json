          "required": false,
          "default": 1,
          "min": 0,
          "max": 500
        },
        {
          "key": "laborHoursPerWeek",
          "type": "number",
          "label": "Labor hours/week",
          "required": false,
          "default": 10,
          "min": 1,
          "max": 200
        },
        {
          "key": "climateZone",
          "type": "select",
          "label": "Climate zone",
          "required": false,
          "default": "unknown",
          "options": [
            "unknown",
            "usda:6",
