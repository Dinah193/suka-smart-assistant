            "usda:11"
          ]
        },
        {
          "key": "dietaryLaws",
          "type": "multiselect",
          "label": "Dietary laws",
          "required": false,
          "options": [
            "no_pork",
            "no_shellfish",
            "no_blood",
            "none"
          ],
          "default": [
            "no_pork"
          ]
        },
        {
          "key": "equipmentLevel",
          "type": "select",
          "label": "Equipment level",
          "required": false,
          "default": "standard",
          "options": [
            "limited",
            "standard",
            "advanced"
          ]
        },
        {
          "key": "rotationMode",
          "type": "select",
          "label": "Rotation mode",
          "default": "simple",
          "options": [
            "none",
            "simple",
            "intensive"
          ]
        }
      ]
    },
    "chips": [
      {
        "key": "mode",
        "label": "Estimate",
        "tag": "mode:estimate"
      }
    ],
    "help": {
      "title": "Stocking Estimate",
      "intro": "Find a sustainable range, not a single number.",
      "tips": [
        "Start low and validate.",
        "Protect forage and humane conditions."
      ]
    }
  },
  "links": {
    "valueStreams": [
      "vs.slaughter_to_storage"
    ],
    "storehousePatterns": [
      "pat.storehouse.winter_reserve",
      "pat.storehouse.weekly_restock"
    ],
    "homesteadPatterns": [
      "pat.homestead.animal_led",
      "pat.homestead.mixed_subsistence"
    ]
  },
  "variants": []
