{
  "id": "pat.animals.stocking_estimate_land_labor",
  "domain": "animals_estimate_recommendation",
  "kind": "planning_pattern",
  "title": "Stocking Estimate by Land + Labor",
  "intentTags": [
    "intent:estimate",
    "goal:stocking",
    "mode:estimate"
  ],
  "description": "Estimate sustainable stocking ranges based on land, labor, forage, and housing constraints.",
  "inputs": [
    {
      "key": "householdSize",
      "type": "number",
      "label": "Household size",
      "required": true,
      "default": 4,
      "min": 1,
      "max": 30
    },
    {
      "key": "spaceType",
      "type": "select",
      "label": "Space type",
      "required": false,
      "default": "mixed",
      "options": [
        "urban_backyard",
        "suburban",
        "rural",
        "mixed"
      ]
    },
    {
      "key": "landAcres",
      "type": "number",
      "label": "Land (acres)",
      "required": false,
      "default": 1,
      "min": 0,
      "max": 500
    },
    {
      "key": "laborHoursPerWeek",
      "type": "number",
      "label": "Labor hours/week",
      "required": false,
      "default": 10,
      "min": 1,
      "max": 200
    },
    {
      "key": "climateZone",
      "type": "select",
      "label": "Climate zone",
      "required": false,
      "default": "unknown",
      "options": [
        "unknown",
        "usda:6",
        "usda:7",
        "usda:8",
        "usda:9",
        "usda:10",
        "usda:11"
      ]
    },
    {
      "key": "dietaryLaws",
      "type": "multiselect",
      "label": "Dietary laws",
      "required": false,
      "options": [
        "no_pork",
        "no_shellfish",
        "no_blood",
        "none"
      ],
      "default": [
        "no_pork"
      ]
    },
    {
      "key": "equipmentLevel",
      "type": "select",
      "label": "Equipment level",
      "required": false,
      "default": "standard",
      "options": [
        "limited",
        "standard",
        "advanced"
      ]
    },
    {
      "key": "proteinGoalPerWeek",
      "type": "number",
      "label": "Protein goal (meals/week)",
      "required": false,
      "default": 7,
      "min": 0,
      "max": 50
    },
    {
      "key": "preferredSpecies",
      "type": "multiselect",
      "label": "Preferred species",
      "required": false,
      "options": [
        "chicken",
        "turkey",
        "duck",
        "goat",
        "sheep",
        "cattle",
        "rabbit",
        "fish",
        "quail"
      ]
    },
    {
      "key": "processingPreference",
      "type": "select",
      "label": "Processing preference",
      "required": false,
      "default": "outsourced",
      "options": [
        "outsourced",
        "on_farm",
        "mixed"
      ]
    }
  ],
  "outputs": [
    {
      "type": "estimate",
      "notes": "Stocking ranges per species with risk flags (overgrazing, labor overload)."
    },
    {
      "type": "sessions",
      "notes": "Suggested build sessions: fencing, shelter, water."
    }
  ],
  "constraints": [
    {
      "type": "humane",
      "tag": "constraint:humane_windows",
      "notes": "Respect humane windows for breeding, transport, and slaughter; recommend rather than force."
    },
    {
      "type": "time",
      "tag": "constraint:time_budget",
      "notes": "Plans must respect labor capacity."
    },
    {
      "type": "neighbors",
      "tag": "constraint:local_rules",
      "notes": "Local ordinances vary; surface as a check, not a blocker."
    }
  ],
  "requires": [
    {
      "type": "seasonal",
      "tag": "seasonTags",
      "optional": true
    }
  ],
  "produces": [
    {
      "type": "session",
      "domain": "animals",
      "title": "Stocking Estimate by Land + Labor Session"
    },
    {
      "type": "session",
      "domain": "storehouse",
      "title": "Storehouse Provisioning Follow-on",
      "optional": true
    }
  ],
  "steps": [
    {
      "id": "inputs",
      "title": "Collect land, labor, and housing constraints",
      "kind": "template",
      "timeboxMin": 20,
      "ui": {
        "fields": [
          "landAcres",
          "laborHoursPerWeek",
          "spaceType"
        ]
      }
    },
    {
      "id": "assumptions",
      "title": "Set assumptions (forage, supplemental feed, rotation)",
      "kind": "template",
      "timeboxMin": 15,
      "ui": {
        "chips": [
          "forage",
          "rotation"
        ],
        "help": "Assumptions are editable; SSA must surface them."
      }
    },
    {
      "id": "estimate",
      "title": "Compute stocking ranges + risk flags",
      "kind": "template",
      "timeboxMin": 20
    },
    {
      "id": "schedule",
      "title": "Schedule infrastructure + chore sessions",
      "kind": "template",
      "timeboxMin": 15
    }
  ],
  "kpis": [
    {
      "key": "overstock_risk",
      "label": "Overstock risk",
      "unit": "flag",
      "target": "Low"
    },
    {
      "key": "labor_overrun",
      "label": "Labor overrun risk",
      "unit": "flag",
      "target": "Low"
    }
  ],
  "lean": {
    "wasteTargets": [
      "overproduction",
      "inventory"
    ],
    "countermeasures": [
      {
        "waste": "overproduction",
        "do": "Scale in phases; validate labor fit before adding animals."
      }
    ]
  },
  "ui": {
    "form": {
      "fields": [
        {
          "key": "householdSize",
          "type": "number",
          "label": "Household size",
          "required": true,
          "default": 4,
          "min": 1,
          "max": 30
        },
        {
          "key": "spaceType",
          "type": "select",
          "label": "Space type",
          "required": false,
