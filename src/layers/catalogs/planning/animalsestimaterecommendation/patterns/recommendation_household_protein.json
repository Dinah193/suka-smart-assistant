          "type": "number",
          "label": "Land (acres)",
          "required": false,
          "default": 1,
          "min": 0,
          "max": 500
        },
        {
          "key": "laborHoursPerWeek",
          "type": "number",
          "label": "Labor hours/week",
          "required": false,
          "default": 10,
          "min": 1,
          "max": 200
        },
        {
          "key": "climateZone",
          "type": "select",
          "label": "Climate zone",
          "required": false,
          "default": "unknown",
          "options": [
            "unknown",
            "usda:6",
            "usda:7",
            "usda:8",
            "usda:9",
            "usda:10",
            "usda:11"
          ]
        },
        {
          "key": "dietaryLaws",
          "type": "multiselect",
          "label": "Dietary laws",
          "required": false,
          "options": [
            "no_pork",
            "no_shellfish",
            "no_blood",
            "none"
          ],
          "default": [
            "no_pork"
          ]
        },
        {
          "key": "equipmentLevel",
          "type": "select",
          "label": "Equipment level",
          "required": false,
          "default": "standard",
          "options": [
            "limited",
