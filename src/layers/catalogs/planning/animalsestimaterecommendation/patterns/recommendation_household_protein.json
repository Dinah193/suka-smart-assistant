{
  "id": "pat.animals.recommendation_household_protein",
  "domain": "animals_estimate_recommendation",
  "kind": "planning_pattern",
  "title": "Household Protein Animal Recommendations",
  "intentTags": [
    "intent:recommend_animals",
    "goal:protein",
    "mode:recommend"
  ],
  "description": "Recommend animals aligned to household protein rhythm, space, labor, and dietary constraints (opt-in, non-prescriptive).",
  "inputs": [
    {
      "key": "householdSize",
      "type": "number",
      "label": "Household size",
      "required": true,
      "default": 4,
      "min": 1,
      "max": 30
    },
    {
      "key": "spaceType",
      "type": "select",
      "label": "Space type",
      "required": false,
      "default": "mixed",
      "options": [
        "urban_backyard",
        "suburban",
        "rural",
        "mixed"
      ]
    },
    {
      "key": "landAcres",
      "type": "number",
      "label": "Land (acres)",
      "required": false,
      "default": 1,
      "min": 0,
      "max": 500
    },
    {
      "key": "laborHoursPerWeek",
      "type": "number",
      "label": "Labor hours/week",
      "required": false,
      "default": 10,
      "min": 1,
      "max": 200
    },
    {
      "key": "climateZone",
      "type": "select",
      "label": "Climate zone",
      "required": false,
      "default": "unknown",
      "options": [
        "unknown",
        "usda:6",
        "usda:7",
        "usda:8",
        "usda:9",
        "usda:10",
        "usda:11"
      ]
    },
    {
      "key": "dietaryLaws",
      "type": "multiselect",
      "label": "Dietary laws",
      "required": false,
      "options": [
        "no_pork",
        "no_shellfish",
        "no_blood",
        "none"
      ],
      "default": [
        "no_pork"
      ]
    },
    {
      "key": "equipmentLevel",
      "type": "select",
      "label": "Equipment level",
      "required": false,
      "default": "standard",
      "options": [
        "limited",
        "standard",
        "advanced"
      ]
    },
    {
      "key": "proteinGoalPerWeek",
      "type": "number",
      "label": "Protein goal (meals/week)",
      "required": false,
      "default": 7,
      "min": 0,
      "max": 50
    },
    {
      "key": "preferredSpecies",
      "type": "multiselect",
      "label": "Preferred species",
      "required": false,
      "options": [
        "chicken",
        "turkey",
        "duck",
        "goat",
        "sheep",
        "cattle",
        "rabbit",
        "fish",
        "quail"
      ]
    },
    {
      "key": "processingPreference",
      "type": "select",
      "label": "Processing preference",
      "required": false,
      "default": "outsourced",
      "options": [
        "outsourced",
        "on_farm",
        "mixed"
      ]
    }
  ],
  "outputs": [
    {
      "type": "recommendations",
      "notes": "Ranked species list with starter counts and rationale."
    },
    {
      "type": "sessions",
      "notes": "Suggested sessions: coop setup, sourcing, processing day, storehouse buffer."
    }
  ],
  "constraints": [
    {
      "type": "humane",
      "tag": "constraint:humane_windows",
      "notes": "Respect humane windows for breeding, transport, and slaughter; recommend rather than force."
    },
    {
      "type": "time",
      "tag": "constraint:time_budget",
      "notes": "Plans must respect labor capacity."
    },
    {
      "type": "neighbors",
      "tag": "constraint:local_rules",
      "notes": "Local ordinances vary; surface as a check, not a blocker."
    }
  ],
  "requires": [
    {
      "type": "seasonal",
      "tag": "seasonTags",
      "optional": true
    }
  ],
  "produces": [
    {
      "type": "session",
      "domain": "animals",
      "title": "Household Protein Animal Recommendations Session"
    },
    {
      "type": "session",
      "domain": "storehouse",
      "title": "Storehouse Provisioning Follow-on",
      "optional": true
    }
  ],
  "steps": [
    {
      "id": "goal",
      "title": "Clarify household rhythm + goals",
      "kind": "template",
      "timeboxMin": 15,
      "voice": {
        "speakOnStart": true,
        "prompt": "Confirm protein rhythm, feast cadence, and preferred species."
      },
      "ui": {
        "fields": [
          "proteinGoalPerWeek",
          "preferredSpecies",
          "dietaryLaws"
        ]
      }
    },
    {
      "id": "fit",
      "title": "Fit-check: space, labor, equipment",
      "kind": "template",
      "timeboxMin": 15,
      "ui": {
        "fields": [
          "spaceType",
          "landAcres",
          "laborHoursPerWeek",
          "equipmentLevel"
        ]
      }
    },
    {
      "id": "recommend",
      "title": "Generate ranked species + starter quantities",
      "kind": "template",
      "timeboxMin": 20,
      "ui": {
        "help": "SSA should show WHY each species fits: labor, feed, processing, storage."
      }
    },
    {
      "id": "next_steps",
      "title": "Choose a path: trial → scale → processing plan",
      "kind": "template",
      "timeboxMin": 10
    }
  ],
  "kpis": [
    {
      "key": "protein_coverage",
      "label": "Protein coverage",
      "unit": "meals/week",
      "target": "Meets goal"
    },
    {
      "key": "labor_fit",
      "label": "Labor fit",
      "unit": "score",
      "target": "≥0.7"
    },
    {
      "key": "waste_rate",
      "label": "Waste rate",
      "unit": "%",
      "target": "Trend down"
    }
  ],
  "lean": {
    "wasteTargets": [
      "unused_talent",
      "motion",
      "waiting"
    ],
    "countermeasures": [
      {
        "waste": "waiting",
        "do": "Batch chores; schedule feed/water route."
      },
      {
        "waste": "motion",
        "do": "Design chore loop to minimize steps."
      }
    ],
    "standardWorkRefs": []
  },
  "ui": {
    "form": {
      "fields": [
        {
          "key": "householdSize",
          "type": "number",
          "label": "Household size",
          "required": true,
          "default": 4,
          "min": 1,
          "max": 30
        },
        {
