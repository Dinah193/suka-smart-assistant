          ]
        }
      ]
    },
    "chips": [
      {
        "key": "goal",
        "label": "Protein",
        "tag": "goal:protein"
      }
    ],
    "help": {
      "title": "Animal Recommendations",
      "intro": "Find animals that fit your household rhythm.",
      "tips": [
        "Start with a trial flock/herd.",
        "Plan storage before scaling.",
        "Connect slaughter plans to storehouse buffers."
      ]
    }
  },
  "links": {
    "valueStreams": [
      "vs.slaughter_to_storage"
    ],
    "storehousePatterns": [
      "pat.storehouse.winter_reserve",
