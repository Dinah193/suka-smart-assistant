{
  "id": "pat.meals.daily_fresh",
  "domain": "meals",
  "kind": "planning_pattern",
  "title": "Daily Fresh Meal Plan",
  "description": "Plan one day at a time with fresh cooking and flexible substitutions from inventory.",
  "intentTags": [
    "plan:meals",
    "horizon:day",
    "mode:fresh"
  ],
  "inputs": [
    {
      "key": "householdSize",
      "label": "Household size",
      "type": "number",
      "required": true,
      "default": 4
    },
    {
      "key": "dietaryLaws",
      "label": "Dietary laws / household rules",
      "type": "object",
      "default": {},
      "notes": "Use household preferences and Torah-based constraints as configured."
    },
    {
      "key": "inventorySnapshot",
      "label": "Inventory snapshot",
      "type": "object",
      "required": true,
      "notes": "Include pantry/cold/frozen/root cellar/leftovers."
    },
    {
      "key": "timeBudgetMinutes",
      "label": "Time budget (minutes)",
      "type": "number",
      "required": true,
      "default": 180
    },
    {
      "key": "equipment",
      "label": "Available equipment",
      "type": "array",
      "default": [
        "stove",
        "oven"
      ],
      "notes": "Examples: stove, oven, slowcooker, pressurecooker, grill, dehydrator, freezer."
    },
    {
      "key": "budgetCap",
      "label": "Budget cap (optional)",
      "type": "number"
    },
    {
      "key": "allergies",
      "label": "Allergies / avoid list (optional)",
      "type": "array",
      "default": []
    },
    {
      "key": "quietHours",
      "label": "Quiet hours / Sabbath guard",
      "type": "object",
      "default": {
        "enabled": false
      },
      "notes": "Use to avoid noisy tasks or disallowed work windows."
    }
  ],
  "outputs": [
    {
      "key": "mealPlan",
      "label": "Meal plan structure",
      "type": "object",
      "required": true
    },
    {
      "key": "sessions",
      "label": "Session blueprints requested",
      "type": "array",
      "required": true
    },
    {
      "key": "shoppingNeeds",
      "label": "Shopping list needs",
      "type": "object",
      "required": true
    },
    {
      "key": "storehouseTriggers",
      "label": "Storehouse patterns triggered",
      "type": "array",
      "default": []
    }
  ],
  "constraints": [
    "quietHours/sabbathGuard",
    "fastingRules",
    "budgetCap",
    "allergiesAvoidList",
    "dietaryLaws"
  ],
  "requires": [
    "artifact:inventorySnapshot"
  ],
  "produces": [
    "artifact:mealPlan",
    "blueprint:cookingSessions",
    "artifact:shoppingListDraft"
  ],
  "lean": {
    "wasteTargets": [
      "motion",
      "waiting",
      "overprocessing"
    ],
    "standardWorkRefs": [
      "stdwork.kitchen.staging",
      "stdwork.batch.prep",
      "stdwork.fifo.labels"
    ],
    "taktModelRef": "takt.household.meals",
    "kpiTargets": {
      "tripsPerMeal": "reduce",
      "spoilageRate": "reduce",
      "timeToFirstPlate": "reduce",
      "leftoverUtilization": "increase"
    },
    "notes": "Advisory only; propose countermeasures via LeanOptimizer hooks."
  },
  "ui": {
    "icon": "utensils",
    "chips": [
      "time:low",
      "difficulty:low",
      "equipment:stove",
      "household:1-6"
    ],
    "defaultFilters": {
      "domain": "meals"
    },
    "form": [
      {
        "key": "mealsToday",
        "type": "multiSelect",
        "label": "Meals to plan today",
        "options": [
          "breakfast",
          "lunch",
          "dinner",
          "snack"
        ],
        "default": [
          "dinner"
        ]
      },
      {
        "key": "maxCookTime",
        "type": "slider",
        "label": "Max cook time per meal",
        "min": 10,
        "max": 120,
        "default": 45
      },
      {
        "key": "freshPriority",
        "type": "select",
        "label": "Fresh priority",
        "options": [
          "produce-first",
          "protein-first",
          "balanced"
        ],
        "default": "balanced"
      }
    ],
    "help": [
      "Patterns create session blueprints (prep/cook/storehouse pulls), not raw UI task lists.",
      "Inventory snapshot enables smarter shopping + fewer duplicates."
    ]
  },
  "steps": [
    {
      "id": "inv.quick",
      "title": "Quick inventory scan",
      "template": "tpl.inventory.snapshot.quick",
      "domain": "storehouse",
      "params": {
        "zones": [
          "cold",
          "pantry"
        ],
        "depth": "quick"
      },
      "hints": [
        "needsInventorySnapshot"
      ]
    },
    {
      "id": "plan.today",
      "title": "Build today's meal structure",
      "template": "tpl.meals.plan.today",
      "domain": "meals",
      "params": {
        "includeKey": "mealsToday",
        "maxCookTimeKey": "maxCookTime"
      }
    },
    {
      "id": "select.recipes",
      "title": "Select approach + substitutions",
      "template": "tpl.meals.select.substitutionFirst",
      "domain": "meals",
      "params": {
        "useInventoryFirst": true,
        "freshPriorityKey": "freshPriority"
      }
    },
    {
      "id": "session.single",
      "title": "Generate single cooking session blueprint",
      "template": "tpl.blueprint.build.sessions",
      "domain": "meals",
      "params": {
        "sessionStyles": [
          "single"
        ],
        "emitEvent": "session.blueprints.created"
      }
    },
    {
      "id": "shopping.micro",
      "title": "Optional micro shopping list",
      "template": "tpl.shopping.microList",
      "domain": "storehouse",
      "params": {
        "threshold": "todayOnly"
      },
      "optional": true
    }
  ],
  "kpis": [
    {
      "key": "timeToFirstPlate",
      "label": "Time to first plate",
      "direction": "down",
      "unit": "min"
    },
    {
      "key": "tripsPerMeal",
      "label": "Trips per meal",
      "direction": "down",
      "unit": "trips"
    }
  ],
  "variants": [],
  "links": {
    "storehouseSuggested": [
      "pat.storehouse.weekly_restock"
    ]
  },
  "meta": {
    "version": "1.0.0",
    "updatedAt": "2025-12-27",
    "tags": []
  }
}
