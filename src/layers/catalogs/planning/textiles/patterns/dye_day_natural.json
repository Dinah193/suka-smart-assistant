      "type": "session",
      "domain": "textiles",
      "title": "Natural Dye Day Session"
    }
  ],
  "steps": [
    {
      "id": "prep",
      "title": "Prep fabrics + safety setup",
      "kind": "template",
      "timeboxMin": 20
    },
    {
      "id": "scour",
      "title": "Scour/clean fabrics",
      "kind": "template",
      "timeboxMin": 30
    },
    {
      "id": "dye",
      "title": "Dye bath batch",
      "kind": "template",
      "timeboxMin": 90,
      "timers": [
        {
          "label": "Dye bath",
          "seconds": 3600
        }
      ]
    },
    {
      "id": "rinse",
      "title": "Rinse + dry window",
      "kind": "template",
      "timeboxMin": 30
    },
    {
      "id": "log",
      "title": "Log dye recipe + repeatability notes",
      "kind": "template",
      "timeboxMin": 15
    }
  ],
  "kpis": [
    {
      "key": "color_repeatability",
