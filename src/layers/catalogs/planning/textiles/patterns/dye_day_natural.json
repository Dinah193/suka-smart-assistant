    {
      "key": "items",
      "type": "multiselect",
      "label": "Items involved",
      "required": false,
      "options": [
        "shirts",
        "pants",
        "dresses",
        "headwraps",
        "aprons",
        "blankets",
        "children_clothes",
        "workwear"
      ]
    },
    {
      "key": "skillLevel",
      "type": "select",
      "label": "Skill level",
      "required": false,
      "default": "beginner",
      "options": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    }
  ],
  "outputs": [
    {
      "type": "planStructure",
      "notes": "Dye session + recipe log."
    }
  ],
  "constraints": [
    {
      "type": "safety",
      "tag": "constraint:safety",
      "notes": "Heat, dyes, sharp tools—surface safety checks."
    },
    {
      "type": "time",
      "tag": "constraint:time_budget",
      "notes": "Respect time caps; propose splitting sessions."
    }
  ],
  "requires": [
    {
      "type": "inventory",
      "tag": "needsTextileInventory",
      "optional": true
    }
  ],
  "produces": [
