{
  "id": "pat.storehouse.monthly_cycle_count",
  "domain": "storehouse",
  "kind": "planning_pattern",
  "title": "Monthly Cycle Count + FIFO Rotation",
  "description": "Cycle count inventory, refresh FIFO labels, and correct deltas monthly.",
  "intentTags": [
    "plan:storehouse",
    "horizon:month",
    "mode:inventory"
  ],
  "inputs": [
    {
      "key": "storageZones",
      "label": "Storage zones",
      "type": "array",
      "required": true,
      "default": [
        "pantry",
        "cold",
        "frozen",
        "rootCellar",
        "fermentationRoom"
      ],
      "notes": "Zones: pantry/cold/frozen/root cellar/fermentation room."
    },
    {
      "key": "inventorySnapshot",
      "label": "Inventory snapshot",
      "type": "object",
      "required": true
    },
    {
      "key": "budgetCap",
      "label": "Budget cap (optional)",
      "type": "number"
    },
    {
      "key": "spaceCap",
      "label": "Space cap (optional)",
      "type": "object"
    },
    {
      "key": "timeCapMinutes",
      "label": "Time cap (minutes)",
      "type": "number"
    },
    {
      "key": "householdSize",
      "label": "Household size",
      "type": "number",
      "default": 4
    },
    {
      "key": "season",
      "label": "Season / mode",
      "type": "string"
    }
  ],
  "outputs": [
    {
      "key": "reorderActions",
      "label": "Reorder actions",
      "type": "array",
      "required": true
    },
    {
      "key": "rotationActions",
      "label": "Rotation actions (FIFO)",
      "type": "array",
      "required": true
    },
    {
      "key": "preservationTriggers",
      "label": "Preservation triggers (surplus risk)",
      "type": "array",
      "required": true
    },
    {
      "key": "sessions",
      "label": "Session blueprints requested",
      "type": "array",
      "required": true
    }
  ],
  "constraints": [
    "budgetCap",
    "spaceCap",
    "timeCap",
    "allergiesAvoidList"
  ],
  "requires": [
    "artifact:inventorySnapshot"
  ],
  "produces": [
    "artifact:reorderList",
    "artifact:rotationPlan",
    "blueprint:storehouseSessions",
    "trigger:preservation"
  ],
  "lean": {
    "wasteTargets": [
      "motion",
      "transport",
      "inventory",
      "defects",
      "waiting"
    ],
    "standardWorkRefs": [
      "stdwork.fifo.labels",
      "stdwork.cycle.count",
      "stdwork.zone.layout"
    ],
    "taktModelRef": "takt.household.storehouse",
    "kpiTargets": {
      "spoilageRate": "reduce",
      "tripsPerWeek": "reduce",
      "stockouts": "reduce",
      "overstocks": "reduce"
    }
  },
  "ui": {
    "icon": "warehouse",
    "chips": [
      "time:medium",
      "difficulty:medium",
      "zones:all",
      "equipment:labels"
    ],
    "defaultFilters": {
      "domain": "storehouse"
    },
    "form": [
      {
        "key": "zonesScope",
        "type": "multiSelect",
        "label": "Zones to include",
        "options": [
          "pantry",
          "cold",
          "frozen",
          "rootCellar",
          "fermentationRoom"
        ],
        "default": [
          "pantry",
          "cold",
          "frozen"
        ]
      },
      {
        "key": "cycleDepth",
        "type": "select",
        "label": "Cycle depth",
        "options": [
          "light",
          "standard",
          "deep"
        ],
        "default": "standard"
      }
    ]
  },
  "steps": [
    {
      "id": "inv.cycle",
      "title": "Perform cycle count",
      "template": "tpl.storehouse.cycle.count",
      "domain": "storehouse",
      "params": {
        "zonesKey": "zonesScope",
        "depthKey": "cycleDepth"
      }
    },
    {
      "id": "fifo.refresh",
      "title": "Refresh FIFO labels + rotation plan",
      "template": "tpl.storehouse.rotation.plan",
      "domain": "storehouse",
      "params": {
        "zonesKey": "zonesScope"
      }
    },
    {
      "id": "risk.detect",
      "title": "Detect spoilage/surplus risks",
      "template": "tpl.inventory.risk.scan",
      "domain": "storehouse",
      "params": {
        "riskHorizonDays": 7
      },
      "hints": [
        "leanSignal:spoilage"
      ]
    },
    {
      "id": "preserve.trigger",
      "title": "Trigger preservation sessions if needed",
      "template": "tpl.preservation.trigger.sessions",
      "domain": "homestead",
      "params": {
        "methods": [
          "freeze",
          "dehydrate",
          "ferment"
        ],
        "emitEvent": "session.blueprints.created"
      },
      "optional": true
    }
  ],
  "kpis": [
    {
      "key": "spoilageRate",
      "label": "Spoilage rate",
      "direction": "down",
      "unit": "%"
    },
    {
      "key": "stockouts",
      "label": "Stockouts",
      "direction": "down",
      "unit": "count"
    },
    {
      "key": "overstocks",
      "label": "Overstocks",
      "direction": "down",
      "unit": "count"
    }
  ],
  "variants": [],
  "links": {
    "preservationSuggested": [
      "pat.meals.preservation_first"
    ]
  },
  "meta": {
    "version": "1.0.0",
    "updatedAt": "2025-12-27",
    "tags": []
  }
}
