{
  "id": "pat.storehouse.weekly_restock",
  "domain": "storehouse",
  "kind": "planning_pattern",
  "title": "Weekly Restock",
  "description": "Weekly restock based on par levels and upcoming demand.",
  "intentTags": [
    "plan:storehouse",
    "horizon:week",
    "mode:restock"
  ],
  "inputs": [
    {
      "key": "storageZones",
      "label": "Storage zones",
      "type": "array",
      "required": true,
      "default": [
        "pantry",
        "cold",
        "frozen",
        "rootCellar",
        "fermentationRoom"
      ],
      "notes": "Zones: pantry/cold/frozen/root cellar/fermentation room."
    },
    {
      "key": "inventorySnapshot",
      "label": "Inventory snapshot",
      "type": "object",
      "required": true
    },
    {
      "key": "budgetCap",
      "label": "Budget cap (optional)",
      "type": "number"
    },
    {
      "key": "spaceCap",
      "label": "Space cap (optional)",
      "type": "object"
    },
    {
      "key": "timeCapMinutes",
      "label": "Time cap (minutes)",
      "type": "number"
    },
    {
      "key": "householdSize",
      "label": "Household size",
      "type": "number",
      "default": 4
    },
    {
      "key": "season",
      "label": "Season / mode",
      "type": "string"
    }
  ],
  "outputs": [
    {
      "key": "reorderActions",
      "label": "Reorder actions",
      "type": "array",
      "required": true
    },
    {
      "key": "rotationActions",
      "label": "Rotation actions (FIFO)",
      "type": "array",
      "required": true
    },
    {
      "key": "preservationTriggers",
      "label": "Preservation triggers (surplus risk)",
      "type": "array",
      "required": true
    },
    {
      "key": "sessions",
      "label": "Session blueprints requested",
      "type": "array",
      "required": true
    }
  ],
  "constraints": [
    "budgetCap",
    "spaceCap",
    "timeCap",
    "allergiesAvoidList"
  ],
  "requires": [
    "artifact:inventorySnapshot"
  ],
  "produces": [
    "artifact:reorderList",
    "artifact:rotationPlan",
    "blueprint:storehouseSessions",
    "trigger:preservation"
  ],
  "lean": {
    "wasteTargets": [
      "motion",
      "transport",
      "inventory",
      "defects",
      "waiting"
    ],
    "standardWorkRefs": [
      "stdwork.fifo.labels",
      "stdwork.cycle.count",
      "stdwork.zone.layout"
    ],
    "taktModelRef": "takt.household.storehouse",
    "kpiTargets": {
      "spoilageRate": "reduce",
      "tripsPerWeek": "reduce",
      "stockouts": "reduce",
      "overstocks": "reduce"
    }
  },
  "ui": {
    "icon": "warehouse",
    "chips": [
      "time:low",
      "difficulty:low",
      "zones:pantry+cold",
      "equipment:labels"
    ],
    "defaultFilters": {
      "domain": "storehouse"
    },
    "form": [
      {
        "key": "parLevelMode",
        "type": "select",
        "label": "Par level mode",
        "options": [
          "baseline",
          "mealPlanDriven",
          "seasonal"
        ],
        "default": "mealPlanDriven"
      },
      {
        "key": "dedupe",
        "type": "toggle",
        "label": "De-duplicate against inventory",
        "default": true
      },
      {
        "key": "fifoLabels",
        "type": "toggle",
        "label": "Print/update FIFO labels",
        "default": true
      }
    ]
  },
  "steps": [
    {
      "id": "inv.snapshot",
      "title": "Confirm inventory snapshot",
      "template": "tpl.inventory.snapshot.confirm",
      "domain": "storehouse",
      "params": {
        "zonesKey": "storageZones"
      }
    },
    {
      "id": "par.compute",
      "title": "Compute par levels + gaps",
      "template": "tpl.storehouse.par.compute",
      "domain": "storehouse",
      "params": {
        "modeKey": "parLevelMode"
      }
    },
    {
      "id": "reorder.build",
      "title": "Build reorder actions",
      "template": "tpl.storehouse.reorder.build",
      "domain": "storehouse",
      "params": {
        "respectBudgetKey": "budgetCap",
        "dedupeKey": "dedupe"
      }
    },
    {
      "id": "rotation.quick",
      "title": "Quick rotation actions",
      "template": "tpl.storehouse.rotation.quick",
      "domain": "storehouse",
      "params": {
        "fifoLabelsKey": "fifoLabels"
      }
    },
    {
      "id": "sessions.build",
      "title": "Generate storehouse session blueprint",
      "template": "tpl.blueprint.build.sessions",
      "domain": "storehouse",
      "params": {
        "sessionStyles": [
          "storehouse_restock"
        ],
        "emitEvent": "session.blueprints.created"
      }
    }
  ],
  "kpis": [
    {
      "key": "stockouts",
      "label": "Stockouts per week",
      "direction": "down",
      "unit": "count"
    },
    {
      "key": "tripsPerWeek",
      "label": "Trips per week",
      "direction": "down",
      "unit": "trips"
    },
    {
      "key": "overstocks",
      "label": "Overstocks",
      "direction": "down",
      "unit": "count"
    }
  ],
  "variants": [],
  "links": {
    "preservationSuggested": [
      "pat.meals.preservation_first"
    ]
  },
  "meta": {
    "version": "1.0.0",
    "updatedAt": "2025-12-27",
    "tags": []
  }
}
