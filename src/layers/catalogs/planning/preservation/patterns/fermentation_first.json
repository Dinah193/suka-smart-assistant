{
  "id": "pat.preservation.fermentation_first",
  "domain": "preservation",
  "kind": "planning_pattern",
  "title": "Fermentation-First Preservation",
  "intentTags": [
    "intent:ferment",
    "intent:preserve",
    "mode:ferment",
    "equipment:fermentation"
  ],
  "description": "Prioritize fermentation as a low-energy preservation path; schedule follow-on storage/rotation.",
  "inputs": [
    {
      "key": "dietaryLaws",
      "type": "multiselect",
      "label": "Dietary laws",
      "required": false,
      "options": [
        "no_pork",
        "no_shellfish",
        "halal_like",
        "kosher_like",
        "none"
      ],
      "default": [
        "no_pork"
      ]
    },
    {
      "key": "householdSize",
      "type": "number",
      "label": "Household size",
      "required": true,
      "default": 4,
      "min": 1,
      "max": 30
    },
    {
      "key": "inventorySnapshot",
      "type": "select",
      "label": "Inventory snapshot",
      "required": false,
      "default": "recommended",
      "options": [
        "missing",
        "recommended",
        "required"
      ]
    },
    {
      "key": "surplusItems",
      "type": "multiselect",
      "label": "Surplus items (tags)",
      "required": false,
      "options": [
        "produce:leafy",
        "produce:fruit",
        "produce:root",
        "meat:raw",
        "dairy:raw",
        "grain:bulk",
        "beans:bulk"
      ]
    },
    {
      "key": "timeBudgetMin",
      "type": "number",
      "label": "Time budget (minutes)",
      "required": false,
      "default": 120,
      "min": 30,
      "max": 960
    },
    {
      "key": "equipmentLevel",
      "type": "select",
      "label": "Equipment level",
      "required": false,
      "default": "standard",
      "options": [
        "limited",
        "standard",
        "advanced",
        "fermentation"
      ]
    },
    {
      "key": "storageZones",
      "type": "multiselect",
      "label": "Storage zones available",
      "required": false,
      "options": [
        "pantry",
        "cold",
        "frozen",
        "root_cellar",
        "fermentation_room",
        "dehydration",
        "smokehouse"
      ]
    }
  ],
  "outputs": [
    {
      "type": "planStructure",
      "notes": "Ferment batch + check cadence sessions."
    },
    {
      "type": "session",
      "domain": "preservation",
      "notes": "Optional recurring check session blueprint."
    }
  ],
  "constraints": [
    {
      "type": "quietHours",
      "tag": "constraint:quiet_hours",
      "notes": "Avoid loud equipment during quiet hours/Sabbath."
    },
    {
      "type": "foodSafety",
      "tag": "constraint:food_safety",
      "notes": "Prefer safe methods; surface warnings instead of silent changes."
    },
    {
      "type": "budget",
      "tag": "constraint:budget",
      "notes": "Respect jar/lid/packaging budget caps if provided."
    }
  ],
  "requires": [
    {
      "type": "inventory",
      "tag": "needsInventorySnapshot",
      "optional": true
    },
    {
      "type": "calendar",
      "tag": "seasonalTags",
      "optional": true
    }
  ],
  "produces": [
    {
      "type": "session",
      "domain": "preservation",
      "title": "Fermentation-First Preservation Session"
    },
    {
      "type": "inventoryMove",
      "notes": "Placeholder inventory moves emitted per method batch."
    },
    {
      "type": "shoppingDelta",
      "notes": "Packaging & supply deltas (jars, lids, salt, vinegar, bags)."
    }
  ],
  "steps": [
    {
      "id": "select",
      "title": "Select ferment candidates + salt/brine plan",
      "kind": "template",
      "timeboxMin": 15
    },
    {
      "id": "prep",
      "title": "Prep and pack ferments",
      "kind": "template",
      "timeboxMin": 45,
      "timers": [
        {
          "label": "Initial ferment check",
          "seconds": 86400
        }
      ],
      "voice": {
        "speakOnStart": true,
        "prompt": "Pack jars, label start date, set check reminders."
      }
    },
    {
      "id": "monitor",
      "title": "Monitoring cadence + adjustments",
      "kind": "template",
      "timeboxMin": 10,
      "ui": {
        "chips": [
          "check_schedule",
          "temperature"
        ],
        "help": "SSA can create micro-sessions for checks."
      }
    },
    {
      "id": "move",
      "title": "Move to cold/root cellar when ready",
      "kind": "template",
      "timeboxMin": 10,
      "inventoryMoves": [
        {
          "type": "placeholder",
          "from": "fermentation_room",
          "to": "cold|root_cellar",
          "itemTag": "ferment:*"
        }
      ]
    }
  ],
  "kpis": [
    {
      "key": "batch_success_rate",
      "label": "Batch success rate",
      "unit": "%",
      "target": "≥95%"
    },
    {
      "key": "energy_use",
      "label": "Energy use",
      "unit": "relative",
      "target": "Low"
    },
    {
      "key": "waste_reduction",
      "label": "Waste reduction",
      "unit": "%",
      "target": "Trend up"
    }
  ],
  "lean": {
    "wasteTargets": [
      "overprocessing",
      "waiting",
      "defects"
    ],
    "countermeasures": [
      {
        "waste": "defects",
        "do": "Label and track temperatures; use checklists for brine ratios."
      }
    ],
    "standardWorkRefs": [
      "std.preservation.seasonal_preservation_push"
    ]
  },
  "ui": {
    "form": {
      "fields": [
        {
          "key": "householdSize",
          "type": "number",
          "label": "Household size",
          "required": true,
          "default": 4,
          "min": 1,
          "max": 30
        },
        {
          "key": "inventorySnapshot",
          "type": "select",
          "label": "Inventory snapshot",
          "required": false,
          "default": "recommended",
          "options": [
            "missing",
            "recommended",
            "required"
          ]
        },
        {
          "key": "surplusItems",
          "type": "multiselect",
          "label": "Surplus items (tags)",
          "required": false,
          "options": [
            "produce:leafy",
            "produce:fruit",
            "produce:root",
            "meat:raw",
            "dairy:raw",
            "grain:bulk",
            "beans:bulk"
          ]
        },
        {
          "key": "timeBudgetMin",
          "type": "number",
          "label": "Time budget (minutes)",
          "required": false,
          "default": 120,
          "min": 30,
          "max": 960
        },
        {
          "key": "equipmentLevel",
          "type": "select",
          "label": "Equipment level",
          "required": false,
          "default": "standard",
          "options": [
            "limited",
            "standard",
            "advanced",
            "fermentation"
          ]
        },
        {
          "key": "storageZones",
          "type": "multiselect",
          "label": "Storage zones available",
          "required": false,
          "options": [
            "pantry",
            "cold",
            "frozen",
            "root_cellar",
            "fermentation_room",
            "dehydration",
            "smokehouse"
          ]
        },
        {
          "key": "fermentTemp",
          "type": "select",
          "label": "Ferment temperature band",
          "default": "cool",
          "options": [
            "cool",
            "room",
            "warm"
          ]
        }
      ]
    },
    "chips": [
      {
        "key": "mode",
        "label": "Fermentation",
        "tag": "mode:ferment"
      }
    ],
    "help": {
      "title": "Fermentation-First",
      "intro": "Low-energy preservation with a check cadence.",
      "tips": [
        "Label start date.",
        "Schedule checks.",
        "Move to cold storage when ready."
      ]
    }
  },
  "links": {
    "storehousePatterns": [
      "pat.storehouse.root_cellar_optimizer",
      "pat.storehouse.monthly_cycle_count"
    ],
    "mealPatterns": [
      "pat.meals.preservation_first"
    ]
  },
  "variants": []
}
