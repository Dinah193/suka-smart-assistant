  "rules": [
    {
      "id": "rule.meals.needs.inventory",
      "when": {
        "anyPhrases": [
          "plan meals",
          "meal planning",
          "batch cook",
          "batch cook for the week"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "needsInventorySnapshot",
          "message": "Meal planning is best when inventory + leftovers are visible."
        }
      ]
    },
    {
      "id": "rule.session.style.batch",
      "when": {
        "anyPhrases": [
          "batch cook",
          "cook ahead",
          "sheet pan"
        ],
        "notAnyPhrases": [
          "prep only"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "sessionStyle:batch",
          "message": "Batch cooking session style detected."
        }
      ]
    },
    {
      "id": "rule.session.style.prep",
      "when": {
        "anyPhrases": [
          "prep only",
          "prep ingredients only"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "sessionStyle:prep_only",
          "message": "Prep-only session style detected."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "emitHintTag",
      "hintTag": "mealsLexiconActive",
      "message": "Meals lexicon active. Route to meal planning patterns + cooking session styles."
    }
  ],
  "signals": []
