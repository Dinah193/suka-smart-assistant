  "rules": [
    {
      "id": "rule.inventory.snapshot.required",
      "when": {
        "anyPhrases": [
          "restock",
          "weekly restock",
          "deep pantry",
          "buffer stock",
          "inventory snapshot",
          "cycle count",
          "pantry reset"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "needsInventorySnapshot",
          "message": "Inventory snapshot improves restock accuracy and prevents overbuying."
        }
      ]
    },
    {
      "id": "rule.disambiguate.preserve",
      "when": {
        "token": "preserve",
        "contextAny": [
          "canning",
          "drying",
          "ferment",
          "freeze",
          "dehydrate",
          "harvest"
        ]
      },
      "then": [
        {
          "type": "boostMethodKey",
          "methodKey": "pat.homestead.preservation.run",
          "amount": 0.6,
          "message": "Context indicates preservation workflow."
        },
        {
          "type": "downrankMethodKey",
          "methodKey": "pat.storehouse.pantry.reset",
          "amount": 0.3
        }
      ]
    },
    {
      "id": "rule.disambiguate.preserve.storehouse",
      "when": {
        "token": "preserve",
        "contextAny": [
          "pantry",
          "rotate",
          "fifo",
          "shelf",
          "labels",
          "inventory"
        ]
      },
      "then": [
        {
          "type": "boostMethodKey",
          "methodKey": "pat.storehouse.pantry.reset",
          "amount": 0.6,
          "message": "Context indicates storehouse maintenance/rotation."
        },
        {
          "type": "downrankMethodKey",
          "methodKey": "pat.homestead.preservation.run",
          "amount": 0.3
        }
      ]
    },
    {
      "id": "rule.feast.prep.needs.storehouse",
      "when": {
        "anyPhrases": [
          "feast prep",
          "prepare for feast"
        ],
        "contextAny": [
          "guests",
          "gathering",
          "holy day",
          "appointed time"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "needsShoppingList",
          "message": "Feast prep usually needs a consolidated shopping list + storehouse pull list."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "emitHintTag",
      "hintTag": "usePlanningCatalogs",
      "message": "Route to planning catalogs (not recipe catalog)."
    }
  ],
  "signals": []
