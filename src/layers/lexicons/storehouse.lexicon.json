  "phrases": [
    {
      "text": "restock the pantry for the week",
      "methodIds": [
        "pat.storehouse.restock.weekly"
      ],
      "boost": 1.5
    },
    {
      "text": "do a pantry reset and label everything",
      "methodIds": [
        "pat.storehouse.pantry.reset",
        "concept.rotate"
      ],
      "boost": 1.55
    },
    {
      "text": "set up fifo rotation",
      "methodIds": [
        "concept.fifo",
        "pat.storehouse.pantry.reset"
      ],
      "boost": 1.6
    },
    {
      "text": "inventory snapshot of dry goods",
      "methodIds": [
        "pat.storehouse.inventory.snapshot",
        "inv.cat.dry"
      ],
      "boost": 1.55
    },
    {
      "text": "inventory the freezer",
      "methodIds": [
        "pat.storehouse.inventory.snapshot",
        "inv.cat.frozen"
      ],
      "boost": 1.45
    },
    {
      "text": "organize the root cellar",
      "methodIds": [
        "pat.storehouse.root.cellar.manage",
        "inv.cat.rootcellar"
      ],
      "boost": 1.55
    },
    {
      "text": "deep pantry build with buffer stock",
      "methodIds": [
        "pat.storehouse.deep.pantry.build",
        "concept.buffer_stock"
      ],
      "boost": 1.6
    }
  ],
  "rules": [
    {
      "id": "rule.storehouse.always.needs.snapshot",
      "when": {
        "anyPhrases": [
          "restock",
          "deep pantry",
          "buffer stock",
          "pantry reset",
          "fifo"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "needsInventorySnapshot",
          "message": "Storehouse planning should start from an inventory snapshot."
        }
      ]
    },
    {
      "id": "rule.storehouse.constraints",
      "when": {
        "anyMethods": [
          "constraint.budget_cap",
          "constraint.space_cap",
          "constraint.time_cap"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "hasStorehouseConstraints",
          "message": "Constraints detected. Apply caps while selecting patterns and generating lists."
        }
      ]
    },
    {
      "id": "rule.storehouse.inventory.category.link",
      "when": {
        "anyMethods": [
          "inv.cat.dry",
          "inv.cat.cold",
          "inv.cat.frozen",
          "inv.cat.rootcellar"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "inventoryCategoryScoped",
          "message": "Storage category detected; scope snapshot and lists to that zone."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "emitHintTag",
      "hintTag": "storehouseLexiconActive",
      "message": "Storehouse lexicon active. Route to storehouse patterns and emit caps/categories."
    }
  ],
  "signals": []
}
