  "rules": [
    {
      "id": "rule.need_machine_for_batch_sew",
      "when": {
        "anyTokens": [
          "batch sew",
          "serger",
          "machine"
        ],
        "missingContext": [
          "equipment"
        ]
      },
      "actions": [
        {
          "type": "emitHintTag",
          "emitHintTag": "needsSewingEquipment"
        }
      ]
    },
    {
      "id": "rule.need_time_for_pipeline",
      "when": {
        "anyTokens": [
          "spin",
          "weave",
          "loom",
          "fiber to fabric"
        ],
        "missingContext": [
          "timeBudgetMin"
        ]
      },
      "actions": [
        {
          "type": "emitHintTag",
          "emitHintTag": "needsTimeBudget"
        }
      ]
    },
    {
      "id": "rule.downrank_pipeline_if_quick",
      "when": {
        "anyTokens": [
          "quick mend",
          "small repair"
        ],
        "alsoTokens": [
          "fast",
          "short"
        ]
      },
      "actions": [
        {
          "type": "downrankMethodKey",
          "methodKey": "pat.textiles.fiber_to_fabric_pipeline",
          "amount": 0.25
        }
      ]
    }
  ],
  "actions": [],
  "signals": [
    {
      "id": "sig.rework_seams",
      "phrases": [
        "seams keep popping",
        "stitches unravel",
        "had to redo it twice"
      ],
      "signal": "waste:defects",
      "severity": 0.7
    },
    {
      "id": "sig.setup_overhead",
      "phrases": [
        "setup takes forever",
        "threading machine every time",
        "always switching tools"
      ],
      "signal": "waste:motion",
      "severity": 0.6
    }
  ]
