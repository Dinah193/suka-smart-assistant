  "rules": [
    {
      "id": "rule.lean.optimizer.hook",
      "when": {
        "anyTags": [
          "symptom",
          "5S"
        ],
        "anyMethods": [
          "lean.waste.motion",
          "lean.waste.waiting",
          "lean.waste.inventory"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "leanOptimizer:recommendStandardWork",
          "message": "Lean signal detected. Suggest standard work + staging checklist (no forced UI changes)."
        },
        {
          "type": "emitHintTag",
          "hintTag": "leanOptimizer:recommend5S",
          "message": "Consider 5S: sort, set-in-order, shine, standardize, sustain."
        }
      ]
    },
    {
      "id": "rule.spoilage.buffer",
      "when": {
        "anyPhrases": [
          "food keeps spoiling"
        ],
        "contextAny": [
          "produce",
          "leftovers",
          "milk",
          "meat",
          "greens"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "leanOptimizer:recommendFIFO",
          "message": "Spoilage suggests FIFO labeling/rotation and tighter par levels."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "emitHintTag",
      "hintTag": "leanSignalsActive",
      "message": "Lean signals lexicon active. Emit signals + optimizer hooks only."
    }
  ],
  "signals": [
    {
      "id": "sig.spoilage",
      "type": "symptom",
      "pattern": "spoil|spoiling|mold|went bad",
      "severity": 4,
      "tags": [
        "lean:symptom:spoilage"
      ]
    },
    {
      "id": "sig.trips",
      "type": "symptom",
      "pattern": "too many trips|back and forth|running back",
      "severity": 3,
      "tags": [
        "lean:symptom:too_many_trips"
      ]
    },
    {
      "id": "sig.behind",
      "type": "symptom",
      "pattern": "always behind|never caught up|overwhelmed",
      "severity": 3,
      "tags": [
        "lean:symptom:always_behind"
      ]
    },
    {
      "id": "sig.prep",
      "type": "symptom",
      "pattern": "prep takes forever|takes forever|too long",
      "severity": 3,
      "tags": [
        "lean:symptom:prep_forever"
      ]
    }
  ]
}
