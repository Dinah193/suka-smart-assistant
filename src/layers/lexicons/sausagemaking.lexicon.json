      },
      "then": [
        { "action": "boostMethodKey", "methodKey": "sausage.general" },
        { "action": "emitHintTag", "tag": "sausagemaking" },
        {
          "action": "addNote",
          "note": "Sausage-making detected. Prefer identifying a subtype (fresh/cooked/smoked/emulsified/dry-cured/fermented) and process steps (grind/mix/stuff/link/cook/smoke/chill) from additional keywords."
        }
      ]
    },

