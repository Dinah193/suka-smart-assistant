  "rules": [
    {
      "id": "rule.emit.culture.tags",
      "when": {
        "hasMethodIds": [
          "tag.culture.israelite",
          "tag.culture.west_african",
          "tag.culture.southern_us"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "applyCulturalOverlays",
          "message": "Cultural tags found. Consider applying optional cultural planning overlays."
        }
      ]
    },
    {
      "id": "rule.preferred.patterns",
      "when": {
        "hasMethodIds": [
          "pref.plan.mode.feast_anchored",
          "pref.plan.mode.batch_weekly"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "hasPreferredPlanningMode",
          "message": "Preferred planning mode detected from phrases; resolver may preselect matching patterns."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "emitHintTag",
      "hintTag": "cultureMappingActive",
      "message": "Culture mapping lexicon active. Emit canonical tags only; never stereotype or force workflows."
    }
  ],
  "signals": []
}
