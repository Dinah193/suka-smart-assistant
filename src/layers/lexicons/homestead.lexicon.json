  "rules": [
    {
      "id": "rule.homestead.needs.season",
      "when": {
        "anyMethods": [
          "mode.season.spring_start",
          "mode.season.harvest_push",
          "mode.season.winterize"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "seasonModeDetected",
          "message": "Season mode detected; apply seasonal overlays and task templates."
        }
      ]
    },
    {
      "id": "rule.homestead.harvest.needs.preservation",
      "when": {
        "anyPhrases": [
          "harvest push"
        ],
        "contextAny": [
          "preserve",
          "canning",
          "freeze",
          "dehydrate",
          "ferment"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "needsPreservationSession",
          "message": "Harvest push likely needs a preservation session blueprint."
        },
        {
          "type": "boostMethodKey",
          "methodKey": "pat.homestead.preservation.run",
          "amount": 0.5
        }
      ]
    },
    {
      "id": "rule.homestead.animals.session",
      "when": {
        "anyMethods": [
          "pat.homestead.breeding.cycle",
          "pat.homestead.butchering.window"
        ]
      },
      "then": [
        {
          "type": "emitHintTag",
          "hintTag": "needsAnimalSession",
          "message": "Animal cycle planning detected; attach animals session templates."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "emitHintTag",
      "hintTag": "homesteadLexiconActive",
      "message": "Homestead lexicon active. Route to homestead patterns + session templates."
    }
  ],
  "signals": []
