    "rules": [
      {
        "id": "rule.new_animals_quarantine",
        "title": "New animal arrival cues → quarantine + biosecurity",
        "severity": "warn",
        "explain": "If text indicates new animals were purchased/arrived, prioritize quarantine and cleaning protocols.",
        "when": {
          "containsAny": [
            "new goat",
            "new sheep",
            "new cow",
            "new calf",
            "new chickens",
            "brought home",
            "picked up",
