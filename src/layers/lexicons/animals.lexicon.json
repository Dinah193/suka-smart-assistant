        "actions": [
          {
            "type": "boostMethodKey",
            "methodKey": "animals.biosecurity.quarantine_new_animals",
            "amount": 0.75,
            "reason": "New arrivals can introduce parasites/disease"
          },
          {
            "type": "boostMethodKey",
            "methodKey": "animals.biosecurity.clean_disinfect",
            "amount": 0.35,
            "reason": "Biosecurity cleaning reduces spread"
          },
          {
            "type": "addWarning",
            "warning": "Quarantine new arrivals before mixing with your herd/flock. Use dedicated tools/buckets and avoid cross-contamination."
          },
          { "type": "emitHintTag", "tag": "biosecurity.quarantine" }
        ]
      },
