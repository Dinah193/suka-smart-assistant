    "rules": [
      {
        "id": "rule.no_bleach_with_ammonia",
        "title": "Chemical safety: never mix bleach and ammonia",
        "severity": "block",
        "explain": "If the user text includes both bleach and ammonia cues, block any method that suggests combining chemicals; add a warning.",
        "when": {
          "all": [
            { "containsAny": ["bleach", "chlorine bleach", "clorox"] },
            { "containsAny": ["ammonia"] }
          ]
        },
        "actions": [
          {
            "type": "addWarning",
            "warning": "Never mix bleach and ammonia. Use one product at a time, rinse thoroughly, ventilate, and follow labels."
          },
          { "type": "emitHintTag", "tag": "safety.no-mixing" }
        ]
      },
      {
        "id": "rule.no_vinegar_on_marble",
        "title": "Surface safety: avoid acids on marble/stone",
        "severity": "warn",
        "explain": "Acids (vinegar) can etch marble and some natural stone.",
        "when": {
          "all": [
            { "containsAny": ["vinegar", "acetic", "vinegar spray"] },
            {
              "containsAny": [
                "marble",
                "natural stone",
                "travertine",
                "limestone"
              ]
            }
          ]
        },
        "actions": [
          {
            "type": "addWarning",
            "warning": "Avoid vinegar/acid on marble/natural stone (etching risk). Use pH-neutral stone-safe cleaner instead."
          },
          {
            "type": "downrankMethodKey",
            "methodKey": "cleaning.natural.vinegar_solution",
            "amount": 0.7,
            "reason": "Acid etching risk on stone"
          },
          { "type": "emitHintTag", "tag": "surface.stone-safe" }
        ]
      },
      {
        "id": "rule.degrease_kitchen_context",
        "title": "Kitchen grease cues → degrease method",
        "severity": "hint",
        "when": {
          "all": [
            { "roomAny": ["kitchen"] },
            {
              "containsAny": [
                "grease",
                "oily",
                "sticky",
                "splatter",
                "range hood",
                "stove",
                "backsplash"
              ]
            }
          ]
        },
        "actions": [
          {
            "type": "boostMethodKey",
            "methodKey": "cleaning.kitchen.degrease",
            "amount": 0.6,
            "reason": "Grease cues in kitchen context"
          },
          {
            "type": "addNote",
            "note": "Degreasing works best after a warm wipe-down (warm water + dish soap) before stronger degreasers."
          }
        ]
      },
      {
        "id": "rule.bathroom_descaling_hard_water",
        "title": "Hard-water cues → descaling",
        "severity": "hint",
        "when": {
          "any": [
            {
              "containsAny": [
                "limescale",
                "calcium",
                "hard water",
                "mineral buildup",
                "water spots"
              ]
            },
            { "containsAny": ["faucet crust", "white crust", "chalky"] }
          ]
        },
        "actions": [
          {
            "type": "boostMethodKey",
            "methodKey": "cleaning.bathroom.descaling",
            "amount": 0.55,
            "reason": "Hard-water/mineral cues"
          },
          {
            "type": "addNote",
            "note": "Test small area first; avoid acids on marble/natural stone."
          }
        ]
      },
      {
        "id": "rule.mold_mildew_requires_ventilation",
        "title": "Mold/mildew cues → ventilation + PPE",
        "severity": "warn",
        "when": {
          "containsAny": ["mold", "mildew", "black spots", "musty", "fungus"]
        },
        "actions": [
          {
            "type": "boostMethodKey",
            "methodKey": "cleaning.bathroom.mold_mildew",
            "amount": 0.65,
            "reason": "Mold cues"
          },
          {
            "type": "requireVentilation",
            "reason": "Mold cleanup should be ventilated."
          },
          {
            "type": "requirePPE",
            "ppe": ["gloves", "mask"],
            "reason": "Avoid skin/lung irritation."
          },
          {
            "type": "addNote",
            "note": "If area is large or recurrent, consider moisture source (leaks/humidity) and remediation."
          }
        ]
      },
      {
        "id": "rule.disinfect_requires_dwell_time",
        "title": "Disinfect cues → dwell time reminder",
        "severity": "hint",
        "when": {
          "containsAny": [
            "disinfect",
            "sanitize",
            "kill germs",
            "after illness",
            "flu",
            "norovirus"
          ]
        },
        "actions": [
          {
            "type": "boostMethodKey",
            "methodKey": "cleaning.sanitize.disinfect",
            "amount": 0.6,
            "reason": "Sanitize/disinfect intent"
          },
          {
            "type": "requireDwellTime",
            "minutes": 5,
            "reason": "Most disinfectants require wet contact time; follow label."
          },
          {
            "type": "addNote",
            "note": "Pre-clean first (remove soil), then disinfect; label contact time matters."
          }
        ]
      },
      {
        "id": "rule.glass_streaks",
        "title": "Streaks + glass cues → glass method",
        "severity": "hint",
        "when": {
          "any": [
            { "containsAny": ["mirror", "streaks", "streaky"] },
            { "containsAny": ["window", "squeegee", "glass"] }
          ]
        },
        "actions": [
          {
            "type": "boostMethodKey",
            "methodKey": "cleaning.glass.mirror",
            "amount": 0.35,
            "reason": "Mirror streak cues"
          },
          {
            "type": "boostMethodKey",
            "methodKey": "cleaning.glass.windows",
            "amount": 0.35,
            "reason": "Window/glass cues"
          },
          {
