{
  "description": "Sample SSA event envelope for `meal.executed`. Emit this when a cooking/meal session is actually completed. This is the point where inventory has been decremented (or should be decremented) and household analytics can count the meal. If familyFundMode=true, a downstream listener can export this to the Hub so the community sees what dishes are actually being cooked and which ingredients are in active rotation.",
  "envelopeShape": {
    "type": "meal.executed",
    "ts": "2025-11-02T13:25:00.000Z",
    "source": "domain/meals/MealSessionEngine",
    "data": {
      "sessionId": "meal_xxxxxxxx",
      "recipes": [
        {
          "id": "rec_xxxxxxxx",
          "name": "string",
          "servingsCooked": 4
        }
      ],
      "inventoryDeltas": [
        {
          "itemId": "inv_xxxxxxxx",
          "name": "string",
          "delta": -1,
          "unit": "each"
        }
      ],
      "notes": "string | null"
    }
  },
