---------------------------------------------------------------------------- */
export const FAMILY_HOOKS_TODO = String.raw`// src/services/sharing/family/hooks.js
import { on, emit } from "@/services/automation/runtime";
import { refreshSelection } from "@/stores/selectionStore.js";

/**
 * Registers listeners so Family composer stays in sync and
 * forwards support forecasts (garden/animals/cleaning/cooking) to the Agrarian.
 *
 * This runs as part of automation/runtime and is safe across route changes.
 */
export function registerFamilyEventGlue(){
  const relays = [
    "mealplan.created",
    "recipes.updated",
    "batch.completed",
    "inventory.updated",
    "calendar.events.updated",
    "garden.plan.updated",
    "animals.plan.updated",
    "chores.routines.updated",
    "storehouse.updated",
    "session.completed",
  ];

  relays.forEach((evt) => on(evt, handleFamilyChange));

  function handleFamilyChange(evt){
    refreshSelection();

    const payload = evt?.data || evt?.payload || null;
    const forecast = buildSupportForecast(payload);

    emit("family.nudge", {
      at: Date.now(),
      message:
        "Share key updates with your family so everyone understands the household rhythm.",
      actions: [
        { label: "Open Family Composer", href: "/family" },
        { label: "Open Family Board", href: "/family/board" },
      ],
      source: evt?.type || "data.change",
    });

    if (forecast){
      emit("family.agrarian.supportForecast", {
        at: Date.now(),
        summary: forecast.summary,
        details: forecast.details,
      });
    }
  }
}

// Minimal placeholder; replace with your real derivation logic
function buildSupportForecast(payload){
  if (!payload) return null;
  return {
    summary: "Upcoming support needs based on plans, sessions, and storehouse changes.",
    details: {
      notes:
        "Auto-generated from current meal plans, batch sessions, chores, garden, animals, and storehouse deltas.",
    },
  };
}
`;

/* --------------------------------------------------------------------------
  6) BACKGROUND SHIM — FAMILY SHARING POSTING ENGINE
     This is the key shim piece: it listens for "family.share.post.requested"
     and takes responsibility for posting, so UI can safely unmount.
---------------------------------------------------------------------------- */
export const FAMILY_SHIM_TODO = String.raw`// src/services/sharing/family/shim.js
import { on, emit } from "@/services/automation/runtime";
import {
  getFamilyShareJob,
  updateFamilyShareJob,
} from "@/services/sharing/family/jobs.js";
import { postToFamilyChannel } from "@/services/sharing/family/registry.js";
import { trackFamilyShareCompleted } from "@/services/sharing/family/telemetry.js";

let registered = false;

/**
 * registerFamilySharingShim
 *
 * Wires background listeners so that:
 *   - UI emits "family.share.post.requested" with { jobId }
 *   - This shim:
 *       * validates job
 *       * updates status "posting" / "done" / "error"
 *       * posts via the appropriate channel
 *       * emits progress events so other parts of SSA can react
 *
 * This is how family sharing continues even if the user navigates away.
 */
export function registerFamilySharingShim(){
  if (registered) return;
  registered = true;

  on("family.share.post.requested", handlePostRequested);
}

async function handlePostRequested(evt){
  try {
    const data = evt?.data || evt || {};
    const jobId = data.jobId;
    if (!jobId) return;

    let job = getFamilyShareJob(jobId);
    if (!job) return;

    updateFamilyShareJob(jobId, { status: "posting" });

    emit("family.share.posting", {
      jobId,
      channelId: job.channelId,
      at: Date.now(),
    });

    const result = await postToFamilyChannel(job.channelId, {
      payload: job.payload,
      audience: job.audience,
      options: job.options,
    });

    job = updateFamilyShareJob(jobId, {
      status: "done",
      result,
      error: null,
    });

    const sizeBytes = safeSize(job.payload);
    trackFamilyShareCompleted({
      channelId: job.channelId,
      sizeBytes,
    });

    emit("family.share.completed", {
      jobId,
      channelId: job.channelId,
      result,
      at: Date.now(),
    });
  } catch (e) {
    const data = evt?.data || evt || {};
    const jobId = data.jobId;
    if (jobId){
      const job = updateFamilyShareJob(jobId, {
        status: "error",
        error: e?.message || String(e),
      });
      emit("family.share.failed", {
        jobId,
        channelId: job?.channelId,
        error: e?.message || String(e),
        at: Date.now(),
      });
    }
  }
}

function safeSize(obj){
  try {
    return JSON.stringify(obj || {}).length;
  } catch {
    return 0;
  }
}
`;

