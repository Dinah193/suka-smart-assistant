import { registerDefaultFamilyChannels } from "@/services/sharing/family/channels/index.js";
import { registerFamilyEventGlue } from "@/services/sharing/family/hooks.js";
import { registerFamilySharingShim } from "@/services/sharing/family/shim.js";

/**
 * bootstrapFamilySharingService
 *
 * Call this once during SSA startup (e.g., app bootstrap) so:
 *   - Channels are registered
 *   - Event glue keeps the selection context in sync
 *   - The background shim is listening for post requests
 */
export function bootstrapFamilySharingService(){
  registerDefaultFamilyChannels();
  registerFamilyEventGlue();
  registerFamilySharingShim();
}
`;

