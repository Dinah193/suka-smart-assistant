export const FAMILY_TELEMETRY_TODO = String.raw`// src/services/sharing/family/telemetry.js
import { emit } from "@/services/automation/runtime";

/**
 * trackFamilyShareCompleted
 *
 * Called by the background shim after a successful post.
 * This can be extended to log to Dexie or hub analytics later.
 */
export function trackFamilyShareCompleted({ channelId, sizeBytes }){
  emit("family.share.completed.metrics", {
    channelId,
    sizeBytes,
    at: Date.now(),
  });
}
`;

