          </span>
          <input
            type="checkbox"
            className="toggle"
            checked={autoNotifyAgrarian}
            onChange={() => setAutoNotifyAgrarian(!autoNotifyAgrarian)}
          />
        </label>

        <label className="label cursor-pointer">
          <span className="label-text mr-3">Auto-summarize shares</span>
          <input
            type="checkbox"
            className="toggle"
            checked={autoSummaries}
            onChange={() => setAutoSummaries(!autoSummaries)}
          />
        </label>
      </div>
      <p className="text-xs opacity-70">
        These preferences can later be wired to the automation/runtime and agent shims,
        so family summaries and support forecasts respect sabbath and quiet-hour guards.
      </p>
    </div>
  );
}
`;

