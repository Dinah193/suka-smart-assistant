/* --------------------------------------------------------------------------
  1) REGISTRY & JOB STATE (Channels + Undo + Persistence)
---------------------------------------------------------------------------- */
export const FAMILY_REGISTRY_TODO = String.raw`// src/services/sharing/family/registry.js
// Registry of output channels (Family Board, DM, Email, SMS, Drive, etc.)
// This can be safely used from UI OR background shims.
const channels = new Map();

/**
 * registerFamilyChannel({ id, label, kind, supports(ctx), post({payload,audience,options}) })
 * - id: "family-board" | "dm" | "email" | "sms" | "drive"
 * - kind: "realtime" | "async" | "broadcast"
 * - supports(ctx): gate by selection/policy (returns boolean)
 * - post(args): async -> { id, url? }
 */
export function registerFamilyChannel(def){
  if (!def?.id || !def?.post) throw new Error("Invalid channel def");
  channels.set(def.id, def);
}

export function listFamilyChannels(ctx){
  return Array.from(channels.values()).filter(ch =>
    typeof ch.supports === "function" ? ch.supports(ctx) : true
  );
}

export async function postToFamilyChannel(id, args){
  const ch = channels.get(id);
  if (!ch) throw new Error(\`Family channel "\${id}" not found\`);
  return ch.post(args);
}
`;

export const FAMILY_JOBS_TODO = String.raw`// src/services/sharing/family/jobs.js
// Lightweight local job registry so family share jobs can outlive UI components.
// NOTE: For deeper resilience, you can later mirror this into Dexie.
const JOBS = new Map();
const UNDO_STACK = [];
const LS_KEY = "suka.family.jobs";

function persist(){
  try {
    const arr = Array.from(JOBS.values());
    localStorage.setItem(LS_KEY, JSON.stringify(arr));
  } catch {}
}

function restore(){
  try {
    const raw = localStorage.getItem(LS_KEY);
    const arr = raw ? JSON.parse(raw) : [];
    JOBS.clear();
    for (const j of arr) JOBS.set(j.id, j);
  } catch {}
}
restore();

export function createFamilyShareJob({ channelId, audience, payload, options }){
  const id =
    (globalThis.crypto?.randomUUID?.() ||
      (Date.now() + "-" + Math.random().toString(36).slice(2)));

  const job = {
    id,
    channelId,
    audience,
    payload,
    options,
    status: "draft", // draft -> ready -> queued -> posting -> done | error | cancelled
    createdAt: Date.now(),
    updatedAt: Date.now(),
    history: [],
    result: null,
    error: null,
  };

  JOBS.set(id, job);
  persist();
  return job;
}

export function updateFamilyShareJob(id, patch){
  const job = JOBS.get(id);
  if (!job) throw new Error("Family share job not found");

  const prev = typeof structuredClone === "function"
    ? structuredClone(job)
    : JSON.parse(JSON.stringify(job));

  Object.assign(job, patch, { updatedAt: Date.now() });
  job.history.push({ ts: Date.now(), patch });
  UNDO_STACK.push(() => {
    JOBS.set(id, prev);
    persist();
  });

  persist();
  return job;
}

export function getFamilyShareJob(id){ return JOBS.get(id); }

export function listFamilyShareJobs(){
  return Array.from(JOBS.values()).sort((a,b) => b.createdAt - a.createdAt);
}

export function undoLastFamilyShare(){
  const fn = UNDO_STACK.pop();
  if (fn) fn();
}

export function clearFamilyShareJobs(){
  JOBS.clear();
  persist();
}
`;

