export const FAMILY_POLICY_TODO = String.raw`// src/services/sharing/family/policy.js
// Very simple role model; you can tighten this later.
export const ROLES = ["householder", "steward", "agrarian", "member"];

export function canFamilyShare(user){
  return !!user;
}

export function enforceRole(user, role){
  return !!user?.roles?.includes(role);
}

export function normalizeFamilyAudience({ members = [], households = [], emails = [], phones = [] } = {}){
  return { members, households, emails, phones };
}
`;

/* --------------------------------------------------------------------------
  4) UI: Compose → Preview → Post (Flow + Empty states + Undo)
     NOTE: The actual posting is now handled by a background shim; UI just
     queues jobs via events so it is safe when users navigate away.
---------------------------------------------------------------------------- */
export const FAMILY_COMPOSE_TODO = String.raw`// src/components/family/FamilyCompose.jsx
import React, { useMemo, useState } from "react";
import { listFamilyChannels } from "@/services/sharing/family/registry.js";
import { createFamilyShareJob, updateFamilyShareJob } from "@/services/sharing/family/jobs.js";
import { useSelectionContext } from "@/stores/selectionStore.js";
import { normalizeFamilyAudience } from "@/services/sharing/family/policy.js";

export function FamilyCompose(){
  // selection = { mealPlan, batch, rows, calendarEvents, garden, animals, chores, storehouse }
  const selection = useSelectionContext();
  const [channelId, setChannelId] = useState(null);
  const [members, setMembers] = useState([]);
  const [emails, setEmails] = useState([]);
  const [phones, setPhones] = useState([]);
  const [title, setTitle] = useState("");
  const [note, setNote] = useState("");

  const context = useMemo(
    () => ({ selection, audience: { members, emails, phones } }),
    [selection, members, emails, phones]
  );
  const channels = useMemo(() => listFamilyChannels(context), [context]);

  const empty =
    !selection ||
    Object.values(selection).every(
      (v) => !v || (Array.isArray(v) && v.length === 0)
    );

  if (empty){
    return (
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Nothing to share with family yet</h3>
        <p className="mb-4 text-sm opacity-80">
          Create a weekly meal plan, a batch cooking session, a garden/animals plan, or
          assign rhythms in chores and storehouse before sending a family update.
        </p>
        <div className="flex flex-wrap gap-2">
          <a className="btn" href="/tier2/household/meals">Meal Planner</a>
          <a className="btn" href="/tier2/household/meals#batch">Batch Cooking</a>
          <a className="btn" href="/tier2/garden">Garden Plan</a>
          <a className="btn" href="/tier2/animals">Animal Plan</a>
          <a className="btn" href="/calendar">Household Calendar</a>
        </div>
      </div>
    );
  }

  const smartTitle =
    title ||
    selection?.mealPlan?.title ||
    selection?.batch?.title ||
    selection?.garden?.title ||
    "Family Update";

  return (
    <div className="space-y-4">
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Channel & Audience</h3>
        <div className="grid md:grid-cols-3 gap-3">
          <div className="flex gap-2 flex-wrap">
            {channels.map((ch) => (
              <button
                key={ch.id}
                className={\`btn \${channelId === ch.id ? "btn-primary" : "btn-outline"}\`}
                onClick={() => setChannelId(ch.id)}
              >
                {ch.label}
              </button>
            ))}
          </div>
          <input
            className="input input-bordered"
            placeholder="Members (comma)"
            onBlur={(e) =>
              setMembers(
                e.target.value
                  .split(",")
                  .map((x) => x.trim())
                  .filter(Boolean)
              )
            }
          />
          <div className="grid grid-cols-2 gap-2">
            <input
              className="input input-bordered"
              placeholder="Emails (comma)"
              onBlur={(e) =>
                setEmails(
                  e.target.value
                    .split(",")
                    .map((x) => x.trim())
                    .filter(Boolean)
                )
              }
            />
            <input
              className="input input-bordered"
              placeholder="Phones (comma)"
              onBlur={(e) =>
                setPhones(
                  e.target.value
                    .split(",")
                    .map((x) => x.trim())
                    .filter(Boolean)
                )
              }
            />
          </div>
        </div>
      </div>

      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Message</h3>
        <input
          className="input input-bordered w-full mb-2"
          placeholder="Title"
          value={title}
          onChange={(e) => setTitle(e.target.value)}
        />
        <textarea
          className="textarea textarea-bordered w-full"
          rows={5}
          placeholder="Context, asks, feast prep, who stewards which part…"
          value={note}
          onChange={(e) => setNote(e.target.value)}
        />
        <div className="text-xs opacity-70 mt-2">
          Tip: Assign an owner and simple time frame for each household provision or rhythm.
        </div>
      </div>

      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">What you’re sharing</h3>
        <pre className="bg-base-200 p-3 rounded max-h-64 overflow-auto text-xs">
{JSON.stringify(selection, null, 2)}
        </pre>
      </div>

      <div className="flex gap-2">
        <a className="btn btn-outline" href="/family/history">
          View History
        </a>
        <button
          className="btn btn-primary"
          disabled={!channelId}
          onClick={() => {
            const audience = normalizeFamilyAudience({ members, emails, phones });
            const payload = { title: smartTitle, note, selection };
            const job = createFamilyShareJob({
              channelId,
              audience,
              payload,
              options: {},
            });
            updateFamilyShareJob(job.id, { status: "ready" });
            sessionStorage.setItem("currentFamilyShareJob", job.id);
            location.href = "/family/preview";
          }}
        >
          Continue
        </button>
      </div>
    </div>
  );
}
`;

// Preview (now shim-aware: it only QUEUES work via events)
export const FAMILY_PREVIEW_TODO = String.raw`// src/components/family/FamilyPreview.jsx
import React, { useEffect, useState } from "react";
import {
  getFamilyShareJob,
  updateFamilyShareJob,
  undoLastFamilyShare,
} from "@/services/sharing/family/jobs.js";
import { emit } from "@/services/automation/runtime";

/**
 * FamilyPreview no longer posts directly.
 * It:
 *   - Updates job to "queued"
 *   - Emits "family.share.post.requested" with { jobId }
 * A background shim listens and performs the actual post so it survives
 * navigation away from this screen.
 */
export function FamilyPreview(){
  const [job, setJob] = useState(null);

  useEffect(() => {
    const id = sessionStorage.getItem("currentFamilyShareJob");
    if (!id) return;
    setJob(getFamilyShareJob(id));
  }, []);

  if (!job){
    return (
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">No family share in progress</h3>
        <p className="mb-4 text-sm opacity-80">
          Start in Family Sharing composer.
        </p>
        <a className="btn" href="/family">
          Go to Family Sharing
        </a>
      </div>
    );
  }

  const postingLike =
    job.status === "posting" || job.status === "queued";

  return (
    <div className="space-y-4">
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Preview</h3>
        <pre className="bg-base-200 p-3 rounded max-h-64 overflow-auto text-xs">
{JSON.stringify(
  {
    channel: job.channelId,
    audience: job.audience,
    payload: job.payload,
  },
  null,
  2
)}
        </pre>
        {job.error && (
          <div className="alert alert-error mt-3 text-sm">
            Error: {job.error}
          </div>
        )}
        <div className="flex gap-2 mt-3">
          <button
            className="btn btn-outline"
            onClick={() => {
              undoLastFamilyShare();
              const updated = getFamilyShareJob(job.id);
              setJob(updated || null);
            }}
          >
            Undo Last Change
          </button>
          <button
            className="btn btn-primary"
            disabled={postingLike}
            onClick={async () => {
              try {
                // Mark as queued and emit an event for the background shim.
                updateFamilyShareJob(job.id, { status: "queued" });

                sessionStorage.setItem(
                  "lastFamilySuggestion",
                  JSON.stringify({
                    message:
                      job.channelId === "family-board"
                        ? "Assign owners & simple time frames on the Family Board."
                        : job.channelId === "drive"
                        ? "Share the folder link on the Family Board and Household Calendar."
                        : "Create calendar reminders and notify the Agrarian/Steward.",
                    actions: [
                      { label: "Open Family Board", href: "/family/board" },
                      { label: "Create Calendar Items", href: "/calendar" },
                      { label: "Share More", href: "/family" },
                    ],
                  })
                );

                emit("family.share.post.requested", {
                  jobId: job.id,
                  source: "ui.family.preview",
                });

                setJob(getFamilyShareJob(job.id));
                setTimeout(() => {
                  location.href = "/family/history";
                }, 150);
              } catch (e) {
                updateFamilyShareJob(job.id, {
                  status: "error",
                  error: e?.message || String(e),
                });
                setJob(getFamilyShareJob(job.id));
              }
            }}
          >
            {postingLike ? "Queued…" : "Post to Family"}
          </button>
        </div>
      </div>
    </div>
  );
}
`;

