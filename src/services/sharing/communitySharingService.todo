export const COMMUNITY_HISTORY_TODO = `
// src/components/community/CommunityHistory.jsx
import React, { useEffect, useState } from "react";
import { listShareJobs } from "@/services/sharing/community/jobs.js";

export function CommunityHistory(){
  const [items, setItems] = useState([]);
  const [tip, setTip] = useState(null);
  useEffect(()=>{
    setItems(listShareJobs());
    const t = sessionStorage.getItem("lastCommunitySuggestion");
    if (t) setTip(JSON.parse(t));
  },[]);
  if (!items.length){
    return (
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">No community shares yet</h3>
        <p className="mb-4 text-sm opacity-80">You’ll see your shared posts and tasks here.</p>
        <a className="btn" href="/community">Compose a Share</a>
      </div>
    );
  }
  return (
    <div className="space-y-4">
      {tip && (
        <div className="alert">
          <div>
            <h4 className="font-semibold">Next best action</h4>
            <p className="text-sm opacity-80">{tip.message}</p>
          </div>
          <div className="ml-auto flex gap-2">
            {tip.actions?.map((a,i)=><a key={i} className="btn btn-sm" href={a.href}>{a.label}</a>)}
          </div>
        </div>
      )}
      <div className="grid gap-3">
        {items.map(j=>(
          <div key={j.id} className="card p-4 border">
            <div className="flex items-center justify-between">
              <div>
                <div className="font-semibold">{j.payload?.title || j.channelId}</div>
                <div className="text-xs opacity-70">{new Date(j.createdAt).toLocaleString()} • {j.status}</div>
              </div>
              <div className="text-xs opacity-70">#{j.id.slice(0,8)}</div>
            </div>
            {j.error && <div className="text-error text-sm mt-2">Error: {j.error}</div>}
          </div>
        ))}
      </div>
    </div>
  );
}
`;

