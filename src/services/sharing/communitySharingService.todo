/* --------------------------------------------------------------------------
  3) POLICY & AUDIENCE (Scopes, Roles, Safety)
---------------------------------------------------------------------------- */
// TODO[community]/policy: Visibility scopes and role checks.

export const COMMUNITY_POLICY_TODO = `
// src/services/sharing/community/policy.js
export const SCOPES = ["public", "circle", "neighborhood", "households", "invited"];
export function canShare(user, scope){
  if (!user) return false;
  if (scope === "public") return true;
  if (scope === "circle") return user.roles?.includes("circle_member");
  if (scope === "neighborhood") return user.roles?.includes("neighbor");
  if (scope === "households") return user.roles?.includes("household_admin");
  if (scope === "invited") return true; // invite list validated in server
  return false;
}
export function normalizeAudience({ scope, invited = [], emails = [], phones = [] }){
  return { scope, invited, emails, phones };
}
`;

/* --------------------------------------------------------------------------
  4) UI: Compose → Preview → Post (Flow + Empty states + Undo)
---------------------------------------------------------------------------- */
// TODO[community]/ui: Compose screen with smart presets and module pickers.

export const COMMUNITY_COMPOSE_TODO = `
// src/components/community/CommunityCompose.jsx
import React, { useMemo, useState } from "react";
import { useNavigate } from "react-router-dom";
import { listChannels } from "@/services/sharing/community/registry.js";
import { createShareJob, updateShareJob } from "@/services/sharing/community/jobs.js";
import { useSelectionContext } from "@/stores/selectionStore.js";
import { SCOPES, normalizeAudience } from "@/services/sharing/community/policy.js";

export function CommunityCompose(){
  const navigate = useNavigate();
  const selection = useSelectionContext(); // { mealPlan, batch, rows, calendarEvents, garden, animals, chores, projects }
  const [scope, setScope] = useState("circle");
  const [invited, setInvited] = useState([]);
  const [channelId, setChannelId] = useState(null);
  const [note, setNote] = useState("");
  const [title, setTitle] = useState("");

  const context = useMemo(() => ({ selection, audience: { scope, invited } }), [selection, scope, invited]);
  const channels = useMemo(() => listChannels(context), [context]);

  const empty = !selection || Object.values(selection).every(v => !v || (Array.isArray(v) && v.length===0));
  if (empty){
    return (
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Nothing to share yet</h3>
        <p className="mb-4 text-sm opacity-80">Build something to share: a weekly meal plan, a batch session, a garden plan, or project tasks.</p>
        <div className="flex flex-wrap gap-2">
          <a className="btn" href="/tier2/household/meals">Open Meal Planner</a>
          <a className="btn" href="/tier2/household/meals#batch">Batch Session</a>
          <a className="btn" href="/tier2/garden">Garden Plan</a>
          <a className="btn" href="/tier2/animals">Animal Tasks</a>
          <a className="btn" href="/calendar">Calendar</a>
        </div>
      </div>
    );
  }

  const smartTitle =
    title || selection?.mealPlan?.title ||
    selection?.projects?.[0]?.title ||
    "Community Update";

  return (
    <div className="space-y-4">
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Audience & Channel</h3>
        <div className="grid md:grid-cols-3 gap-3">
          <select className="select select-bordered" value={scope} onChange={(e)=>setScope(e.target.value)}>
            {["public","circle","neighborhood","households","invited"].map(s=><option key={s} value={s}>{s}</option>)}
          </select>
          <input className="input input-bordered" placeholder="Add invited user emails (comma)" onBlur={(e)=>setInvited(e.target.value.split(",").map(x=>x.trim()).filter(Boolean))}/>
          <div className="flex gap-2 flex-wrap">
            {channels.map(ch=>(
              <button key={ch.id} className={\`btn \${channelId===ch.id?"btn-primary":"btn-outline"}\`} onClick={()=>setChannelId(ch.id)}>{ch.label}</button>
            ))}
          </div>
        </div>
      </div>

      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Message</h3>
        <input className="input input-bordered w-full mb-2" placeholder="Title" value={title} onChange={(e)=>setTitle(e.target.value)} />
        <textarea className="textarea textarea-bordered w-full" rows={5} placeholder="Context, asks, due dates…" value={note} onChange={(e)=>setNote(e.target.value)} />
        <div className="text-xs opacity-70 mt-2">Tip: Be specific: who, what, where, when. Add deliverables and due dates.</div>
      </div>

      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">What you're sharing</h3>
        <pre className="bg-base-200 p-3 rounded max-h-64 overflow-auto text-xs">
{JSON.stringify(selection, null, 2)}
        </pre>
      </div>

      <div className="flex gap-2">
        <a className="btn btn-outline" href="/community/history">View History</a>
        <button
          className="btn btn-primary"
          disabled={!channelId}
          onClick={()=>{
            const audience = normalizeAudience({ scope, invited });
            const payload = { title: smartTitle, note, selection };
            const job = createShareJob({ channelId, audience, payload, options: {} });
            updateShareJob(job.id, { status: "ready" });
            sessionStorage.setItem("currentShareJob", job.id);
            // Move to preview
            location.href="/community/preview";
          }}
        >
          Continue
        </button>
      </div>
    </div>
  );
}
`;

// TODO[community]/ui: Preview with Undo + Post + Next Best Action.

export const COMMUNITY_PREVIEW_TODO = `
// src/components/community/CommunityPreview.jsx
import React, { useEffect, useState } from "react";
import { getShareJob, updateShareJob, undoLastShare } from "@/services/sharing/community/jobs.js";
import { postToChannel } from "@/services/sharing/community/registry.js";

export function CommunityPreview(){
  const [job, setJob] = useState(null);
  useEffect(()=>{
    const id = sessionStorage.getItem("currentShareJob");
    if (!id) return;
    setJob(getShareJob(id));
  },[]);

  if (!job){
    return (
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">No share in progress</h3>
        <p className="mb-4 text-sm opacity-80">Start in the Community composer.</p>
        <a className="btn" href="/community">Go to Community</a>
      </div>
    );
  }

  const posting = job.status === "posting";
  return (
    <div className="space-y-4">
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Preview</h3>
        <pre className="bg-base-200 p-3 rounded max-h-64 overflow-auto text-xs">
{JSON.stringify({ channel: job.channelId, audience: job.audience, payload: job.payload }, null, 2)}
        </pre>
        {job.error && <div className="alert alert-error mt-3 text-sm">Error: {job.error}</div>}
        <div className="flex gap-2 mt-3">
          <button className="btn btn-outline" onClick={()=>undoLastShare()}>Undo Last Change</button>
          <button
            className="btn btn-primary"
            disabled={posting}
            onClick={async ()=>{
              try{
                updateShareJob(job.id, { status: "posting" });
                const result = await postToChannel(job.channelId, {
                  payload: job.payload,
                  audience: job.audience,
                  options: job.options,
                });
                updateShareJob(job.id, { status: "done", result, error: null });
                // Next best actions:
                sessionStorage.setItem("lastCommunitySuggestion", JSON.stringify({
                  message: job.channelId==="board"
                    ? "Assign tasks and due dates on the Shared Board?"
                    : job.channelId==="email"
                      ? "Follow up with a Board post for task tracking?"
                      : "Pin to Board and create subtasks?",
                  actions: [
                    { label: "Open Shared Board", href: "/community/board" },
                    { label: "Create Calendar Tasks", href: "/calendar" },
                    { label: "Share More", href: "/community" },
                  ],
                }));
              }catch(e){
                updateShareJob(job.id, { status: "error", error: e?.message || String(e) });
              }
              setTimeout(()=>{ location.href="/community/history"; }, 150);
            }}
          >
            {posting ? "Posting…" : "Post to Community"}
          </button>
        </div>
      </div>
    </div>
  );
}
`;

