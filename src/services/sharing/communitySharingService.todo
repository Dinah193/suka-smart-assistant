// TODO[community]/registry: Central place to register sharing channels.

export const COMMUNITY_REGISTRY_TODO = `
// src/services/sharing/community/registry.js
const channels = new Map();
/**
 * registerChannel({ id, label, kind, supports, post })
 * - id: unique string (e.g., "feed", "email", "sms", "board")
 * - label: UI label
 * - kind: "realtime" | "async" | "broadcast"
 * - supports: (context) => boolean (gate by selection/policy)
 * - post: async ({ payload, audience, options, signal }) => { id, url? }
 */
export function registerChannel(def) {
  if (!def?.id || !def?.post) throw new Error("Invalid channel def");
  channels.set(def.id, def);
}
export function listChannels(ctx) {
  return Array.from(channels.values()).filter(ch =>
    typeof ch.supports === "function" ? ch.supports(ctx) : true
  );
}
export async function postToChannel(id, args) {
  const ch = channels.get(id);
  if (!ch) throw new Error(\`Channel "\${id}" not found\`);
  return ch.post(args);
}
`;

// TODO[community]/jobs: Share jobs with undo.

export const COMMUNITY_JOBS_TODO = `
// src/services/sharing/community/jobs.js
const JOBS = new Map();
const UNDO_STACK = [];

export function createShareJob({ channelId, audience, payload, options }) {
  const id = crypto.randomUUID();
  const job = {
    id, channelId, audience, payload, options,
    status: "draft", // draft -> ready -> posting -> done | error | cancelled
    createdAt: Date.now(),
    updatedAt: Date.now(),
    history: [],
    result: null,
    error: null,
  };
  JOBS.set(id, job);
  return job;
}
export function updateShareJob(id, patch) {
  const job = JOBS.get(id);
  if (!job) throw new Error("Share job not found");
  const prev = structuredClone(job);
  Object.assign(job, patch, { updatedAt: Date.now() });
  job.history.push({ ts: Date.now(), patch });
  UNDO_STACK.push(() => JOBS.set(id, prev));
  return job;
}
export function getShareJob(id){ return JOBS.get(id); }
export function listShareJobs(){ return Array.from(JOBS.values()).sort((a,b)=>b.createdAt-a.createdAt); }
export function undoLastShare(){ const fn = UNDO_STACK.pop(); if (fn) fn(); }
export function clearShareJobs(){ JOBS.clear(); }
`;

