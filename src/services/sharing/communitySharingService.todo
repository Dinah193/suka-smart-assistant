// TODO[community]/hooks: Recompute selection & create smart prompts on events.

export const COMMUNITY_HOOKS_TODO = `
// src/services/sharing/community/hooks.js
import { on, emit } from "@/services/automation/runtime";
import { refreshSelection } from "@/stores/selectionStore.js";

/**
 * Registers listeners so Community composer stays in sync
 * and can produce timely suggestions (nudges).
 */
export function registerCommunityEventGlue(){
  // Core data sources
  on("mealplan.created", handleNudge);
  on("recipes.updated", handleNudge);
  on("batch.completed", handleNudge);
  on("inventory.updated", handleNudge);
  on("calendar.events.updated", handleNudge);
  on("garden.plan.updated", handleNudge);
  on("animals.tasks.updated", handleNudge);
  on("chores.routines.updated", handleNudge);

  function handleNudge(evt){
    refreshSelection(); // Make latest selection available to composer
    // Emit a subtle suggestion for community planning
    emit("community.nudge", {
      at: Date.now(),
      message: "Share updates with your circle to align tasks and schedules?",
      actions: [
        { label: "Open Community Composer", href: "/community" },
        { label: "Open Shared Board", href: "/community/board" },
      ],
      source: evt?.type || "data.change",
    });
  }
}
`;

