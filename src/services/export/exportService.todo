export const EXPORT_START_TODO = `
// src/components/export/ExportStart.jsx
import React, { useMemo, useState } from "react";
import { useSelectionContext } from "@/stores/selectionStore.js"; // selected mealPlan/batch/inventory/calendar
import { listExporters, runExporter } from "@/services/export/registry.js";
import { createJob, updateJob } from "@/services/export/jobs.js";
import { useNavigate } from "react-router-dom";

export function ExportStart() {
  const navigate = useNavigate();
  const selection = useSelectionContext(); // { mealPlan, batch, rows, calendarEvents, labels }
  const exporters = useMemo(() => listExporters(selection), [selection]);
  const [chosen, setChosen] = useState(null);
  const [filename, setFilename] = useState("");

  const empty = !selection || Object.keys(selection).length === 0;

  if (empty) {
    return (
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Nothing to export yet</h3>
        <p className="mb-4 text-sm opacity-80">
          Add meals to your plan, queue a batch, select inventory rows, or pick calendar items.
        </p>
        <div className="flex gap-2">
          <a className="btn" href="/tier2/household/meals">Open Meal Planner</a>
          <a className="btn" href="/tier2/household/meals#batch">Start Batch Cooking</a>
          <a className="btn" href="/tier2/household/inventory">Review Inventory</a>
          <a className="btn" href="/calendar">Open Calendar</a>
        </div>
      </div>
    );
  }

  return (
    <div className="space-y-4">
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Choose format</h3>
        <div className="grid md:grid-cols-3 gap-3">
          {exporters.map((x) => (
            <button
              key={x.id}
              onClick={() => setChosen(x.id)}
              className={\`btn \${chosen===x.id ? "btn-primary" : "btn-outline"}\`}
            >
              {x.label}
            </button>
          ))}
        </div>
      </div>

      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Name your file</h3>
        <input
          className="input input-bordered w-full"
          value={filename}
          onChange={(e) => setFilename(e.target.value)}
          placeholder="e.g., week-42-mealplan.pdf"
        />
      </div>

      <div className="flex gap-2">
        <button className="btn btn-outline" onClick={() => navigate("/export/history")}>
          View History
        </button>
        <button
          className="btn btn-primary"
          disabled={!chosen}
          onClick={async () => {
            const job = createJob({
              type: chosen,
              selection,
              options: { filename: filename?.trim() || undefined },
            });
            updateJob(job.id, { status: "preparing" });
            // Precompute/normalize can go here
            updateJob(job.id, { status: "ready" });
            // move to preview
            sessionStorage.setItem("currentExportJob", job.id);
            navigate("/export/preview");
          }}
        >
          Continue
        </button>
      </div>
    </div>
  );
}
`;

/*
File: src/components/export/ExportPreview.jsx
*/
export const EXPORT_PREVIEW_TODO = `
// src/components/export/ExportPreview.jsx
import React, { useEffect, useMemo, useState } from "react";
import { getJob, updateJob, undoLast } from "@/services/export/jobs.js";
import { runExporter } from "@/services/export/registry.js";

function downloadBlob(blob, filename) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url; a.download = filename || "export";
  document.body.appendChild(a);
  a.click();
  setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 0);
}

export function ExportPreview() {
  const [job, setJob] = useState(null);
  useEffect(() => {
    const id = sessionStorage.getItem("currentExportJob");
    if (!id) return;
    setJob(getJob(id));
  }, []);

  const ready = job && job.status === "ready";
  if (!job) {
    return (
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">No export in progress</h3>
        <p className="mb-4 text-sm opacity-80">Start from the Export Center.</p>
        <a className="btn" href="/export">Go to Export Center</a>
      </div>
    );
  }

  return (
    <div className="space-y-4">
      <div className="card p-6 border">
        <h3 className="text-lg font-semibold mb-2">Preview</h3>
        <p className="text-sm opacity-80 mb-4">
          Confirm your selection and export format. Use “Undo” to revert any last change.
        </p>
        <pre className="bg-base-200 p-3 rounded max-h-64 overflow-auto text-xs">
{JSON.stringify({ type: job.type, selection: job.selection, options: job.options }, null, 2)}
        </pre>
        <div className="flex gap-2 mt-3">
          <button className="btn btn-outline" onClick={() => undoLast()}>
            Undo Last Change
          </button>
          <button
            className="btn btn-primary"
            disabled={!ready}
            onClick={async () => {
              try {
                updateJob(job.id, { status: "exporting" });
                const out = await runExporter(job.type, {
                  selection: job.selection,
                  options: job.options,
                });
                updateJob(job.id, { status: "done", result: out, error: null });
                downloadBlob(out.blob, out.filename);
                // Suggest next best action:
                sessionStorage.setItem("lastExportSuggestion",
                  JSON.stringify({
                    message: job.type === "ics" ? "Add to your calendar app?" :
                              job.type === "labels" ? "Print labels now?" :
                              "Share with family or save to Drive?",
                    actions: [
                      { label: "Share to Family", href: "/sharing/family" },
                      { label: "Open Drive Folder", href: "/files/exports" },
                      { label: "Back to Planner", href: "/tier2/household/meals" },
                    ],
                  })
                );
              } catch (e) {
                updateJob(job.id, { status: "error", error: e?.message || String(e) });
              }
              // force refresh
              setTimeout(() => { location.href = "/export/history"; }, 100);
            }}
          >
            Export Now
          </button>
        </div>
      </div>
    </div>
  );
}
`;

/*
File: src/components/export/ExportHistory.jsx
