/*
File: src/services/export/registry.js
*/
export const EXPORT_REGISTRY_TODO = `
// src/services/export/registry.js
// Register exporters here: pdf, csv, json, ics, labels, etc.

const exporters = new Map();

/**
 * registerExporter({ id, label, supports, run })
 * - id: unique string
 * - label: user-facing name
 * - supports: (context) => boolean (e.g., supports mealPlan / inventory / calendar)
 * - run: async ({ selection, options, signal }) => { blob, filename, mime }
 */
export function registerExporter(def) {
  if (!def?.id || !def?.run) throw new Error("Invalid exporter def");
  exporters.set(def.id, def);
}

export function listExporters(context) {
  return Array.from(exporters.values()).filter((x) =>
    typeof x.supports === "function" ? x.supports(context) : true
  );
}

export async function runExporter(id, args) {
  const def = exporters.get(id);
  if (!def) throw new Error(\`Exporter "\${id}" not found\`);
  return def.run(args);
}
`;

/*
File: src/services/export/jobs.js
*/
export const EXPORT_JOBS_TODO = `
// src/services/export/jobs.js
// Simple job state machine + undo stack

const JOBS = new Map();
const UNDO_STACK = []; // command pattern snapshots

export function createJob({ type, selection, options }) {
  const id = crypto.randomUUID();
  const job = {
    id,
    type,
    selection,
    options,
    status: "draft", // draft -> preparing -> ready -> exporting -> done | error | cancelled
    createdAt: Date.now(),
    updatedAt: Date.now(),
    history: [],
    result: null,
    error: null,
  };
  JOBS.set(id, job);
  return job;
}

export function updateJob(id, patch) {
  const job = JOBS.get(id);
  if (!job) throw new Error("Job not found");
  const prev = structuredClone(job);
  Object.assign(job, patch, { updatedAt: Date.now() });
  job.history.push({ ts: Date.now(), patch });
  // push undo snapshot
  UNDO_STACK.push(() => JOBS.set(id, prev));
  return job;
}

export function getJob(id) {
  return JOBS.get(id);
}

export function listJobs() {
  return Array.from(JOBS.values()).sort((a, b) => b.createdAt - a.createdAt);
}

export function undoLast() {
  const fn = UNDO_STACK.pop();
  if (fn) fn();
}

export function clearJobs() {
  JOBS.clear();
}
`;

