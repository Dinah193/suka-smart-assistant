export const EXPORT_HOOKS_TODO = `
// src/services/export/hooks.js
// Listen for app-wide events and refresh selection context
import { on } from "@/services/automation/runtime"; // your event bus
import { refreshSelection } from "@/stores/selectionStore.js";

export function registerExportEventGlue() {
  // Recipes/meal plan updates
  on("mealplan.created", refreshSelection);
  on("recipes.updated", refreshSelection);
  on("batch.started", refreshSelection);
  on("batch.completed", refreshSelection);

  // Inventory updates
  on("inventory.updated", refreshSelection);
  on("storehouse.updated", refreshSelection);

  // Calendar updates
  on("calendar.synced", refreshSelection);
  on("calendar.events.updated", refreshSelection);

  // Garden/labels updates (labels exporter)
  on("labels.updated", refreshSelection);
}
`;

