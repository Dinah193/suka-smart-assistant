/*
File: src/services/export/exporters/csvExporter.js
*/
export const CSV_EXPORTER_TODO = `
// src/services/export/exporters/csvExporter.js
function toCSV(rows) {
  if (!rows?.length) return "";
  const headers = Object.keys(rows[0]);
  const lines = [
    headers.join(","),
    ...rows.map((r) => headers.map((h) => JSON.stringify(r[h] ?? "")).join(",")),
  ];
  return lines.join("\\n");
}

export const csvExporter = {
  id: "csv",
  label: "CSV (Spreadsheet)",
  supports: (ctx) => Array.isArray(ctx?.rows),
  async run({ selection, options }) {
    const csv = toCSV(selection?.rows || []);
    return {
      blob: new Blob([csv], { type: "text/csv" }),
      filename: options?.filename || "export.csv",
      mime: "text/csv",
    };
  },
};
`;

