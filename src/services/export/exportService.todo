/*
File: src/services/export/exporters/icsExporter.js
*/
export const ICS_EXPORTER_TODO = `
// src/services/export/exporters/icsExporter.js
function buildICS(events=[]) {
  const head = [
    "BEGIN:VCALENDAR",
    "VERSION:2.0",
    "PRODID:-//Suka//Export//EN",
  ];
  const body = events.map((e) => [
    "BEGIN:VEVENT",
    \`UID:\${crypto.randomUUID()}@suka\`,
    \`DTSTAMP:\${new Date().toISOString().replace(/[-:]/g, "").split(".")[0]}Z\`,
    \`SUMMARY:\${(e.title||"Task").replace(/\\n/g," ")}\`,
    e.start ? \`DTSTART:\${e.start}\` : "",
    e.end ? \`DTEND:\${e.end}\` : "",
    "END:VEVENT",
  ].filter(Boolean).join("\\n"));
  const foot = ["END:VCALENDAR"];
  return [...head, ...body, ...foot].join("\\n");
}

export const icsExporter = {
  id: "ics",
  label: "Calendar (.ics)",
  supports: (ctx) => Array.isArray(ctx?.calendarEvents),
  async run({ selection, options }) {
    const ics = buildICS(selection?.calendarEvents || []);
    return {
      blob: new Blob([ics], { type: "text/calendar" }),
      filename: options?.filename || "schedule.ics",
      mime: "text/calendar",
    };
  },
};
`;

