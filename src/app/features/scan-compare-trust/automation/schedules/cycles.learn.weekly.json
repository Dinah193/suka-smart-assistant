{
  "$schema": "../../../../../schemas/automation.schedule.schema.json",
  "id": "schedule.cycles.learn.weekly",
  "version": 1,
  "kind": "schedule",
  "title": "Weekly Deal Cadence Learning",
  "description": "Batch-learn store/brand discount cycles from the Pricebook and Coupons Ledger, then compute next expected sale windows and refresh smart watchlists.",
  "owner": {
    "type": "user-or-system",
    "userId": "${user.id|null}",
    "householdId": "${household.id|null}"
  },
  "enabled": true,
  "timezone": "America/New_York",
  "when": {
    "rrules": [
      "FREQ=WEEKLY;BYDAY=MO;BYHOUR=03;BYMINUTE=30;BYSECOND=00"
    ],
    "dtstartISO": "${now.aligned('America/New_York','03:30')}",
    "window": {
      "maxStartSkewMs": 600000,
      "maxDurationMs": 900000
    },
    "catchUpMode": "run_once"
  },
  "guards": {
    "respectSabbath": true,
    "respectQuietHours": true,
    "quietHours": {
      "start": "${prefs.quietHours.start||'21:30'}",
      "end": "${prefs.quietHours.end||'06:30'}"
    },
    "doNotDisturb": "${prefs.doNotDisturb||false}",
    "network": {
      "skipOnMetered": true,
      "minBandwidthKbps": 256
    },
    "battery": {
      "minPercent": 20,
      "requireNotLowPowerMode": true
    },
    "onGuarded": {
      "action": "defer",
      "emit": "automation:deferred",
      "inboxItem": {
        "type": "automation",
        "title": "Cadence learning deferred",
        "body": "Quiet Hours / Sabbath Guard active. You can run learning anytime from Inbox.",
        "cta": [{ "id": "automation:run_now", "label": "Run now" }]
      }
    }
  },
  "concurrency": {
    "key": "household:${household.id}",
    "limit": 1,
    "queuePolicy": "drop_latest"
  },
  "retry": {
    "maxAttempts": 3,
    "strategy": "exponential",
    "baseDelayMs": 30000,
    "maxDelayMs": 300000,
    "jitter": 0.2
  },
  "inputs": {
    "stores": "${prefs.stores||[]}",
    "brands": "${analytics.topBrands(60)||[]}",
    "recentSkus": "${scans.recentSkus(30)||[]}",
    "categories": "${analytics.topCategories(20)||[]}",
    "favoriteSessionId": "${favorites.lookup('cyclesLearning')||null}"
  },
  "trigger": {
    "emit": "cycles:learn:requested",
    "payloadTemplate": {
      "requestId": "${uid.rid()}",
      "sessionId": "${uid.sid()}",
      "userId": "${user.id|null}",
      "householdId": "${household.id|null}",
      "stores": "${inputs.stores}",
      "segments": {
        "brands": "${inputs.brands}",
        "recentSkus": "${inputs.recentSkus}",
        "categories": "${inputs.categories}"
      },
      "context": {
        "device": "${device.kind||'automation'}",
        "location": "${device.location||null}"
      },
      "flags": {
        "enableToasts": false,
        "deferIfGuarded": true,
        "allowPartial": true
      },
      "meta": {
        "scheduleId": "${schedule.id}",
        "favoriteSessionName": "${favorites.name(inputs.favoriteSessionId)||'Weekly Deal Cadence'}",
        "templateId": "${inputs.favoriteSessionId}"
      }
    }
  },
  "pipeline": [
    {
      "fanout": [
        { "emit": "pricebook:history:requested", "payload": { "stores": "${inputs.stores}", "brands": "${inputs.brands}", "recentSkus": "${inputs.recentSkus}" } },
        { "emit": "coupons:ledger:history:requested", "payload": { "stores": "${inputs.stores}", "brands": "${inputs.brands}" } }
      ],
      "timeoutMs": 20000
    },
    {
      "await": "cycles:learn:completed",
      "timeoutMs": 240000,
      "fanout": [
        { "emit": "cycles:predictions:requested", "payload": { "stores": "${inputs.stores}", "brands": "${inputs.brands}" } },
        { "emit": "compare:smartlists:rebuild", "payload": { "scope": "deals_watchlist", "stores": "${inputs.stores}" } }
      ]
    },
    {
      "await": "cycles:predictions:ready",
      "timeoutMs": 60000,
      "fanout": [
        { "emit": "insights:deals:updated" }
      ]
    }
  ],
  "postActions": {
    "emit": [
      { "event": "automation:run:completed", "payload": { "id": "${schedule.id}", "ts": "${now.iso}" } }
    ],
    "rememberLastRun": true,
    "persist": {
      "dexie": {
        "table": "automationRuns",
        "row": {
          "id": "${uid.rid()}",
          "scheduleId": "${schedule.id}",
          "userId": "${user.id|null}",
          "householdId": "${household.id|null}",
          "startedAt": "${now.iso}",
          "status": "completed",
          "metrics": {
            "storesCount": "${(inputs.stores||[]).length}",
            "brandsCount": "${(inputs.brands||[]).length}",
            "recentSkusCount": "${(inputs.recentSkus||[]).length}",
            "cyclesLearned": "${metrics.cycles.learned||0}",
            "predictionsCount": "${metrics.cycles.predictions||0}"
          }
        }
      }
    }
  },
  "favorites": {
    "allowUserSaveAsTemplate": true,
    "templateKind": "cyclesLearning",
    "defaultName": "Weekly Deal Cadence",
    "exposeIn": ["TemplatePicker", "Scheduler"]
  },
  "observability": {
    "logLevel": "info",
    "metrics": {
      "emit": "metrics:automation",
      "fields": [
        "latencyMs",
        "cycles.learned",
        "cycles.predictions",
        "stores.count",
        "brands.count"
      ]
    },
    "trace": true
  },
  "security": {
    "scopes": ["household:read", "pricebook:read", "coupons:read", "cycles:write", "insights:write"],
    "allowHouseholdMembers": true
  }
}
