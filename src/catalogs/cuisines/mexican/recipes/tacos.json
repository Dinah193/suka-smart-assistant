  "steps": [
    {
      "id": "step.prep_aromatics",
      "title": "Prepare aromatics",
      "activeMins": 5,
      "body": "Dice the onion finely and mince the garlic. Set aside."
    },
    {
      "id": "step.cook_filling",
      "title": "Cook the filling",
      "activeMins": 15,
      "body": "Heat a skillet over medium heat. Add ground beef and cook until browned. Add onion and garlic; sauté until softened. Stir in cumin, chili powder, salt, and pepper.",
      "timers": [
        { "label": "Brown meat", "minutes": 7 },
        { "label": "Simmer spices", "minutes": 5 }
      ],
