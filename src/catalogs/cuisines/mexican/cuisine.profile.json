  "substitutionGuidance": {
    "proteinSubstitutions": [
      {
        "for": "ingredient.pork",
        "options": ["ingredient.chicken", "ingredient.beef", "ingredient.goat"],
        "notes": "For braises/stews, goat can substitute well; adjust cook time and keep moisture higher."
      },
      {
        "for": "ingredient.beef",
        "options": ["ingredient.pork", "ingredient.goat"],
        "notes": "Use similar cuts for braise; goat can be leaner—use more stock and gentler simmer."
      },
      {
        "for": "ingredient.fish",
        "options": ["ingredient.shrimp", "ingredient.chicken"],
        "notes": "Shrimp keeps the seafood profile. Chicken changes identity; keep salsa/lime/herbs to retain Mexican flavor."
      }
    ],
    "sideSubstitutions": [
      {
        "for": "dish.mexican_rice",
        "options": ["ingredient.white_rice", "dish.cilantro_lime_rice"],
        "notes": "Any rice base works if paired with salsa and beans."
      },
      {
        "for": "dish.refried_beans",
        "options": ["dish.black_beans_simmered", "dish.pinto_beans_simmered"],
        "notes": "Simmered beans + mash partially to approximate refried texture."
      }
    ],
    "thickenerSubstitutions": [
      {
        "for": "ingredient.masa_harina",
        "options": ["ingredient.cornmeal_fine", "ingredient.tortilla_corn"],
        "notes": "Use finely ground cornmeal or crumble tortillas into simmering liquid to thicken soups (tortilla-soup style)."
      }
    ],
    "notes": [
      "When substituting chiles: match (1) fruitiness, (2) smokiness, (3) heat. E.g., guajillo \u2192 ancho (fruitier, less heat), chipotle \u2192 smoked paprika + jalape\u00f1o."
    ]
  },

