        "id": "sub.tomatillo",
        "whenMissing": ["ingredient.tomatillos"],
        "use": ["ingredient.tomatoes"],
        "ratio": 1,
        "notes": "Tomatoes are less tart. Increase lime/vinegar and consider adding a pinch of cumin for depth."
