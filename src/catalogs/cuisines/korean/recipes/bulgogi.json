      "changes": {
        "swap": [
          {
            "from": "ingredient.beef_ribeye_or_sirloin_thin_sliced",
            "to": "ingredient.tofu_extra_firm",
            "notes": "Press tofu 20 minutes; cube; pan-sear first, then glaze with marinade reduced (boil marinade before glazing)."
          }
        ]
      }
    },
    {
