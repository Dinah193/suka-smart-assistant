  "adaptations": [
    {
      "id": "adapt.protein.chicken",
      "label": "Chicken Bulgogi",
      "when": { "missing": ["ingredient.beef_ribeye_or_sirloin_thin_sliced"] },
      "changes": {
        "swap": [
          {
            "from": "ingredient.beef_ribeye_or_sirloin_thin_sliced",
