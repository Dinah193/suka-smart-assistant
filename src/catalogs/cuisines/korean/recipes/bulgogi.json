  "notes": [
    "For best flavor: marinate at least 1 hour; overnight is excellent for deeper seasoning.",
    "For best texture: sear hot and fast; do not simmer the meat.",
    "If using very lean beef, include mushrooms and onions to add moisture and sweetness."
  ],

  "steps": [
    {
      "id": "step.01_prep_beef",
      "title": "Prep the beef",
      "instructions": [
        "If the beef isn’t pre-sliced, place it in the freezer for 20–30 minutes to firm up.",
        "Slice across the grain into thin slices (about 2–3 mm).",
        "Place beef in a large bowl."
      ],
      "activeMins": 10,
      "handsOffMins": 0,
      "checks": [
        "Slices are thin and mostly uniform for quick searing.",
        "Sliced across the grain for tenderness."
      ]
    },
    {
      "id": "step.02_make_marinade",
      "title": "Make the marinade",
      "instructions": [
        "Grate (or blend) the pear until pulpy; add to a bowl.",
        "Add soy sauce, brown sugar, sesame oil, sesame seeds, garlic, ginger, sliced scallions, and black pepper.",
        "Stir well until sugar is mostly dissolved."
      ],
      "activeMins": 7,
      "handsOffMins": 0,
      "checks": ["Marinade tastes savory-sweet with clear garlic/ginger aroma."]
    },
    {
      "id": "step.03_marinate",
      "title": "Marinate the beef",
      "instructions": [
        "Pour marinade over beef and toss thoroughly to coat.",
        "Optional: fold in sliced onion, carrot, and mushrooms.",
        "Cover and refrigerate at least 1 hour (up to overnight)."
      ],
      "activeMins": 3,
      "handsOffMins": 60,
      "timers": [
        { "label": "Minimum marinade time", "minutes": 60 },
        { "label": "Optional overnight marinade", "minutes": 720 }
      ],
      "checks": ["Beef is evenly coated and refrigerated."]
    },
    {
      "id": "step.04_sear_batches",
      "title": "Sear in batches (skillet method)",
      "instructions": [
        "Heat a large skillet over medium-high until very hot.",
        "Add neutral oil, then add a single layer of beef (do not overcrowd).",
        "Sear 60–90 seconds, then toss and cook another 60–90 seconds until browned and cooked through.",
        "Transfer to a serving plate and repeat with remaining beef."
      ],
      "activeMins": 10,
      "handsOffMins": 0,
      "timers": [
        { "label": "Sear first side (per batch)", "seconds": 75 },
        { "label": "Finish sear (per batch)", "seconds": 75 }
      ],
      "temperature": {
        "type": "stovetop",
        "notes": "Medium-high heat for caramelization; adjust as needed to avoid burning sugar."
      },
      "checks": [
        "Beef is browned with caramelized edges (not steamed).",
        "Pan stays hot between batches."
      ]
    },
    {
      "id": "step.05_finish_and_garnish",
      "title": "Finish and serve",
      "instructions": [
        "Taste a piece and adjust: add a pinch of salt if needed (rare), or a tiny splash of soy if under-seasoned.",
        "Top with reserved scallion greens and extra sesame seeds.",
        "Serve with rice and banchan, or as lettuce wraps with ssamjang."
      ],
      "activeMins": 5,
      "handsOffMins": 0,
      "checks": [
        "Balanced savory-sweet flavor and fragrant sesame finish.",
        "Serving setup includes rice or wraps + condiments."
      ]
    }
  ],

