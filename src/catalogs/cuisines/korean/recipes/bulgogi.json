  "safety": {
    "notes": [
      "Marinate refrigerated. Do not leave raw marinated beef at room temperature.",
      "Cook beef to a safe internal temperature appropriate for your household preferences; thin slices cook quickly—avoid prolonged simmering (gets tough).",
      "If reusing marinade as a sauce, boil it thoroughly (at least 1 minute) before serving."
    ]
  },

