  "adaptations": [
    {
      "id": "adapt.add_bulgogi",
      "label": "Add Bulgogi",
      "when": { "available": ["cuisines.korean.recipes.bulgogi"] },
      "changes": {
        "notes": [
          "Top bowls with 1/2–3/4 cup cooked bulgogi per serving for a classic meat bibimbap."
        ]
      }
    },
    {
      "id": "adapt.vegetarian",
      "label": "Vegetarian Bibimbap",
      "when": { "diet": ["vegetarian"] },
      "changes": {
        "swap": [
          {
            "from": "ingredient.eggs",
            "to": "ingredient.tofu_extra_firm",
            "notes": "Pan-sear tofu cubes until crisp; season with soy + sesame."
          }
        ],
        "notes": ["Keep the bowl vibrant with extra mushrooms and zucchini."]
      }
    },
    {
      "id": "adapt.gluten_free",
      "label": "Gluten-free",
      "when": { "diet": ["gluten_free"] },
      "changes": {
        "notes": [
          "Use tamari instead of soy sauce and verify your gochujang is gluten-free."
        ]
      }
    },
    {
      "id": "adapt.quick_weeknight",
      "label": "Quick weeknight version",
      "when": { "constraint": ["time_short"] },
      "changes": {
        "notes": [
          "Use pre-cooked rice (reheat covered).",
          "Use 2–3 toppings instead of 5 (spinach + sprouts + mushrooms is a strong trio).",
          "Serve cucumber raw with sesame oil + salt for a fast crunch topping."
        ]
      }
    }
  ],

  "variations": [
    {
      "id": "var.dolsot",
      "label": "Dolsot Bibimbap (crispy rice)",
      "notes": [
        "Heat a stone bowl, brush with sesame oil, add rice, then let it crisp 3–5 minutes before topping.",
        "Use caution: the bowl stays dangerously hot."
      ]
    },
    {
      "id": "var.extra_spicy",
      "label": "Extra spicy",
      "notes": [
        "Add gochugaru (Korean chili flakes) to sauce or top with sliced fresh chilies."
      ]
    }
  ],

  "notes": [
    "Bibimbap is best when toppings are seasoned separately—each one should taste good on its own.",
    "Make-ahead: cook rice and prep toppings; assemble fresh to keep textures bright."
  ],

  "steps": [
    {
      "id": "step.01_cook_rice",
      "title": "Cook the rice",
      "instructions": [
        "Rinse rice until the water runs mostly clear.",
        "Cook in a rice cooker or pot with the measured water until tender.",
        "Keep warm while you prepare toppings."
      ],
      "activeMins": 5,
      "handsOffMins": 15,
      "timers": [
        { "label": "Rice cook time (typical)", "minutes": 15 },
        { "label": "Rice rest time (optional)", "minutes": 10 }
      ],
      "checks": ["Rice is tender and fluffy; not mushy."]
    },
    {
      "id": "step.02_make_sauce",
      "title": "Make bibimbap sauce",
      "instructions": [
        "In a small bowl, mix gochujang, soy sauce, sesame oil, honey (or sugar), and 1/3 of the garlic.",
        "Optional: add rice vinegar for brightness.",
        "Stir in sesame seeds. Taste and adjust: more honey for sweetness, more gochujang for heat."
      ],
      "activeMins": 5,
      "handsOffMins": 0,
      "checks": ["Sauce is balanced spicy-sweet-salty; spoonable consistency."]
    },
    {
      "id": "step.03_spinach_namul",
      "title": "Prepare spinach namul",
      "instructions": [
        "Bring a pot of lightly salted water to a boil.",
        "Blanch spinach 30–45 seconds until bright green, then rinse under cold water.",
        "Squeeze out excess water and cut into bite-size lengths.",
        "Season with a pinch of salt, a drizzle of sesame oil, a little soy sauce (optional), and a pinch of garlic."
      ],
      "activeMins": 8,
      "handsOffMins": 0,
      "timers": [{ "label": "Blanch spinach", "seconds": 40 }],
      "checks": ["Spinach is bright green and not watery after squeezing."]
    },
    {
      "id": "step.04_sprout_namul",
      "title": "Prepare bean sprout namul",
      "instructions": [
        "Blanch sprouts 2–3 minutes until just tender but still crisp, then drain well.",
        "Season with a pinch of salt, sesame oil, sesame seeds, and a little garlic.",
        "Taste and adjust seasoning."
      ],
      "activeMins": 7,
      "handsOffMins": 0,
      "timers": [{ "label": "Blanch sprouts", "minutes": 2.5 }],
      "checks": ["Sprouts are tender-crisp and not soggy."]
    },
    {
      "id": "step.05_saute_veg",
      "title": "Sauté remaining vegetables",
      "instructions": [
        "Heat a skillet over medium-high with a small amount of neutral oil.",
        "Sauté carrots 2–3 minutes with a pinch of salt; remove to a plate.",
        "Sauté zucchini 2–3 minutes with a pinch of salt; remove to a plate.",
        "Sauté mushrooms 4–6 minutes until browned; season lightly with soy (optional) and sesame oil at the end."
      ],
      "activeMins": 12,
      "handsOffMins": 0,
      "timers": [
        { "label": "Sauté carrots", "minutes": 2.5 },
        { "label": "Sauté zucchini", "minutes": 2.5 },
        { "label": "Sauté mushrooms", "minutes": 5 }
      ],
      "checks": [
        "Carrots are tender-crisp.",
        "Mushrooms are browned (not pale/steamed)."
      ]
    },
    {
      "id": "step.06_fry_eggs",
      "title": "Fry eggs",
      "instructions": [
        "In the same skillet, add a little more oil if needed.",
        "Fry eggs sunny-side up or over-easy (your preference).",
        "Season lightly with salt."
      ],
      "activeMins": 6,
      "handsOffMins": 0,
      "timers": [
        { "label": "Sunny-side cook time", "minutes": 2.5 },
        { "label": "Over-easy flip time", "seconds": 20 }
      ],
      "checks": ["Egg whites are set; yolk doneness matches preference."]
    },
    {
      "id": "step.07_assemble",
      "title": "Assemble bowls and mix",
      "instructions": [
        "Divide warm rice among 4 bowls.",
        "Arrange toppings in sections: spinach, sprouts, carrots, zucchini, mushrooms, and optional cucumber.",
        "Top each bowl with a fried egg.",
        "Add 1–2 tbsp bibimbap sauce per bowl, plus sesame seeds and optional shredded gim.",
        "Mix thoroughly before eating."
      ],
      "activeMins": 7,
      "handsOffMins": 0,
      "checks": [
        "Bowl includes a balance of colors/textures.",
        "Sauce amount is adjusted per eater."
      ]
    }
