    "equipmentAliases": {
      "tool.dutch_oven": ["dutch oven", "heavy pot", "cocotte"],
      "tool.heavy_pot": ["heavy pot", "stockpot", "stew pot"],
      "tool.cast_iron_skillet": ["cast iron skillet", "cast iron pan"],
      "tool.skillet": ["skillet", "frying pan", "saute pan"],
      "tool.whisk": ["whisk"],
      "tool.immersion_blender": ["immersion blender", "stick blender"],
      "tool.blender": ["blender"],
