  "updatedAt": "2026-01-19T00:00:00.000Z",
  "kind": "cuisine_ruleset",
  "meta": {
    "id": "cuisines.ethiopian.ruleset",
    "type": "cuisine_ruleset",
    "label": "Ethiopian • Cuisine Ruleset",
    "cuisineId": "cuisines.ethiopian",
    "status": "canonical",
    "source": {
      "kind": "catalog",
      "name": "SSA Catalog",
      "notes": [
        "Deterministic adaptation rules for Ethiopian flavor + dish identity.",
        "Use with RecipeAdapterService / planner scoring."
      ]
    }
  },
  "scope": {
