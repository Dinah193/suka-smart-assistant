  "substitutionGuidance": [
    {
      "id": "sub_scotch_bonnet",
      "whenMissing": ["pepper_hot_scotch_bonnet"],
      "useInstead": ["pepper_hot_habanero", "pepper_red_flakes"],
      "notes": "Habanero is the closest heat/fruity profile; adjust quantity carefully."
    },
    {
      "id": "sub_red_palm_oil",
      "whenMissing": ["oil_palm_red"],
      "useInstead": ["oil_neutral", "oil_olive_optional"],
      "notes": "Red palm oil adds color and distinctive flavor; neutral oil keeps profile lighter."
    },
    {
      "id": "sub_iru_dawadawa",
      "whenMissing": ["fermented_locust_beans_iru"],
      "useInstead": [
        "seasoning_stock_cube_optional",
        "fish_dried_smoked_optional"
      ],
      "notes": "Use sparingly; keep umami balanced."
    },
    {
      "id": "sub_smoked_fish",
      "whenMissing": ["fish_dried_smoked"],
      "useInstead": [
        "stock_chicken_or_beef_optional",
        "seasoning_msg_optional"
      ],
      "notes": "Smoked fish adds deep savory smoke; compensate with stock and careful seasoning."
    }
  ],
  "mealTemplates": [
    {
      "id": "template_weeknight_jollof_style",
      "label": "Weeknight Tomato Pepper Rice + Protein + Quick Veg",
      "archetypeId": "archetype_rice_pot",
      "components": [
        { "role": "starch", "ingredientIds": ["rice_white_longgrain"] },
        {
          "role": "base",
          "ingredientIds": [
            "tomato",
            "tomato_paste",
            "onion_yellow",
            "pepper_bell",
            "garlic",
            "ginger"
          ]
        },
        {
          "role": "protein",
          "ingredientIds": ["chicken_generic", "beef_generic", "fish_generic"],
          "chooseOne": true
        },
        {
          "role": "veg",
          "ingredientIds": [
            "leafy_greens_spinach",
            "okra",
            "cabbage_green_optional"
          ],
          "chooseOne": true
        }
      ],
      "prepNotes": [
        "Blend or finely chop base; cook down until aromatic before adding rice/stock."
      ]
    },
    {
      "id": "template_groundnut_soup",
      "label": "Groundnut Soup + Rice/Yam",
      "archetypeId": "archetype_stew_with_starch",
      "components": [
        {
          "role": "stew_base",
          "ingredientIds": [
            "onion_yellow",
            "garlic",
            "ginger",
            "tomato_optional",
            "pepper_hot_scotch_bonnet_optional"
          ]
        },
        {
          "role": "thickener",
          "ingredientIds": ["peanut"],
          "notes": "Use peanut butter or ground peanuts if available."
        },
        {
          "role": "protein",
          "ingredientIds": ["chicken_generic", "goat", "beef_generic"],
          "chooseOne": true
        },
        {
          "role": "starch",
          "ingredientIds": ["rice_white_longgrain", "yam", "plantain"],
          "chooseOne": true
        }
      ],
      "prepNotes": [
        "Simmer gently to prevent splitting; adjust with stock/water for desired thickness."
      ]
    }
  ],
  "safetyNotes": [
