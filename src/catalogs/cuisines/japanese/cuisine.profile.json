  "substitutionGuidance": {
    "proteinSubstitutions": [
      {
        "for": "ingredient.salmon",
        "options": [
          "ingredient.trout",
          "ingredient.mackerel",
          "ingredient.sardines"
        ],
        "notes": "Use oily fish for grilling; adjust salt and cooking time by thickness."
      },
      {
        "for": "ingredient.chicken_thigh",
        "options": ["ingredient.chicken_breast", "ingredient.tofu_firm"],
        "notes": "Breast dries faster—use lower heat or sauce; tofu works well for donburi and soups."
      },
      {
        "for": "ingredient.pork_cutlet",
        "options": ["ingredient.chicken_cutlet", "ingredient.tofu_firm"],
        "notes": "For katsu: match thickness and breading method; tofu katsu benefits from pressing + chilling."
      }
    ],
    "sideSubstitutions": [
      {
        "for": "dish.quick_pickles",
        "options": [
          "dish.cucumber_sunomono",
          "dish.daikon_pickles",
          "dish.cabbage_asazuke"
        ],
        "notes": "Any quick pickle adds brightness and crunch."
      },
      {
        "for": "dish.edamame",
        "options": ["dish.blistered_shishito", "dish.cucumber_sunomono"],
        "notes": "Swap based on availability and season."
      }
    ],
    "thickenerSubstitutions": [
      {
        "for": "ingredient.potato_starch",
        "options": ["ingredient.cornstarch", "ingredient.tapioca_starch"],
        "notes": "Potato starch yields a clearer, glossier sauce; cornstarch is fine at similar ratios."
      }
    ],
    "notes": [
      "If kombu + katsuobushi aren’t available, use dried shiitake + a small amount of fish sauce for umami.",
      "If mirin isn’t available, combine a small amount of sugar/honey with rice vinegar and a splash of sake or water.",
      "Ponzu can be approximated with soy sauce + citrus (lemon/lime) + a touch of rice vinegar."
    ]
  },

