  "substitutions": {
    "rules": [
      {
        "id": "sub_olive_oil_primary_fat",
        "type": "ingredient_substitution",
        "from": ["butter", "neutral_oil"],
        "to": ["olive_oil"],
        "notes": "Default to olive oil as the primary cooking fat where flavor profile allows."
      },
      {
        "id": "sub_lemon_or_vinegar_acid",
        "type": "ingredient_substitution",
        "from": ["white_vinegar", "lime"],
        "to": ["lemon", "red_wine_vinegar"],
        "notes": "Prefer lemon or red wine vinegar for Mediterranean-style acidity."
      },
      {
        "id": "sub_herb_swap",
        "type": "ingredient_substitution",
        "from": ["cilantro"],
        "to": ["parsley", "mint"],
        "notes": "Parsley/mint/dill are common; cilantro can be used but reads more non-Mediterranean in many dishes."
      },
      {
        "id": "sub_legume_base",
        "type": "ingredient_substitution",
        "from": ["black_beans", "kidney_beans"],
        "to": ["chickpeas", "white_beans", "lentils"],
        "notes": "Chickpeas/white beans/lentils are typical Mediterranean pantry legumes."
      }
    ]
