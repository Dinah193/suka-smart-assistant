  "safetyNotes": [
    {
      "id": "safety.cream_sauces",
      "label": "Cream sauce handling",
      "notes": [
        "Avoid boiling cream-heavy sauces hard; keep at a gentle simmer to prevent splitting.",
        "Cool quickly and refrigerate within 2 hours; reheat gently with a splash of stock/milk if thickened."
      ]
    },
    {
      "id": "safety.braises",
      "label": "Braise cooling and reheating",
      "notes": [
        "Braises are ideal make-ahead but must be cooled quickly in shallow containers.",
        "Reheat to steaming hot; keep above safe temps if holding for service."
      ]
    }
  ],

