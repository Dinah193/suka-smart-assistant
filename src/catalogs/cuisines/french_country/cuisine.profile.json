      {
        "id": "seasoning.cumin",
        "label": "Cumin (limit)",
        "reason": "Not typical for classic French country profiles; can overpower pan sauces and herb-forward dishes."
      },
      {
        "id": "seasoning.soy_sauce",
        "label": "Soy sauce (limit)",
        "reason": "Use only as a last-resort umami builder; prefer stock reduction, mushrooms, tomato paste, or anchovy."
      },
      {
        "id": "heat.hot_chili",
        "label": "Hot chili heat (limit)",
        "reason": "French country is generally low-heat; keep heat subtle unless explicitly requested."
      }
    ]
