  "substitutionGuidance": {
    "proteinSubstitutions": [
      {
        "for": "protein.chicken",
        "options": [
          "protein.turkey",
          "protein.rabbit_optional",
          "protein.pork"
        ],
        "notes": "Chicken patterns often translate to turkey or pork tenderloin; adjust cook time for lean cuts."
      },
      {
        "for": "protein.beef",
        "options": ["protein.lamb", "protein.pork_shoulder"],
        "notes": "Braise substitutions should match collagen content; choose chuck/shoulder-like cuts."
      },
      {
        "for": "protein.fish_white",
        "options": ["protein.salmon", "protein.shrimp"],
        "notes": "Switch to quick methods; shorten cook time; keep sauce lighter (lemon/butter, white wine)."
      }
    ],
    "sideSubstitutions": [
      {
        "for": "starch.potato",
        "options": ["starch.rice", "starch.egg_noodles", "starch.bread_crusty"],
        "notes": "Potatoes are classic; rice/noodles work especially with saucy braises."
      },
      {
        "for": "starch.bread_crusty",
        "options": ["starch.potato", "starch.rice"],
        "notes": "Use a starch that can catch sauce. If avoiding bread, pick potatoes or rice."
      }
    ],
    "thickenerSubstitutions": [
      {
        "for": "thickener.flour",
        "options": ["thickener.cornstarch", "thickener.butter_manie"],
        "notes": "For pan sauces, butter manié is closest. Cornstarch yields a glossier, less rustic finish."
      }
    ],
    "notes": [
      "Prefer substitutions that preserve sauce behavior: stock + reduction + butter finish.",
      "If no wine: use stock + splash of wine vinegar/lemon to mimic acidity; reduce gently."
    ]
  },

