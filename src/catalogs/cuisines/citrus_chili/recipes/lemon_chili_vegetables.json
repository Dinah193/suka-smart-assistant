  "steps": [
    {
      "id": "step_01",
      "title": "Preheat and prep the pan",
      "instructions": [
        "Heat oven to 425°F / 218°C.",
        "Line a sheet pan with parchment (optional) for easier cleanup.",
        "For best browning: preheat the empty sheet pan for 5 minutes while you finish chopping."
      ],
      "activeMins": 4,
      "timers": [{ "label": "Preheat empty pan (optional)", "minutes": 5 }]
    },
    {
      "id": "step_02",
      "title": "Cut vegetables for even roasting",
      "instructions": [
        "Cut broccoli and cauliflower into medium florets (avoid tiny pieces that burn).",
        "Slice peppers, wedge onion, and cut zucchini into thick half-moons.",
        "If using cherry tomatoes, keep them whole and set aside for later."
      ],
      "activeMins": 12,
      "checks": [
        "Vegetables are similar in thickness so they finish together",
        "Zucchini pieces are thick enough to resist getting mushy"
      ]
    },
    {
      "id": "step_03",
      "title": "Season vegetables",
      "instructions": [
        "In a large bowl, toss broccoli, cauliflower, peppers, onion, and zucchini with olive oil, salt, black pepper, garlic, chili flakes (or chili powder), and smoked paprika (optional).",
        "Spread evenly on the hot sheet pan in a single layer—avoid crowding."
      ],
      "activeMins": 4,
      "checks": [
        "Vegetables are evenly coated with oil and seasoning",
        "Pan is not overcrowded (use a second pan if needed)"
      ]
    },
    {
      "id": "step_04",
      "title": "Roast until browned and tender-crisp",
      "instructions": [
        "Roast 18–22 minutes, stirring once halfway, until broccoli/cauliflower have browned edges and peppers are softened.",
        "If using cherry tomatoes: add them for the final 8–10 minutes so they blister without collapsing."
      ],
      "handsOffMins": 22,
      "timers": [
        { "label": "Roast (first phase)", "minutes": 12 },
        { "label": "Roast (second phase)", "minutes": 10 }
      ],
      "checks": [
        "Edges are browned (not burned)",
        "Vegetables are tender but still have some bite"
      ]
    },
    {
      "id": "step_05",
      "title": "Finish with lemon-chili brightness",
      "instructions": [
        "While vegetables roast (or right after), whisk lemon juice with lemon zest. Add honey (optional) if you want a slightly rounder flavor.",
        "When vegetables come out, drizzle the lemon mixture over the hot pan and toss to coat.",
        "Taste and adjust: add a pinch of salt, extra chili flakes, or extra lemon juice as needed.",
        "Finish with fresh herbs (optional)."
      ],
      "activeMins": 6,
      "checks": [
        "Lemon flavor is bright but not harsh (use honey if needed)",
        "Heat level matches your household (add or reduce chili)"
      ]
    }
  ],
