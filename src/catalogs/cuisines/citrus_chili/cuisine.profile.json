  "substitutionGuidance": {
    "proteinSubstitutions": [
      {
        "for": "protein.fish_white",
        "options": ["protein.shrimp", "protein.chicken"],
        "notes": "When fish is unavailable, shrimp keeps the bright profile; chicken works for sheet-pan and grill patterns."
      },
      {
        "for": "protein.goat",
        "options": ["protein.lamb", "protein.beef"],
        "notes": "Goat is less common in citrus-chili overlays, but when used, treat like lamb/beef and finish with citrus-chili sauce."
      }
    ],
    "sideSubstitutions": [
      {
        "for": "starch.plantain",
        "options": ["starch.rice", "starch.potato"],
        "notes": "Plantain is a natural sweet-balance starch; rice/potato are neutral and take sauce well."
      }
    ],
    "thickenerSubstitutions": [
      {
        "for": "thickener.cornstarch",
        "options": ["thickener.arrowroot", "thickener.flour"],
        "notes": "Use arrowroot for glossy sauces; flour for roux-like thickening."
      }
    ],
    "notes": [
      "If fresh chiles aren’t available, use dried flakes + a little paprika + extra citrus zest.",
      "If lime is missing, lemon works; add a touch of orange zest to restore brightness."
    ]
  },

