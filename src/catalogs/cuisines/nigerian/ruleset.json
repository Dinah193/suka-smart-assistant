  "globals": {
    "heatScale": {
      "min": 0,
      "max": 5,
      "notes": [
        "0 = no heat, 1 = mild, 2 = medium, 3 = hot, 4 = very hot, 5 = extreme"
      ]
    },
    "typicalAromatics": [
      "ingredient.onion",
      "ingredient.ginger",
      "ingredient.garlic"
    ],
    "typicalFats": ["ingredient.palm_oil", "ingredient.oil"],
    "typicalUmami": ["ingredient.iru", "ingredient.maggi", "ingredient.knorr"],
    "plannerDefaults": {
      "preferOnePot": true,
      "preferSwallowPairingForSoups": true
    }
