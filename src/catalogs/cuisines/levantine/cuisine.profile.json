  "safetyNotes": [
    {
      "id": "safety.sesame_allergen",
      "label": "Sesame (tahini) allergen awareness",
      "notes": [
        "Tahini (sesame) is common in sauces and dips; flag for sesame allergy.",
        "Offer yogurt-lemon sauce or garlic-lemon oil dressing as alternatives."
      ]
    },
    {
      "id": "safety.garlic_emulsion",
      "label": "Garlic emulsion handling (toum)",
      "notes": [
        "Use clean utensils; store toum refrigerated and discard if off odor develops.",
        "If using raw egg whites in any emulsion variant, follow safe egg handling or use pasteurized egg."
      ]
    }
  ],

