  "substitutionGuidance": {
    "proteinSubstitutions": [
      {
        "for": "protein.lamb",
        "options": ["protein.beef", "protein.goat"],
        "notes": "For kofta/kebab patterns, beef or goat work well; keep fat moderate for juiciness."
      },
      {
        "for": "protein.chicken_thigh",
        "options": ["protein.chicken_breast", "protein.turkey_thigh"],
        "notes": "Thigh is preferred for grill juiciness; if using breast, shorten cook time and increase marinade oil/yogurt slightly."
      }
    ],
    "sideSubstitutions": [
      {
        "for": "bread.pita",
        "options": ["bread.flatbread", "grain.rice", "grain.bulgur"],
        "notes": "Use rice/bulgur when bread isn’t available; keep a dip/sauce element for balance."
      },
      {
        "for": "condiment.tahini",
        "options": ["nut.sesame_paste", "nut.cashew_butter"],
        "notes": "Cashew butter can mimic tahini creaminess in a pinch; adjust with lemon and water to thin."
      }
    ],
    "thickenerSubstitutions": [
      {
        "for": "thickener.tahini",
        "options": ["thickener.yogurt", "thickener.blended_chickpeas"],
        "notes": "For sauces, yogurt or blended chickpeas can add body; preserve lemon/garlic profile."
      }
    ],
    "notes": [
      "When substituting, preserve the Levantine balance: acid (lemon/sumac) + herb freshness + olive oil richness.",
      "If herbs are limited, lean on lemon zest and dried mint to keep the signature aromatic lift."
    ]
  },

