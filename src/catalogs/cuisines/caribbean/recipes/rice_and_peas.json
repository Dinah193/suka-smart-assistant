  "steps": [
    {
      "id": "rinse_rice",
      "title": "Rinse the rice",
      "domain": "cooking",
      "activeMins": 3,
      "instructions": [
        "Rinse rice under cold water until the water runs mostly clear."
      ],
      "inputs": {
        "ingredients": ["long_grain_rice"],
        "equipment": ["fine_mesh_strainer"]
      }
    },
    {
      "id": "build_pot",
      "title": "Build the pot",
      "domain": "cooking",
      "activeMins": 5,
      "instructions": [
        "Add rice, beans, coconut milk, water, scallion, thyme, allspice, salt, and Scotch bonnet to the pot.",
        "Stir gently once to distribute."
      ],
      "inputs": {
        "ingredients": [
          "long_grain_rice",
          "dried_red_kidney_beans",
          "coconut_milk",
          "water",
          "scallion",
          "thyme",
          "allspice",
          "salt",
          "scotch_bonnet"
        ],
        "equipment": ["pot_with_lid"]
      }
    },
    {
      "id": "cook",
      "title": "Cook the rice",
      "domain": "cooking",
      "handsOffMins": 35,
      "instructions": [
        "Bring to a gentle boil uncovered.",
        "Cover, reduce heat to low, and simmer 30–35 minutes until liquid is absorbed.",
        "Remove from heat and rest 5 minutes."
      ],
      "timers": [{ "label": "Simmer", "mins": 35 }],
      "inputs": {
        "equipment": ["pot_with_lid", "stovetop"]
      }
    },
    {
      "id": "finish",
      "title": "Fluff and serve",
      "domain": "cooking",
      "activeMins": 2,
      "instructions": [
        "Remove scallion, thyme stems, allspice, and Scotch bonnet.",
        "Fluff rice gently with a fork and serve."
      ]
    }
  ],

