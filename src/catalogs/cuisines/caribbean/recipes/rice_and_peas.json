      "label": "Fresh thyme",
      "amount": { "value": 4, "unit": "sprig" },
      "role": "herb"
    },
    {
      "id": "scotch_bonnet",
      "label": "Scotch bonnet (whole)",
      "amount": { "value": 1, "unit": "each" },
