  "substitutions": {
    "ingredientRules": [
      {
        "id": "scotch_bonnet_swap",
        "whenMissing": ["scotch_bonnet"],
        "use": ["habanero"],
        "ratio": 1.0,
        "notes": "Start with less for lower heat; adjust with pepper sauce."
      },
      {
        "id": "chadon_beni_swap",
        "whenMissing": ["chadon_beni"],
        "use": ["culantro", "cilantro"],
        "ratio": 0.75,
        "notes": "Culantro is potent; cilantro is milder; adjust to taste."
      },
      {
        "id": "sour_orange_swap",
        "whenMissing": ["sour_orange"],
        "use": ["orange_juice", "lime_juice"],
        "ratio": 1.0,
        "notes": "Combine to approximate the sour-bitter citrus profile."
      },
      {
        "id": "saltfish_low_sodium",
        "whenHealthFlag": ["low_sodium"],
        "replace": ["saltfish"],
        "with": ["fresh_white_fish", "smoked_fish_small_amount"],
        "notes": "Preserve the seafood note without full sodium load; ensure bouillon is also low-sodium."
      }
    ],
    "methodRules": [
      {
        "id": "jerk_without_grill",
        "whenNoEquipment": ["grill", "smoker"],
        "adapt": "oven_roast_then_broil",
        "notes": "Boost flavor with allspice, thyme, smoke element (smoked paprika or a small amount of smoke seasoning)."
      },
      {
        "id": "braise_with_pressure",
        "whenHasEquipment": ["pressure_cooker"],
        "adapt": "pressure_cook_then_reduce",
        "notes": "Use pressure to tenderize; finish by reducing sauce for body."
      }
    ]
  },
