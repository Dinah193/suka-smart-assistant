  "steps": [
    {
      "id": "step.slice_prep",
      "title": "Slice and prep components",
      "activeMins": 12,
      "instructions": [
        "If using beef: chill briefly (20–30 minutes in freezer) for easier thin slicing, then slice across the grain.",
        "Grate onion (collect juices). Mince garlic.",
        "Shred cabbages; dice tomatoes (and optional cucumber); thin-slice red onion.",
        "Set up a build station: meat, sauce, salad, and breads."
      ],
      "checks": ["Meat sliced thin", "Veg prepped", "Build station ready"]
    },
    {
      "id": "step.marinade",
      "title": "Marinate the meat",
      "activeMins": 8,
      "handsOffMins": 15,
      "instructions": [
        "In a bowl, combine grated onion (with juices), minced garlic, yogurt, lemon juice, olive oil, paprika, cumin, coriander, black pepper, salt, and optional oregano/cayenne.",
        "Add sliced beef (or chicken). Toss thoroughly to coat.",
        "Marinate at least 15 minutes (or up to overnight in the fridge)."
      ],
      "timers": [{ "label": "Minimum marinade", "minutes": 15 }],
      "checks": ["Meat evenly coated", "Marinating started"]
    },
    {
      "id": "step.make_sauce",
      "title": "Make creamy garlic sauce",
      "activeMins": 6,
      "instructions": [
        "In a bowl, whisk Greek yogurt with optional mayo until smooth.",
        "Add microplaned garlic, lemon juice, salt, black pepper, and optional dill/parsley.",
        "Taste: it should be boldly garlicky and tangy. Chill until serving."
      ],
      "checks": ["Sauce balanced", "Sauce chilled (optional)"]
    },
    {
      "id": "step.quick_salad",
      "title": "Quick-toss cabbage salad",
      "activeMins": 6,
      "instructions": [
        "In a large bowl, toss shredded cabbage (green and optional red) with vinegar, salt, black pepper, and optional sugar.",
        "Massage briefly (30–45 seconds) to soften slightly while keeping crunch.",
        "Fold in diced tomatoes and sliced red onion (and optional cucumber/pickles) just before serving for best texture."
      ],
      "checks": ["Cabbage lightly softened", "Crunch retained"]
    },
    {
      "id": "step.cook_meat",
      "title": "Cook meat hot for browning",
      "activeMins": 12,
      "instructions": [
        "Heat a large skillet over medium-high until very hot.",
        "Cook meat in batches in a single layer (do not overcrowd) so it sears and browns.",
        "Let it sit 1–2 minutes before stirring, then flip/toss until cooked through and browned at edges.",
        "Transfer cooked batches to a plate; keep warm while finishing remaining meat."
      ],
      "timers": [
        { "label": "Batch sear (first side)", "minutes": 2 },
        { "label": "Finish batch", "minutes": 3 }
      ],
      "checks": ["Browned edges", "Cooked through (165°F chicken)"],
      "temperature": {
        "type": "internal_optional",
        "value": 165,
        "unit": "F",
        "notes": "Use thermometer for chicken; for beef, cook to desired doneness (thin slices cook quickly)."
      }
    },
    {
      "id": "step.warm_bread",
      "title": "Warm the bread",
      "activeMins": 5,
      "instructions": [
        "Warm pita/flatbread in a dry skillet, oven, or microwave briefly until pliable.",
        "Optional: brush with butter and toast lightly for extra flavor."
      ],
      "checks": ["Bread warm and pliable"]
    },
    {
      "id": "step.assemble",
      "title": "Assemble döner kebabs",
      "activeMins": 8,
      "instructions": [
        "Spread garlic sauce on warm bread.",
        "Pile on hot meat, then add cabbage salad and tomatoes/onions (plus optional cucumber/pickles).",
        "Add optional spicy sauce or hot sauce.",
        "Fold/roll tightly; serve immediately."
      ],
      "checks": ["Balanced meat/salad/sauce", "Wrap holds together"]
    }
  ],
