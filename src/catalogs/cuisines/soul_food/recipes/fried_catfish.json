  "steps": [
    {
      "id": "step_01_prep_fish",
      "title": "Prep catfish",
      "body": "Pat catfish fillets dry. If very large, cut into serving-sized pieces."
    },
    {
      "id": "step_02_soak",
      "title": "Buttermilk soak",
      "body": "In a bowl, mix buttermilk, hot sauce, lemon juice (optional), salt, and pepper. Add catfish and turn to coat. Let soak 15–30 minutes (refrigerate if holding longer)."
    },
    {
      "id": "step_03_mix_dredge",
      "title": "Mix cornmeal dredge",
      "body": "In a wide bowl, combine cornmeal, flour, paprika, garlic powder, onion powder, cayenne (optional), salt, and pepper. Mix well."
    },
    {
      "id": "step_04_heat_oil",
      "title": "Heat oil",
      "body": "Add oil to a skillet to reach about 1/2 inch depth. Heat to 350°F, using a thermometer to monitor."
    },
    {
      "id": "step_05_dredge",
      "title": "Dredge the fish",
      "body": "Lift catfish from soak and let excess drip off. Press into cornmeal mixture on both sides until well coated."
    },
    {
      "id": "step_06_fry",
      "title": "Fry in batches",
      "body": "Carefully place catfish in hot oil without overcrowding. Fry 3–5 minutes per side, until deep golden and crisp. Maintain oil around 340–360°F."
    },
    {
      "id": "step_07_drain",
      "title": "Drain on rack",
      "body": "Transfer fried fish to a wire rack over a sheet pan (not paper towels) to stay crisp. Repeat with remaining batches."
    },
    {
      "id": "step_08_serve",
      "title": "Serve",
      "body": "Serve hot with lemon wedges, hot sauce, and classic sides (cornbread, coleslaw, fries, or greens)."
    }
  ]
}
