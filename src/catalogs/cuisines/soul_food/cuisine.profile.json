  "dietaryAdaptation": {
    "commonConstraints": [
      "low_sodium",
      "gluten_free",
      "dairy_free",
      "pork_free",
      "vegetarian",
      "plant_forward"
    ],
    "adaptationRules": [
      {
        "id": "pork_free_greens",
        "label": "Pork-free greens",
        "when": { "excludeIngredientsAny": ["pork", "bacon", "ham_hock"] },
        "do": {
          "useInstead": [
            "smoked_turkey",
            "smoked_chicken",
            "mushroom_umami",
            "smoked_paprika"
          ],
          "notes": "Replace ham hock/bacon with smoked turkey leg/wing; add smoked paprika for depth."
        }
      },
      {
        "id": "low_sodium_base",
        "label": "Low-sodium baseline",
        "when": { "dietAny": ["low_sodium"] },
        "do": {
          "reduce": ["seasoned_salt", "bouillon", "soy_sauce_optional"],
          "increase": ["acid_finish", "herbs", "aromatics"],
          "notes": "Use unsalted stock; finish with vinegar/lemon/hot sauce for perceived saltiness."
        }
      },
      {
        "id": "gluten_free_frying",
        "label": "Gluten-free frying dredge",
        "when": { "dietAny": ["gluten_free"] },
        "do": {
          "swap": [
            { "from": "all_purpose_flour", "to": "rice_flour_or_gf_blend" },
            { "from": "regular_breading", "to": "cornmeal_or_gf_crumbs" }
          ],
          "notes": "Cornmeal works well for fish; rice flour yields crisp chicken skin."
        }
      },
      {
        "id": "dairy_free_sides",
        "label": "Dairy-free sides",
        "when": { "dietAny": ["dairy_free"] },
        "do": {
          "swap": [
            { "from": "butter", "to": "neutral_oil_or_plant_butter" },
            { "from": "milk", "to": "oat_milk_or_almond_milk" }
          ],
          "notes": "Use plant fats in cornbread and mashed sides; check margarine labels."
        }
      },
      {
        "id": "plant_forward_plate",
        "label": "Plant-forward soul plate",
        "when": { "dietAny": ["vegetarian", "plant_forward"] },
        "do": {
          "prioritizeDishes": [
            "beans_and_rice",
            "greens_without_meat",
            "cabbage_sides",
            "sweet_potato",
            "cornbread",
            "okra_tomato_stew_optional"
          ],
          "notes": "Use mushrooms + smoked paprika + onion/garlic for 'meaty' depth; serve with cornbread."
        }
      }
    ]
  },

