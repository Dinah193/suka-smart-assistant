  "qualityAndSafety": {
    "donenessTargets": [
      {
        "item": "chicken_dark_meat",
        "target": { "f": 175, "c": 79 },
        "notes": "Dark meat is forgiving; higher temp yields tender bite and safer reheats."
      },
      {
        "item": "chicken_breast",
        "target": { "f": 165, "c": 74 },
        "notes": "Avoid overcooking; rest before slicing."
      },
      {
        "item": "fried_fish",
        "target": { "f": 145, "c": 63 },
        "notes": "Cook until opaque and flakes; avoid long holds."
      },
      {
        "item": "braised_oxtails",
        "target": { "f": 195, "c": 91 },
        "notes": "Tenderness comes from collagen breakdown; cook until fork-tender."
      }
    ],
