    "plateModel": {
      "default": {
        "proteinShareTarget": 0.45,
        "starchShareTarget": 0.35,
        "vegShareMin": 0.2,
        "notes": [
          "BBQ plates are protein-forward with classic starchy + crunchy/acidic sides.",
          "Sauce is optional and style-dependent; rub + smoke + bark are the signature."
        ]
      }
    }
