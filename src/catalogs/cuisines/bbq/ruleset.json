  "rules": [
    {
      "id": "bbq.base.tag_cuisine_bbq",
      "enabled": true,
      "priority": 900,
      "title": "Tag cuisine as BBQ",
      "description": "Adds BBQ cuisine tag for downstream scoring and filtering.",
      "tags": ["bbq", "cuisine"],
      "source": "catalog",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          {
            "type": "eq",
            "path": "$.context.cuisineId",
            "value": "cuisines.bbq"
          },
          { "type": "hasTag", "value": "cuisine.bbq" },
          {
            "type": "matches",
            "path": "$.recipe.title",
            "regex": "(?i)bbq|barbecue|barbeque|smoked|brisket|pulled pork|ribs"
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "addTag", "value": "cuisine.bbq" },
          { "type": "addTag", "value": "flavor.smoke" },
          { "type": "addTag", "value": "method.low_and_slow" }
        ]
      }
    },
    {
      "id": "bbq.search.bias.smoke_rub_sauce_patterns",
      "enabled": true,
      "priority": 820,
      "title": "Prefer smoke/rub/sauce BBQ patterns",
      "description": "Adjusts scoring toward recipes featuring classic rub ingredients, smoke cues, and BBQ sauce/vinegar sauce patterns.",
      "tags": ["bbq", "ranking"],
      "source": "catalog",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          {
            "type": "intersects",
            "path": "$.recipe.ingredientsCanonical",
            "values": [
              "ingredients.smoked_paprika",
              "ingredients.paprika",
              "ingredients.brown_sugar",
              "ingredients.garlic_powder",
              "ingredients.onion_powder"
            ]
          },
          {
            "type": "intersects",
            "path": "$.recipe.ingredientsCanonical",
            "values": [
              "ingredients.apple_cider_vinegar",
              "ingredients.ketchup",
              "ingredients.molasses",
              "ingredients.worcestershire",
              "ingredients.mustard_powder"
            ]
          },
          {
            "type": "matches",
            "path": "$.recipe.title",
            "regex": "(?i)smok|brisket|pulled|rib|burnt end|bbq|barbecue|barbeque|rub|dry rub|sauce"
          },
          {
            "type": "intersects",
            "path": "$.recipe.methods",
            "values": [
              "methods.smoke",
              "methods.slow_cook",
              "methods.wrap",
              "methods.rest",
              "methods.grill"
            ]
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": 9 },
          { "type": "addTag", "value": "bbq.core" }
        ]
      }
    },
    {
      "id": "bbq.plan.default_plate_shares",
      "enabled": true,
      "priority": 760,
      "title": "Apply BBQ plate share defaults",
      "description": "If planner is building a BBQ plate, set default share targets (protein-forward) and typical side balance.",
      "tags": ["bbq", "planner"],
      "source": "catalog",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          { "type": "exists", "path": "$.planner" },
          {
            "type": "eq",
            "path": "$.context.cuisineId",
            "value": "cuisines.bbq"
          }
        ]
      },
      "then": {
        "actions": [
          {
            "type": "set",
            "path": "$.planner.plateModel",
            "value": {
              "proteinShareTarget": 0.45,
              "starchShareTarget": 0.35,
              "vegShareMin": 0.2
            }
          },
          { "type": "addTag", "value": "planner.plate.bbq" }
        ]
      }
    },
    {
      "id": "bbq.method.bias.smoke_low_and_slow",
      "enabled": true,
      "priority": 730,
      "title": "Prefer smoke + low-and-slow methods",
      "description": "BBQ is defined by smoke and controlled heat over time; boost recipes using smoke/grill/slow-cook patterns.",
      "tags": ["bbq", "technique", "ranking"],
      "source": "catalog",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          {
            "type": "intersects",
            "path": "$.recipe.methods",
            "values": [
              "methods.smoke",
              "methods.slow_cook",
              "methods.wrap",
              "methods.rest"
            ]
          },
          {
            "type": "matches",
            "path": "$.recipe.title",
            "regex": "(?i)smok|low\\s*and\\s*slow|brisket|pulled|rib|burnt end"
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": 5 },
          { "type": "addTag", "value": "bbq.technique_core" }
        ]
      }
    },
    {
      "id": "bbq.adaptation.internal_temp_safety_hint",
      "enabled": true,
      "priority": 700,
      "title": "Internal temperature + safety guidance for BBQ proteins",
      "description": "Emits a hint to use an instant-read/probe thermometer and follow safe doneness targets for poultry and reheating.",
      "tags": ["bbq", "adaptation", "safety"],
      "source": "catalog",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          {
            "type": "eq",
            "path": "$.context.cuisineId",
            "value": "cuisines.bbq"
          },
          { "type": "exists", "path": "$.recipe" }
        ]
      },
      "then": {
        "actions": [
          {
            "type": "emitEvent",
            "event": {
              "name": "cuisineRuleset.hint",
              "payload": {
                "kind": "safety",
                "hint": "Use a thermometer for BBQ proteins. Poultry should reach a safe internal temperature; large cuts benefit from resting/holding for tenderness. Cool leftovers quickly and reheat safely.",
                "tags": ["thermometer", "doneness", "safety"]
              }
            }
          }
        ]
      }
    },
    {
      "id": "bbq.substitution.neutral_oil_is_ok",
      "enabled": true,
      "priority": 680,
      "title": "Keep neutral oil/binders as default for BBQ",
      "description": "BBQ often uses neutral oils, mustard binders, or rendered fats; do not bias toward olive oil by default.",
      "tags": ["bbq", "substitution"],
      "source": "catalog",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          {
            "type": "eq",
            "path": "$.context.cuisineId",
            "value": "cuisines.bbq"
          },
          {
            "type": "intersects",
            "path": "$.recipe.ingredientsCanonical",
            "values": ["ingredients.neutral_oil"]
          }
        ]
      },
      "then": {
        "actions": [
          {
            "type": "emitEvent",
            "event": {
              "name": "cuisineRuleset.suggestion",
              "payload": {
                "kind": "substitution",
                "from": "ingredients.neutral_oil",
                "to": "ingredients.neutral_oil",
                "reason": "Neutral oils (or mustard binders/rendered fats) are common in BBQ rub adhesion and high-heat grilling; keep neutral oil as default unless user preferences override."
              }
            }
          }
        ]
      }
    },
    {
      "id": "bbq.pairing.default_sides",
      "enabled": true,
      "priority": 650,
      "title": "Suggest common BBQ side pairings",
      "description": "Provides optional side suggestions (slaw, beans, potato salad, pickles) to build complete BBQ plates.",
      "tags": ["bbq", "pairing"],
      "source": "catalog",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          {
            "type": "eq",
            "path": "$.context.cuisineId",
            "value": "cuisines.bbq"
          },
          { "type": "exists", "path": "$.planner" }
        ]
      },
      "then": {
        "actions": [
          {
            "type": "set",
            "path": "$.planner.pairingSuggestions",
            "value": {
              "sides": [
                {
                  "id": "dishes.bbq.cole_slaw",
                  "tags": ["side", "cooling", "crunchy", "acidic"]
                },
                {
                  "id": "dishes.bbq.baked_beans",
                  "tags": ["side", "beans", "sweet_savory"]
                },
                {
                  "id": "dishes.bbq.potato_salad",
                  "tags": ["side", "picnic", "creamy_or_vinegar"]
                },
                {
                  "id": "dishes.bbq.pickles_onions",
                  "tags": ["side", "condiment", "acidic", "cut_fat"]
                }
              ],
              "sauces": [
                {
                  "id": "dishes.bbq.tomato_based_bbq_sauce",
                  "tags": ["sauce", "classic"]
                },
                {
                  "id": "dishes.bbq.vinegar_sauce_carolina",
                  "tags": ["sauce", "vinegar", "tangy"]
                },
                {
                  "id": "dishes.bbq.white_sauce_alabama",
                  "tags": ["sauce", "tangy", "mayo_based"]
                }
              ],
              "breads": [
                {
                  "id": "dishes.bbq.bread_buns",
                  "tags": ["bread", "sandwich"]
                },
                { "id": "dishes.bbq.cornbread", "tags": ["bread", "side"] }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "bbq.protein.bias.classic_cuts",
      "enabled": true,
      "priority": 620,
      "title": "Prefer classic BBQ proteins",
      "description": "Boost brisket, ribs, pulled pork, and smoked chicken/turkey patterns for BBQ cuisine selection.",
      "tags": ["bbq", "protein", "ranking"],
      "source": "catalog",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          {
            "type": "intersects",
            "path": "$.recipe.ingredientsCanonical",
            "values": [
              "ingredients.beef_brisket",
              "ingredients.pork_ribs",
              "ingredients.pork_shoulder"
            ]
          },
          {
            "type": "matches",
            "path": "$.recipe.title",
            "regex": "(?i)brisket|rib|ribs|pulled\\s+pork|burnt\\s+ends|smoked\\s+chicken|smoked\\s+turkey"
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": 4 },
          { "type": "addTag", "value": "bbq.protein_classic" }
        ]
      }
    }
  ]
}
