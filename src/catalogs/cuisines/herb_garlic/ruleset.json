  "globals": {
    "overlayCuisine": true,
    "flavor": {
      "pillars": ["garlic", "fresh_herbs", "citrus", "olive_oil"],
      "avoidOverpowering": [
        "heavy_sweetness",
        "smoke_dominant",
        "very_hot_chili"
      ]
    },
    "plannerDefaults": {
      "targetHeat": 1,
      "weeknightTotalMinsMax": 45,
      "batchBias": 0.15
    },
    "adapterHints": {
      "finishers": ["lemon_zest", "fresh_herbs", "olive_oil_drizzle"],
      "saltTiming": [
        "salt_proteins_early",
        "salt_vegetables_after_roast_if_needed"
      ]
    }
