  "rules": [
    {
      "id": "hg.tag.base_overlay",
      "enabled": true,
      "priority": 10,
      "title": "Apply base Herb & Garlic overlay tag",
      "description": "Any item evaluated under this cuisine scope receives the herb_garlic overlay tag for downstream browse/filter behavior.",
      "tags": ["tagging", "overlay"],
      "source": "ssa.catalog.cuisines.herb_garlic",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          { "type": "hasTag", "value": "cuisines.herb_garlic" },
          {
            "type": "eq",
            "path": "$.cuisineId",
            "value": "cuisines.herb_garlic"
          },
          {
            "type": "intersects",
            "path": "$.tags",
            "values": ["cuisine.herb_garlic", "cuisines.herb_garlic"]
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "addTag", "value": "herb_garlic" },
          { "type": "set", "path": "$.signals.overlayCuisine", "value": true }
        ]
      }
    },
    {
      "id": "hg.score.garlic_herb_citrus_olive_alignment",
      "enabled": true,
      "priority": 20,
      "title": "Score up recipes that strongly match garlic + herbs + citrus + olive oil",
      "description": "Boost score when core Herb & Garlic pillars appear in ingredients/keywords.",
      "tags": ["scoring", "match"],
      "source": "ssa.catalog.cuisines.herb_garlic",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          {
            "op": "any",
            "conditions": [
              {
                "type": "intersects",
                "path": "$.ingredients.required",
                "values": ["ing.garlic"]
              },
              {
                "type": "intersects",
                "path": "$.ingredientsCore",
                "values": ["ing.garlic"]
              },
              { "type": "matches", "path": "$.title", "regex": "(?i)garlic" }
            ]
          },
          {
            "op": "any",
            "conditions": [
              {
                "type": "intersects",
                "path": "$.ingredients.required",
                "values": ["ing.olive_oil"]
              },
              {
                "type": "intersects",
                "path": "$.ingredientsCore",
                "values": ["ing.olive_oil"]
              },
              {
                "type": "matches",
                "path": "$.summary",
                "regex": "(?i)olive\\s*oil|evoo"
              }
            ]
          },
          {
            "op": "any",
            "conditions": [
              {
                "type": "intersects",
                "path": "$.ingredients.required",
                "values": [
                  "ing.parsley",
                  "ing.basil",
                  "ing.thyme",
                  "ing.rosemary",
                  "ing.oregano",
                  "ing.dill",
                  "ing.mint"
                ]
              },
              {
                "type": "intersects",
                "path": "$.ingredientsCore",
                "values": [
                  "ing.parsley",
                  "ing.basil",
                  "ing.thyme",
                  "ing.rosemary",
                  "ing.oregano",
                  "ing.dill",
                  "ing.mint"
                ]
              },
              {
                "type": "matches",
                "path": "$.summary",
                "regex": "(?i)fresh\\s+herb|herb-forward|herby"
              }
            ]
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": 1.25 },
          { "type": "addTag", "value": "garlic_forward" },
          { "type": "addTag", "value": "herb_forward" }
        ]
      }
    },
    {
      "id": "hg.score.lemon_citrus_finish",
      "enabled": true,
      "priority": 30,
      "title": "Boost lemon/citrus-finished profiles",
      "description": "Prefer dishes that include lemon/citrus or mention bright finishing acidity.",
      "tags": ["scoring", "citrus"],
      "source": "ssa.catalog.cuisines.herb_garlic",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          {
            "type": "intersects",
            "path": "$.ingredients.required",
            "values": ["ing.lemon"]
          },
          {
            "type": "intersects",
            "path": "$.ingredientsCore",
            "values": ["ing.lemon"]
          },
          {
            "type": "matches",
            "path": "$.summary",
            "regex": "(?i)lemon|citrus|zest|bright"
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": 0.6 },
          { "type": "addTag", "value": "lemony" },
          {
            "type": "set",
            "path": "$.flavor.finishAcidPreferred",
            "value": true
          }
        ]
      }
    },
    {
      "id": "hg.score.weeknight",
      "enabled": true,
      "priority": 40,
      "title": "Prefer weeknight-possible dishes",
      "description": "If total time is <= 45 minutes OR tags indicate weeknight, boost score and tag as weeknight.",
      "tags": ["scoring", "weeknight"],
      "source": "ssa.catalog.cuisines.herb_garlic",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          { "type": "lte", "path": "$.time.totalMins", "value": 45.0 },
          {
            "type": "eq",
            "path": "$.signals.weeknightPossible",
            "value": true
          },
          {
            "type": "intersects",
            "path": "$.plannerTags",
            "values": ["weeknight"]
          },
          { "type": "intersects", "path": "$.tags", "values": ["weeknight"] }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": 0.35 },
          { "type": "addTag", "value": "weeknight" }
        ]
      }
    },
    {
      "id": "hg.score.batch_friendly",
      "enabled": true,
      "priority": 50,
      "title": "Prefer batch-friendly dishes",
      "description": "Boost dishes that declare batch-friendly signals or tags; useful for meal prep and storehouse workflows.",
      "tags": ["scoring", "batch"],
      "source": "ssa.catalog.cuisines.herb_garlic",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          { "type": "eq", "path": "$.signals.batchFriendly", "value": true },
          { "type": "eq", "path": "$.signals.batchFriendly", "value": "yes" },
          {
            "type": "intersects",
            "path": "$.plannerTags",
            "values": ["batch_friendly", "meal_prep"]
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": 0.4 },
          { "type": "addTag", "value": "batch_friendly" }
        ]
      }
    },
    {
      "id": "hg.adapter.add_finisher_hints",
      "enabled": true,
      "priority": 60,
      "title": "Set adapter finisher hints for Herb & Garlic",
      "description": "Provide deterministic finishing guidance for recipe adapters and cook setup.",
      "tags": ["adapter", "hints"],
      "source": "ssa.catalog.cuisines.herb_garlic",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          {
            "type": "eq",
            "path": "$.cuisineId",
            "value": "cuisines.herb_garlic"
          },
          {
            "type": "intersects",
            "path": "$.plannerTags",
            "values": ["herb_garlic"]
          },
          { "type": "intersects", "path": "$.tags", "values": ["herb_garlic"] }
        ]
      },
      "then": {
        "actions": [
          {
            "type": "set",
            "path": "$.adapterHints.finishers",
            "value": ["lemon_zest", "fresh_herbs", "olive_oil_drizzle"]
          },
          {
            "type": "set",
            "path": "$.adapterHints.preferredFats",
            "value": ["ing.olive_oil"]
          },
          {
            "type": "set",
            "path": "$.adapterHints.preferredAromatics",
            "value": ["ing.garlic"]
          }
        ]
      }
    },
    {
      "id": "hg.tag.avoid_smoke_dominant",
      "enabled": true,
      "priority": 70,
      "title": "Downscore smoke-dominant profiles under Herb & Garlic overlay",
      "description": "Herb & Garlic overlay is bright/aromatic; heavy smoke-forward items are less aligned unless explicitly desired.",
      "tags": ["scoring", "avoid"],
      "source": "ssa.catalog.cuisines.herb_garlic",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          { "type": "hasTag", "value": "smoke_dominant" },
          {
            "type": "intersects",
            "path": "$.tags",
            "values": ["smoked", "smoke_dominant", "bbq"]
          },
          {
            "type": "matches",
            "path": "$.summary",
            "regex": "(?i)smok(e|y)|bbq|barbecue"
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": -0.5 },
          {
            "type": "set",
            "path": "$.fitNotes.overlayConflict",
            "value": "smoke_dominant_vs_bright_herb_garlic"
          }
        ]
      }
    },
    {
      "id": "hg.event.on_match_emit",
      "enabled": true,
      "priority": 999,
      "title": "Emit event when Herb & Garlic overlay rules apply",
      "description": "Optional event for SSA event bus listeners (analytics/debug/UI).",
      "tags": ["event"],
      "source": "ssa.catalog.cuisines.herb_garlic",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          {
            "type": "intersects",
            "path": "$.plannerTags",
            "values": ["herb_garlic"]
          },
          { "type": "intersects", "path": "$.tags", "values": ["herb_garlic"] },
          {
            "type": "eq",
            "path": "$.cuisineId",
            "value": "cuisines.herb_garlic"
          }
        ]
      },
      "then": {
        "actions": [
          {
            "type": "emitEvent",
            "event": {
              "name": "ssa.ruleset.applied",
              "payload": {
                "rulesetId": "cuisines.herb_garlic.ruleset",
                "cuisineId": "cuisines.herb_garlic",
                "overlay": true
              }
            }
          }
        ]
      }
    }
  ]
