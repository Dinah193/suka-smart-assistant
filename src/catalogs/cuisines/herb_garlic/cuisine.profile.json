          "ingredients.cauliflower_optional"
        ],
        "pairings": [
          "dish.archetype.herb_garlic_protein",
          "dish.archetype.lemon_garlic_sauce"
        ]
      }
    },
    {
      "id": "dish.archetype.lemon_garlic_sauce",
      "label": "Lemon-Garlic Herb Sauce",
      "description": "Quick finishing sauce (or marinade) built from garlic, herbs, lemon, oil, salt, and pepper.",
      "commonExamples": [
        "Lemon-garlic vinaigrette",
        "Garlic-herb pan sauce",
        "Herb-garlic marinade"
      ],
      "defaults": {
        "sauceOptions": [
          "ingredients.olive_oil",
          "ingredients.lemon",
          "ingredients.garlic"
        ],
        "pairings": [
          "dish.archetype.herb_garlic_protein",
          "dish.archetype.sheet_pan_veg",
          "dish.archetype.legume_salad"
        ]
      }
    },
    {
      "id": "dish.archetype.legume_salad",
      "label": "Herb-Forward Legume Salad",
      "description": "Chickpeas/lentils tossed with herbs, garlic, olive oil, and lemon; served as side or main bowl component.",
      "commonExamples": [
        "Chickpea herb salad",
        "Lentil salad with lemon and parsley"
      ],
      "defaults": {
        "proteinOptions": ["ingredients.chickpeas", "ingredients.lentils"],
        "pairings": [
          "dish.archetype.herb_garlic_protein",
          "dish.archetype.sheet_pan_veg"
        ]
      }
    }
  ],

  "substitutionGuidance": {
    "proteinSubstitutions": [
      {
        "for": "ingredients.fish",
        "options": ["ingredients.chicken", "ingredients.lamb_optional"],
        "notes": "If replacing fish with chicken, increase cook time and keep lemon/herb finishing."
      },
      {
        "for": "ingredients.chicken",
        "options": [
          "ingredients.fish",
          "ingredients.chickpeas",
          "ingredients.lentils"
        ],
        "notes": "For plant-based swaps, emphasize herbs, acid, and a savory salt/umami component (olives/cheese optional)."
      }
    ],
    "sideSubstitutions": [
      {
        "for": "ingredients.rice_optional",
        "options": [
          "ingredients.potatoes",
          "ingredients.couscous_optional",
          "ingredients.pasta_optional"
        ],
        "notes": "Any neutral starch works; keep the herb/garlic sauce as the connector."
      }
    ],
    "notes": [
      "If you don't have fresh herbs, use dried oregano/thyme and finish with lemon.",
      "If you don't have lemon, use vinegar; keep acid as a finishing step.",
      "If avoiding dairy, skip cheese/anchovy and keep umami via olives or salt-forward seasoning."
    ]
  },

