          "dish.archetype.legume_salad"
        ]
      }
    },
    {
      "id": "dish.archetype.sheet_pan_veg",
      "label": "Sheet-Pan Vegetables",
      "description": "Roasted vegetables with olive oil, garlic, herbs, salt, and pepper.",
      "commonExamples": [
        "Roasted zucchini and bell peppers",
        "Roasted carrots and onions",
        "Roasted broccoli and cauliflower"
      ],
      "defaults": {
        "vegOptions": [
          "ingredients.zucchini_optional",
          "ingredients.bell_pepper_optional",
          "ingredients.onion_optional",
          "ingredients.carrots_optional",
