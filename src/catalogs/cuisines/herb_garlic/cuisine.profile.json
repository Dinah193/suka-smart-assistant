  "safetyNotes": [
    {
      "id": "safety.raw_garlic",
      "label": "Raw garlic intensity",
      "notes": [
        "Raw garlic can be harsh; mellow by grating finely and letting it sit in lemon/vinegar for 5 minutes before adding oil.",
        "For sensitive stomachs, use lightly sautéed garlic instead of raw."
      ]
    }
