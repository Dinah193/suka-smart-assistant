    "locale": "en-US",
    "label": "Herb & Garlic",
    "description": "Aromatic, savory cooking built around garlic, fresh herbs, citrus, and olive oil. Works as a flexible overlay cuisine for poultry, fish, vegetables, legumes, and simple grains.",
    "tags": [
      "cuisine.herb_garlic",
      "flavor.herb_forward",
      "flavor.garlic_forward",
      "profile.overlay",
      "weeknight.friendly",
      "batch.friendly"
    ],
