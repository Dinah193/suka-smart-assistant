  "flavorSystem": {
    "signatureNotes": [
      "Garlic + herbs + olive oil is the core triangle.",
      "Brighten with lemon/vinegar at the end.",
      "Use salt + pepper as the base seasoning; add gentle heat optionally.",
      "Pair with roasted vegetables, grilled proteins, legumes, and simple grains."
    ],

    "aromaticsCore": [
