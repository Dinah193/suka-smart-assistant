  "dishArchetypes": [
    {
      "id": "dish.archetype.herb_garlic_protein",
      "label": "Herb-Garlic Protein",
      "description": "A simple grilled/roasted/sautéed protein seasoned with garlic, herbs, oil, and citrus.",
      "commonExamples": [
        "Lemon-herb grilled chicken",
        "Garlic-herb baked fish",
        "Pan-seared chicken with herb butter"
      ],
      "defaults": {
        "proteinOptions": [
          "ingredients.chicken",
          "ingredients.fish",
          "ingredients.lamb_optional",
          "ingredients.eggs_optional"
