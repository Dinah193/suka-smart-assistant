  "variations": [
    {
      "id": "variation.chicken",
      "label": "Chicken tacos (quick skillet)",
      "when": { "protein": "chicken" },
      "adapt": {
        "swap": [
          {
            "from": "ingredient.beef.ground_80_20",
            "to": "ingredient.chicken.thighs_diced",
            "notes": "Use diced thighs or ground chicken; add 1 tbsp oil if very lean."
          }
        ],
        "notes": [
          "Cook chicken through (165°F / 74°C).",
          "Chicken benefits from an extra squeeze of lime."
        ]
      }
    },
    {
      "id": "variation.beans_only",
      "label": "Bean-forward vegetarian tacos",
      "when": { "diet": "vegetarian" },
