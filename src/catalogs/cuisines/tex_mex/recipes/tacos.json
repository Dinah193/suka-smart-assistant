  "steps": [
    {
      "id": "step.mise_en_place",
      "title": "Prep + mise en place",
      "activeMins": 8,
      "instructions": [
        "Dice onion and tomatoes; mince garlic (and jalapeño if using).",
        "Chop cilantro if using.",
        "Set out taco toppings (lettuce, cheese, guacamole) and tortillas."
      ],
      "checks": ["Knife + board ready", "Toppings staged for fast assembly"]
    },
    {
      "id": "step.quick_pico",
      "title": "Make quick pico de gallo",
      "activeMins": 4,
      "instructions": [
        "In a bowl, combine diced tomatoes, diced onion, jalapeño (optional), cilantro (optional), lime juice, and salt.",
        "Taste and adjust: add more lime for brightness or a pinch more salt if flat.",
        "Let sit while you cook the filling."
      ],
      "timers": [{ "label": "Rest pico briefly", "minutes": 10 }],
      "checks": [
        "Pico tastes bright and lightly salty",
        "Drain excess tomato juice if watery"
      ]
    },
    {
      "id": "step.cook_beef",
      "title": "Brown beef + build Tex-Mex seasoning base",
      "activeMins": 10,
      "handsOffMins": 5,
      "instructions": [
        "Heat a skillet over medium-high heat. Add ground beef and cook, breaking it up, until browned.",
        "If there is a lot of rendered fat, spoon off excess (leave ~1 tbsp for flavor).",
        "Add diced onion and cook until softened (2–3 minutes). Add garlic and cook 30 seconds.",
        "Stir in chili powder, cumin, paprika, oregano, salt, and pepper. Toast spices for 20–30 seconds to bloom."
      ],
      "timers": [
        { "label": "Brown beef", "minutes": 6 },
        { "label": "Soften onions", "minutes": 3 }
      ],
      "checks": [
        "Beef is browned with no raw pink",
        "Spices smell fragrant (not burnt)"
      ]
    },
    {
      "id": "step.sauce_fill",
      "title": "Sauce the filling",
      "activeMins": 3,
      "handsOffMins": 5,
      "instructions": [
        "Stir in tomato paste and cook 30–60 seconds to deepen flavor.",
        "Add water and simmer until slightly saucy and cohesive (3–5 minutes).",
        "Finish with lime juice; taste and adjust salt/heat."
      ],
      "timers": [{ "label": "Simmer filling", "minutes": 4 }],
      "checks": [
        "Filling is saucy (not watery) and coats the meat",
        "Seasoning is balanced: salty, cumin/chile forward, lightly tangy"
      ]
    },
    {
      "id": "step.quick_sauce",
      "title": "Optional quick taco sauce",
      "activeMins": 2,
      "instructions": [
        "In a small bowl, mix sour cream, mayo (optional), lime juice, hot sauce, garlic powder, and a pinch of salt.",
        "Taste: add more hot sauce for heat or lime for brightness."
      ],
      "checks": ["Sauce is creamy and tangy", "Heat level matches preference"]
    },
    {
      "id": "step.warm_tortillas",
      "title": "Warm tortillas",
      "activeMins": 3,
      "instructions": [
        "Warm tortillas in a dry skillet (20–30 seconds per side) OR wrap in foil and warm in a 300°F oven for 8–10 minutes.",
        "Keep warm under a clean towel or in a covered dish."
      ],
      "temperature": {
        "type": "oven_optional",
        "value": 300,
        "unit": "F",
        "notes": "Oven method is convenient for many tortillas."
      },
      "timers": [{ "label": "Warm tortillas (oven option)", "minutes": 9 }]
    },
    {
      "id": "step.assemble",
      "title": "Assemble + serve",
      "activeMins": 5,
      "instructions": [
        "Fill each warm tortilla with seasoned beef.",
        "Top with lettuce, cheese, quick pico, and optional sauce/guacamole.",
        "Serve with lime wedges and any extra pico on the side."
      ],
      "checks": [
        "Tortillas are warm and pliable",
        "Toppings distributed for texture + freshness"
      ]
    }
  ],
