        "swap": [
          {
            "from": "ingredient.beef.ground_80_20",
            "to": "ingredient.beans.black",
            "notes": "Use 2 cups cooked black beans; mash ~1/3 for binding."
          }
        ],
        "notes": [
          "Add 1 tbsp oil when blooming spices.",
          "Optional: add roasted corn for sweetness and texture."
        ]
      }
    },
    {
      "id": "variation.crispy_shells",
      "label": "Crispy taco shells (oven method)",
      "when": { "preference": "crispy" },
