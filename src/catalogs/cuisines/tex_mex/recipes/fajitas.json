  "steps": [
    {
      "id": "step.mix_marinade",
      "title": "Mix marinade / seasoning",
      "activeMins": 5,
      "instructions": [
        "In a bowl, mix: 2 tbsp oil, juice of 1 lime (about 2 tbsp), garlic, chili powder, cumin, paprika (optional), oregano (optional), 1 tsp salt, pepper, and brown sugar (optional).",
        "Reserve remaining lime for finishing/serving."
      ],
      "checks": ["Seasoning smells chili-cumin forward and slightly tangy"]
    },
    {
      "id": "step.marinade_protein",
      "title": "Marinate protein (quick)",
      "activeMins": 3,
      "handsOffMins": 15,
      "instructions": [
        "Choose ONE: chicken strips or steak strips.",
        "Toss protein with the marinade until evenly coated.",
        "Let rest 15 minutes at room temp (or refrigerate up to 8 hours)."
      ],
      "timers": [{ "label": "Quick marinade", "minutes": 15 }],
      "checks": [
        "Protein evenly coated",
        "If using steak, slice across the grain for tenderness"
      ]
    },
    {
      "id": "step.prep_veg",
      "title": "Slice peppers and onions",
      "activeMins": 7,
      "instructions": [
        "Slice bell peppers and onion into thin strips for fast cooking.",
        "Slice jalapeño if using.",
        "Keep vegetables separate from the protein so they sear properly."
      ]
    },
    {
      "id": "step.sear_veg",
      "title": "Sear peppers and onions",
      "activeMins": 8,
      "instructions": [
        "Heat a large skillet (preferably cast iron) over medium-high until hot.",
        "Add 1 tbsp oil. Add peppers and onions (and jalapeño if using).",
        "Cook, stirring occasionally, until softened with browned edges (6–8 minutes).",
        "Season with a pinch of salt, then transfer vegetables to a plate."
      ],
      "timers": [{ "label": "Sear vegetables", "minutes": 7 }],
      "checks": [
        "Veg has charred edges (some browning is good)",
        "Veg still has slight bite (not mushy)"
      ]
    },
    {
      "id": "step.sear_protein",
      "title": "Sear protein quickly",
      "activeMins": 8,
      "instructions": [
        "Return skillet to high heat. Add a small splash of oil if dry.",
        "Add marinated protein in a single layer (work in batches if needed).",
        "Sear without moving for 1–2 minutes to develop browning, then toss and continue until cooked through."
      ],
      "timers": [{ "label": "Sear protein", "minutes": 6 }],
      "checks": [
        "Good browning on some pieces",
        "No steaming—cook in batches if the pan is crowded"
      ]
    },
    {
      "id": "step.finish",
      "title": "Combine, finish with lime, and serve",
      "activeMins": 5,
      "instructions": [
        "Return cooked vegetables to the skillet with the protein and toss to combine.",
        "Squeeze remaining lime over the fajitas and taste. Add salt if needed.",
        "Optional: sprinkle cilantro.",
        "Serve in warm tortillas or as bowls. Offer toppings: salsa, sour cream, cheese, guacamole, hot sauce."
      ],
      "checks": [
        "Final flavor pops with lime",
        "Seasoning tastes balanced (salt + acid + chili/cumin)"
      ]
    }
  ],
