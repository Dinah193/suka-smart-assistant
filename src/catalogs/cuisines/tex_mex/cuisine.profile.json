  "substitutionGuidance": {
    "proteinSubstitutions": [
      {
        "for": "protein.beef",
        "options": [
          "protein.turkey_optional",
          "protein.chicken",
          "protein.beans"
        ],
        "notes": "Swap based on availability: turkey for lean ground, chicken for fajitas/enchiladas, beans for vegetarian."
      },
      {
        "for": "protein.chicken",
        "options": ["protein.pork", "protein.beef", "protein.beans"],
        "notes": "Use pork for carnitas-style shreds, beef for taco meat, beans for budget/vegetarian."
      }
    ],
    "sideSubstitutions": [
      {
        "for": "side.spanish_rice",
        "options": ["side.rice_plain", "side.cauli_rice_optional"],
        "notes": "Plain rice + salsa works as a shortcut. Cauli rice for low-carb."
      },
      {
        "for": "side.beans",
        "options": [
          "side.refried_beans_optional",
          "side.black_beans",
          "side.pinto_beans"
        ],
        "notes": "Refried is richest; black beans are clean/firm; pinto beans are classic and creamy when simmered."
      }
    ],
    "thickenerSubstitutions": [
      {
        "for": "thickener.flour",
        "options": ["thickener.cornstarch", "thickener.masa_harina_optional"],
        "notes": "Cornstarch thickens sauces quickly; masa harina adds corn flavor and body for chili/enchilada sauces."
      }
    ],
    "notes": [
      "Flour vs corn tortillas: flour for fajitas/burritos; corn for enchiladas/tacos. Either can work depending on preference.",
      "Dairy is common but optional: replace sour cream with lime-cashew crema or omit; use dairy-free shreds if needed."
    ]
  },

