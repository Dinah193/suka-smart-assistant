  "substitutionGuidance": {
    "proteinSubstitutions": [
      {
        "for": "ingredient.chicken_thigh",
        "options": [
          "ingredient.chicken_breast",
          "ingredient.turkey_thigh",
          "ingredient.tofu_firm"
        ],
        "notes": "Thighs stay juicier in curries; if using breast, add later and avoid overcooking."
      },
      {
        "for": "ingredient.shrimp",
        "options": [
          "ingredient.chicken",
          "ingredient.fish_white",
          "ingredient.mushrooms"
        ],
        "notes": "Use seafood stock or add extra umami if swapping to non-seafood proteins."
      }
    ],
    "sideSubstitutions": [
      {
        "for": "ingredient.jasmine_rice",
        "options": [
          "ingredient.sticky_rice",
          "ingredient.brown_rice",
          "ingredient.cauliflower_rice"
        ],
        "notes": "Sticky rice pairs especially well with grilled meats and Isan-style dishes."
      },
      {
        "for": "ingredient.rice_noodles",
        "options": [
          "ingredient.wide_rice_noodles",
          "ingredient.glass_noodles",
          "ingredient.zucchini_noodles"
        ],
        "notes": "Adjust soak/cook times; keep noodle texture springy and avoid overhydration."
      }
    ],
    "thickenerSubstitutions": [
      {
        "for": "ingredient.coconut_milk",
        "options": [
          "ingredient.coconut_cream",
          "ingredient.cashew_cream",
          "ingredient.oat_cream"
        ],
        "notes": "Coconut cream is richer; thin with water/stock. Non-coconut creams change aroma; compensate with extra herbs/acid."
      }
    ],
    "notes": [
      "For fish sauce substitutes: use soy sauce + a small amount of anchovy paste (if allowed) or seaweed/shiitake for vegetarian umami.",
      "For galangal substitutes: ginger is acceptable but less floral; add a little lime leaf or lemongrass to compensate.",
      "For kaffir lime leaves: use lime zest + a small piece of lemongrass (not identical, but keeps citrus top notes)."
    ]
  },

