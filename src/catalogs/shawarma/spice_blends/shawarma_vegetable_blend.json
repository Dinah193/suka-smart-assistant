    "source": {
      "curation": "ssa",
      "author": "SSA Catalog",
      "notes": "Shawarma spice blend tuned for vegetables: bright, smoky-warm, with extra herbs and tangy notes that pop on roasted veg."
    }
  },
  "ingredients": [
    {
      "id": "ing.cumin_ground",
      "label": "Ground cumin",
      "amount": { "value": 14, "unit": "g" },
      "notes": ["About 4 1/2 teaspoons (1 tablespoon + 1 1/2 teaspoons)."]
    },
    {
      "id": "ing.coriander_ground",
      "label": "Ground coriander",
      "amount": { "value": 14, "unit": "g" },
      "notes": ["About 4 1/2 teaspoons (1 tablespoon + 1 1/2 teaspoons)."]
    },
    {
      "id": "ing.paprika",
      "label": "Paprika (sweet)",
      "amount": { "value": 18, "unit": "g" },
      "notes": ["About 6 teaspoons (2 tablespoons)."]
    },
    {
      "id": "ing.paprika_smoked",
      "label": "Smoked paprika",
      "amount": { "value": 8, "unit": "g" },
      "notes": ["About 2 2/3 teaspoons; helps roasted veggies taste grilled."]
    },
    {
      "id": "ing.turmeric_ground",
      "label": "Ground turmeric",
      "amount": { "value": 6, "unit": "g" },
      "notes": ["About 2 1/4 teaspoons; color + earthiness."]
    },
    {
