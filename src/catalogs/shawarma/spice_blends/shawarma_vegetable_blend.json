      "label": "Ground sumac",
      "amount": { "value": 6, "unit": "g" },
      "notes": [
        "About 2 1/2 teaspoons; tangy brightness that loves roasted veg.",
        "Optional but highly recommended."
      ]
    },
    {
      "id": "ing.garlic_powder",
      "label": "Garlic powder",
      "amount": { "value": 8, "unit": "g" },
