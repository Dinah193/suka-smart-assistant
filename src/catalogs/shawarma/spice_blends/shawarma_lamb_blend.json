  "steps": [
    {
      "id": "step.01",
      "title": "Mix the blend",
      "instructions": [
        "Add all spices to a bowl or jar.",
        "Whisk (or shake in a sealed jar) until evenly combined and uniform in color."
      ]
    },
    {
      "id": "step.02",
      "title": "How to use (application notes)",
      "instructions": [
        "Dry rub: use ~10–14 g (1–1 1/2 tbsp) per 450 g (1 lb) lamb, plus salt to taste; grill/roast/sear.",
        "Marinade shortcut (per 900 g / 2 lb lamb): 20–28 g blend (2–3 tbsp) + 30 ml oil + 30–45 ml lemon juice/vinegar + garlic; optional 120 g yogurt for a clingy coating; marinate 4–24 hours.",
        "Skewers: for cubes, use slightly more blend and cook hot for char."
      ]
    },
    {
      "id": "step.03",
      "title": "Storage",
      "instructions": [
        "Store in an airtight jar away from heat and light.",
        "Best flavor within 3–6 months; usable longer but aroma fades."
      ]
    },
    {
      "id": "step.04",
      "title": "Batch notes",
      "instructions": [
        "This recipe yields about 90–105 g spice blend (varies by grind).",
        "Scale up easily for bulk prep and catalog usage."
      ]
    }
  ]
