  "steps": [
    {
      "id": "step.01",
      "title": "Mix the blend",
      "instructions": [
        "Add all spices to a bowl or jar.",
        "Whisk (or shake in a sealed jar) until evenly combined and uniform in color."
      ]
    },
    {
      "id": "step.02",
      "title": "How to use (application notes)",
      "instructions": [
        "Dry rub: use ~10–14 g (1–1 1/2 tbsp) per 450 g (1 lb) beef, plus salt to taste, then sear/roast/grill.",
        "Marinade shortcut: per 450 g (1 lb) beef, combine 10–14 g blend + 15 ml oil + 15 ml lemon juice/vinegar + 1–2 cloves garlic; marinate 2–12 hours.",
        "If your cooking method is short/high-heat, use slightly more blend to keep flavor after searing."
      ]
    },
    {
      "id": "step.03",
      "title": "Storage",
      "instructions": [
        "Store in an airtight jar away from heat and light.",
        "Best flavor within 3–6 months; usable longer but aroma fades over time."
      ]
    },
    {
      "id": "step.04",
      "title": "Batch notes",
      "instructions": [
        "This recipe yields about 70–80 g spice blend (varies by grind).",
        "Double or triple easily for batch cooking and catalog usage."
      ]
    }
  ]
