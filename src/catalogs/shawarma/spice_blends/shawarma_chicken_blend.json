  "steps": [
    {
      "id": "step.01",
      "title": "Mix the blend",
      "instructions": [
        "Add all spices to a bowl or jar.",
        "Whisk (or shake in a sealed jar) until evenly combined and uniform in color."
      ]
    },
    {
      "id": "step.02",
      "title": "How to use (application notes)",
      "instructions": [
        "Dry rub: use ~8–12 g (1–1 1/2 tbsp) per 450 g (1 lb) chicken, plus salt to taste; roast/grill/sear.",
        "Classic shawarma marinade: per 900 g (2 lb) chicken, combine 18–24 g blend (2–3 tbsp) + 240 g yogurt + 30 ml oil + 30–45 ml lemon juice + 3–5 cloves garlic + salt; marinate 2–12 hours.",
        "For chicken breast (lean), prefer yogurt-based marinade and avoid long acidic marination beyond ~12 hours."
      ]
    },
    {
      "id": "step.03",
      "title": "Storage",
      "instructions": [
        "Store in an airtight jar away from heat and light.",
        "Best flavor within 3–6 months; usable longer but aroma fades."
      ]
    },
    {
      "id": "step.04",
      "title": "Batch notes",
      "instructions": [
        "This recipe yields about 75–85 g spice blend (varies by grind).",
        "Double/triple easily for batch cooking and catalog usage."
      ]
    }
  ]
