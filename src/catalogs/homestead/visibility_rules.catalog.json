      "enabled": true,
      "priority": 120,
      "title": "Route gating by ui.minLevel",
      "description": "If a route/menu item declares ui.minLevel and current levelOrder is lower, lock the route entry.",
      "tags": ["visibility", "routes", "level"],
      "source": "homestead.visibility_rules",
