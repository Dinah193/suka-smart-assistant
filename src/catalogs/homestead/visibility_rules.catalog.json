    {
      "id": "visibility.equipment_gate_required_tags",
      "enabled": true,
      "priority": 140,
      "title": "Equipment gate by ui.requiredEquipmentTags",
      "description": "If a UI item declares requiredEquipmentTags (string[]) and user capability tags do not intersect, lock the item.",
      "tags": ["visibility", "equipment", "capabilities"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          { "type": "exists", "path": "$.ui.requiredEquipmentTags" },
          {
            "op": "not",
            "conditions": [
              {
                "type": "intersects",
                "path": "$.kitchen.capabilities.tags",
                "values": ["equipment.placeholder"]
              }
            ]
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "set", "path": "$.ui.locked", "value": true },
          { "type": "set", "path": "$.ui.visibility", "value": "locked" },
          { "type": "set", "path": "$.ui.lockBadge", "value": "EQUIPMENT" },
          {
            "type": "set",
            "path": "$.ui.lockReason",
            "value": "Missing required equipment to use this feature."
          },
          { "type": "scoreAdjust", "scoreDelta": -40 },
          { "type": "addTag", "value": "visibility.locked.equipment" }
        ]
      }
    },

    {
      "id": "visibility.hide_locked_when_preference_enabled",
      "enabled": true,
      "priority": 160,
      "title": "Hide locked modules when preference enabled",
      "description": "If homestead.ui.hideLockedModules is true and item is locked, set visibility to hidden.",
      "tags": ["visibility", "lock", "preference"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          {
            "type": "eq",
            "path": "$.homestead.ui.hideLockedModules",
            "value": true
          },
          { "type": "eq", "path": "$.ui.locked", "value": true }
        ]
      },
      "then": {
        "actions": [
          { "type": "set", "path": "$.ui.visibility", "value": "hidden" },
          { "type": "addTag", "value": "visibility.hidden.locked" }
        ]
      }
    },

    {
      "id": "visibility.attach_upgrade_cta",
      "enabled": true,
      "priority": 170,
      "title": "Attach upgrade CTA when locked and preference enabled",
      "description": "If showUpgradeCTA is true and item is locked, attach ui.cta for the UI to render.",
      "tags": ["visibility", "cta"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          {
            "type": "eq",
            "path": "$.homestead.ui.showUpgradeCTA",
            "value": true
          },
          { "type": "eq", "path": "$.ui.locked", "value": true }
        ]
      },
      "then": {
        "actions": [
          {
            "type": "set",
            "path": "$.ui.cta",
            "value": {
              "kind": "upgrade",
              "label": "Unlock this",
              "action": "open_homestead_level_modal"
            }
          },
          { "type": "addTag", "value": "visibility.cta.upgrade" }
        ]
      }
    },

    {
      "id": "visibility.rank_boost_core_modules",
      "enabled": true,
      "priority": 220,
      "title": "Ranking: boost core modules",
      "description": "Boost score for core modules so they appear earlier in dashboards/menus.",
      "tags": ["visibility", "ranking"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": {
        "op": "any",
        "conditions": [
          { "type": "eq", "path": "$.ui.moduleKey", "value": "meals" },
          { "type": "eq", "path": "$.ui.moduleKey", "value": "inventory" },
          { "type": "eq", "path": "$.ui.moduleKey", "value": "calendar" },
          { "type": "eq", "path": "$.ui.moduleKey", "value": "cleaning" }
        ]
      },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": 20 },
          { "type": "addTag", "value": "visibility.rank.core" }
        ]
      }
    },

    {
      "id": "visibility.rank_penalty_locked",
      "enabled": true,
      "priority": 230,
      "title": "Ranking: down-rank locked items",
      "description": "Down-rank locked items so they appear later in lists when shown.",
      "tags": ["visibility", "ranking"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": { "type": "eq", "path": "$.ui.locked", "value": true },
      "then": {
        "actions": [
          { "type": "scoreAdjust", "scoreDelta": -25 },
          { "type": "addTag", "value": "visibility.rank.locked" }
        ]
      }
    }
  ]
}
