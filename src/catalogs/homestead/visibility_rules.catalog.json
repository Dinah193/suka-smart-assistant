{
  "$schema": "../../schemas/ruleset.schema.json",
  "schemaVersion": "1.0.0",
  "updatedAt": "2026-01-24T00:00:00.000Z",
  "kind": "ruleset",
  "meta": {
    "id": "homestead.visibility_rules",
    "type": "ruleset",
    "label": "Homestead • Visibility Rules",
    "status": "canonical",
    "source": {
      "kind": "catalog",
      "name": "src/catalogs/homestead/visibility_rules.catalog.json",
      "notes": [
        "Deterministic UI gating rules based on homestead level, module/domain tags, and per-level uiFlags.",
        "These rules are intended for UI visibility/client experience. Enforce authorization separately if needed."
      ]
    }
  },
  "scope": {
    "kind": "module",
    "locales": ["en-US"]
  },
  "normalization": {
    "idPattern": "^[a-z0-9_\\.\\-]+$",
    "idCase": "lower",
    "aliasCaseFold": true,
    "keywordCaseFold": true,
    "trimWhitespace": true,
    "collapseSpaces": true,
    "tokens": {
      "stopWords": [
        "a",
        "an",
        "the",
        "and",
        "or",
        "of",
        "to",
        "for",
        "with",
        "in",
        "on"
      ]
    }
  },
  "globals": {
    "module": "homestead.visibility",
    "engineHints": {
      "contextPaths": {
        "levelId": "$.homestead.levelId",
        "levelOrder": "$.homestead.levelOrder",
        "uiFlags": "$.homestead.uiFlags",
        "capabilityTags": "$.kitchen.capabilities.tags",
        "moduleKey": "$.ui.moduleKey",
        "featureKey": "$.ui.featureKey",
        "itemTags": "$.ui.item.tags",
        "route": "$.nav.route"
      },
      "conventions": [
        "UI passes ui.item.tags (string[]) for the nav card/module being evaluated.",
        "UI passes homestead.levelOrder (0..4).",
        "UI optionally passes homestead.uiFlags.features (object) for current level.",
        "Equipment gating expects ui.requiredEquipmentTags (string[]) if needed."
      ]
    },
    "defaults": {
      "visibility": "visible",
      "locked": false,
      "lockReason": null,
      "lockBadge": null,
      "score": 0
    }
  },
  "rules": [
    {
      "id": "visibility.base_init",
      "enabled": true,
      "priority": 0,
      "title": "Base: initialize visibility fields",
      "description": "Initialize deterministic UI fields. Downstream rules may lock/hide and attach reasons/badges.",
      "tags": ["visibility", "baseline"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": { "type": "exists", "path": "$.ui" },
      "then": {
        "actions": [
          { "type": "set", "path": "$.ui.visibility", "value": "visible" },
          { "type": "set", "path": "$.ui.locked", "value": false },
          { "type": "set", "path": "$.ui.lockReason", "value": null },
          { "type": "set", "path": "$.ui.lockBadge", "value": null },
          { "type": "set", "path": "$.ui.score", "value": 0 }
        ]
      }
    },

    {
      "id": "visibility.level_required_missing",
      "enabled": true,
      "priority": 10,
      "title": "Lock/Hide: level required but missing",
      "description": "If requireLevelForRoutes is true and homestead.levelId is missing, mark item hidden + locked.",
      "tags": ["visibility", "level", "lock"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": true,
      "when": {
        "op": "all",
        "conditions": [
          {
            "type": "eq",
            "path": "$.homestead.ui.requireLevelForRoutes",
            "value": true
          },
          {
            "op": "not",
            "conditions": [{ "type": "exists", "path": "$.homestead.levelId" }]
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "set", "path": "$.ui.locked", "value": true },
          { "type": "set", "path": "$.ui.visibility", "value": "hidden" },
          {
            "type": "set",
            "path": "$.ui.lockReason",
            "value": "Homestead level is required to display this module."
          },
          { "type": "set", "path": "$.ui.lockBadge", "value": "LOCKED" },
          { "type": "addTag", "value": "visibility.hidden.missing_level" }
        ]
      }
    },

    {
      "id": "visibility.feature_flag_gate",
      "enabled": true,
      "priority": 40,
      "title": "Feature flag gating",
      "description": "If a UI item declares featureKey and current level disables it, lock (and hide if hideLockedModules is true).",
      "tags": ["visibility", "feature_flags"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          { "type": "exists", "path": "$.ui.featureKey" },
          {
            "type": "eq",
            "path": "$.homestead.uiFlags.features[$.ui.featureKey]",
            "value": false
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "set", "path": "$.ui.locked", "value": true },
          {
            "type": "set",
            "path": "$.ui.lockReason",
            "value": "This feature is disabled for your current homestead level."
          },
          { "type": "set", "path": "$.ui.lockBadge", "value": "LOCKED" },
          { "type": "set", "path": "$.ui.visibility", "value": "locked" },
          { "type": "scoreAdjust", "scoreDelta": -50 },
          { "type": "addTag", "value": "visibility.locked.feature_flag" }
        ]
      }
    },

    {
      "id": "visibility.targets_panel_lock_if_not_allowed",
      "enabled": true,
      "priority": 55,
      "title": "Targets Panel: lock unless (level >= 1 AND inside Homestead Planner)",
      "description": "Implements: showTargetsPanel only if homesteadLevel >= 1 AND user is in Homestead Planner.",
      "tags": ["visibility", "targets_panel", "homestead_planner"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          {
            "type": "eq",
            "path": "$.ui.featureKey",
            "value": "showTargetsPanel"
          },
          {
            "op": "any",
            "conditions": [
              { "type": "lt", "path": "$.homestead.levelOrder", "value": 1 },
              {
                "op": "not",
                "conditions": [
                  {
                    "type": "matches",
                    "path": "$.nav.route",
                    "regex": "^(\\/)?(homestead|homestead_planner)(\\/|$)"
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "set", "path": "$.ui.locked", "value": true },
          { "type": "set", "path": "$.ui.visibility", "value": "locked" },
          { "type": "set", "path": "$.ui.lockBadge", "value": "LEVEL 1" },
          {
            "type": "set",
            "path": "$.ui.lockReason",
            "value": "Targets Panel is available in Homestead Planner at Level 1+."
          },
          { "type": "scoreAdjust", "scoreDelta": -60 },
          { "type": "addTag", "value": "visibility.locked.targets_panel" }
        ]
      }
    },

    {
      "id": "visibility.targets_panel_allow_when_allowed",
      "enabled": true,
      "priority": 56,
      "title": "Targets Panel: allow when (level >= 1 AND inside Homestead Planner)",
      "description": "Explicit allow rule (mostly for clarity).",
      "tags": ["visibility", "targets_panel", "homestead_planner"],
      "source": "homestead.visibility_rules",
      "stopOnMatch": false,
      "when": {
        "op": "all",
        "conditions": [
          {
            "type": "eq",
            "path": "$.ui.featureKey",
            "value": "showTargetsPanel"
          },
          { "type": "gte", "path": "$.homestead.levelOrder", "value": 1 },
          {
            "type": "matches",
            "path": "$.nav.route",
            "regex": "^(\\/)?(homestead|homestead_planner)(\\/|$)"
          }
        ]
      },
      "then": {
        "actions": [
          { "type": "set", "path": "$.ui.locked", "value": false },
          { "type": "set", "path": "$.ui.visibility", "value": "visible" },
          { "type": "addTag", "value": "visibility.allowed.targets_panel" },
          { "type": "scoreAdjust", "scoreDelta": 10 }
        ]
      }
    },

    {
      "id": "visibility.lock_preservation_if_level_lt1",
      "enabled": true,
      "priority": 60,
      "title": "Domain gate: preservation (min level 1)",
      "description": "If item is tagged domain.preservation and levelOrder < 1, lock.",
