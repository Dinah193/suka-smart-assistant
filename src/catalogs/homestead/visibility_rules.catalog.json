            "type": "set",
            "path": "$.ui.lockReason",
            "value": "Preservation unlocks at Homestead Level 1."
          },
          { "type": "scoreAdjust", "scoreDelta": -80 },
          { "type": "addTag", "value": "visibility.locked.domain.preservation" }
        ]
      }
    },

