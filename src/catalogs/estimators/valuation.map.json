          },
          {
            "match": { "tagsAny": ["category.legumes"] },
            "unit": { "kind": "mass", "unit": "g", "basis": 100 },
            "usd": 0.3,
            "portion": { "label": "1 serving dry legumes", "g": 50 },
            "notes": ["Dry beans/lentils; cooked yield not modeled here."]
          },
          {
            "match": { "tagsAny": ["category.produce"] },
            "unit": { "kind": "serving", "unit": "serving", "basis": 1 },
            "usd": 0.75,
            "portion": { "label": "produce serving", "g": 80 },
            "notes": [
              "Used when produce is tracked by servings rather than weight."
            ]
          },
          {
            "match": { "tagsAny": ["category.meat"] },
            "unit": { "kind": "mass", "unit": "g", "basis": 100 },
            "usd": 1.2,
            "portion": { "label": "4 oz meat serving", "g": 113 },
            "notes": [
              "Blended average across beef/poultry/pork; user pricing preferred."
            ]
          },
          {
            "match": { "tagsAny": ["category.seafood"] },
            "unit": { "kind": "mass", "unit": "g", "basis": 100 },
            "usd": 1.5,
            "portion": { "label": "4 oz fish serving", "g": 113 }
          },
          {
            "match": { "tagsAny": ["category.dairy"] },
            "unit": { "kind": "volume", "unit": "ml", "basis": 240 },
            "usd": 0.6,
            "portion": { "label": "1 cup dairy", "ml": 240 }
          },
          {
            "match": { "tagsAny": ["category.fats"] },
            "unit": { "kind": "volume", "unit": "tbsp", "basis": 1 },
            "usd": 0.18,
            "portion": { "label": "1 tbsp fat", "tbsp": 1 }
          },
          {
            "match": { "tagsAny": ["category.spices"] },
            "unit": { "kind": "volume", "unit": "tsp", "basis": 1 },
            "usd": 0.08,
            "portion": { "label": "1 tsp spice", "tsp": 1 },
            "notes": [
              "Spices vary; used mostly for basket-estimation and substitution scoring."
            ]
          },
          {
            "match": { "tagsAny": ["category.bakery"] },
            "unit": { "kind": "serving", "unit": "serving", "basis": 1 },
            "usd": 1.25,
            "portion": { "label": "bakery serving", "g": 60 },
            "notes": [
              "Covers bread/pastries; overridden by specific bread slice/item entries."
            ]
          }
        ]
      }
    },

