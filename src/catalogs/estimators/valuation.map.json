{
  "$schema": "../../schemas/catalog.schema.json",
  "schemaVersion": "1.0.0",
  "updatedAt": "2026-01-24T00:00:00.000Z",
  "meta": {
    "id": "estimators.valuation_map",
    "type": "catalog",
    "domain": "estimators",
    "locale": "en-US",
    "name": "Valuation Map",
    "label": "Valuation Map",
    "subtitle": "Deterministic food valuation map (unit/portion assumptions) for SSA estimators",
    "source": {
      "kind": "catalog",
      "name": "src/catalogs/estimators/valuation.map.json",
      "notes": [
        "Deterministic fallback valuation map used by SSA estimators when item-level prices are unknown.",
        "Values are directional estimates and should be replaced by user price history whenever available.",
        "Engines may compute valuations by: (a) explicit itemId match, (b) tag/category match, (c) macro-based basket estimation."
      ]
    }
  },
  "scope": {
    "kind": "global",
    "module": "estimators.valuation",
    "locales": ["en-US"]
  },
  "defaults": {
    "currency": "USD",
    "basis": "usd_per_unit",
    "rounding": { "mode": "round", "precision": 2 },
    "fallbacks": {
      "usdPer1000Calories": 1.75,
      "usdPer100gProtein": 3.5,
      "usdPerServingProduce": 0.75,
      "usdPerTbspFat": 0.18
    },
    "portionStandards": {
      "produceServingG": 80,
      "grainServingDryG": 45,
      "legumeServingDryG": 50,
      "meatServingG": 113,
      "fishServingG": 113,
      "dairyServingMl": 240,
      "fatServingTbsp": 1,
      "breadSliceG": 30,
      "eggEachG": 50
    }
  },
  "items": [
    {
      "id": "valuation.meta",
      "label": "Valuation Map Metadata",
      "group": "meta",
      "rank": 0,
      "status": "active",
      "tags": ["estimator.valuation", "meta", "rules"],
      "profile": {
        "matchOrder": [
          "exact.itemId",
          "exact.canonicalId",
          "tag.match.any",
          "category.match",
          "macro.fallback"
        ],
        "notes": [
          "Engines should treat this as deterministic, but always allow user overrides.",
          "Use tag-matching when components are abstract (e.g., 'component.protein')."
        ]
      }
    },

    {
      "id": "valuation.tag_defaults",
      "label": "Default Valuations by Tag (USD per unit/portion)",
      "group": "tags",
      "rank": 10,
      "status": "active",
      "tags": ["estimator.valuation", "defaults", "tags"],
      "profile": {
        "currency": "USD",
        "entries": [
          {
            "match": { "tagsAny": ["category.grains"] },
            "unit": { "kind": "mass", "unit": "g", "basis": 100 },
            "usd": 0.25,
            "portion": { "label": "1 serving dry grains", "g": 45 },
            "notes": [
              "Approx. $0.11 per 45g serving; varies by rice/pasta/flour."
