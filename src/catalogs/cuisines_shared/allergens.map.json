  "confidenceRules": {
    "explicit_term": {
      "score": 0.95,
      "notes": "Matched from termMap or label text (e.g., 'contains milk')."
    },
    "ingredient_trigger": {
      "score": 0.75,
      "notes": "Matched a trigger token in ingredient name."
    },
    "derived_or_ambiguous": {
      "score": 0.6,
      "notes": "Likely allergen via derived ingredients; should request user confirmation (e.g., 'mayo' often contains egg)."
    }
  }
}
