  "schemaVersion": "1.0.0",
  "updatedAt": "2026-01-13",
  "notes": [
    "SSA Ingredients Aliases (shared across cuisines).",
    "Purpose: map messy ingredient names from recipes/imports to canonical ingredient IDs.",
    "How to use: normalize by lowercasing, trimming, removing punctuation/extra spaces, then match exact key in `aliases`.",
    "If no match: optionally try a second pass that removes size/packaging words (e.g., 'large', 'can', 'jar') before matching.",
    "Do NOT store brand names here. Keep this catalog stable and cuisine-agnostic.",
    "Keys should be common human ingredient strings; values should be canonical IDs used by your ingredient catalog.",
    "Avoid over-aggressive mappings that collapse distinct ingredients (e.g., 'chili powder' vs 'cayenne')."
  ],
  "meta": {
    "id": "cuisines_shared.ingredients.aliases",
    "type": "aliases",
    "domain": "ingredients",
    "locale": "en-US",
    "normalization": {
      "case": "lower",
      "trim": true,
      "collapseWhitespace": true,
      "stripPunctuation": true
    }
  },
