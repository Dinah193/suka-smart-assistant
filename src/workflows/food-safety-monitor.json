    {
      "parameters": {
        "functionCode": "const list = Array.isArray(items[0]?.json) ? items[0].json : (items[0]?.json?.items || []);\nif (!list.length) return [{ json: { count: 0, tasks: [] } }];\nconst tasks = list.map((it) => ({\n  title: `Use or preserve: ${it.name}`,\n  category: 'food-safety',\n  labels: ['expiring'],\n  priority: 2,\n  due: new Date().toISOString(),\n  meta: { item: it }\n}));\nreturn [{ json: { count: tasks.length, tasks } }];"
      },
