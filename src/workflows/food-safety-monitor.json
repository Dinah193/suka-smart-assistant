      "id": "Webhook_Temp",
      "name": "Webhook (Sensor Temp)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        -1060,
        -100
      ]
    },
    {
      "parameters": {
        "functionCode": "/*\nExpected body example:\n{\n  \"userId\": \"user_123\",\n  \"deviceId\": \"fridge_1\",\n  \"zone\": \"fridge\" | \"freezer\" | \"hot_hold\",\n  \"temp\": 41.2,          // number\n  \"unit\": \"F\" | \"C\",   // optional; default F\n  \"sampledAt\": \"ISO\"     // optional\n}\n*/\nconst b = items[0]?.json || {};\n\nfunction toF(v, unit) {\n  const u = String(unit || 'F').toUpperCase();\n  if (u === 'F') return Number(v);\n  return Number(v) * 9/5 + 32; // C->F\n}\n\nconst apiBase = $env.SUKA_API_BASE || 'http://localhost:4000';\nconst alertsWebhook = $env.ALERTS_WEBHOOK || null;\n\nconst zone = String(b.zone || '').toLowerCase();\nconst tempF = toF(b.temp, b.unit || 'F');\nconst userId = b.userId || null;\nconst deviceId = b.deviceId || null;\nconst sampledAt = b.sampledAt ? new Date(b.sampledAt).toISOString() : new Date().toISOString();\n\n// Thresholds (°F). Adjust here if needed.\nconst limits = {\n  fridge: { min: 33, max: 41 },\n  freezer: { min: -10, max: 5 },\n  hot_hold: { min: 135, max: 212 }\n};\n\nconst L = limits[zone] || { min: 33, max: 41 };\nconst inRange = tempF >= L.min && tempF <= L.max;\n\n// Severity heuristic\nlet severity = 'info';\nif (!inRange) {\n  const diff = tempF < L.min ? (L.min - tempF) : (tempF - L.max);\n  severity = diff >= 10 ? 'critical' : diff >= 5 ? 'warning' : 'info';\n}\n\nreturn [{ json: {\n  apiBase, alertsWebhook, userId, deviceId, sampledAt,\n  zone, tempF, limits: L, inRange, severity,\n  alertTitle: inRange ? 'Temp OK' : `Temp out of range: ${zone}`,\n  alertBody: inRange\n    ? `Sensor ${deviceId || ''} at ${tempF.toFixed(1)}°F (${zone})`\n    : `Sensor ${deviceId || ''} reported ${tempF.toFixed(1)}°F in ${zone}. Expected ${L.min}–${L.max}°F.`,\n  taskPayload: inRange ? null : {\n    title: `Investigate ${zone} temperature (${tempF.toFixed(1)}°F)`,\n    category: 'food-safety',\n    labels: [ `zone:${zone}`, 'temperature' ],\n    priority: severity === 'critical' ? 1 : 2,\n    due: new Date().toISOString(),\n    meta: { zone, tempF, deviceId, sampledAt, severity },\n    userId\n  }\n} }];"
      },
      "id": "Fn_EvalTemp",
      "name": "Function: Evaluate Temp",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        -840,
        -100
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [],
          "string": [],
          "number": [
            {
              "value1": "={{$json.inRange ? 0 : 1}}",
              "operation": "larger"
            }
          ]
        }
      },
