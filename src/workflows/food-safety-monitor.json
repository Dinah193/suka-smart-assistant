      "name": "HTTP: Get Recalls (past 14d)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        -620,
        520
      ]
    },
    {
      "parameters": {
        "functionCode": "const inv = Array.isArray($items('HTTP: Get Inventory Brands', 0, 0)[0]?.json) ? $items('HTTP: Get Inventory Brands', 0, 0)[0].json : ($items('HTTP: Get Inventory Brands', 0, 0)[0]?.json?.brands || []);\nconst recalls = items[0]?.json?.results || items[0]?.json || [];\nconst brands = inv.map(x => String(x).toLowerCase());\nconst hits = [];\nfor (const r of recalls) {\n  const desc = (r.product_description || r.recall_initiation_date || JSON.stringify(r)).toLowerCase();\n  const m = brands.find(b => b && desc.includes(b));\n  if (m) hits.push({ recall: r, match: m });\n}\nreturn [{ json: { count: hits.length, hits } }];"
      },
      "id": "Fn_FilterRecalls",
      "name": "Function: Filter Recalls vs Inventory",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        -400,
        520
