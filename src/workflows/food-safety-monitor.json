    {
      "parameters": {
        "functionCode": "const out = [];\nfor (const h of ($json.hits || [])) {\n  const r = h.recall;\n  out.push({ json: {\n    title: `Recall alert: ${h.match}`,\n    category: 'food-safety',\n    labels: ['recall', h.match],\n    priority: 1,\n    due: new Date().toISOString(),\n    meta: { recall: r }\n  }});\n}\nreturn out.length ? out : [{ json: { skip: true } }];"
      },
