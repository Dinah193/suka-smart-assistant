{
  "$id": "https://suka.local/schemas/yieldCurve.dairy.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Suka Dairy / Livestock / Poultry Yield Curve",
  "description": "Schema for yield curves (dairy: goat/cow, poultry: eggs) that can feed cleaning, garden, storehouse, meal, inventory, and animal-care engines. Includes reverse-generation + user favorites + Hebrew-calendar awareness.",
  "type": "object",
  "required": [
    "version",
    "meta",
    "curve"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Local/relative path to this schema so editors can validate."
    },
    "version": {
      "type": "string",
      "description": "ISO timestamp for versioning"
    },
    "meta": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "species": {
          "type": "string",
          "description": "e.g. caprine, bovine, poultry. Not required to be breed-specific."
        },
        "breed": {
          "type": "string",
          "description": "Optional. Leave out for standard/non-breed-specific profiles."
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "calendar": {
          "type": "object",
          "properties": {
            "hebrewMonthStart": { "type": "string" },
            "supportsAltStart": { "type": "boolean" },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "description": "UI hints for the app (cards, timeline, badge colors, etc.)",
      "additionalProperties": true
    },
    "engines": {
      "type": "object",
      "properties": {
        "primary": { "type": "string" },
        "supports": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "orchestration": {
      "type": "object",
      "description": "Glue to window.__suka?.eventBus and shared scopes.",
      "properties": {
        "bus": { "type": "string" },
        "emitOnLoad": {
          "type": "array",
          "items": { "type": "string" }
        },
        "listen": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sharedScopes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "reverse": {
      "type": "object",
      "description": "Reverse generation: start from storehouse/meal/coop targets -> produce dairy/egg/animal schedule.",
      "properties": {
        "generateFrom": {
          "type": "array",
          "items": { "type": "string" }
        },
        "strategies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "input": { "type": "object" },
              "output": { "type": "object" }
            },
            "required": ["id", "title"]
          }
        }
      },
      "additionalProperties": true
    },
    "curve": {
      "type": "object",
      "required": ["units", "base"],
      "properties": {
        "units": {
          "type": "string",
          "enum": [
            "liters-per-day",
            "gallons-per-day",
            "kg-per-day",
            "eggs-per-day",
            "eggs-per-week"
          ]
        },
        "lactationWindowDays": {
          "type": "integer",
          "minimum": 1,
          "description": "For poultry/eggs, treat as production window days."
        },
        "base": {
          "type": "array",
          "description": "Primary time series of the curve",
          "items": {
            "type": "object",
            "required": ["day", "value"],
            "properties": {
              "day": { "type": "integer", "minimum": 1 },
              "value": { "type": "number", "minimum": 0 },
              "stage": { "type": "string" }
            }
          }
        },
        "weeklyView": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["week", "avg"],
            "properties": {
              "week": { "type": "integer", "minimum": 1 },
              "avg": { "type": "number", "minimum": 0 }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "adjustments": {
      "type": "object",
      "description": "Adjust curve by climate, feed, litter size, age class (for poultry), etc.",
      "properties": {
        "byClimateZone": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["zone", "multiplier"],
            "properties": {
              "zone": { "type": "string" },
              "multiplier": { "type": "number" },
              "notes": { "type": "string" }
            }
          }
        },
        "byFeedQuality": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["level", "multiplier"],
            "properties": {
              "level": { "type": "string" },
              "multiplier": { "type": "number" }
            }
          }
        },
        "byLitterSize": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kidding", "multiplier"],
            "properties": {
              "kidding": { "type": "string" },
              "multiplier": { "type": "number" }
            }
          }
        },
        "byAgeClass": {
          "type": "array",
          "description": "For poultry: pullets, 1st-year, 2nd-year, 3rd-year etc.",
          "items": {
            "type": "object",
            "required": ["age", "multiplier"],
            "properties": {
              "age": { "type": "string" },
              "multiplier": { "type": "number" },
              "notes": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "storehouse": {
      "type": "object",
      "description": "Storehouse stock planner link: dairy/eggs -> targets -> inventory.",
      "properties": {
        "targets": {
          "type": "object",
          "additionalProperties": {
            "type": ["number", "string", "boolean"]
          }
        },
        "grocerySectionsInspiration": {
          "type": "array",
          "items": { "type": "string" }
        },
        "autoPlan": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "emit": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "meals": {
      "type": "object",
      "description": "Meal-planning hooks – define recipes/sessions that consume this output.",
      "properties": {
        "recipes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "useWithinHours": { "type": "number" },
              "linksTo": {
                "type": "array",
                "items": { "type": "string" }
              },
              "emit": { "type": "string" }
            }
          }
        },
        "autoSession": {
          "type": "object",
          "properties": {
            "everyDays": { "type": "number" },
            "emit": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "garden": {
      "type": "object",
      "description": "Garden / compost / whey / soiled-bedding use hooks.",
      "additionalProperties": true
    },
    "cleaning": {
      "type": "object",
      "description": "Cleaning / sanitizing sessions emitted from dairy/egg tasks.",
      "properties": {
        "routines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "frequency": { "type": "string" },
              "emit": { "type": "string" },
              "tools": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        },
        "sabbathGuard": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "animals": {
      "type": "object",
      "description": "Animal acquisition/care/butchery integration.",
      "properties": {
        "acquisition": {
          "type": "object",
          "properties": {
            "allowedSpecies": {
              "type": "array",
              "items": { "type": "string" }
            },
            "disallowedSpecies": {
              "type": "array",
              "items": { "type": "string" }
            },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        },
        "care": {
          "type": "object",
          "properties": {
            "milkingPerDay": { "type": "number" },
            "collectionPerDay": {
              "type": "number",
              "description": "For poultry/eggs: how many collections per day"
            },
            "hoovesPerYear": { "type": "number" },
            "dewormSchedule": { "type": "string" },
            "emit": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "butchery": {
          "type": "object",
          "properties": {
            "notes": { "type": "string" },
            "emit": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "favoriteSessions": {
      "type": "array",
      "description": "User + system session templates that can be saved.",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "domain": { "type": "string" },
          "schedule": { "type": "string" },
          "sabbathGuard": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "scheduleTemplates": {
      "type": "array",
      "description": "RRULE-based schedule patterns (daily milking, 2x egg collection, weekly coop clean, weekly cheese day, etc.)",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "rrules": {
            "type": "array",
            "items": { "type": "string" }
          },
          "options": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "userProfiles": {
      "type": "object",
      "description": "Permissions for user-owned favorites/schedules/export.",
      "properties": {
        "allowUserOwnedSchedules": { "type": "boolean" },
        "allowUserOwnedFavorites": { "type": "boolean" },
        "allowExportShare": { "type": "boolean" },
        "shareFormats": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "events": {
      "type": "object",
      "properties": {
        "emits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "consumes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
