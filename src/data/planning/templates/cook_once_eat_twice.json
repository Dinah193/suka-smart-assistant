              "mealType": "dinner",
              "status": "planned",
              "labels": ["Remix #2 (No-Cook/Reheat tilt)"],
              "recipeRef": { "recipeId": "rec_beef_pita_salad_10m", "versionId": "v1", "servings": 6 },
              "sabbathSensitive": false
            }
          ]
        }
      }
    }
  ]
}
