        "group": "utility"
      }
    },
    {
      "id": "freezer-room",
      "label": "Freezer / Cold Storage Room",
      "kind": "utility",
      "priority": 2,
      "sabbathAllowed": true,
      "quietHoursAllowed": true,
      "supports": [
        "storehouse.intake.expected",
        "animals.butchery",
        "garden.harvest.cold"
      ],
      "reverseGeneration": {
        "enabled": true,
        "listensFor": [
          "animals.butchery.completed",
          "garden.harvest.logged"
        ],
        "emit": [
          "cleaning.storehouse-meat-intake",
          "cleaning.storehouse-harvest-sanitize"
        ]
      },
      "uiHints": {
        "icon": "snowflake",
        "group": "utility"
      }
    }
  ],
  "userCanSaveFavorites": true,
  "favoritesTemplate": [
    {
      "id": "fav-zone-sabbath-prep",
      "source": "system",
      "cloneOf": "kitchen-main",
      "label": "My Kitchen Sabbath Prep",
      "allowUserScheduleOverride": true
    },
    {
      "id": "fav-zone-harvest-to-pantry",
      "source": "system",
      "cloneOf": "garden-processing-area",
      "label": "My Harvest → Pantry Flow",
      "allowUserScheduleOverride": true
    }
  ],
  "userFavoritePolicy": {
    "maxPerHousehold": 50,
    "allowCustomSchedule": true,
    "allowCustomGuards": [
      "sabbathGuard",
      "quietHoursGuard"
    ]
  }
}
