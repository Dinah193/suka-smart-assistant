        "cleaning.garden-bin-sanitize"
      ],
      "reverseGeneration": {
        "enabled": true,
        "listensFor": [
          "garden.harvest.logged"
        ],
        "emit": [
          "cleaning.garden-bin-sanitize"
        ]
      },
      "climate": {
        "zone": "8b",
        "heatTolerance": "high",
        "humidityTolerance": "high"
      },
      "uiHints": {
