      ],
      "reverseGeneration": {
        "enabled": true,
        "listensFor": [
          "animals.butchery.completed",
          "animals.large-butchery.generated"
        ],
        "emit": [
          "cleaning.processing-area.requested",
          "storehouse.intake.expected"
        ],
        "rules": [
          {
            "id": "butchery-cleaning",
            "ifEvent": "animals.butchery.completed",
            "generate": "cleaning.animal-processing"
          }
        ]
      },
      "climate": {
        "zone": "8b",
        "heatTolerance": "high"
      },
      "uiHints": {
        "icon": "knife",
        "group": "processing"
      }
    },
    {
      "id": "fermentation-room",
      "label": "Fermentation / Preservation Room",
      "kind": "utility",
      "priority": 2,
      "sabbathAllowed": true,
      "quietHoursAllowed": true,
      "supports": [
        "meals.batch-cooking",
