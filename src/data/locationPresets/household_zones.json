      }
    },
    {
      "id": "animal-processing-bay",
      "label": "Animal Processing / Butchery Bay",
      "kind": "outdoor",
      "priority": 1,
      "sabbathAllowed": false,
      "quietHoursAllowed": false,
      "supports": [
        "animals.butchery",
        "animals.processing",
        "cleaning.processing-area",
