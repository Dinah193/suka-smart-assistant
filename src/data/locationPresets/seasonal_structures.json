{
  "version": "2025-10-31T13:45:00-05:00",
  "description": "Seasonal / feast / temporary outdoor structures for Suka Smart Assistant. Used for Sukkot/Feast prep, outdoor batch cooking, temporary harvest stations, overflow storehouse staging, animal shade in extreme heat, and event-based cleaning. Only active in specific months/seasons. Supports user-owned favorites and schedules. Reverse generation so calendar/feast/garden/animals/storehouse events can light these up.",
  "meta": {
    "sourceOfTruth": "scraper",
    "allowHubOverrides": true,
    "mergeStrategy": "scraper-wins",
    "ingestionPipelines": [
      "scraperService",
      "importService",
      "bookmarklet",
      "linked-accounts"
    ],
    "sharedOrchestration": {
      "emitOnUpdate": true,
      "reason": "seasonal-structures-update",
      "channels": [
        "calendar",
        "cleaning",
        "meals",
        "garden",
        "storehouse",
        "animals"
      ]
    },
    "notes": [
      "Do NOT include Jewish traditions / Talmud / Mishna — this is for Torah-feast/Sukkot style events only.",
      "Meal planner and cleaning planner should check 'isActive' and 'seasonWindow' before scheduling here.",
      "Garden + animals can use these as covered processing/shade spaces if active."
    ]
  },
  "defaults": {
    "timezone": "America/Chicago",
    "sabbathGuard": true,
    "quietHoursGuard": true,
    "onMismatch": "allow-with-mitigation",
    "supportsReverseGeneration": true
  },
  "structures": [
