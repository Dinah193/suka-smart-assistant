    {
      "id": "garden-spring-8b-intensive",
      "label": "Spring – Zone 8b Intensive Beds",
      "zone": "8b",
      "season": "spring",
      "layout": {
        "type": "raised-beds",
        "beds": [
          {
            "id": "bed-1",
            "crop": "tomato",
            "variety": "roma",
            "count": 12,
            "spacingInches": 18,
            "purpose": "sauce/canning"
          },
          {
            "id": "bed-2",
            "crop": "pepper",
            "variety": "jalapeno",
            "count": 10,
