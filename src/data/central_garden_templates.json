      "importService",
      "scraperService",
      "bookmarklet",
      "linked-accounts"
    ],
    "mergeStrategy": "scraper-wins",
    "allowHubOverrides": true,
    "overrideFields": [
      "storehouseMapping",
      "collaboration",
      "sabbathGuard",
      "zones"
    ],
    "sharedOrchestration": {
      "emitOnUpdate": true,
