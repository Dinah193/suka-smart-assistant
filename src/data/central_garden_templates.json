        "pest": {
          "monitorEveryDays": 3,
          "emitOnPressure": "garden.pest-pressure.detected"
        },
        "cleaning": {
          "afterCareEmit": [
            "cleaning.garden-bin-sanitize",
            "cleaning.tool-sanitize"
          ]
        }
      },
      "harvestProfile": {
        "expectedStart": "2025-04-15",
        "expectedEnd": "2025-06-30",
        "cadence": "2x-week",
        "logAs": "garden.harvest.logged",
        "storehouseMapping": [
          {
            "crop": "tomato",
            "toStorehouse": "preservedTomato",
            "method": "pressure-can",
            "batchSizeLbs": 10,
            "emit": [
              "storehouse.intake.expected",
              "meals.refresh.requested"
            ]
          },
          {
            "crop": "pepper",
            "toStorehouse": "ferments",
            "method": "brine-ferment"
          },
          {
            "crop": "greens",
            "toStorehouse": "frozenGreens",
            "method": "blanch-freeze"
          }
        ]
      },
      "reverseGeneration": {
        "enabled": true,
        "rules": [
          {
            "id": "garden-to-meals",
            "ifHarvestIn": ["tomato", "greens", "pepper"],
            "generate": "meal-plan-from-harvest",
            "emit": [
              "meals.plan.fromHarvest.requested"
            ]
          },
          {
            "id": "storehouse-goal-to-garden",
            "ifStorehouseNeeds": ["preservedTomato", "frozenGreens"],
            "generate": "garden-planting-plan-from-storehouse-goal",
            "copyContext": ["zone", "season"]
          },
          {
            "id": "pest-pressure-to-animals",
            "ifGardenEvent": "garden.pest-pressure.detected",
            "generate": "animal-mobile-tractor-session",
            "emit": [
              "animals.garden-assist.requested",
              "cleaning.garden-area.expected"
            ]
          }
        ]
      },
      "collaboration": {
        "enabled": true,
        "mode": "co-op",
        "capacityHouseholds": 5,
        "sharedOutputs": [
          "preservedTomato",
          "ferments",
          "frozenGreens"
        ],
        "notes": "Use when multiple households agree: one grows heavy tomatoes, another peppers, etc. This template is 1/3 of that plan."
      },
      "uiHints": {
        "icon": "sprout",
        "group": "spring",
        "color": "green"
