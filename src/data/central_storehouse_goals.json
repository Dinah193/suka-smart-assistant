          "meals.sabbath-cooking.planned"
        ],
        "rules": [
          {
            "id": "feast-upcoming-to-meals",
            "ifEvent": "calendar.feast.upcoming",
            "generate": "meals.plan.fromFeast",
            "emit": [
              "meals.plan.fromFeast.requested"
            ]
          },
          {
            "id": "feast-upcoming-to-cleaning",
            "ifEvent": "calendar.feast.upcoming",
            "generate": "cleaning.sabbath-prep",
            "emit": [
              "cleaning.sabbath-prep.requested"
            ]
          }
        ]
      },
      "collaboration": {
        "enabled": true,
        "mode": "co-op",
        "capacityHouseholds": 20,
        "shareable": true,
        "notes": "Co-op can pre-position feast-day foods together; households pull what they need on their calendar schedule."
      },
      "uiHints": {
        "icon": "calendar-star",
        "group": "feast",
        "color": "emerald"
      }
    },
    {
