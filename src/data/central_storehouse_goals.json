{
  "version": "2025-10-31T11:40:00-05:00",
  "description": "CENTRAL: storehouse goals for Suka Smart Assistant: 3-month pantry, feast-day pantry, preservation pantry. Auto-fed by scrapers/ingestors (weekly ads, recipe/meal imports, garden harvest logs), with hub override for Torah/culture-specific observances and local co-op targets. Feeds Storehouse Planner, Inventory Monitor, MealPlanEngine, GardenQueueManager, Cleaning (storehouse visibility + intake sanitation), and Animal Planner (when meat/eggs are below target).",
  "meta": {
    "sourceOfTruth": "scraper",
    "lastIngestedAt": "2025-10-31T11:40:00-05:00",
    "ingestionPipelines": [
      "scraperService",
      "importService",
      "bookmarklet",
      "linked-accounts",
      "scan-compare-trust"
    ],
    "mergeStrategy": "scraper-wins",
    "allowHubOverrides": true,
    "overrideFields": [
      "torahFeastTargets",
      "coOpTargets",
      "sabbathGuard",
      "preservationMethods"
    ],
    "sharedOrchestration": {
      "emitOnUpdate": true,
      "reason": "scraper-update",
      "channels": [
        "storehouse",
        "inventory",
        "meals",
        "garden",
        "cleaning",
        "animals"
      ]
    },
    "notes": [
      "Scraper/ingestor can bump goal quantities when new meal plans, garden harvests, or sale/coupon events arrive.",
      "Hub can lock specific feast-day and Torah-required stock even if the scraper wants to reduce it.",
      "This file tries to keep ‘grocery section’ style groupings so it’s familiar like well-executed pantry/meal sites.",
      "Integrates with your rule: users can save THEIR goals/schedules, not just the system goals."
    ]
  },
  "defaults": {
    "timezone": "America/Chicago",
    "goalWindowDays": 90,
    "autoGenerateCleaning": true,
    "autoGenerateGarden": true,
    "autoGenerateMealPlans": true,
    "autoGenerateAnimalProvisioning": true,
    "grocerySections": [
      "produce",
      "dry-goods",
      "baking",
      "ferments",
      "freezer",
      "meat",
      "eggs-dairy",
      "oils-condiments",
      "hygiene"
    ]
  },
  "goals": [
    {
      "id": "storehouse-3mo-pantry",
      "label": "3-Month Pantry (Household Core)",
      "type": "duration",
      "durationDays": 90,
      "grocerySections": [
        "produce",
        "dry-goods",
        "baking",
        "freezer",
        "eggs-dairy",
        "oils-condiments",
        "hygiene"
      ],
      "items": [
        {
          "sku": "flour-wheat-hard",
          "label": "Hard Wheat / Flour",
          "section": "baking",
          "targetQty": 50,
          "unit": "lb",
          "preservationMethods": ["dry-store", "vac-seal"],
          "reverseGeneration": {
            "enabled": true,
            "rules": [
              {
                "id": "low-flour-meal-gen",
                "ifBelowPct": 0.3,
                "generate": "meal-plan-low-flour",
                "emit": [
                  "meals.plan.fromStorehouse.requested"
                ]
              },
              {
                "id": "low-flour-garden-gen",
                "ifBelowPct": 0.3,
                "generate": "garden-grains-or-feed-plan",
                "emit": [
                  "garden.plan.fromStorehouse.requested"
                ]
              }
            ]
          }
        },
        {
          "sku": "beans-black",
          "label": "Black Beans (Dry or Canned)",
          "section": "dry-goods",
          "targetQty": 24,
          "unit": "lb",
          "preservationMethods": ["dry-store", "pressure-can"],
          "reverseGeneration": {
            "enabled": true,
            "rules": [
              {
                "id": "beans-low-trigger-cleaning",
                "ifBelowPct": 0.2,
                "generate": "cleaning.storehouse-bin-sanitize",
                "emit": [
                  "cleaning.session.created"
                ]
              },
              {
                "id": "beans-low-trigger-meal",
                "ifBelowPct": 0.2,
                "generate": "meal-plan-from-beans",
                "emit": [
                  "meals.plan.fromStorehouse.requested"
                ]
              }
            ]
          }
        },
        {
          "sku": "rice-long-grain",
          "label": "Rice (Long Grain)",
          "section": "dry-goods",
          "targetQty": 40,
          "unit": "lb",
          "reverseGeneration": {
            "enabled": true,
            "rules": [
              {
                "id": "rice-low",
                "ifBelowPct": 0.25,
                "generate": "import.pricebook-best-rice",
                "emit": [
                  "scan.compare-trust.requested"
                ]
              }
            ]
          }
        },
        {
          "sku": "meat-lamb",
          "label": "Lamb / Mutton (from own animals)",
          "section": "meat",
          "targetQty": 30,
          "unit": "lb",
          "source": "animals",
          "reverseGeneration": {
            "enabled": true,
            "rules": [
              {
                "id": "meat-lamb-low",
                "ifBelowPct": 0.35,
                "generate": "animals.plan.fromStorehouse.low-lamb",
                "emit": [
                  "animals.plan.fromStorehouse.generated",
                  "cleaning.processing-area.requested",
                  "storehouse.intake.expected"
                ],
                "copyContext": [
                  "householdId",
                  "timezone"
                ]
              }
            ]
          }
        },
        {
          "sku": "eggs-dozen",
          "label": "Eggs (dozens)",
          "section": "eggs-dairy",
          "targetQty": 12,
          "unit": "dozen",
          "source": "animals/poultry",
          "reverseGeneration": {
            "enabled": true,
            "rules": [
              {
                "id": "eggs-low",
                "ifBelowPct": 0.3,
                "generate": "animals.poultry-production-boost",
                "emit": [
                  "animals.poultry-production.generated"
                ]
              }
            ]
          }
        }
      ],
      "reverseGeneration": {
        "enabled": true,
        "listensFor": [
          "inventory.item.below-threshold",
          "storehouse.visibility.logged",
          "meals.plan.created",
          "garden.harvest.logged",
          "animals.butchery.completed"
        ],
        "rules": [
          {
            "id": "visibility-to-cleaning",
            "ifEvent": "storehouse.visibility.logged",
            "generate": "cleaning.storehouse-visibility-pass",
            "emit": [
              "cleaning.session.created"
            ]
          },
          {
            "id": "meals-to-storehouse",
            "ifEvent": "meals.plan.created",
            "generate": "storehouse.provision-from-meal",
            "emit": [
              "storehouse.provision.requested"
            ]
          },
          {
            "id": "harvest-to-storehouse",
            "ifEvent": "garden.harvest.logged",
            "generate": "storehouse.intake.from-garden",
            "emit": [
              "storehouse.intake.expected",
              "cleaning.storehouse-harvest-sanitize"
            ]
          }
        ]
      },
      "collaboration": {
        "enabled": true,
        "mode": "plan-with-others",
        "capacityHouseholds": 10,
        "shareable": true,
        "tradeable": true,
        "notes": "Allows multiple allied households to maintain a 90-day buffer together while each has their own pantry view."
      },
      "uiHints": {
        "icon": "pantry",
        "group": "core",
        "color": "amber"
      }
    },
