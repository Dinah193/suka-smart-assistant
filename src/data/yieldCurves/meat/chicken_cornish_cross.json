          "sheetpan_clean"
        ]
      }
    ],
    "reverse_generation": {
      "can_generate_animal_plan": true,
      "handler_event": "animal.plan.requested",
      "notes": "If a month has 6 roasts + 3 soups + 2 parts meals, propose ‘raise 20 Cornish X’ and schedule butchery 6–8 weeks ahead."
    }
  },
  "garden_integration": {
    "purpose": "Even though Cornish is not a pass bird, the meals it produces need the same pantry garden (carrot, onion, celery, greens) so we still tell the garden planner what to grow.",
    "crops_to_recommend": [
      {
        "crop": "carrot",
        "use_case": "roast sides, soup base",
        "harvest_window": "spring-fall",
        "preservation": ["pressure can", "dehydrate"],
        "cleaning_profile_ref": "garden_root"
      },
      {
        "crop": "onion",
        "use_case": "soup/roast base",
        "harvest_window": "late summer",
        "preservation": ["cure", "store dry"],
        "cleaning_profile_ref": "garden_root"
      },
      {
        "crop": "celery",
        "use_case": "soup/broth base",
        "harvest_window": "cool season",
        "preservation": ["freeze", "dehydrate"],
        "cleaning_profile_ref": "garden_light"
      },
      {
        "crop": "greens",
        "use_case": "sides",
        "harvest_window": "cool seasons",
        "preservation": ["blanch-freeze"],
        "cleaning_profile_ref": "garden_light"
      }
    ],
    "reverse_generation": {
      "when_meat_menu_fixed_event": "garden.plan.adjust.requested",
      "notes": "If the meal planner commits to weekly Cornish roast + weekly soup, garden should schedule onion/celery/carrot and add harvest reminders."
    }
  },
  "animal_care_and_butchery": {
    "pre_slaughter_care_checklist": [
      "12hr feed withdrawal",
      "clean water until 2hr before",
      "shade/low-stress holding",
      "inspect for disease",
      "torah_compliant_tools_ready"
    ],
    "butchery_session_template": {
      "id": "butchery-session-chicken-cornish",
      "label": "Cornish Cross – Poultry Processing Day",
      "estimated_duration_hours": 3,
      "scales_with_bird_count": true,
      "roles_needed": [
        "scalder/plucker",
        "eviscerator",
        "chill-station",
        "sanitation-runner"
      ],
      "outputs": [
        "whole_birds",
        "parted_birds",
        "stock_packs",
        "organs"
      ],
      "emits_events": [
        "inventory.add.requested",
        "storehouse.update.requested",
        "cleaning.plan.requested",
        "mealplan.refresh.requested",
        "garden.plan.adjust.requested"
      ],
      "scheduling": {
        "supports_user_favorites": true,
        "supports_recurring": true,
        "supports_coop_mode": true,
        "coop_mode_notes": "Co-op / family fund members can bring their Cornish X to the same day; cleaning must scale."
      }
    },
    "cleaning_after_butchery": {
      "cleaning_profile_id": "poultry_sanitation_heavy",
      "label": "Post-Cornish Poultry Sanitation",
      "tasks": [
        "collect offal for compost/render/blood-meal line",
        "wash scalders, pluckers, evisceration tables",
        "sanitize with poultry-safe, torah-safe cleaner",
        "mop floor / drains",
        "launder aprons/towels"
      ],
      "emits_events": [
        "cleaning.log.added",
        "inventory.cleaning-supplies.decrement"
      ]
    }
  },
