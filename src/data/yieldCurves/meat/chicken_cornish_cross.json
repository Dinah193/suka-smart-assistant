          "garlic",
          "greens"
        ],
        "cleaning_profiles": [
          "poultry_sanitation_heavy",
          "oven_tray_deep_clean"
        ]
      },
      {
        "id": "mt-cornish-soup",
        "label": "Cornish Chicken Soup / Broth Batch",
        "uses_cuts": [
          {
            "cut_id": "cornish_stock",
            "qty_lb": 2.5
          }
        ],
        "suggested_sides": [
          "bread",
