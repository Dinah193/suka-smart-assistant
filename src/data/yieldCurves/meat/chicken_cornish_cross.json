          "noodles"
        ],
        "garden_suggestions": [
          "celery",
          "carrot",
          "onion",
          "parsley"
        ],
        "cleaning_profiles": [
          "poultry_sanitation_heavy"
        ]
      },
      {
        "id": "mt-cornish-parts",
        "label": "Cornish Parts → Fry/Grill",
        "uses_cuts": [
          {
            "cut_id": "cornish_parts",
            "qty_lb": 3.5
          }
        ],
        "suggested_sides": [
          "salad",
          "fermented veg",
          "fries"
        ],
        "garden_suggestions": [
          "lettuce",
