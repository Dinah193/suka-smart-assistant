{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2025-10-31T14:58:00-05:00",
  "description": "Meat yield curve for Cornish Cross / Cornish-X broilers – tuned for your Suka Smart Assistant multi-domain pipeline. This one assumes: (1) fast grow-out, (2) limited or no garden passes (bio-safety), (3) high storehouse demand for whole + parted + stock packs, (4) meal planner pushes a lot of chicken meals, (5) cleaning/sanitation is STRONGER than the garden-pass birds, (6) reverse generation from storehouse & meal & feast days, and (7) users can save their own butchery-day templates/schedules in Dexie.",
  "__notes": [
    "This is your ‘industrial’ / high-yield bird, so we do NOT default to garden passes like we did for chicken_garden_pass.json. We CAN support a very controlled pass (short, supervised), but defaults should be OFF.",
    "It stays schema-compatible with your existing chicken_ranger.json and garden-pass poultry JSONs so your ImportService.js can treat them all the same.",
    "We also added storehouse grocery inspiration based on big-box stores (Costco, Walmart, Sam’s) because Cornish Cross aligns best with those cuts.",
    "Reverse generation: storehouse shortage for ‘Poultry → Whole → Cornish’ → back into ‘grow 25 Cornish X’ and schedule butchery ~8 weeks out."
  ],
  "animal": {
    "species": "chicken",
    "breed": "Cornish Cross",
    "class": "poultry",
    "high_yield": true,
    "garden_pass_capable": false,
    "typical_live_weight_lbs": [5.5, 6, 6.5, 7],
    "default_live_weight_lbs": 6.25,
    "live_to_dressed_yield_pct": 0.74,
    "dressed_to_cut_yield_pct": 0.9,
    "default_chill_hours": 0.5,
    "butchery_style_default": "whole-bird",
    "butchery_supported_styles": [
      "whole-bird",
      "parted-8pc",
      "bone-in-breast + thighs + drumsticks",
      "stock-pack / broth-pack",
      "poultry-torah-compliant-no-unclean-cross-contamination"
    ],
    "torah_compliant_profile": {
      "allow_unclean_animals": false,
      "separate_tools_required": true,
      "separate_surfaces_required": true,
      "blood_draining_required": true,
      "notes": "This profile is meant for clean, controlled grow-out → slaughter → process. Do NOT mix with unclean animals."
    }
  },
  "yield_model": {
    "formula_hint": "dressed = live_weight * live_to_dressed_yield_pct; cut_weight = dressed * dressed_to_cut_yield_pct",
    "example": {
      "live_weight_lbs": 6.25,
      "live_to_dressed_yield_pct": 0.74,
      "dressed_to_cut_yield_pct": 0.9,
      "calculated_dressed_weight_lbs": 4.625,
      "calculated_cut_weight_lbs": 4.1625
    },
    "cut_profile_defaults": [
      {
        "cut_id": "cornish_whole",
        "label": "Cornish Cross – Whole Bird",
        "default_pct_of_dressed": 0.62,
        "storehouse_section_hint": "Meat → Poultry → Whole Birds",
        "mealplanner_tags": [
          "roast-chicken",
          "batch-cook",
          "sabbath"
        ],
        "inventory_unit": "bird",
        "preservation": ["freeze", "brine-freeze"],
        "cleaning_profile_ref": "poultry_sanitation_heavy"
      },
      {
        "cut_id": "cornish_parts",
        "label": "Cornish – Parts (thigh/drum/breast/wing)",
        "default_pct_of_dressed": 0.3,
        "storehouse_section_hint": "Meat → Poultry → Parts",
        "mealplanner_tags": [
          "fry",
          "grill",
          "sheet-pan",
          "kid-friendly"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze", "vac-seal"],
        "cleaning_profile_ref": "poultry_sanitation_heavy"
      },
      {
        "cut_id": "cornish_stock",
        "label": "Cornish – Stock / Broth Pack",
        "default_pct_of_dressed": 0.05,
        "storehouse_section_hint": "Meat → Poultry → Stock Pack",
        "mealplanner_tags": [
          "broth",
          "soup",
          "pressure-can"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze"],
        "cleaning_profile_ref": "poultry_sanitation_heavy"
      },
      {
        "cut_id": "cornish_organs",
        "label": "Cornish – Giblets (liver, heart, gizzard)",
        "default_pct_of_dressed": 0.01,
        "storehouse_section_hint": "Meat → Poultry → Organs",
        "mealplanner_tags": [
          "gravy",
          "dog-food",
          "nutrient-dense"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze"],
        "cleaning_profile_ref": "poultry_sanitation_heavy"
      }
    ]
  },
  "storehouse_mapping": {
    "purpose": "Map Cornish X butchery output → storehouse goals → inventory execution, with grocery-section inspiration from big-box & warehouse clubs.",
    "sections": [
      {
        "id": "STH-POULTRY-WHOLE-CORNISH",
        "label": "Meat → Poultry → Whole (Cornish Cross)",
        "target_inventory_unit": "bird",
        "auto_replenish_from": [
          "cornish_whole"
        ],
        "grocery_inspo": [
          "Costco – rotisserie/whole",
          "Sam’s Club – family pack",
          "Walmart – whole chicken"
        ]
      },
      {
        "id": "STH-POULTRY-PARTS-CORNISH",
        "label": "Meat → Poultry → Parts (Cornish)",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "cornish_parts"
        ],
        "grocery_inspo": [
          "Walmart – value pack thighs/drums",
          "Kroger – family pack"
        ]
      },
      {
        "id": "STH-POULTRY-STOCK-CORNISH",
        "label": "Meat → Poultry → Stock / Broth (Cornish)",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "cornish_stock"
        ],
        "grocery_inspo": [
          "Warehouse – bone broth starter",
          "Asian market – backs/necks"
        ]
      }
    ],
    "reverse_generation_rules": [
      {
        "id": "RG-CORNISH-WHOLE",
        "when_event": "storehouse.goal.short.cornish-whole",
        "action": "calc required whole birds → map to live Cornish X → emit automation.schedule.request (poultry-butchery + cleaning + mealplan.refresh)",
        "notes": "If storehouse wants 30 whole birds, schedule 30 live birds for butchery."
      },
      {
        "id": "RG-CORNISH-PARTS",
        "when_event": "storehouse.goal.short.cornish-parts",
        "action": "calc required lb → back-calc to birds → emit automation.schedule.request"
      }
    ]
  },
  "meal_planner_hooks": {
    "default_meal_templates": [
      {
        "id": "mt-cornish-roast",
        "label": "Roast Cornish Bird + Garden Root Veg",
        "uses_cuts": [
