      {
        "id": "STH-GOAT-FROZEN",
        "label": "Meat → Goat → Frozen",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "goat_curry_cubes",
          "goat_ground",
          "goat_ribs_breast",
