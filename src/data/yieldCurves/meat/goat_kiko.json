    "reverse_generation_rules": [
      {
        "id": "RG-GOAT-FEAST",
        "when_event": "mealplanner.requests.meat.goat.feast",
        "action": "estimate feast portions → map to goat legs + shoulders → map to live goats → emit automation.schedule.request (butchery, cleaning, storehouse)",
        "notes": "Use for big family/community meals – ‘many hands make light work’ co-op planning."
      },
      {
        "id": "RG-GOAT-STOREHOUSE",
        "when_event": "storehouse.goal.short.goat-curry",
        "action": "trigger animal.acquisition.plan('goat-kiko') and goat-butchery.session.generate"
      }
    ]
  },
