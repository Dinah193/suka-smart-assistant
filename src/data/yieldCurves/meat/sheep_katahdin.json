      "label": "Post-Lamb Butchery Sanitation",
      "tasks": [
        "bag offal / byproducts for compost/render/blood-meal line",
        "wash tables, knives, tubs",
        "sanitize with torah-safe cleaner",
        "mop floor",
        "launder aprons/towels"
      ],
      "emits_events": [
        "cleaning.log.added",
        "inventory.cleaning-supplies.decrement"
      ]
    }
