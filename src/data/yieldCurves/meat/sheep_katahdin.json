  "animal_care_and_butchery": {
    "pre_slaughter_care_checklist": [
      "fasting_window_8hr",
      "clean_water_available",
      "low_stress_handling",
      "inspect_for_disease",
      "torah_compliant_tools_ready"
    ],
    "butchery_session_template": {
      "id": "butchery-session-sheep-katahdin",
      "label": "Katahdin – Household Lamb Butchery",
      "estimated_duration_hours": 2,
      "roles_needed": [
        "primary-butcher",
        "assistant",
        "sanitation-runner"
      ],
      "outputs": [
        "whole_or_halves",
        "retail_cuts",
        "bones",
        "offal",
        "fat_for_rendering"
      ],
      "emits_events": [
        "inventory.add.requested",
        "storehouse.update.requested",
        "cleaning.plan.requested",
        "mealplan.refresh.requested",
        "garden.plan.adjust.requested"
      ],
      "scheduling": {
        "supports_user_favorites": true,
        "supports_recurring": true,
        "supports_coop_mode": true,
        "coop_mode_notes": "Multiple households can bring sheep and share knives/tables → Cleaning module must schedule a bigger sanitation job."
      }
