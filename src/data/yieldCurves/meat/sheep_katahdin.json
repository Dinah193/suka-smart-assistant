  "storehouse_mapping": {
    "purpose": "Map Katahdin lamb/mutton output → storehouse goals → inventory execution.",
    "sections": [
      {
        "id": "STH-LAMB-FRESH",
        "label": "Meat → Lamb → Fresh / Chilled",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "lamb_leg_whole",
          "lamb_shoulder_roast",
          "lamb_chops"
        ],
        "grocery_inspo": [
          "Mediterranean groceries – lamb",
          "Halal butchers – fresh lamb"
        ]
      },
      {
        "id": "STH-LAMB-FROZEN",
        "label": "Meat → Lamb → Frozen",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "lamb_stew_cubes",
          "lamb_ground",
          "lamb_bones"
        ],
        "grocery_inspo": [
          "Costco – frozen lamb",
          "Restaurant supply – frozen lamb legs"
        ]
      },
      {
        "id": "STH-LAMB-PRESERVED",
        "label": "Meat → Lamb → Preserved / Canned / Smoked",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "lamb_stew_cubes",
          "lamb_bones"
        ],
        "grocery_inspo": [
          "North African pantry",
          "Middle Eastern dried meats"
        ]
      }
    ],
    "reverse_generation_rules": [
      {
        "id": "RG-FEAST-LAMB",
        "when_event": "mealplanner.requests.meat.lamb.feast",
        "action": "estimate feast portions → map to lamb legs + shoulders → map to live sheep → emit automation.schedule.request (butchery + cleaning + storehouse)",
        "notes": "Use for Sukkot / Hanukkah-style feasts (your 2025-10-30 Hanukkah research)."
      },
      {
        "id": "RG-STOREHOUSE-LAMB",
        "when_event": "storehouse.goal.short.lamb-ground",
        "action": "trigger animal.acquisition.plan('sheep-katahdin') and lamb-butchery.session.generate"
      }
    ]
  },
