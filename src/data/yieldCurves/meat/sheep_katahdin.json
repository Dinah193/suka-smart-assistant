{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2025-10-31T13:55:00-05:00",
  "description": "Meat yield curve for hair sheep – Katahdin. Built for Suka Smart Assistant so that lamb/mutton butchery → storehouse → meal planner → garden → cleaning → reverse generation all talk to each other. Katahdin chosen because you already have it in your business context (sheep + butchery + blood meal) and it’s a low-maintenance, meat-forward, parasite-aware breed.",
  "__notes": [
    "This follows the same multi-domain pattern as beef_brangus.json, beef_senepol.json, and cattle_dexter.json so your ImportService / ImportNormalizer can treat all yieldCurves uniformly.",
    "Because sheep → smaller carcass, this file is more preservation- and feast-friendly, and to match your Torah-compliant context, there is no unclean cross-contamination.",
    "Reverse generation is especially useful here: if your meal planner or feast calendar says ‘we need lamb for Feast day on X’, this file gives the runtime enough info to generate an animal plan + butchery session + cleaning + garden sides.",
    "User favorites: users can save their preferred cut mix (more ground vs more roasts vs more stew) in Dexie; they don’t edit this file directly."
  ],
  "animal": {
    "species": "sheep",
    "breed": "Katahdin",
    "class": "lamb/mutton",
    "hair_sheep": true,
    "typical_live_weight_lbs": [90, 110, 130, 150],
    "default_live_weight_lbs": 120,
    "live_to_hanging_yield_pct": 0.5,
    "hanging_to_carcass_yield_pct": 0.72,
    "default_hanging_days": 3,
    "butchery_style_default": "whole-carcass-or-halves",
    "butchery_supported_styles": [
      "whole-carcass-or-halves",
      "roasts + ground",
      "stew-heavy",
      "bbq/smoking",
      "halal/torah-compliant-no-unclean-cross-contamination"
    ],
    "torah_compliant_profile": {
      "allow_unclean_animals": false,
      "separate_tools_required": true,
      "separate_surfaces_required": true,
      "blood_draining_required": true,
      "notes": "Pairs with your USDA/Torah facility design (no pork; separate tables; sheep-specific cleaning)."
    }
  },
  "yield_model": {
    "formula_hint": "carcass = live_weight * live_to_hanging_yield_pct * hanging_to_carcass_yield_pct",
    "example": {
      "live_weight_lbs": 120,
      "live_to_hanging_yield_pct": 0.5,
      "hanging_to_carcass_yield_pct": 0.72,
      "calculated_hanging_weight_lbs": 60,
      "calculated_carcass_weight_lbs": 43.2
