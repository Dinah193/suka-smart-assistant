          "sheetpan_clean"
        ]
      }
    ],
    "reverse_generation": {
      "can_generate_animal_plan": true,
      "handler_event": "animal.plan.requested",
      "notes": "If user pins 4 roast birds + 2 soup weeks, emit animal.plan.requested with breed ‘Kosher King’ and grow-out date 9–11 weeks earlier for southern heat."
    }
  },
  "garden_integration": {
    "purpose": "Connect chicken meal demand to easy southern garden crops – especially the broth trio (onion/celery/carrot) and greens.",
    "crops_to_recommend": [
      {
        "crop": "carrot",
        "use_case": "roast & soup",
        "harvest_window": "spring-fall",
        "preservation": ["pressure can", "dehydrate"],
        "cleaning_profile_ref": "garden_root"
      },
      {
        "crop": "onion",
        "use_case": "all chicken meals",
        "harvest_window": "late summer",
        "preservation": ["cure", "store dry"],
        "cleaning_profile_ref": "garden_root"
      },
      {
        "crop": "celery",
        "use_case": "broth/soup base",
        "harvest_window": "cool season",
        "preservation": ["freeze", "dehydrate"],
        "cleaning_profile_ref": "garden_light"
      },
      {
        "crop": "greens",
        "use_case": "sides",
        "harvest_window": "cool seasons",
        "preservation": ["blanch-freeze"],
        "cleaning_profile_ref": "garden_light"
      }
    ],
    "reverse_generation": {
      "when_meat_menu_fixed_event": "garden.plan.adjust.requested",
      "notes": "If Kosher King is the main poultry in the month, garden must schedule the broth trio and send harvest reminders to the calendar."
    }
  },
  "animal_care_and_butchery": {
    "pre_slaughter_care_checklist": [
      "10–12hr feed withdrawal",
      "clean water until 2hr before",
      "shade/low-stress holding (heat + humidity in the South)",
      "inspect for disease/parasites",
      "torah_compliant_tools_ready"
    ],
    "butchery_session_template": {
      "id": "butchery-session-chicken-kosher-king",
      "label": "Kosher King – Clean Poultry Processing Day",
      "estimated_duration_hours": 3,
      "scales_with_bird_count": true,
      "roles_needed": [
        "scalder/plucker",
        "eviscerator",
        "chill-station",
        "sanitation-runner"
      ],
      "outputs": [
        "whole_birds",
        "parted_birds",
        "stock_packs",
        "organs"
      ],
      "emits_events": [
        "inventory.add.requested",
        "storehouse.update.requested",
        "cleaning.plan.requested",
        "mealplan.refresh.requested",
        "garden.plan.adjust.requested"
      ],
      "scheduling": {
        "supports_user_favorites": true,
        "supports_recurring": true,
        "supports_coop_mode": true,
        "coop_mode_notes": "Family fund / co-op can bring their Kosher King birds to the same processing day – sanitation must run at the end."
      }
    },
    "cleaning_after_butchery": {
      "cleaning_profile_id": "poultry_sanitation_torah",
      "label": "Post–Kosher King Poultry Sanitation",
      "tasks": [
        "collect offal for compost/render/blood-meal",
        "wash scalders, pluckers, evisceration tables",
        "sanitize with torah-safe cleaner",
        "mop floor / drains",
        "launder aprons/towels"
      ],
      "emits_events": [
        "cleaning.log.added",
        "inventory.cleaning-supplies.decrement"
      ]
    }
  },
