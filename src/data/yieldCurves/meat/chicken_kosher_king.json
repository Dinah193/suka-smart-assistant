{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2025-10-31T15:12:00-05:00",
  "description": "Meat yield curve for ‘Kosher King’ / clean hybrid meat bird – tuned for southern U.S. Israelites. Slower and hardier than Cornish Cross, more controlled than garden-pass birds, and good on pasture in heat/humidity. This profile plugs into Suka Smart Assistant to: (1) schedule flock acquisition → (2) grow-out → (3) butchery day → (4) storehouse stock planning (grocery-style sections) → (5) meal planning (roast, parts, broth) → (6) cleaning/sanitation (torah-safe) → (7) reverse generation from storehouse/meal/garden. User-owned favorites & schedules are expected to be saved in Dexie/local DB, not in this file.",
  "__notes": [
    "Purpose: give you a Cornish-Cross alternative that still feels ‘modern’ but fits torah-compliant, warm-climate, smallholder/co-op processing days.",
    "Follows the same structure as chicken_ranger.json and chicken_cornish_cross.json we just built, so ImportService.jsx and ImportSettings.jsx don’t need new branching.",
    "We assume this bird is *allowed* to forage and pasture, but we keep garden passes OPTIONAL, not default.",
    "We also assume you want to trigger cleaning sessions across cleaning, meals, garden, and storehouse whenever this bird is processed."
  ],
  "animal": {
    "species": "chicken",
    "breed": "Kosher King",
    "class": "poultry",
    "warm_zone_preset": true,
    "pasture_suitable": true,
    "garden_pass_capable": true,
    "typical_live_weight_lbs": [4.75, 5.25, 5.75, 6.25],
    "default_live_weight_lbs": 5.5,
    "live_to_dressed_yield_pct": 0.72,
    "dressed_to_cut_yield_pct": 0.9,
    "default_chill_hours": 0.5,
    "butchery_style_default": "whole-bird",
    "butchery_supported_styles": [
      "whole-bird",
      "parted-8pc",
      "bone-in-breast + thighs + drumsticks",
      "stock-pack / broth-pack",
      "poultry-torah-compliant-no-unclean-cross-contamination"
    ],
    "torah_compliant_profile": {
      "allow_unclean_animals": false,
      "separate_tools_required": true,
      "separate_surfaces_required": true,
      "blood_draining_required": true,
      "notes": "Use this profile inside USDA + Torah-compliant plants: label equipment ‘poultry-clean’ and run poultry sanitation after each batch."
    }
  },
  "yield_model": {
    "formula_hint": "dressed = live_weight * live_to_dressed_yield_pct; cut_weight = dressed * dressed_to_cut_yield_pct",
    "example": {
      "live_weight_lbs": 5.5,
      "live_to_dressed_yield_pct": 0.72,
      "dressed_to_cut_yield_pct": 0.9,
      "calculated_dressed_weight_lbs": 3.96,
      "calculated_cut_weight_lbs": 3.564
    },
    "cut_profile_defaults": [
      {
        "cut_id": "kk_whole",
        "label": "Kosher King – Whole Bird",
        "default_pct_of_dressed": 0.6,
        "storehouse_section_hint": "Meat → Poultry → Whole Birds (Clean)",
        "mealplanner_tags": [
          "roast-chicken",
          "sabbath",
          "family-meal"
        ],
        "inventory_unit": "bird",
        "preservation": ["freeze", "brine-freeze"],
        "cleaning_profile_ref": "poultry_sanitation_torah"
      },
      {
        "cut_id": "kk_parts",
        "label": "Kosher King – Parts (thigh/drum/breast/wing)",
        "default_pct_of_dressed": 0.32,
        "storehouse_section_hint": "Meat → Poultry → Parts (Clean)",
        "mealplanner_tags": [
          "fry",
          "grill",
          "sheet-pan"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze", "vac-seal"],
        "cleaning_profile_ref": "poultry_sanitation_torah"
      },
      {
        "cut_id": "kk_stock",
        "label": "Kosher King – Stock / Broth Pack",
        "default_pct_of_dressed": 0.05,
        "storehouse_section_hint": "Meat → Poultry → Stock Pack",
        "mealplanner_tags": [
          "broth",
          "soup",
          "pressure-can"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze"],
        "cleaning_profile_ref": "poultry_sanitation_torah"
      },
      {
        "cut_id": "kk_organs",
        "label": "Kosher King – Giblets (liver, heart, gizzard)",
        "default_pct_of_dressed": 0.01,
        "storehouse_section_hint": "Meat → Poultry → Organs",
        "mealplanner_tags": [
          "gravy",
          "nutrient-dense",
          "dog-food"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze"],
        "cleaning_profile_ref": "poultry_sanitation_torah"
      }
    ]
  },
  "garden_pass_profiles": {
    "purpose": "Allow *optional* pest passes for this bird (short, supervised), because households in the South often battle slugs, grasshoppers, and dropped fruit pests.",
    "enabled_by_default": false,
    "passes": [
      {
        "id": "kk-short-pest-pass",
        "label": "Kosher King – Short Pest Pass",
        "duration_minutes": 20,
        "allowed_seasons": ["spring", "summer", "early-fall"],
        "requires_supervision": true,
        "post_pass_cleaning_profile": "poultry_sanitation_light",
        "emits_events": [
          "garden.pestpass.completed",
          "garden.log.updated"
        ]
      }
    ],
    "reverse_generation": {
      "when_garden_detects_pest_event": "poultry.garden-pass.requested",
      "notes": "Automation runtime should check ‘is this flock allowed garden passes?’ before assigning this bird. We set enabled_by_default=false to keep bio-safety tight."
    }
  },
  "storehouse_mapping": {
    "purpose": "Map Kosher King to storehouse sections so users see ‘clean poultry’ as an inspirational grocery-like lane.",
    "sections": [
      {
        "id": "STH-POULTRY-WHOLE-KK",
        "label": "Meat → Poultry → Whole (Kosher King)",
        "target_inventory_unit": "bird",
        "auto_replenish_from": [
          "kk_whole"
        ],
        "grocery_inspo": [
          "Clean/pasture poultry section",
          "Farmer’s market chilled poultry"
        ]
      },
      {
        "id": "STH-POULTRY-PARTS-KK",
        "label": "Meat → Poultry → Parts (Kosher King)",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "kk_parts"
        ],
        "grocery_inspo": [
          "Butcher case – premium chicken parts",
          "Halal shop – clean parts"
        ]
      },
      {
        "id": "STH-POULTRY-STOCK-KK",
        "label": "Meat → Poultry → Stock / Broth (Kosher King)",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "kk_stock"
        ],
        "grocery_inspo": [
          "Broth kits / soup packs",
          "Shabbat soup starter"
        ]
      }
    ],
    "reverse_generation_rules": [
      {
        "id": "RG-KK-WHOLE",
        "when_event": "storehouse.goal.short.kosher-king-whole",
        "action": "calc required whole birds → map to live Kosher King → emit automation.schedule.request (poultry-butchery + cleaning + mealplan.refresh)",
        "notes": "Used when a householder wants ‘12 clean birds in freezer’ before a feast/hot season."
      },
      {
        "id": "RG-KK-PARTS",
        "when_event": "storehouse.goal.short.kosher-king-parts",
        "action": "calc required lb of parts → back-calc to birds → emit automation.schedule.request"
      }
    ]
  },
  "meal_planner_hooks": {
