    "reverse_generation": {
      "can_generate_animal_plan": true,
      "handler_event": "animal.plan.requested",
      "notes": "When a family locks in 8–10 lb beef for the month and has small cold storage, ask Dexter first."
    }
  },
  "garden_integration": {
    "purpose": "Connect Dexter beef meals to home garden crops, especially for small households.",
    "crops_to_recommend": [
      {
        "crop": "tomato",
        "use_case": "sauce for ground beef pasta",
        "harvest_window": "summer",
        "preservation": ["can", "freeze"],
        "cleaning_profile_ref": "garden_light"
      },
      {
        "crop": "onion",
        "use_case": "base for roasts/stews",
        "harvest_window": "late summer",
        "preservation": ["cure", "store dry"],
        "cleaning_profile_ref": "garden_root"
      },
      {
        "crop": "carrot",
        "use_case": "roast side, soup, broth",
        "harvest_window": "spring-fall (succession)",
        "preservation": ["pressure can", "dehydrate"],
        "cleaning_profile_ref": "garden_root"
      },
      {
        "crop": "greens",
        "use_case": "side dish to beef meals",
        "harvest_window": "cool seasons",
        "preservation": ["blanch-freeze"],
        "cleaning_profile_ref": "garden_light"
      }
    ],
    "reverse_generation": {
      "when_meat_menu_fixed_event": "garden.plan.adjust.requested",
      "notes": "If family chooses Dexter roast + stew often, schedule onions/carrots in garden and send harvest window to calendar."
    }
  },
  "animal_care_and_butchery": {
    "pre_slaughter_care_checklist": [
      "fasting_window_8hr",
      "fresh_water_available",
      "low_stress_handling",
      "inspect_for_disease",
      "torah_compliant_tools_ready"
    ],
    "butchery_session_template": {
      "id": "butchery-session-cattle-dexter",
      "label": "Dexter – Family-Scale Butchery",
      "estimated_duration_hours": 4,
      "roles_needed": [
        "primary-butcher",
        "assistant",
        "sanitation-runner"
      ],
      "outputs": [
        "primal_cuts",
        "retail_cuts",
        "bones",
        "offal",
        "rendering_fat"
      ],
      "emits_events": [
        "inventory.add.requested",
        "storehouse.update.requested",
        "cleaning.plan.requested",
        "mealplan.refresh.requested",
        "garden.plan.adjust.requested"
      ],
      "scheduling": {
        "supports_user_favorites": true,
        "supports_recurring": true,
        "supports_coop_mode": true,
        "coop_mode_notes": "Co-op households can each bring 1 Dexter; output is manageable for each freezer."
      }
    },
    "cleaning_after_butchery": {
      "cleaning_profile_id": "meat_heavy_sanitation",
      "label": "Post-Butchery Heavy Sanitation",
      "tasks": [
        "collect offal / byproducts for compost or render (if allowed)",
        "wash food-contact surfaces",
        "sanitize with torah-safe cleaner",
        "mop floor",
        "launder aprons/towels"
      ],
      "emits_events": [
        "cleaning.log.added",
        "inventory.cleaning-supplies.decrement"
      ]
    }
  },
