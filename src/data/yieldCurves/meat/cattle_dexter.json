        ],
        "inventory_unit": "lb",
        "preservation": ["freeze"],
        "cleaning_profile_ref": "meat_heavy_sanitation"
      }
    ]
  },
  "storehouse_mapping": {
    "purpose": "Map family-scale Dexter butchery output → storehouse goals & inventory execution.",
    "sections": [
      {
        "id": "STH-MEAT-FRESH",
        "label": "Meat → Fresh / Chilled",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "dexter_ground",
          "dexter_roast",
          "dexter_steak"
        ],
        "grocery_inspo": [
          "Aldi → Fresh meat (small packs)",
          "Lidl → Beef (small families)"
        ]
      },
      {
        "id": "STH-MEAT-FROZEN",
        "label": "Meat → Frozen",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "dexter_ground",
          "dexter_stew",
          "dexter_brisket",
          "dexter_soup_bones"
        ],
        "grocery_inspo": [
          "Costco → but in single-family portioning",
          "Farm freezer share"
        ]
      },
      {
        "id": "STH-MEAT-PRESERVED",
        "label": "Meat → Preserved / Canned / Smoked",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "dexter_stew",
          "dexter_soup_bones"
        ],
        "grocery_inspo": [
          "Canned beef (Caribbean / African markets)",
          "Homestead pantry – pressure-canned beef"
        ]
      }
    ],
    "reverse_generation_rules": [
      {
        "id": "RG-MEAL-TO-DEXTER",
        "when_event": "mealplanner.requests.meat.beef.family",
        "action": "estimate required beef → map to Dexter carcass → map to live animals → emit automation.schedule.request",
        "notes": "This is the family-scale path. If user says ‘I only have a chest freezer’, pick Dexter instead of large-frame."
      },
      {
        "id": "RG-STOREHOUSE-TO-BUTCHERY",
        "when_event": "storehouse.goal.short.beef-dexter",
        "action": "trigger animal.acquisition.plan('cattle-dexter') and butchery.session.generate"
      }
    ]
  },
  "meal_planner_hooks": {
    "default_meal_templates": [
      {
        "id": "mt-dexter-ground-family",
        "label": "Dexter Ground – Family Weeknight (2–3 meals)",
        "uses_cuts": [
          {
            "cut_id": "dexter_ground",
            "qty_lb": 2
          }
        ],
        "suggested_sides": [
          "rice",
          "garden veg",
          "bread"
        ],
        "garden_suggestions": [
          "tomato",
          "onion",
          "bell pepper",
          "leafy greens"
        ],
