{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2025-10-31T13:40:00-05:00",
  "description": "Meat yield curve for small-frame cattle – Dexter. Tuned for family-scale butchery and for Suka Smart Assistant’s cross-domain flow: animal acquisition → butchery → storehouse stock planning (with grocery-section inspiration) → meal planning → garden planning/care/harvest → cleaning/sanitation → reverse generation → user-favoriteable sessions/schedules.",
  "__notes": [
    "Dexters are ideal for your 'family-scale' path where you don’t want 450–500 lb of carcass showing up at once.",
    "This JSON follows the same high-signal structure as beef_brangus.json and beef_senepol.json so your import/normalizer can treat them uniformly.",
    "Reverse generation works in both directions: (1) meal/storehouse → how many Dexters do we need and when? (2) animal/butchery planned → tell meals/storehouse/garden/cleaning what to do.",
    "User favorites are referenced, but actual user data should live in Dexie/local DB."
  ],
  "animal": {
    "species": "cattle",
    "breed": "Dexter",
    "class": "beef",
    "small_frame": true,
    "family_scale": true,
    "typical_live_weight_lbs": [550, 650, 750, 850],
    "default_live_weight_lbs": 700,
    "live_to_hanging_yield_pct": 0.58,
    "hanging_to_carcass_yield_pct": 0.7,
    "default_hanging_days": 7,
    "butchery_style_default": "family-kitchen",
    "butchery_supported_styles": [
      "family-kitchen",
      "bbq/smoking",
      "low-waste",
      "bulk-ground",
      "halal/torah-compliant-no-unclean-cross-contamination"
    ],
    "torah_compliant_profile": {
      "allow_unclean_animals": false,
      "separate_tools_required": true,
      "separate_surfaces_required": true,
      "blood_draining_required": true,
      "notes": "Use this when scheduling butchery inside a Torah-compliant, no-pork facility. Cleaning module should pick torah-safe cleaner sets."
    }
  },
  "yield_model": {
    "formula_hint": "carcass = live_weight * live_to_hanging_yield_pct * hanging_to_carcass_yield_pct",
    "example": {
      "live_weight_lbs": 700,
      "live_to_hanging_yield_pct": 0.58,
      "hanging_to_carcass_yield_pct": 0.7,
      "calculated_hanging_weight_lbs": 406,
      "calculated_carcass_weight_lbs": 284.2
    },
    "primal_breakdown_pct": {
      "chuck": 0.25,
      "rib": 0.08,
      "loin": 0.15,
      "round": 0.22,
      "brisket": 0.06,
      "plate_flank": 0.07,
      "other_trim_fat_bones": 0.17
    },
    "retail_cut_defaults": [
      {
        "cut_id": "dexter_ground",
        "label": "Ground Beef (Dexter)",
        "source_primals": ["chuck", "round", "trim"],
        "default_pct_of_carcass": 0.19,
        "storehouse_section_hint": "Meat → Ground / Mince → Beef",
        "mealplanner_tags": [
          "family-quick",
          "tacos",
          "spaghetti",
          "meat-sauce",
          "batch-cookable"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze", "pressure-can"],
        "cleaning_profile_ref": "meat_standard_sanitation"
      },
      {
        "cut_id": "dexter_roast",
        "label": "Dexter Pot Roast",
        "source_primals": ["chuck"],
        "default_pct_of_carcass": 0.055,
        "storehouse_section_hint": "Meat → Roasts → Beef",
        "mealplanner_tags": [
          "slow-cooker",
          "sabbath/feast",
          "root-veg"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze", "smoke"],
        "cleaning_profile_ref": "meat_heavy_sanitation"
      },
      {
        "cut_id": "dexter_steak",
        "label": "Dexter Family Steaks",
        "source_primals": ["rib", "loin"],
        "default_pct_of_carcass": 0.04,
        "storehouse_section_hint": "Meat → Steaks → Family",
        "mealplanner_tags": [
          "grill",
          "pan-sear",
          "special-meal"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze", "vac-seal"],
        "cleaning_profile_ref": "meat_standard_sanitation"
      },
      {
        "cut_id": "dexter_brisket",
        "label": "Dexter Brisket (smaller)",
        "source_primals": ["brisket"],
        "default_pct_of_carcass": 0.055,
        "storehouse_section_hint": "Meat → Roasts → Brisket",
        "mealplanner_tags": [
          "smoke",
          "event",
          "holiday"
        ],
        "inventory_unit": "lb",
        "preservation": ["smoke", "freeze"],
        "cleaning_profile_ref": "meat_heavy_sanitation"
      },
      {
        "cut_id": "dexter_stew",
        "label": "Dexter Stew Meat",
        "source_primals": ["chuck", "round"],
        "default_pct_of_carcass": 0.06,
        "storehouse_section_hint": "Meat → Stew / Curry",
        "mealplanner_tags": [
          "soups",
          "curries",
          "winter"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze", "pressure-can"],
        "cleaning_profile_ref": "meat_standard_sanitation"
      },
      {
        "cut_id": "dexter_soup_bones",
        "label": "Soup / Marrow Bones (Dexter)",
        "source_primals": ["other_trim_fat_bones"],
        "default_pct_of_carcass": 0.035,
        "storehouse_section_hint": "Meat → Bones / Broth Base",
        "mealplanner_tags": [
          "bone-broth",
