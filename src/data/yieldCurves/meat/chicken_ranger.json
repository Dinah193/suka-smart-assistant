  "animal_care_and_butchery": {
    "pre_slaughter_care_checklist": [
      "12hr feed withdrawal",
      "clean water available until 2hr before",
      "shade/low-stress holding",
      "inspect for disease",
      "torah_compliant_tools_ready"
    ],
    "butchery_session_template": {
      "id": "butchery-session-chicken-ranger",
      "label": "Ranger Chicken – Poultry Processing Day",
      "estimated_duration_hours": 3,
      "scales_with_bird_count": true,
      "roles_needed": [
        "scalder/plucker",
        "eviscerator",
        "chill-station",
        "sanitation-runner"
      ],
      "outputs": [
        "whole_birds",
        "parted_birds",
        "stock_packs",
        "organs",
        "feathers (compost or disposal)"
      ],
      "emits_events": [
        "inventory.add.requested",
        "storehouse.update.requested",
        "cleaning.plan.requested",
        "mealplan.refresh.requested",
        "garden.plan.adjust.requested"
      ],
      "scheduling": {
        "supports_user_favorites": true,
        "supports_recurring": true,
        "supports_coop_mode": true,
        "coop_mode_notes": "Co-op / family fund members can bring their own ranger birds to the same setup. Cleaning module must schedule BIG poultry sanitation after."
      }
    },
    "cleaning_after_butchery": {
      "cleaning_profile_id": "poultry_sanitation",
      "label": "Post-Poultry Processing Sanitation",
      "tasks": [
        "collect feathers and offal for compost/render/blood-meal line",
        "wash scalders, pluckers, evisceration tables",
        "sanitize with poultry-safe, torah-safe cleaner",
        "mop floor / drains",
        "launder aprons/towels"
      ],
      "emits_events": [
        "cleaning.log.added",
        "inventory.cleaning-supplies.decrement"
      ]
    }
  },
