{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2025-10-31T14:35:00-05:00",
  "description": "Meat yield curve for pasture / freedom / 'color' meat chickens – Ranger / Freedom Ranger. Designed for Suka Smart Assistant multi-domain flow: flock acquisition → grow-out → butchery day → storehouse stock planning (with grocery-section inspo) → meal planning (whole, parted, broth, batch cook) → garden planning/care/harvest (feed + soup veg) → cleaning/sanitation (poultry) → reverse generation (from storehouse/meal/feast). Users can save favorite sessions & schedules in Dexie; this JSON defines system defaults.",
  "__notes": [
    "Ranger-type birds are a common homestead alternative to Cornish X; they dress a bit smaller and slower, but more flavorful, and often better suited for warm zones you mentioned.",
    "We keep naming/layout consistent with goat/sheep/cattle yieldCurves so ImportService.js can load them all and present one ImportPreview modal.",
    "Reverse generation is important for chicken because users often plan ‘I want 24 whole birds in the freezer’ OR ‘I need 16 parted packs + 5 broth bags’ → we convert to live bird count + butchery day + cleaning."
  ],
  "animal": {
    "species": "chicken",
    "breed": "Ranger",
    "class": "poultry",
    "pasture_suitable": true,
    "typical_live_weight_lbs": [4.5, 5, 5.5, 6],
    "default_live_weight_lbs": 5.25,
    "live_to_dressed_yield_pct": 0.72,
    "dressed_to_cut_yield_pct": 0.9,
    "default_chill_hours": 0.5,
    "butchery_style_default": "whole-bird",
    "butchery_supported_styles": [
      "whole-bird",
      "parted-8pc",
      "bone-in-breast + thighs + drumsticks",
      "stock-pack / broth-pack",
      "poultry-torah-compliant-no-unclean-cross-contamination"
    ],
    "torah_compliant_profile": {
      "allow_unclean_animals": false,
      "separate_tools_required": true,
      "separate_surfaces_required": true,
      "blood_draining_required": true,
      "notes": "Schedule poultry sanitation after butchery and keep it separate from red-meat sanitation."
    }
  },
  "yield_model": {
    "formula_hint": "dressed = live_weight * live_to_dressed_yield_pct; cut_weight = dressed * dressed_to_cut_yield_pct",
    "example": {
      "live_weight_lbs": 5.25,
      "live_to_dressed_yield_pct": 0.72,
      "dressed_to_cut_yield_pct": 0.9,
      "calculated_dressed_weight_lbs": 3.78,
      "calculated_cut_weight_lbs": 3.40
    },
    "cut_profile_defaults": [
      {
        "cut_id": "chicken_whole_ranger",
        "label": "Whole Ranger Bird",
        "default_pct_of_dressed": 0.65,
        "storehouse_section_hint": "Meat → Poultry → Whole Birds",
        "mealplanner_tags": [
          "roast-chicken",
          "shabbat/sabbath",
          "batch-cook"
        ],
        "inventory_unit": "bird",
        "preservation": ["freeze", "brine-freeze"],
        "cleaning_profile_ref": "poultry_sanitation"
      },
      {
        "cut_id": "chicken_parts_ranger",
        "label": "Parted – Thigh/Drum/Breast/Wing",
        "default_pct_of_dressed": 0.3,
        "storehouse_section_hint": "Meat → Poultry → Parts",
        "mealplanner_tags": [
          "fried-chicken",
          "grill",
          "sheet-pan"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze", "vac-seal"],
        "cleaning_profile_ref": "poultry_sanitation"
      },
      {
        "cut_id": "chicken_stock_bones",
        "label": "Stock / Broth Bones + Feet",
        "default_pct_of_dressed": 0.05,
        "storehouse_section_hint": "Meat → Poultry → Stock Pack",
        "mealplanner_tags": [
          "broth",
          "soup",
          "stew"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze"],
        "cleaning_profile_ref": "poultry_sanitation"
      },
      {
        "cut_id": "chicken_organs",
        "label": "Giblets (liver, heart, gizzard)",
        "default_pct_of_dressed": 0.01,
        "storehouse_section_hint": "Meat → Poultry → Organs",
        "mealplanner_tags": [
          "gravy",
          "dog-food",
          "nutrient-dense"
        ],
        "inventory_unit": "lb",
        "preservation": ["freeze"],
        "cleaning_profile_ref": "poultry_sanitation"
      }
    ]
  },
  "storehouse_mapping": {
    "purpose": "Map Ranger chicken butchery output → storehouse goals → inventory execution (freezer, chilled, canned broth).",
    "sections": [
      {
        "id": "STH-POULTRY-WHOLE",
        "label": "Meat → Poultry → Whole Birds",
        "target_inventory_unit": "bird",
        "auto_replenish_from": [
          "chicken_whole_ranger"
        ],
        "grocery_inspo": [
          "Costco → whole chicken twin pack",
          "Aldi → small whole chicken",
          "Halal grocer → whole bird"
        ]
      },
      {
        "id": "STH-POULTRY-PARTS",
        "label": "Meat → Poultry → Parts",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "chicken_parts_ranger"
        ],
        "grocery_inspo": [
          "Walmart → Value pack thighs/drums",
          "Trader Joe’s → air-chilled parts"
        ]
      },
      {
        "id": "STH-POULTRY-STOCK",
        "label": "Meat → Poultry → Stock / Broth Base",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "chicken_stock_bones"
        ],
        "grocery_inspo": [
          "Whole Foods → broth kits",
          "Asian markets → backs/necks/feet"
        ]
      },
      {
        "id": "STH-POULTRY-ORGANS",
        "label": "Meat → Poultry → Organs",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "chicken_organs"
        ],
        "grocery_inspo": [
          "Ethnic markets → gizzards/hearts"
        ]
      }
    ],
    "reverse_generation_rules": [
      {
        "id": "RG-CHICKEN-WHOLE",
        "when_event": "storehouse.goal.short.whole-chickens",
        "action": "calc required whole birds → map to live ranger birds → emit automation.schedule.request (poultry-butchery + cleaning + mealplan.refresh)",
        "notes": "If storehouse says ‘we want 18 whole birds’ we figure 18 live birds + 1 butchery day."
      },
      {
        "id": "RG-CHICKEN-PARTS",
        "when_event": "storehouse.goal.short.chicken-parts",
        "action": "calc required parts → back-calc to birds → emit automation.schedule.request"
      }
    ]
  },
