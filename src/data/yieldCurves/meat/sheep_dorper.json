    }
  },
  "scheduling_and_favorites": {
    "can_be_favorited": true,
    "favorite_key": "yieldcurve:meat:sheep_dorper",
    "suggested_schedules": [
      {
        "id": "sched-dorper-spring-feast",
        "label": "Dorper – Spring Feast Cycle",
        "rule": "FREQ=YEARLY;BYMONTH=4;BYDAY=SU;BYSETPOS=1",
        "creates": [
          "butchery-session-sheep-dorper",
          "cleaning:sheep_meat_sanitation",
          "storehouse:update",
          "mealplan:refresh",
          "garden.plan.adjust.requested"
        ]
      },
      {
        "id": "sched-dorper-bi-monthly",
        "label": "Dorper Every 2 Months",
        "rule": "FREQ=MONTHLY;INTERVAL=2;BYDAY=SA;BYSETPOS=1",
        "creates": [
          "butchery-session-sheep-dorper"
        ]
      }
    ],
    "shared_orchestration": {
      "event_bus_path": "window.__suka.eventBus",
      "events_emitted": [
        "yieldcurve.loaded",
        "yieldcurve.butchery.session.generated",
        "storehouse.goal.derived",
        "cleaning.session.derived",
        "mealplan.refresh.requested",
        "garden.plan.adjust.requested"
      ],
      "events_listened_for": [
        "automation.schedule.request",
        "mealplanner.menu.locked",
        "storehouse.goal.short",
        "garden.plan.adjust.requested"
      ]
    }
  },
  "reverse_generation": {
    "enabled": true,
    "scenarios": [
      {
        "id": "RG-DORPER-01",
        "source": "meal-planner",
        "input_example": {
          "dorper_grill_feasts": 2,
          "dorper_curry_meals": 3
        },
        "output_example": {
          "required_carcass_lb": 110,
          "required_live_sheep": 2,
          "suggested_date": "next-feast-window",
          "auto_cleaning_sessions": [
