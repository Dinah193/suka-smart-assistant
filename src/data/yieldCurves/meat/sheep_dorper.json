      {
        "id": "RG-DORPER-02",
        "source": "storehouse",
        "input_example": {
          "target_section": "STH-DORPER-FROZEN",
          "target_lb": 70
        },
        "output_example": {
          "required_carcass_lb": 105,
          "required_live_sheep": 2,
          "notes": "2 Dorper at ~50 lb carcass ≈ 100 lb; round to 2 for simplicity."
        }
      }
    ],
    "notes": "UI should offer: ‘Generate Dorper Butchery Day’, ‘Generate Cleaning After Dorper’, and ‘Adjust Garden for Dorper Menu’."
  },
  "user_overrides_placeholder": {
