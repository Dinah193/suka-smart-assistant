{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2025-10-31T13:25:00-05:00",
  "description": "Meat yield curve for Beef – Senepol (heat-tolerant). Built for Suka Smart Assistant cross-domain flows: animal acquisition → butchery → storehouse stock planning → meal planning → garden planning → cleaning/sanitation → reverse generation → user favorites.",
  "__notes": [
    "Senepol is heat-tolerant, so this profile can be preferred for your Southern / West African / Caribbean / Sahel style deployments that you talked about.",
    "Patterned to match beef_brangus.json but tuned slightly for Senepol (often a bit smaller and selected for tropics).",
    "This file is system-level. User overrides go to Dexie/local DB (your favorite sessions/schedules).",
    "Supports reverse generation: storehouse or meal plan can ask 'how many Senepol do we need, and when do we butcher?'"
  ],
  "animal": {
    "species": "cattle",
    "breed": "Senepol",
    "class": "beef",
    "heat_tolerant": true,
    "tropics_suitable": true,
    "typical_live_weight_lbs": [850, 950, 1050, 1150],
    "default_live_weight_lbs": 1000,
    "live_to_hanging_yield_pct": 0.58,
    "hanging_to_carcass_yield_pct": 0.71,
    "default_hanging_days": 8,
    "butchery_style_default": "household-standard",
    "butchery_supported_styles": [
      "household-standard",
      "bbq/smoking",
      "low-waste",
      "bulk-ground",
      "halal/torah-compliant-no-unclean-cross-contamination"
    ],
    "torah_compliant_profile": {
      "allow_unclean_animals": false,
      "separate_tools_required": true,
      "separate_surfaces_required": true,
      "blood_draining_required": true,
      "notes": "Same logic as Brangus, but exposed here so your USDA/Torah facility blueprint can pick from data."
    }
  },
  "yield_model": {
    "formula_hint": "carcass = live_weight * live_to_hanging_yield_pct * hanging_to_carcass_yield_pct",
    "example": {
      "live_weight_lbs": 1000,
      "live_to_hanging_yield_pct": 0.58,
      "hanging_to_carcass_yield_pct": 0.71,
      "calculated_hanging_weight_lbs": 580,
      "calculated_carcass_weight_lbs": 411.8
    },
    "primal_breakdown_pct": {
      "chuck": 0.26,
      "rib": 0.085,
      "loin": 0.16,
      "round": 0.215,
      "brisket": 0.05,
      "plate_flank": 0.065,
      "other_trim_fat_bones": 0.165
    },
