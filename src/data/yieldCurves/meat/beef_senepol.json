  "storehouse_mapping": {
    "purpose": "Map Senepol butchery output → storehouse goals → inventory execution.",
    "sections": [
      {
        "id": "STH-MEAT-FRESH",
        "label": "Meat → Fresh / Chilled",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "beef_ground",
          "beef_stew_meat",
          "beef_steak_senepol"
        ],
        "grocery_inspo": [
          "H-E-B → Beef (warm climate retail pattern)",
          "Caribbean groceries → Beef cuts"
        ]
      },
      {
        "id": "STH-MEAT-FROZEN",
        "label": "Meat → Frozen",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "beef_ground",
          "beef_roast_chuck",
          "beef_steak_senepol",
          "beef_brisket",
          "beef_soup_bones"
        ],
        "grocery_inspo": [
          "Costco → Frozen Meats",
          "Farm store co-op freezer"
        ]
      },
      {
        "id": "STH-MEAT-PRESERVED",
        "label": "Meat → Preserved / Canned / Smoked",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "beef_stew_meat",
          "beef_soup_bones"
        ],
        "grocery_inspo": [
          "Village market → Smoked meats",
          "Amish bulk → Canned meats"
        ]
      }
    ],
    "reverse_generation_rules": [
      {
        "id": "RG-MEAL-TO-SENEPOL",
        "when_event": "mealplanner.requests.meat.beef.senepol",
        "action": "estimate required beef → map to Senepol carcass → map to live animals → emit automation.schedule.request",
        "notes": "Use this when the meal plan prefers 'heat-tolerant' or 'local Senepol source.'"
      },
      {
        "id": "RG-STOREHOUSE-TO-BUTCHERY",
        "when_event": "storehouse.goal.short.beef-ground",
        "action": "trigger animal.acquisition.plan('beef-senepol') and butchery.session.generate"
      }
    ]
  },
