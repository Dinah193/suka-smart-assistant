  "storehouse_mapping": {
    "purpose": "Map Boer goat output → storehouse goals & inventory execution (family + co-op).",
    "sections": [
      {
        "id": "STH-BOER-FRESH",
        "label": "Meat → Boer Goat → Fresh / Chilled",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "boer_leg",
          "boer_shoulder"
        ],
        "grocery_inspo": [
          "West African butcher – fresh goat",
          "Caribbean grocery – fresh goat"
        ]
      },
      {
        "id": "STH-BOER-FROZEN",
        "label": "Meat → Boer Goat → Frozen",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "boer_curry_cubes",
          "boer_ground",
          "boer_ribs_breast",
          "boer_bones"
        ],
        "grocery_inspo": [
          "Restaurant supply – frozen goat chunks",
          "Ethnic markets – frozen goat"
        ]
      },
      {
        "id": "STH-BOER-PRESERVED",
        "label": "Meat → Boer Goat → Preserved / Canned / Smoked",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "boer_curry_cubes",
          "boer_bones"
        ],
        "grocery_inspo": [
          "West African pantry – smoked meats",
          "Caribbean stewed/canned goat"
        ]
      }
    ],
    "reverse_generation_rules": [
      {
        "id": "RG-BOER-FEAST",
        "when_event": "mealplanner.requests.meat.goat.boer.feast",
        "action": "estimate feast portions → map to Boer legs + shoulders → map to live goats → emit automation.schedule.request (butchery + cleaning + storehouse)",
        "notes": "Use this when your Feast / Sukkot / Hanukkah-as-original demands goat instead of lamb."
      },
      {
        "id": "RG-BOER-STOREHOUSE",
        "when_event": "storehouse.goal.short.boer-curry",
        "action": "trigger animal.acquisition.plan('goat-boer') and boer-butchery.session.generate"
      }
    ]
  },
