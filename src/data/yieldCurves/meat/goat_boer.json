    "reverse_generation": {
      "can_generate_animal_plan": true,
      "handler_event": "animal.plan.requested",
      "notes": "If user pins 3 Boer curries + 1 pepper soup in same warm month, emit this so Animals module can propose 1 Boer goat (110 lb live), plus post-butchery cleaning."
    }
  },
