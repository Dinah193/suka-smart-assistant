      {
        "cut_id": "boer_ground",
        "label": "Ground Boer (sausages/mixed dishes)",
        "source_primals": ["trim", "neck_shank_trim"],
        "default_pct_of_carcass": 0.09,
        "storehouse_section_hint": "Meat → Goat → Ground / Sausage",
