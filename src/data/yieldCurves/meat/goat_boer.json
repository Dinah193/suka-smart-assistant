{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2025-10-31T14:25:00-05:00",
  "description": "Meat yield curve for meat goat – Boer. This variant is for warm-zone presets (Gulf Coast, Caribbean, West/Central Africa, Sahel-adjacent) so it ties into your garden (peppers, okra, tomatoes), storehouse (frozen goat chunks, curry packs), meal planner (pepper soup, curry goat, grilled goat), cleaning (goat/butchery sanitation, grill clean), and shared orchestration (event bus). It supports user-favoriteable sessions/schedules via Dexie and supports reverse generation so storehouse or meal requests can produce animal acquisition + butchery jobs.",
  "__notes": [
    "Boer is usually a bit bigger and meatier than Kiko in smallholder contexts, so we bump default live weight and slightly better hanging yield.",
    "Pattern stays aligned with your other yieldCurves so ImportService.js / ImportSettings.jsx won’t have to special-case Boer.",
    "This file is system-level. Let users save their own ‘Goat – Curry Pack’ or ‘Goat – Feast Day’ templates in Dexie.",
    "Torah-compliant profile is included so your USDA-Torah facility configuration can filter out unclean sequences."
  ],
  "animal": {
    "species": "goat",
    "breed": "Boer",
    "class": "chevon/goat",
    "meat_goat": true,
    "warm_zone_preset": true,
    "typical_live_weight_lbs": [90, 105, 125, 145],
    "default_live_weight_lbs": 110,
    "live_to_hanging_yield_pct": 0.5,
    "hanging_to_carcass_yield_pct": 0.72,
    "default_hanging_days": 2,
    "butchery_style_default": "whole-or-primal-goat",
    "butchery_supported_styles": [
      "whole-or-primal-goat",
      "stew-heavy",
      "roast/BBQ",
      "halal/torah-compliant-no-unclean-cross-contamination"
    ],
    "torah_compliant_profile": {
      "allow_unclean_animals": false,
      "separate_tools_required": true,
      "separate_surfaces_required": true,
      "blood_draining_required": true,
      "notes": "Same rules as Kiko, but you can attach a ‘Boer only’ cleaning profile if you want heavier post-butchery sanitation."
    }
  },
  "yield_model": {
    "formula_hint": "carcass = live_weight * live_to_hanging_yield_pct * hanging_to_carcass_yield_pct",
    "example": {
      "live_weight_lbs": 110,
      "live_to_hanging_yield_pct": 0.5,
      "hanging_to_carcass_yield_pct": 0.72,
      "calculated_hanging_weight_lbs": 55,
      "calculated_carcass_weight_lbs": 39.6
    },
    "primal_breakdown_pct": {
      "leg": 0.24,
      "shoulder": 0.21,
      "loin": 0.11,
      "rib_breast": 0.09,
      "neck_shank_trim": 0.11,
      "fat_bones_other": 0.24
    },
    "retail_cut_defaults": [
