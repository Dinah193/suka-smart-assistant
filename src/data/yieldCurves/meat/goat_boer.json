  "animal_care_and_butchery": {
    "pre_slaughter_care_checklist": [
      "fasting_window_6hr",
      "clean_water_available",
      "shade/low_stress_handling",
      "inspect_for_disease_parasites",
      "torah_compliant_tools_ready"
    ],
    "butchery_session_template": {
      "id": "butchery-session-goat-boer",
      "label": "Boer Goat – Household / Co-op Butchery",
      "estimated_duration_hours": 1.75,
      "roles_needed": [
        "primary-butcher",
        "assistant",
        "sanitation-runner"
      ],
      "outputs": [
