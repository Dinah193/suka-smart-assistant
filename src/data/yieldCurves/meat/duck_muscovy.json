{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2025-10-31T15:23:00-05:00",
  "description": "Meat yield curve for Muscovy duck – tuned for Israelite households in the U.S. South building agrarian, Torah-compliant, multi-species systems inside the Suka Smart Assistant. Muscovy is heat-tolerant, excellent on pasture, powerful for insect control (flies/mosquitos near livestock), and gives a redder, leaner meat than most ducks. This profile is designed to: (1) schedule flock acquisition/grow-out, (2) support garden/orchard pest passes, (3) run a duck butchery day, (4) update storehouse with grocery-style sections, (5) suggest meal plans (roast, confit, stews), (6) auto-create cleaning/sanitation sessions using duck-safe/Torah-safe cleaners, and (7) support reverse generation from storehouse, meal, and garden events. User-owned templates, favorites, and schedules live in Dexie/local DB – this file just gives the system defaults.",
  "__notes": [
    "Muscovy is one of the best ‘hot climate’ waterfowl – perfect for your southern, Florida/AL/GA/TX contexts and your NW Nigeria/Burkina Faso ambitions.",
    "Unlike Cornish X, ducks will often have wetter, messier processing – so we add a DUCK sanitation profile and tie it to cleaning.",
    "We also tie Muscovy to your storehouse with inspiration from premium/ethnic grocers: confit, smoked duck, broth, fat for cooking, and offal.",
    "Reverse generation is important here because people don’t always think ‘I need to harvest ducks’ – they think ‘I want duck for Sukkot / feast / smoked meat’ → we turn it into a butchery day."
  ],
  "animal": {
    "species": "duck",
    "breed": "Muscovy",
    "class": "waterfowl",
    "warm_zone_preset": true,
    "pest_control_capable": true,
    "pasture_or_orchard_suitable": true,
    "typical_live_weight_lbs": [7, 8, 9, 10],
    "default_live_weight_lbs": 8.5,
    "live_to_dressed_yield_pct": 0.68,
    "dressed_to_cut_yield_pct": 0.9,
    "default_chill_hours": 0.5,
    "butchery_style_default": "whole-duck",
    "butchery_supported_styles": [
      "whole-duck",
      "quartered",
      "breast + legs",
      "stock-pack / broth-pack",
      "duck-fat-render",
      "poultry/waterfowl-torah-compliant-no-unclean-cross-contamination"
    ],
    "torah_compliant_profile": {
      "allow_unclean_animals": false,
      "separate_tools_required": true,
      "separate_surfaces_required": true,
      "blood_draining_required": true,
      "notes": "Slaughter/bleed ducks in a waterfowl-safe area; do not mix with unclean species; run duck sanitation after."
    }
  },
  "yield_model": {
    "formula_hint": "dressed = live_weight * live_to_dressed_yield_pct; cut_weight = dressed * dressed_to_cut_yield_pct",
