        "id": "STH-DUCK-PARTS-MUSCOVY",
        "label": "Meat → Waterfowl → Parts (Muscovy Legs/Breast)",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "muscovy_legs",
          "muscovy_breast"
