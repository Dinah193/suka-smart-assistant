          "Specialty stores – duck breast",
          "French/cajun shops – duck legs for confit"
        ]
      },
      {
        "id": "STH-DUCK-STOCK-MUSCOVY",
        "label": "Meat → Waterfowl → Stock / Broth (Muscovy)",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
          "muscovy_stock"
        ],
        "grocery_inspo": [
          "Restaurant supply – duck bone broth",
          "Pho/ramen suppliers – duck base"
        ]
      },
      {
        "id": "STH-DUCK-FAT-MUSCOVY",
        "label": "Pantry → Fats → Duck",
        "target_inventory_unit": "lb",
        "auto_replenish_from": [
