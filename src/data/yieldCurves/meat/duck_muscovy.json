        "grocery_inspo": [
          "French markets – duck fat jars",
          "Gourmet stores – confit fat"
        ]
      }
    ],
    "reverse_generation_rules": [
      {
        "id": "RG-MUSCOVY-WHOLE",
        "when_event": "storehouse.goal.short.muscovy-whole",
        "action": "calc required whole ducks → map to live Muscovy → emit automation.schedule.request (waterfowl-butchery + cleaning + mealplan.refresh)",
        "notes": "Use for feasts like Sukkot / big family gathering where duck is preferred over chicken."
      },
      {
        "id": "RG-MUSCOVY-CONFIT",
        "when_event": "storehouse.goal.short.muscovy-legs-confit",
        "action": "calc required legs → back-calc to ducks → emit automation.schedule.request"
      }
    ]
  },
