      "notes": "If garden/orchard detects slug or fruit-drop pests, the runtime can schedule a Muscovy pass BEFORE the planned butchery date."
    }
  },
  "storehouse_mapping": {
    "purpose": "Map Muscovy outputs to storehouse sections with grocery-style inspiration, so users see ‘premium duck’ lanes like better grocery sites.",
    "sections": [
      {
        "id": "STH-DUCK-WHOLE-MUSCOVY",
        "label": "Meat → Waterfowl → Whole (Muscovy)",
