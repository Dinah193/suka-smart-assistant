  "garden_pass_profiles": {
    "purpose": "Let Muscovy help in orchard/pond/garden zones for insect and slug control before butchery.",
    "passes": [
      {
        "id": "muscovy-orchard-pass",
        "label": "Muscovy – Orchard Pest Pass",
