          }
        ]
      },
      "userCanSaveAsFavorite": true,
      "uiHints": {
        "icon": "cow",
        "group": "large",
        "color": "red"
      }
    },
    {
      "id": "animal-plan-poultry-batch",
      "label": "Poultry – Batch Raise & Process",
      "species": "poultry",
      "torahClean": true,
      "purpose": [
        "meat",
        "eggs"
      ],
      "phases": [
        {
          "id": "acquisition",
          "label": "Acquire Chicks / Meat Birds",
          "trigger": "meals.plan.batch-cooking.requested",
          "actions": [
            "order meat chicks",
            "schedule brooder setup",
            "emit cleaning.brooder-prep.requested"
          ]
        },
        {
          "id": "care",
          "label": "Brooder → Tractor → Pasture",
          "actions": [
            "daily feed and water",
            "move tractor",
            "check for pest load in garden"
          ],
          "gardenIntegration": {
            "canAssist": true,
            "emitOnPestPass": [
              "garden.pest-pressure.reduced"
            ]
          },
          "schedule": {
            "type": "recurring",
            "rule": "RRULE:FREQ=DAILY;BYHOUR=7;BYMINUTE=30;BYSECOND=0"
          }
        },
        {
          "id": "butchery",
          "label": "Poultry Processing Day",
          "processing": {
            "complexity": "low",
            "byproducts": [
