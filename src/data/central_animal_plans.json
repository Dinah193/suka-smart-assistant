  "userCanSaveFavorites": true,
  "userFavoritePolicy": {
    "maxPerHousehold": 30,
    "allowCustomSchedule": true,
    "allowCustomCleaningProfiles": true,
    "allowCustomStorehouseIntake": true
  }
}
