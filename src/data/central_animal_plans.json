            "qty": 300,
            "unit": "lb"
          },
          {
            "sku": "milk-raw",
            "qty": 5,
            "unit": "gal",
            "note": "per week, if dairy"
          }
        ]
      },
      "reverseGeneration": {
        "enabled": true,
        "listensFor": [
          "storehouse.beef-intake.low",
          "meals.plan.created"
        ],
        "rules": [
          {
            "id": "beef-low",
            "ifEvent": "storehouse.beef-intake.low",
