          "actions": [
            "find suitable goat breed from breeds.json",
            "assign to brush-control zone",
            "emit cleaning.outdoor-zone.expected"
          ]
        },
        {
          "id": "care",
          "label": "Brush Rotation",
          "actions": [
            "move goats along fenceline",
            "check water and shelter",
            "monitor for parasite load"
          ],
          "schedule": {
            "type": "recurring",
            "rule": "RRULE:FREQ=DAILY;BYHOUR=8;BYMINUTE=30;BYSECOND=0"
          },
          "reverseGeneration": {
            "enabled": true,
            "listensFor": [
              "garden.plan.created",
              "garden.pest-pressure.detected"
            ],
            "emit": [
              "garden.care-session.generated"
            ]
          }
        },
        {
          "id": "butchery",
          "label": "Goat Butchery (Medium Complexity)",
          "processing": {
            "complexity": "medium",
            "byproducts": [
              "blood-meal",
              "bone-broth-stock"
            ]
          },
          "actions": [
            "prep butchery station",
            "process goat into storehouse cuts",
            "emit storehouse.intake.expected"
          ],
          "cleaningProfiles": [
            "cleaning.processing-area.requested",
            "cleaning.storehouse-meat-intake"
          ]
        }
      ],
      "storehouseIntake": {
        "items": [
          {
            "sku": "meat-goat",
            "qty": 55,
            "unit": "lb"
          }
        ]
      },
      "reverseGeneration": {
        "enabled": true,
        "listensFor": [
          "storehouse.meat-goat.low",
          "meals.plan.created",
          "garden.brush-control.requested"
        ],
        "rules": [
          {
            "id": "goat-meat-low",
            "ifEvent": "storehouse.meat-goat.low",
            "generate": "animal-plan-goat-meat-brush",
            "emit": [
              "animals.plan.generated",
              "cleaning.processing-area.requested"
            ]
          },
          {
            "id": "meal-goat-demand",
            "ifEvent": "meals.plan.created",
            "ifProteinIn": [
              "goat"
            ],
            "generate": "animal-plan-goat-meat-brush"
          }
        ]
      },
      "userCanSaveAsFavorite": true,
      "uiHints": {
        "icon": "goat",
        "group": "torah-clean",
        "color": "green"
      }
    },
    {
      "id": "animal-plan-cattle-family",
      "label": "Cattle – Family Beef Intake Plan",
      "species": "cattle",
      "torahClean": true,
      "purpose": [
        "meat",
