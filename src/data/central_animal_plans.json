{
  "version": "2025-10-31T12:05:00-05:00",
  "description": "CENTRAL: animal acquisition / care / butchery archetypes for Suka Smart Assistant. Auto-fed by scrapers/ingestors and breed table (breeds.json), with hub override for Torah-clean rules and local processing safety. Feeds Animal Planner, Storehouse intake, Cleaning (post-process), Garden (grazing/brush-control), and MealPlanEngine (reverse → animal when meals call for certain proteins).",
  "meta": {
    "sourceOfTruth": "scraper",
    "lastIngestedAt": "2025-10-31T12:05:00-05:00",
    "ingestionPipelines": [
      "scraperService",
      "importService",
      "bookmarklet",
      "linked-accounts"
    ],
    "mergeStrategy": "scraper-wins",
    "allowHubOverrides": true,
    "overrideFields": [
      "torahClean",
      "processing",
      "storehouseIntake",
      "cleaningProfiles"
    ],
    "sharedOrchestration": {
      "emitOnUpdate": true,
      "reason": "scraper-update",
      "channels": [
        "animals",
        "storehouse",
        "meals",
        "cleaning",
        "garden"
      ]
    },
    "notes": [
      "This file is the canonical list of 'patterns' for animals: acquire → care → harvest/butchery → storehouse → cleaning.",
      "Households can clone any archetype into their prefs and schedule it or favorite it.",
      "Reverse generation is enabled so low storehouse levels, meal plans, or garden brush-control needs can create animal sessions automatically.",
      "Integrates with central breeds.json for yields and Torah-clean."
    ]
  },
  "defaults": {
    "timezone": "America/Chicago",
    "supportsCleaning": true,
    "emitCleaningOnComplete": true,
    "defaultButcheryComplexity": "medium"
  },
  "archetypes": [
    {
      "id": "animal-plan-sheep-meat-cycle",
      "label": "Sheep – Meat Cycle (Torah-Clean)",
      "species": "sheep",
      "torahClean": true,
      "purpose": [
        "meat",
        "byproduct"
      ],
      "phases": [
        {
          "id": "acquisition",
          "label": "Acquire Feeder/Katahdin/Dorper",
          "trigger": "storehouse.meat-lamb.low",
          "actions": [
            "check local inventory for feeder lambs",
            "schedule acquisition day",
            "update storehouse.intake.expected"
          ],
          "reverseGeneration": {
            "enabled": true,
            "listensFor": [
              "meals.plan.fromStorehouse.requested",
              "storehouse.meat-lamb.low"
            ],
            "emit": [
              "animals.plan.fromStorehouse.generated"
            ]
          }
        },
        {
          "id": "care",
          "label": "Pasture + Supplement",
          "actions": [
            "daily water check",
            "rotational graze if garden/yard needs",
            "weekly health check (hooves, eyes, parasites)"
          ],
          "gardenIntegration": {
            "canAssist": true,
            "emitOnBrushUse": [
              "garden.care-session.generated",
              "cleaning.outdoor-zone.expected"
            ]
          },
          "schedule": {
            "type": "recurring",
            "rule": "RRULE:FREQ=DAILY;BYHOUR=7;BYMINUTE=0;BYSECOND=0"
          }
        },
        {
          "id": "butchery",
          "label": "On-Farm Butchery (Sheep)",
          "actions": [
            "prep butchery area",
            "perform Torah-compliant slaughter",
            "process carcass per central breeds yield",
            "emit storehouse.intake.expected"
          ],
          "processing": {
            "complexity": "low",
            "byproducts": [
              "blood-meal",
              "tallow",
              "bones"
            ]
          },
          "cleaningProfiles": [
            "cleaning.processing-area.requested",
            "cleaning.storehouse-meat-intake"
          ],
          "reverseGeneration": {
            "enabled": true,
            "listensFor": [
              "animals.butchery.completed"
            ],
            "emit": [
              "cleaning.processing-area.requested",
              "storehouse.intake.expected"
            ]
          }
        }
      ],
      "storehouseIntake": {
        "items": [
          {
            "sku": "meat-lamb",
            "qty": 50,
            "unit": "lb",
            "source": "butchery"
          },
          {
            "sku": "byproduct-blood-meal",
            "qty": 1,
            "unit": "bucket",
            "source": "processing"
          }
        ]
      },
      "reverseGeneration": {
        "enabled": true,
        "listensFor": [
          "meals.plan.created",
          "storehouse.meat-lamb.low"
        ],
        "rules": [
          {
            "id": "meal-lamb-demand",
            "ifEvent": "meals.plan.created",
            "ifProteinIn": [
              "lamb",
              "mutton"
            ],
            "generate": "animal-plan-sheep-meat-cycle"
          }
        ]
      },
      "userCanSaveAsFavorite": true,
      "uiHints": {
        "icon": "sheep",
        "group": "torah-clean",
        "color": "slate"
      }
    },
    {
      "id": "animal-plan-goat-meat-brush",
      "label": "Goat – Meat + Brush-Control Dual",
      "species": "goat",
      "torahClean": true,
      "purpose": [
        "meat",
        "brush-control"
      ],
      "phases": [
        {
          "id": "acquisition",
          "label": "Acquire Boer/Kiko",
