              "offal-compost"
            ]
          },
          "actions": [
            "setup scald + pluck",
            "process batch",
            "package to storehouse",
            "emit cleaning.processing-area.requested"
          ],
          "cleaningProfiles": [
            "cleaning.processing-area.requested",
            "cleaning.storehouse-meat-intake"
          ]
        }
      ],
      "storehouseIntake": {
        "items": [
          {
            "sku": "meat-poultry",
