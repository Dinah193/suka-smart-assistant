  "globals": {
    "quietHours": { "startHour": 21, "endHour": 7 },
    "toolNoiseRatings": {
      "vacuum": 3,
      "carpet_extractor": 3,
      "steam_cleaner": 2,
      "mop": 1,
      "broom": 1,
      "microfiber": 0,
      "squeegee": 0,
      "blower": 3
    },
    "forbiddenPairs": [
      { "a": "bleach", "b": "ammonia", "reason": "chloramine gas risk" },
      { "a": "bleach", "b": "acid", "reason": "chlorine gas risk (vinegar, muriatic, etc.)" }
    ],
    "defaultSequence": [
      "declutter",
      "dust_high",
      "dust_mid",
      "dust_low",
      "vacuum",
      "spot_treat",
      "mop",
      "sanitize_touchpoints",
      "trash_out"
