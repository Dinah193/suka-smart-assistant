{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:suka:contracts:barnplan",
  "title": "Barn Plan Contract",
  "description": "Canonical data contract for Barn (animals/butchery) plans used across Suka Smart Assistant. Designed to interoperate with useWorkPlanDraft, useWorkDecider, useNBANudges, and useMappingLinks.",
  "x-version": "1.0.0",
  "x-domain": "animals",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^(workplan|barnplan):[A-Za-z0-9_-]+(:\\d+)?$" },
    "kind": { "type": "string", "const": "barnplan" },
    "title": { "type": "string", "minLength": 1, "default": "Barn Plan" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "sessionId": { "type": ["string", "null"] },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": { "type": ["string", "null"] },
        "notes": { "type": "string", "default": "" },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
        "flags": { "type": "array", "items": { "type": "string" }, "default": [] }
      },
      "default": {}
    },
    "timeline": { "$ref": "#/definitions/Timeline" },
    "herd": {
      "description": "Optional herd/batch context for tasks.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "batchId": { "type": ["string", "null"] },
        "species": { "type": "string", "enum": ["chicken","turkey","duck","goose","rabbit","goat","sheep","pig","cow","other"], "default": "chicken" },
        "count": { "type": "integer", "minimum": 0, "default": 0 },
        "liveWeightAvgKg": { "type": ["number","null"], "minimum": 0 },
        "source": { "type": ["string","null"], "enum": ["on-farm","purchase","other"] },
        "processingPurpose": { "type": "string", "enum": ["home-consumption","sale","custom","share","other"], "default": "home-consumption" }
      },
      "default": {}
    },
    "sanitation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ppeRequired": {
          "type": "array",
          "items": { "type": "string", "enum": ["gloves","apron","face-shield","mask","goggles","boots"] },
          "default": ["gloves","apron","boots"]
        },
        "biosecurity": { "$ref": "#/definitions/Biosecurity" },
        "zones": {
          "description": "Clean/dirty zone delineation for HACCP-like flow.",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "kind": { "type": "string", "enum": ["dirty","transition","clean"] },
              "locationHint": { "type": ["string","null"] }
            },
            "required": ["name","kind"]
          },
          "default": []
        }
      },
      "default": {}
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sabbathGuard": { "type": "boolean", "default": false },
        "maxBudget": { "type": ["number","null"], "minimum": 0 },
        "timeWindowMinutes": { "type": ["integer","null"], "minimum": 5 },
        "weatherRequired": { "type": "string", "enum": ["indoor-only","outdoor-ok","dry-only","any"], "default": "any" }
      },
      "default": {}
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/definitions/Task" },
      "default": []
    },
    "conflicts": {
      "type": "array",
      "items": { "$ref": "#/definitions/Conflict" },
      "default": []
    },
    "cost": { "$ref": "#/definitions/Cost" },
    "score": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stability": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 },
        "signals": { "type": "array", "items": { "type": "string" }, "default": [] }
      },
      "default": {}
    },
    "nba": {
      "description": "Next-Best-Action slot for UX surfaces.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": ["string","null"] },
        "label": { "type": ["string","null"] },
        "reason": { "type": ["string","null"] },
        "taskId": { "type": ["string","null"] }
      },
      "default": { "id": null, "label": null, "reason": null, "taskId": null }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "past": { "type": "array", "items": { "type": "object" }, "default": [] },
        "future": { "type": "array", "items": { "type": "object" }, "default": [] }
      },
      "default": {}
    }
  },
  "required": ["id","kind","title","createdAt","updatedAt","timeline","tasks","cost"],
  "definitions": {
    "Timeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startAt": { "type": ["string","null"], "format": "date-time" },
        "endAt": { "type": ["string","null"], "format": "date-time" },
        "timezone": { "type": "string", "default": "UTC" },
        "holds": {
          "type": "array",
          "items": { "$ref": "#/definitions/Hold" },
        "default": []
        },
        "reminders": {
          "type": "array",
          "items": { "$ref": "#/definitions/Reminder" },
          "default": []
        }
      },
      "default": {}
    },
    "Reminder": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "atISO": { "type": "string", "format": "date-time" },
        "channel": { "type": "string", "enum": ["push","toast","email","sms"], "default": "push" }
      },
      "required": ["title","atISO"]
    },
    "Hold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["weather","withhold","cooling","resting","sabbath"] },
        "startISO": { "type": "string", "format": "date-time" },
        "endISO": { "type": "string", "format": "date-time" },
        "reason": { "type": ["string","null"] }
      },
      "required": ["type","startISO","endISO"]
    },
    "Cost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currency": { "type": "string", "default": "USD" },
        "subtotal": { "type": "number", "minimum": 0, "default": 0 },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "amount": { "type": "number", "minimum": 0 },
              "category": { "type": ["string","null"], "enum": ["feed","consumable","energy","disposal","packaging","other",null] }
            },
            "required": ["label","amount"]
          },
          "default": []
        }
      },
      "required": ["currency","subtotal","lines"],
      "default": { "currency": "USD", "subtotal": 0, "lines": [] }
    },
    "Biosecurity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entryFootbath": { "type": "boolean", "default": false },
        "toolDisinfection": { "type": "boolean", "default": true },
        "handwashStation": { "type": "boolean", "default": true },
        "wasteSegregation": { "type": "boolean", "default": true }
      },
      "default": {}
    },
    "Withhold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["medication","spray","vaccine","other"] },
        "untilISO": { "type": "string", "format": "date-time" },
        "note": { "type": ["string","null"] }
      },
      "required": ["type","untilISO"]
    },
    "ChillChain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxMinutesOut": { "type": "integer", "minimum": 0, "default": 30 },
        "targetTempC": { "type": "number", "minimum": -5, "maximum": 15, "default": 4 },
        "monitorId": { "type": ["string","null"] }
      },
      "default": {}
    },
    "Task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^task:[A-Za-z0-9_-]+$" },
        "title": { "type": "string", "minLength": 1 },
        "domain": { "type": "string", "enum": ["animals"] },
        "kind": { "type": "string", "enum": ["care","transport","stun","bleed","scald","pluck","eviscerate","rinse","chill","quarter","package","cleandown","dispose","custom"], "default": "custom" },
        "status": { "type": "string", "enum": ["pending","ready","active","paused","done","blocked"], "default": "pending" },
        "estMinutes": { "type": "integer", "minimum": 1, "default": 15 },
        "actualMinutes": { "type": "integer", "minimum": 0, "default": 0 },
        "ppe": {
          "type": "array",
          "items": { "type": "string", "enum": ["gloves","apron","face-shield","mask","goggles","boots","ear-protection"] },
          "default": ["gloves","apron","boots"]
        },
        "resources": { "type": "array", "items": { "type": "string" }, "default": [] },
        "appliances": { "type": "array", "items": { "type": "string", "enum": ["scalder","plucker","butcher-table","hose","sink","chiller","saw","grinder","sealer","other"] }, "default": [] },
        "deps": { "type": "array", "items": { "type": "string", "pattern": "^task:[A-Za-z0-9_-]+$" }, "default": [] },
        "window": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "earliest": { "type": ["string","null"], "format": "date-time" },
            "latest": { "type": ["string","null"], "format": "date-time" }
          },
          "default": {}
        },
        "scheduledAt": { "type": ["string","null"], "format": "date-time" },
        "timers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "startAt": { "type": ["string","null"], "format": "date-time" },
            "endAt": { "type": ["string","null"], "format": "date-time" },
            "alarms": {
              "type": "array",
              "items": { "type": "string", "format": "date-time" },
              "default": []
            }
          },
          "default": {}
        },
        "inventory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "items": {
              "type": "array",
              "items": { "$ref": "#/definitions/InventoryItem" },
              "default": []
            },
            "reserveOnStart": { "type": "boolean", "default": true }
          },
          "default": {}
        },
        "costHints": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "category": { "type": ["string","null"], "enum": ["feed","consumable","energy","disposal","packaging","labor","other",null] },
            "supplierProfileId": { "type": ["string","null"] },
            "overrides": { "type": "object", "additionalProperties": true, "default": {} }
          },
          "default": {}
        },
        "withholds": { "type": "array", "items": { "$ref": "#/definitions/Withhold" }, "default": [] },
        "chillChain": { "$ref": "#/definitions/ChillChain" },
        "haccp": {
          "description": "Lightweight hazard control markers for UX (not a full HACCP doc).",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ccp": { "type": "boolean", "default": false },
            "checklist": { "type": "array", "items": { "type": "string" }, "default": [] }
          },
          "default": {}
        },
        "notes": { "type": "string", "default": "" },
        "flags": { "type": "array", "items": { "type": "string" }, "default": [] }
      },
      "required": ["id","title","domain","kind","status"]
    },
    "InventoryItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sku": { "type": ["string","null"] },
        "name": { "type": "string" },
        "qty": { "type": "number", "minimum": 0 },
        "unit": { "type": ["string","null"] },
        "aliases": { "type": "array", "items": { "type": "string" }, "default": [] }
      },
      "required": ["name","qty"]
    },
    "Conflict": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["resource-overlap","ppe-missing","withhold-active","appliance-locked","weather-hold"] },
        "resource": { "type": ["string","null"] },
        "tasks": { "type": "array", "items": { "type": "string", "pattern": "^task:[A-Za-z0-9_-]+$" }, "default": [] },
        "taskId": { "type": ["string","null"], "pattern": "^task:[A-Za-z0-9_-]+$" },
        "message": { "type": "string" }
      },
      "required": ["type","message"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "constraints": {
            "properties": { "sabbathGuard": { "const": true } },
            "required": ["sabbathGuard"]
          }
        }
      },
      "then": {
        "properties": {
          "timeline": {
            "properties": {
              "holds": {
                "items": {
                  "anyOf": [
                    {},
                    { "properties": { "type": { "const": "sabbath" } } }
                  ]
                }
              }
            }
          }
        }
      }
    }
  ],
  "x-orchestration": {
    "events": {
      "emit": [
        "workplan.draft.created",
        "workplan.draft.updated",
        "workplan.draft.published",
        "workplan.draft.discarded",
        "ui.sessionHUD.focusTask",
        "ui.conflictResolver.open",
        "mapping.link.added",
        "mapping.link.updated",
        "mapping.link.removed"
      ],
      "listen": [
        "decider:top-candidate",
        "inventory.updated",
        "session.paused",
        "session.resumable",
        "mealplan:finalize",
        "garden.plan.updated"
      ]
    },
    "cta": {
      "routes": [
        "SCHEDULE_TASKS",
        "SCHEDULE_BLOCK",
        "OPEN_BUTCHERY",
        "OPEN_CLEANING",
        "OPEN_GROCERY",
        "OPEN_MEAL_PICKER_WITH_FILTER",
        "SESSION_RESUME",
        "LINK_LEFTOVERS"
      ]
    }
  },
  "x-ui": {
    "icons": {
      "plan": "🔪",
      "care": "🐑",
      "butchery": "🪓",
      "clean": "🧼",
      "chill": "🧊",
      "package": "📦"
    },
    "lists": {
      "taskChips": {
        "primary": "title",
        "secondary": "kind",
        "meta": ["estMinutes","status","appliances"]
      }
    },
    "defaults": {
      "ppe": ["gloves","apron","boots"]
    }
  },
  "examples": [
    {
      "id": "barnplan:abc123:1730070000000",
      "kind": "barnplan",
      "title": "Broilers – Small Batch",
      "createdAt": "2025-10-20T12:00:00.000Z",
      "updatedAt": "2025-10-20T12:05:00.000Z",
      "sessionId": null,
      "meta": { "author": "larho", "notes": "Keep chill chain tight.", "tags": ["butchery","broilers"], "flags": [] },
      "timeline": {
        "startAt": "2025-10-24T13:00:00.000Z",
        "endAt": null,
        "timezone": "America/New_York",
        "holds": [],
        "reminders": [{ "title": "Ice bath ready", "atISO": "2025-10-24T12:45:00.000Z", "channel": "push" }]
      },
      "herd": { "batchId": "B-2025-10-24", "species": "chicken", "count": 8, "liveWeightAvgKg": 2, "source": "on-farm", "processingPurpose": "home-consumption" },
      "sanitation": {
        "ppeRequired": ["gloves","apron","boots","face-shield"],
        "biosecurity": { "entryFootbath": true, "toolDisinfection": true, "handwashStation": true, "wasteSegregation": true },
        "zones": [
          { "name": "Scald/Pluck", "kind": "dirty", "locationHint": "Driveway" },
          { "name": "Evisceration", "kind": "transition", "locationHint": "Table 1" },
          { "name": "Chill/Package", "kind": "clean", "locationHint": "Kitchen sink & chiller" }
        ]
      },
      "constraints": { "sabbathGuard": true, "timeWindowMinutes": 240, "weatherRequired": "dry-only" },
      "tasks": [
        {
          "id": "task:prep-ice",
          "title": "Prep ice and sanitizer",
          "domain": "animals",
          "kind": "cleandown",
          "status": "ready",
          "estMinutes": 20,
          "actualMinutes": 0,
          "ppe": ["gloves","apron","boots"],
          "resources": ["bucket","bleach","towels"],
          "appliances": ["sink","chiller"],
          "deps": [],
          "window": {},
          "scheduledAt": "2025-10-24T12:30:00.000Z",
          "timers": {},
          "inventory": {
            "items": [
              { "sku": "ICE-001", "name": "Ice", "qty": 30, "unit": "lb" },
              { "sku": "BLEACH-001", "name": "Sanitizer (bleach)", "qty": 100, "unit": "ml" }
            ],
            "reserveOnStart": true
          },
          "costHints": { "category": "consumable" },
          "withholds": [],
          "chillChain": { "maxMinutesOut": 30, "targetTempC": 4 },
          "haccp": { "ccp": false, "checklist": ["Mix sanitizer 50–100 ppm"] },
          "notes": "",
          "flags": ["prep"]
        },
        {
          "id": "task:scald-pluck",
          "title": "Scald & pluck",
          "domain": "animals",
          "kind": "scald",
          "status": "pending",
          "estMinutes": 60,
          "ppe": ["gloves","apron","boots","face-shield"],
          "resources": ["propane","thermometer"],
          "appliances": ["scalder","plucker","hose"],
          "deps": ["task:prep-ice"],
          "window": {},
          "scheduledAt": "2025-10-24T13:00:00.000Z",
          "timers": {},
          "inventory": { "items": [], "reserveOnStart": true },
          "costHints": { "category": "energy" },
          "withholds": [],
          "chillChain": { "maxMinutesOut": 30, "targetTempC": 4 },
          "haccp": { "ccp": true, "checklist": ["Scald 60–65°C, 60–90s"] },
          "notes": "",
          "flags": ["outdoor","heavy-labor"]
        },
        {
          "id": "task:eviscerate",
          "title": "Evisceration & rinse",
          "domain": "animals",
          "kind": "eviscerate",
          "status": "blocked",
          "estMinutes": 60,
          "ppe": ["gloves","apron","boots"],
          "appliances": ["butcher-table","sink"],
          "deps": ["task:scald-pluck"],
          "inventory": { "items": [], "reserveOnStart": true },
          "withholds": [],
          "chillChain": { "maxMinutesOut": 30, "targetTempC": 4 },
          "haccp": { "ccp": true, "checklist": ["No fecal contamination", "Rinse thoroughly"] },
          "notes": "",
          "flags": []
        },
        {
          "id": "task:chill-package",
          "title": "Chill & package",
          "domain": "animals",
          "kind": "package",
          "status": "pending",
          "estMinutes": 40,
          "appliances": ["chiller","sealer"],
          "deps": ["task:eviscerate"],
          "inventory": { "items": [{ "sku": "BAG-POULTRY", "name": "Shrink bags", "qty": 10, "unit": "pcs" }], "reserveOnStart": true },
          "withholds": [],
          "chillChain": { "targetTempC": 4 },
          "haccp": { "ccp": true, "checklist": ["Core temp <=4°C before packing"] },
          "notes": "",
          "flags": ["clean-zone"]
        }
      ],
      "conflicts": [],
      "cost": {
        "currency": "USD",
        "subtotal": 12.5,
        "lines": [
          { "label": "Ice", "amount": 8, "category": "consumable" },
          { "label": "Propane", "amount": 4.5, "category": "energy" }
        ]
      },
      "score": { "stability": 0.72, "signals": ["inventory-ok","weather-dry"] },
      "nba": { "id": "schedule-presteps", "label": "Schedule pre-steps", "reason": "Ice & sanitizer prep", "taskId": "task:prep-ice" },
      "history": { "past": [], "future": [] }
    }
  ]
}
