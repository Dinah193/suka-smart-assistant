{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:suka:contracts:gardenplan",
  "title": "Garden Plan Contract",
  "description": "Canonical data contract for garden plans used across Suka Smart Assistant. Designed to interoperate with useWorkPlanDraft, useWorkDecider, useNBANudges, and useMappingLinks.",
  "x-version": "1.0.0",
  "x-domain": "garden",
  "type": "object",
  "additionalProperties": false,

  "properties": {
    "id": { "type": "string", "pattern": "^(workplan|gardenplan):[A-Za-z0-9_-]+(:\\d+)?$" },
    "kind": { "type": "string", "const": "gardenplan" },
    "title": { "type": "string", "minLength": 1, "default": "Garden Plan" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "sessionId": { "type": ["string","null"] },

    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": { "type": ["string","null"] },
        "notes": { "type": "string", "default": "" },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
        "flags": { "type": "array", "items": { "type": "string" }, "default": [] }
      },
      "default": {}
    },

    "timeline": { "$ref": "#/definitions/Timeline" },

    "plot": {
      "description": "Garden context: zones/beds, soil, and season hints.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timezone": { "type": "string", "default": "UTC" },
        "lastFrostISO": { "type": ["string","null"], "format": "date-time" },
        "firstFrostISO": { "type": ["string","null"], "format": "date-time" },
        "irrigation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "system": { "type": ["string","null"], "enum": ["drip","soaker","sprinkler","hand","none",null] },
            "wateringDayHints": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0, "maximum": 6 },
              "default": []
            },
            "skipOnRain": { "type": "boolean", "default": true }
          },
          "default": {}
        },
        "zones": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "bed": { "type": ["string","null"] },
              "row": { "type": ["string","null"] },
              "areaSqFt": { "type": ["number","null"], "minimum": 0 },
              "sun": { "type": ["string","null"], "enum": ["full","partial","shade",null] },
              "soilPH": { "type": ["number","null"], "minimum": 3, "maximum": 10 },
              "lastPlantedISO": { "type": ["string","null"], "format": "date-time" }
            },
            "required": ["id","name"]
          },
          "default": []
        }
      },
      "default": {}
    },

    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sabbathGuard": { "type": "boolean", "default": false },
        "timeWindowMinutes": { "type": ["integer","null"], "minimum": 5 },
        "weather": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minTempF": { "type": ["number","null"] },
            "maxTempF": { "type": ["number","null"] },
            "maxRainChance": { "type": ["number","null"], "minimum": 0, "maximum": 1 },
            "maxWindMph": { "type": ["number","null"], "minimum": 0 },
            "maxUVIndex": { "type": ["number","null"], "minimum": 0 }
          },
          "default": {}
        },
        "organicOnly": { "type": "boolean", "default": false }
      },
      "default": {}
    },

    "tasks": {
      "type": "array",
      "items": { "$ref": "#/definitions/Task" },
      "default": []
    },

    "conflicts": {
      "type": "array",
      "items": { "$ref": "#/definitions/Conflict" },
      "default": []
    },

    "cost": { "$ref": "#/definitions/Cost" },

    "score": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stability": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 },
        "signals": { "type": "array", "items": { "type": "string" }, "default": [] }
      },
      "default": {}
    },

    "nba": {
      "description": "Next-Best-Action slot for UX surfaces.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": ["string","null"] },
        "label": { "type": ["string","null"] },
        "reason": { "type": ["string","null"] },
        "taskId": { "type": ["string","null"] }
      },
      "default": { "id": null, "label": null, "reason": null, "taskId": null }
    },

    "history": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "past": { "type": "array", "items": { "type": "object" }, "default": [] },
        "future": { "type": "array", "items": { "type": "object" }, "default": [] }
      },
      "default": {}
    }
  },

  "required": ["id","kind","title","createdAt","updatedAt","timeline","tasks","cost"],

  "definitions": {
    "Timeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startAt": { "type": ["string","null"], "format": "date-time" },
        "endAt": { "type": ["string","null"], "format": "date-time" },
        "timezone": { "type": "string", "default": "UTC" },
        "holds": {
          "type": "array",
          "items": { "$ref": "#/definitions/Hold" },
          "default": []
        },
        "reminders": {
          "type": "array",
          "items": { "$ref": "#/definitions/Reminder" },
          "default": []
        }
      },
      "default": {}
    },

    "Reminder": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "atISO": { "type": "string", "format": "date-time" },
        "channel": { "type": "string", "enum": ["push","toast","email","sms"], "default": "push" }
      },
      "required": ["title","atISO"]
    },

    "Hold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["weather","frost-risk","heatwave","wind","rain","uv","sabbath","irrigation-cycle","reentry"]
        },
        "startISO": { "type": "string", "format": "date-time" },
        "endISO": { "type": "string", "format": "date-time" },
        "reason": { "type": ["string","null"] }
      },
      "required": ["type","startISO","endISO"]
    },

    "Cost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currency": { "type": "string", "default": "USD" },
        "subtotal": { "type": "number", "minimum": 0, "default": 0 },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "amount": { "type": "number", "minimum": 0 },
              "category": {
                "type": ["string","null"],
                "enum": ["seed","fertilizer","amendment","water","tool","energy","pesticide","other",null]
              }
            },
            "required": ["label","amount"]
          },
          "default": []
        }
      },
      "required": ["currency","subtotal","lines"],
      "default": { "currency": "USD", "subtotal": 0, "lines": [] }
    },

    "ChemicalUse": {
      "description": "Fertilizers, amendments, and crop-protection (inc. organic).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": ["string","null"] },
        "kind": { "type": "string", "enum": ["fertilizer","amendment","fungicide","herbicide","insecticide","biocontrol","other"] },
        "organic": { "type": ["boolean","null"] },
        "dilution": { "type": ["string","null"] },
        "reentryHours": { "type": ["integer","null"], "minimum": 0 },
        "preHarvestIntervalDays": { "type": ["integer","null"], "minimum": 0 },
        "incompatibleWith": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      },
      "required": ["name","kind"]
    },

    "InventoryItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sku": { "type": ["string","null"] },
        "name": { "type": "string" },
        "qty": { "type": "number", "minimum": 0 },
        "unit": { "type": ["string","null"] },
        "aliases": { "type": "array", "items": { "type": "string" }, "default": [] }
      },
      "required": ["name","qty"]
    },

    "Task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^task:[A-Za-z0-9_-]+$" },
        "title": { "type": "string", "minLength": 1 },
        "domain": { "type": "string", "enum": ["garden"] },
        "kind": {
          "type": "string",
          "enum": [
            "plan","sow","transplant","irrigate","fertilize","amend","mulch","weed",
            "trellis","prune","pest-scout","spray","harvest","compost","tool-maintenance","custom"
          ],
          "default": "custom"
        },
        "status": { "type": "string", "enum": ["pending","ready","active","paused","done","blocked"], "default": "pending" },

        "zoneId": { "type": ["string","null"] },
        "crop": { "type": ["string","null"] },
        "variety": { "type": ["string","null"] },
        "rowFeet": { "type": ["number","null"], "minimum": 0 },
        "spacingIn": { "type": ["number","null"], "minimum": 0 },

        "estMinutes": { "type": "integer", "minimum": 1, "default": 15 },
        "actualMinutes": { "type": "integer", "minimum": 0, "default": 0 },

        "appliances": { "type": "array", "items": { "type": "string" }, "default": [] },
        "resources": { "type": "array", "items": { "type": "string" }, "default": [] },

        "deps": { "type": "array", "items": { "type": "string", "pattern": "^task:[A-Za-z0-9_-]+$" }, "default": [] },

        "window": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "earliest": { "type": ["string","null"], "format": "date-time" },
            "latest": { "type": ["string","null"], "format": "date-time" }
          },
          "default": {}
        },

        "scheduledAt": { "type": ["string","null"], "format": "date-time" },

        "timers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "startAt": { "type": ["string","null"], "format": "date-time" },
            "endAt": { "type": ["string","null"], "format": "date-time" },
            "alarms": { "type": "array", "items": { "type": "string", "format": "date-time" }, "default": [] }
          },
          "default": {}
        },

        "inventory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "items": {
              "type": "array",
              "items": { "$ref": "#/definitions/InventoryItem" },
              "default": []
            },
            "reserveOnStart": { "type": "boolean", "default": true }
          },
          "default": {}
        },

        "chemicals": { "type": "array", "items": { "$ref": "#/definitions/ChemicalUse" }, "default": [] },

        "costHints": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "category": { "type": ["string","null"], "enum": ["seed","fertilizer","amendment","water","tool","energy","pesticide","other",null] },
            "supplierProfileId": { "type": ["string","null"] },
            "overrides": { "type": "object", "additionalProperties": true, "default": {} }
          },
          "default": {}
        },

        "notes": { "type": "string", "default": "" },
        "flags": { "type": "array", "items": { "type": "string" }, "default": [] }
      },
      "required": ["id","title","domain","kind","status"]
    },

    "Conflict": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "resource-overlap","zone-overlap","weather-hold","frost-risk","heatwave",
            "uv-high","rain-expected","wind-high","reentry-restricted","withhold-active"
          ]
        },
        "resource": { "type": ["string","null"] },
        "tasks": { "type": "array", "items": { "type": "string", "pattern": "^task:[A-Za-z0-9_-]+$" }, "default": [] },
        "taskId": { "type": ["string","null"], "pattern": "^task:[A-Za-z0-9_-]+$" },
        "message": { "type": "string" }
      },
      "required": ["type","message"]
    }
  },

  "allOf": [
    {
      "if": {
        "properties": {
          "constraints": {
            "properties": { "sabbathGuard": { "const": true } },
            "required": ["sabbathGuard"]
          }
        }
      },
      "then": {
        "properties": {
          "timeline": {
            "properties": {
              "holds": {
                "items": {
                  "anyOf": [
                    {},
                    { "properties": { "type": { "const": "sabbath" } } }
                  ]
                }
              }
            }
          }
        }
      }
    }
  ],

  "x-orchestration": {
    "events": {
      "emit": [
        "workplan.draft.created",
        "workplan.draft.updated",
        "workplan.draft.published",
        "workplan.draft.discarded",
        "ui.sessionHUD.focusTask",
        "ui.conflictResolver.open",
        "mapping.link.added",
        "mapping.link.updated",
        "mapping.link.removed",
        "garden.plan.updated"
      ],
      "listen": [
        "decider:top-candidate",
        "inventory.updated",
        "session.paused",
        "session.resumable",
        "mealplan:finalize",
        "weather.updated",
        "garden.plan.updated"
      ]
    },
    "cta": {
      "routes": [
        "SCHEDULE_TASKS",
        "SCHEDULE_BLOCK",
        "OPEN_GARDEN",
        "OPEN_GROCERY",
        "OPEN_MEAL_PICKER_WITH_FILTER",
        "SESSION_RESUME",
        "OPEN_ZONE_PICKER"
      ]
    }
  },

  "x-ui": {
    "icons": {
      "plan": "🪴",
      "sow": "🌱",
      "transplant": "🧺",
      "irrigate": "💧",
      "fertilize": "🧪",
      "mulch": "🪵",
      "weed": "🪚",
      "trellis": "🪜",
      "prune": "✂️",
      "pest": "🐛",
      "spray": "🧴",
      "harvest": "🧺",
      "compost": "♻️",
      "tool": "🛠️"
    },
    "lists": {
      "taskChips": {
        "primary": "title",
        "secondary": "kind",
        "meta": ["zoneId","crop","estMinutes","status"]
      }
    }
  },

  "examples": [
    {
      "id": "gardenplan:fall-bed-01:1730075000000",
      "kind": "gardenplan",
      "title": "Fall Bed A — Greens & Roots",
      "createdAt": "2025-10-20T15:00:00.000Z",
      "updatedAt": "2025-10-20T15:10:00.000Z",
      "sessionId": null,
      "meta": { "author": "larho", "notes": "Focus on cold-hardy crops; protect from first frost.", "tags": ["fall","bed-a"] },
      "timeline": {
        "startAt": "2025-10-24T13:00:00.000Z",
        "endAt": null,
        "timezone": "America/New_York",
        "holds": [],
        "reminders": [
          { "title": "Pre-soak spinach seed", "atISO": "2025-10-23T23:00:00.000Z", "channel": "push" }
        ]
      },
      "plot": {
        "timezone": "America/New_York",
        "lastFrostISO": "2025-04-15T12:00:00.000Z",
        "firstFrostISO": "2025-11-05T12:00:00.000Z",
        "irrigation": { "system": "drip", "wateringDayHints": [1,4], "skipOnRain": true },
        "zones": [
          { "id": "bed-a", "name": "Bed A", "bed": "A", "row": "1-3", "areaSqFt": 48, "sun": "full", "soilPH": 6.5, "lastPlantedISO": "2025-08-20T12:00:00.000Z" },
          { "id": "bed-b", "name": "Bed B", "bed": "B", "row": "1-2", "areaSqFt": 32, "sun": "partial", "soilPH": 6.8 }
        ]
      },
      "constraints": {
        "sabbathGuard": true,
        "timeWindowMinutes": 180,
        "weather": { "maxRainChance": 0.5, "maxWindMph": 20, "maxUVIndex": 8 },
        "organicOnly": true
      },
      "tasks": [
        {
          "id": "task:sow-spinach",
          "title": "Sow spinach — Bed A rows 1–2",
          "domain": "garden",
          "kind": "sow",
          "status": "ready",
          "zoneId": "bed-a",
          "crop": "Spinach",
          "variety": "Bloomsdale",
          "rowFeet": 20,
          "spacingIn": 3,
          "estMinutes": 25,
          "inventory": {
            "items": [{ "sku": "SEED-SPIN-001", "name": "Spinach seed", "qty": 0.25, "unit": "lb" }],
            "reserveOnStart": true
          },
          "notes": "Firm seed-to-soil contact; consider board press."
        },
        {
          "id": "task:amend-bed-a",
          "title": "Amend bed with compost",
          "domain": "garden",
          "kind": "amend",
          "status": "pending",
          "zoneId": "bed-a",
          "estMinutes": 30,
          "inventory": { "items": [{ "sku": "CMP-001", "name": "Finished compost", "qty": 2, "unit": "cu ft" }], "reserveOnStart": true },
          "chemicals": [{ "name": "Compost", "kind": "amendment", "organic": true }],
          "deps": [],
          "notes": "Layer 0.5–1 inch, rake level."
        },
        {
          "id": "task:install-trellis-b",
          "title": "Install pea trellis",
          "domain": "garden",
          "kind": "trellis",
          "status": "pending",
          "zoneId": "bed-b",
          "estMinutes": 20,
          "resources": ["stakes","netting"],
          "deps": [],
          "notes": "Wind < 15 mph preferred."
        },
        {
          "id": "task:scout-pests",
          "title": "Pest scout — all beds",
          "domain": "garden",
          "kind": "pest-scout",
          "status": "pending",
          "estMinutes": 15,
          "notes": "Look for leaf miner on beets; remove damaged leaves."
        },
        {
          "id": "task:harvest-arugula",
          "title": "Harvest arugula — Bed B",
          "domain": "garden",
          "kind": "harvest",
          "status": "blocked",
          "zoneId": "bed-b",
          "estMinutes": 15,
          "deps": [],
          "notes": "Morning harvest preferred."
        }
      ],
      "conflicts": [],
      "cost": {
        "currency": "USD",
        "subtotal": 9.5,
        "lines": [
          { "label": "Spinach seed", "amount": 4.0, "category": "seed" },
          { "label": "Compost", "amount": 5.5, "category": "amendment" }
        ]
      },
      "score": { "stability": 0.71, "signals": ["weather-dry","inventory-ok"] },
      "nba": { "id": "prep-bed-a", "label": "Amend Bed A now", "reason": "Weather window & materials on-hand", "taskId": "task:amend-bed-a" },
      "history": { "past": [], "future": [] }
    }
  ]
}
