  "routines": [
    {
      "id": "clean-daily-core",
      "label": "Daily Core – Kitchen + High Touch",
      "category": "daily",
      "domain": "cleaning",
      "priority": 1,
      "steps": [
        "Wipe kitchen counters and stove",
        "Spot sweep kitchen, entry, and animal-traffic areas",
        "Sanitize sink and dish drying area",
        "Take out trash/compost if at threshold",
        "Check pantry/storehouse floor for spills"
      ],
      "durationMinutes": 20,
      "schedule": {
        "type": "recurring",
        "rule": "RRULE:FREQ=DAILY;BYHOUR=9;BYMINUTE=0;BYSECOND=0"
      },
      "reverseGeneration": {
        "enabled": true,
        "listensFor": [
          "meals.cooking-session.completed",
          "inventory.spill.detected"
        ],
        "generateOn": "meals.cooking-session.completed",
        "emit": [
          "cleaning.session.created",
          "inventory.visibility.requested"
        ]
      },
      "uiHints": {
        "icon": "sparkles",
        "group": "today"
      }
    },
    {
