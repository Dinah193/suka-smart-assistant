exports[`SSA showcase page contract and visual snapshots > matches token overview and seasonal cue matrix visuals 1`] = `"<section class="ssa-hero-wrap space-y-3 p-4 xl:col-span-2" aria-label="Token overview"><h2 class="ssa-hero-title text-lg">Color, Typography, Spacing, and Rhythm</h2><p class="ssa-hero-subtitle">Use design tokens as the source of truth. Avoid hardcoded values in page components.</p><div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4"><div class="rounded-[var(--ssa-radius-card)] border border-[var(--ssa-border-default)] p-3"><p class="text-xs text-[var(--ssa-text-secondary)]">Surface</p><div class="mt-2 flex gap-1"><div class="h-8 w-8 rounded bg-[var(--ssa-surface-0)] border border-[var(--ssa-border-subtle)]"></div><div class="h-8 w-8 rounded bg-[var(--ssa-surface-1)] border border-[var(--ssa-border-subtle)]"></div><div class="h-8 w-8 rounded bg-[var(--ssa-surface-2)] border border-[var(--ssa-border-subtle)]"></div><div class="h-8 w-8 rounded bg-[var(--ssa-surface-elevated)] border border-[var(--ssa-border-subtle)]"></div></div></div><div class="rounded-[var(--ssa-radius-card)] border border-[var(--ssa-border-default)] p-3"><p class="text-xs text-[var(--ssa-text-secondary)]">Type Scale</p><p class="ssa-hero-title text-lg">H2 Semantic</p><p class="text-sm text-[var(--ssa-text-primary)]">Body Medium Sample</p><p class="text-xs text-[var(--ssa-text-secondary)]">Caption + labels</p></div><div class="rounded-[var(--ssa-radius-card)] border border-[var(--ssa-border-default)] p-3"><p class="text-xs text-[var(--ssa-text-secondary)]">Spacing Rhythm</p><div class="mt-2 space-y-2"><div class="h-2 w-16 rounded bg-[var(--ssa-action-primary-bg)]"></div><div class="h-2 w-24 rounded bg-[var(--ssa-action-primary-bg)]"></div><div class="h-2 w-32 rounded bg-[var(--ssa-action-primary-bg)]"></div></div></div><div class="rounded-[var(--ssa-radius-card)] border border-[var(--ssa-border-default)] p-3"><p class="text-xs text-[var(--ssa-text-secondary)]">Collaboration Status</p><div class="mt-2 flex flex-wrap gap-2"><span class="ssa-hero-chip text-[var(--ssa-collab-request)]">request</span><span class="ssa-hero-chip text-[var(--ssa-collab-assigned)]">assigned</span><span class="ssa-hero-chip text-[var(--ssa-collab-complete)]">complete</span><span class="ssa-hero-chip text-[var(--ssa-collab-blocked)]">blocked</span></div></div></div></section>"`;

exports[`SSA showcase page contract and visual snapshots > matches token overview and seasonal cue matrix visuals 2`] = `"<section class="ssa-hero-wrap space-y-3 p-4 xl:col-span-2" aria-label="Household module seasonal cues"><h2 class="ssa-hero-title text-lg">Household Collaboration Cues by Module</h2><div class="grid gap-3 md:grid-cols-[1fr_220px]"><select class="w-full rounded-[var(--ssa-radius-chip)] border px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--ssa-focus-ring-color)] border-[var(--ssa-border-default)] bg-[var(--ssa-surface-elevated)] "><option value="spring">Spring</option><option value="summer">Summer</option><option value="autumn">Autumn</option><option value="winter">Winter</option></select><input min="10" max="100" aria-label="Module completion" class="w-full rounded-[var(--ssa-radius-chip)] border px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--ssa-focus-ring-color)] border-[var(--ssa-border-default)] bg-[var(--ssa-surface-elevated)] " type="range" value="64"></div><div class="grid gap-4 xl:grid-cols-2"><div class="space-y-2 rounded-[var(--ssa-radius-card)] border border-[var(--ssa-border-default)] p-3"><article class="ssa-hero-wrap ssa-seasonal-card p-3 border-[var(--ssa-status-warning)]" data-ssa-season="spring"><h4 class="ssa-hero-title text-sm">Meals and Batch Cooking</h4><p class="ssa-hero-subtitle">Seasonal recipe lane: root broth, nettle omelet, herb porridge</p></article><div class="ssa-hero-wrap p-3"><div class="mb-1 flex items-center justify-between text-xs text-[var(--ssa-text-secondary)]"><span>Meals and Batch Cooking seasonal readiness</span><span>62%</span></div><div class="h-2 overflow-hidden rounded-full bg-[var(--ssa-surface-1)]"><div class="h-2 bg-[var(--ssa-status-success)] transition-[width] duration-300" style="width: 62%;" role="progressbar" aria-valuenow="62" aria-valuemin="0" aria-valuemax="100" aria-label="Meals and Batch Cooking seasona