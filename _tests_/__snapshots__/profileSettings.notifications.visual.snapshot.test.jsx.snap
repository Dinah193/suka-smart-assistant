exports[`profile settings notifications visual snapshots > matches notifications detail modal state 1`] = `"<div class="fixed inset-0 z-50 grid place-items-center bg-black/40 p-4" role="dialog" aria-modal="true" aria-label="Seasonal menu reminder"><div class="ssa-hero-wrap w-full max-w-xl p-4"><header class="flex items-center justify-between"><h3 class="ssa-hero-title text-lg">Seasonal menu reminder</h3><button type="button" class="ssa-hero-chip">Close</button></header><div class="mt-3"><div class="space-y-3"><div class="flex items-center gap-2"><span role="img" aria-label="Willow Collective" title="Willow Collective" class="inline-flex items-center justify-center rounded-full border border-[var(--ssa-border-default)] bg-[var(--ssa-surface-1)] h-8 w-8 text-base">🐔</span><span class="text-sm text-[var(--ssa-text-primary)]">Willow Collective</span><span class="ssa-hero-chip text-[var(--ssa-text-secondary)]">Meals and Batch Cooking</span></div><div class="ssa-hero-wrap border-l-4 p-3 text-sm border-[var(--ssa-status-warning)]" role="status">Spring herb menu closes in 4 hours. Confirm batch prep portions.</div><div class="ssa-hero-wrap p-3"><div class="mb-1 flex items-center justify-between text-xs text-[var(--ssa-text-secondary)]"><span>Resolution progress</span><span>58%</span></div><div class="h-2 overflow-hidden rounded-full bg-[var(--ssa-surface-1)]"><div class="h-2 bg-[var(--ssa-status-success)] transition-[width] duration-300" style="width: 58%;" role="progressbar" aria-valuenow="58" aria-valuemin="0" aria-valuemax="100" aria-label="Resolution progress progress"></div></div></div><div class="rounded-[var(--ssa-radius-card)] border border-[var(--ssa-border-subtle)] p-3"><h4 class="ssa-hero-title text-sm">Seasonal context</h4><p class="mt-1 text-sm text-[var(--ssa-text-secondary)]">Seasonal recipe focus: nettle omelet and root broth</p><p class="mt-2 text-xs text-[var(--ssa-text-secondary)]">2 households requested shared prep window</p></div></div></div></div></div>"`;

exports[`profile settings notifications visual snapshots > matches notifications panel baseline 1`] = `"<section class="ssa-hero-wrap p-4" aria-label="Notifications panel"><div class="mb-3 flex flex-wrap items-center justify-between gap-2"><div><h2 class="ssa-hero-title text-base">Module Notifications</h2><p class="text-xs text-[var(--ssa-text-secondary)]">Spring context is embedded in each household module update.</p></div><div class="flex items-center gap-2"><span class="ssa-hero-chip text-[var(--ssa-collab-request)]">Unread 3</span><button type="button" role="switch" aria-checked="true" class="inline-flex items-center gap-2"><span class="relative h-6 w-11 rounded-full border transition-colors bg-[var(--ssa-action-primary-bg)] border-[var(--ssa-action-primary-bg)]"><span class="absolute top-0.5 h-4.5 w-4.5 rounded-full bg-white transition-transform translate-x-5"></span></span><span class="text-sm text-[var(--ssa-text-primary)]">Live</span></button></div></div><div class="mb-3 grid grid-cols-[88px_minmax(0,1fr)] gap-3 rounded-[var(--ssa-radius-card)] border border-[var(--ssa-border-subtle)] p-3"><div class="flex items-center justify-center"><svg width="64" height="64" role="img" aria-label="Progress 60%"><circle cx="32" cy="32" r="29" stroke="var(--ssa-surface-2)" stroke-width="6" fill="none"></circle><circle cx="32" cy="32" r="29" stroke="var(--ssa-action-primary-bg)" stroke-width="6" fill="none" stroke-dasharray="182.212373908208" stroke-dashoffset="72.8849495632832" stroke-linecap="round" transform="rotate(-90 32 32)"></circle><text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-size="12" fill="var(--ssa-text-primary)">60%</text></svg></div><div class="space-y-2"><div class="ssa-hero-wrap border-l-4 p-3 text-sm border-[var(--ssa-status-info)]" role="status">Cross-module readiness is at 60% with 3 unread collaboration signals.</div><div class="ssa-hero-wrap p-3"><div class="mb-1 flex items-center justify-between text-xs text-[var(--ssa-text